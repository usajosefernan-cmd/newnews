# Excluir bases de datos y archivos de journal/WAL en cualquier nivel
**/data/
**/*.db*
**/*.db-wal
**/*.db-shm
**/*.sync-conflict-*

# Excluir temporales de Syncthing (?d permite borrarlos localmente si se requiere)
(?d).syncthing.*
(?d)~syncthing~*
(?d)*.tmp
(?d).syncthing*

# Excluir carpetas de compilación, dependencias y caches
dist/
dist_temp/
dist_backup/
.astro/
node_modules/
.venv/
.pytest_cache/

# Excluir manifiestos dinámicos compilados (.mjs) para evitar 'pull: file is invalid'
**/*.mjs
