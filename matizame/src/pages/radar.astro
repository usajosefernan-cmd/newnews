---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { getDatabase } from '../lib/db.js';
import path from 'node:path';

// Cargar envíos recientes del radar para mostrarlos de forma anónima
const db = getDatabase();


const submissions = db.prepare(`
  SELECT * FROM user_submissions 
  ORDER BY created_at DESC 
  LIMIT 15
`).all() as any[];

db.close();

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;

function getStatusBadgeClass(status: string) {
  const s = status.toLowerCase();
  if (s === 'recibido') return 'amber';
  if (s === 'en_cola') return 'purple';
  if (s === 'investigando') return 'blue';
  if (s === 'publicado') return 'green';
  if (s === 'descartado_por_baja_relevancia') return 'rose';
  return 'muted';
}

function getStatusLabel(status: string) {
  const s = status.toLowerCase();
  if (s === 'recibido') return 'Recibido';
  if (s === 'en_cola') return 'En cola';
  if (s === 'investigando') return 'Investigando';
  if (s === 'publicado') return 'Publicado';
  if (s === 'descartado_por_baja_relevancia') return 'Descartado';
  return status;
}
---

<Layout title="Radar Ciudadano de Desinformación - MATIZA">
  <div class="container" style="padding-top: 2rem; padding-bottom: 4rem; max-width: 680px;">
    
    <!-- Volver -->
    <a href={cleanBase || "/"} style="text-decoration: none; color: var(--neon-blue); font-size: 0.8rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 1.5rem;">
      &larr; Volver al Portal
    </a>

    <!-- Encabezado -->
    <header style="margin-bottom: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
      <span class="pulse-dot" style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--neon-rose); letter-spacing: 0.15em; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--neon-rose); display: inline-block;"></span>
        Radar de Intercepción Colaborativa
      </span>
      <h1 style="font-size: 1.8rem; font-weight: 900; letter-spacing: -0.03em; margin: 0; line-height: 1.2; color: #ffffff;">
        Envía un claim sospechoso
      </h1>
      <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.5; margin-top: 0.5rem;">
        ¿Has visto un post, un vídeo en YouTube o TikTok con datos alarmantes o enlaces promocionales encubiertos? Pégalo aquí. Nuestros motores autónomos evaluarán su relevancia, viralidad y daño potencial antes de iniciar la verificación.
      </p>
    </header>

    <!-- Formulario de envío -->
    <section class="cyber-card" style="padding: 1.75rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%); margin-bottom: 3rem;">
      <form id="radar-form">
        <div style="margin-bottom: 1.25rem;">
          <label for="url" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--neon-blue); letter-spacing: 0.05em; margin-bottom: 0.5rem;">Enlace original (Opcional)</label>
          <input type="url" id="url" name="url" placeholder="https://tiktok.com/@usuario/video/12345..." style="width: 100%; background: rgba(0,0,0,0.3); border: 1px solid var(--border-color); color: #fff; padding: 0.75rem; border-radius: 8px; font-size: 0.85rem; outline: none; transition: border-color 0.2s;" />
        </div>

        <div style="margin-bottom: 1.5rem;">
          <label for="text" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--neon-blue); letter-spacing: 0.05em; margin-bottom: 0.5rem;">Afirmación a verificar o descripción</label>
          <textarea id="text" name="text" rows="4" placeholder="Ej: Aseguran en un vídeo que van a dar 4.200€ al mes de ayuda a todos los inmigrantes que lleguen a Canarias..." style="width: 100%; background: rgba(0,0,0,0.3); border: 1px solid var(--border-color); color: #fff; padding: 0.75rem; border-radius: 8px; font-size: 0.85rem; outline: none; transition: border-color 0.2s; resize: vertical;" required></textarea>
        </div>

        <button type="submit" class="cyber-btn accent" style="width: 100%; padding: 0.75rem; border-radius: 8px; font-size: 0.85rem; font-weight: 800; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em;">
          Enviar al Radar de Triage &rarr;
        </button>
      </form>

      <!-- Div de feedback del envío -->
      <div id="feedback-message" style="display: none; margin-top: 1.25rem; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; line-height: 1.4;"></div>
    </section>

    <!-- Envíos recientes en el radar -->
    <section>
      <h2 style="font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 1.25rem; letter-spacing: -0.01em; display: flex; align-items: center; justify-content: space-between;">
        <span>Actividad del Radar Ciudadano</span>
        <span style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">Muestra de envíos recientes</span>
      </h2>

      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {submissions.map((sub: any) => (
          <div class="cyber-card" style="padding: 1rem; background: rgba(18, 22, 41, 0.3); display: flex; flex-direction: column; gap: 0.5rem;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <span class={`verdict-badge ${getStatusBadgeClass(sub.status)}`} style="font-size: 0.6rem; padding: 0.2rem 0.5rem; border-radius: 6px;">
                {getStatusLabel(sub.status)}
              </span>
              <span style="font-size: 0.65rem; color: var(--text-muted);">
                {new Date(sub.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })}
              </span>
            </div>
            
            <p style="font-size: 0.85rem; color: var(--text-main); margin: 0; line-height: 1.35; font-style: italic;">
              "{sub.submitted_text || sub.submitted_url}"
            </p>

            {sub.reason && (
              <span style="font-size: 0.7rem; color: var(--text-muted); display: block; background: rgba(255,255,255,0.02); padding: 0.4rem; border-radius: 4px; border-left: 2px solid var(--border-color);">
                 Diagnóstico: {sub.reason}
              </span>
            )}
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>

<script>
  const form = document.getElementById('radar-form') as HTMLFormElement;
  const feedback = document.getElementById('feedback-message') as HTMLDivElement;

  // Leer parámetros de URL para precargar campos
  const urlParams = new URLSearchParams(window.location.search);
  const paramUrl = urlParams.get('url');
  const paramText = urlParams.get('text');
  
  const urlInput = document.getElementById('url') as HTMLInputElement;
  const textInput = document.getElementById('text') as HTMLTextAreaElement;

  if (paramUrl) {
    if (urlInput) urlInput.value = paramUrl;
  }
  if (paramText) {
    const isUrl = paramText.trim().startsWith('http://') || paramText.trim().startsWith('https://');
    if (isUrl) {
      if (urlInput) urlInput.value = paramText.trim();
      if (textInput) {
        textInput.placeholder = 'Añade un comentario o aclaración sobre este enlace... (Requerido)';
        textInput.focus();
      }
    } else {
      if (textInput) textInput.value = paramText;
    }
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const url = formData.get('url')?.toString() || '';
      const text = formData.get('text')?.toString() || '';

      // Reset feedback
      feedback.style.display = 'none';
      feedback.className = '';

      try {
        const res = await fetch('/api/submit-radar', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ url, text })
        });

        const result = await res.json();

        feedback.style.display = 'block';
        if (result.success) {
          if (result.already_exists && result.slug) {
            feedback.className = 'feedback-success';
            feedback.style.backgroundColor = 'rgba(0, 240, 255, 0.05)';
            feedback.style.border = '1px solid var(--neon-blue)';
            feedback.style.color = '#fff';
            feedback.innerHTML = `<strong>${result.message}</strong><br/> Veredicto: <span class="verdict-badge green" style="font-size: 0.65rem;">${result.verdict}</span><br/><br/><a href="/noticia/${result.slug}" class="cyber-btn" style="padding: 0.35rem 0.75rem; font-size: 0.7rem; text-decoration: none; display: inline-block;">Ver verificación en vivo &rarr;</a>`;
          } else {
            feedback.className = 'feedback-success';
            feedback.style.backgroundColor = 'rgba(0, 230, 115, 0.05)';
            feedback.style.border = '1px solid var(--neon-green)';
            feedback.style.color = 'var(--neon-green)';
            feedback.innerHTML = result.message;
            form.reset();
            // Recargar tras 2 segundos para ver reflejado el cambio
            setTimeout(() => {
              window.location.reload();
            }, 2500);
          }
        } else {
          feedback.className = 'feedback-error';
          feedback.style.backgroundColor = 'rgba(255, 51, 102, 0.05)';
          feedback.style.border = '1px solid var(--neon-rose)';
          feedback.style.color = 'var(--neon-rose)';
          feedback.innerHTML = ` Error: ${result.error}`;
        }
      } catch (err: any) {
        feedback.style.display = 'block';
        feedback.style.backgroundColor = 'rgba(255, 51, 102, 0.05)';
        feedback.style.border = '1px solid var(--neon-rose)';
        feedback.style.color = 'var(--neon-rose)';
        feedback.innerHTML = ` Error de red: ${err.message}`;
      }
    });
  }
</script>
