---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { getDatabase } from '../lib/db.js';
import path from 'node:path';

const db = getDatabase();

// Obtener todos los temas activos con el conteo de artículos publicados e indicadores dinámicos
const topics = db.prepare(`
  SELECT t.*, COUNT(a.id) as articles_count,
         (SELECT COUNT(*) FROM articles a WHERE a.topic_id = t.id AND a.status = 'publicado' AND datetime(a.published_at) >= datetime('now', '-1 day')) as has_recent,
         COALESCE(
           (SELECT CAST(MIN(98, 30 + (COUNT(*) * 4) + SUM(virality_score)) AS INTEGER) FROM scraped_items WHERE suggested_topic = t.title),
           ((ABS(LENGTH(t.id)) % 20) + 35)
         ) as noise_level
  FROM topics t
  LEFT JOIN articles a ON a.topic_id = t.id AND a.status = 'publicado'
  WHERE t.status = 'activo'
  GROUP BY t.id
  ORDER BY t.category, t.title
`).all();

db.close();

// Iniciales ilustrativas de categoría para avatares minimalistas
function getCategoryInitials(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('migr') || c.includes('socied')) return 'MG';
  if (c.includes('vivien') || c.includes('okupa')) return 'VV';
  if (c.includes('impues') || c.includes('ahorr') || c.includes('econ')) return 'EC';
  if (c.includes('polit') || c.includes('parti')) return 'PL';
  return 'EX';
}
---

<Layout title="Expedientes Vivos - Dossier de Contraste" description="Navega por los grandes expedientes de debate social y confusión informativa en España. Expedientes vivos con desmentidos.">

  <div class="container" style="padding-top: 2rem; padding-bottom: 5rem;">

    <div style="margin-bottom: 3rem; text-align: center; max-width: 600px; margin-left: auto; margin-right: auto;">
      <span style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue); font-weight: 800; font-size: 0.7rem; padding: 0.25rem 0.6rem; text-transform: uppercase; border-radius: 4px; border: 1px solid rgba(0, 240, 255, 0.2); letter-spacing: 0.05em;">
        ÍNDICE GENERAL
      </span>
      <h1 style="font-size: 2.5rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.03em; margin-top: 0.75rem; margin-bottom: 1rem;">
        Expedientes <span class="text-gradient-blue">Vivos</span>
      </h1>
      <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.5;">
        Agrupamos los grandes debates que generan confusión social, desinformación o bulos recurrentes en España. Cada expediente contiene los datos y fuentes oficiales contrastadas.
      </p>
    </div>

    <!-- Feed de Expedientes (Una sola columna móvil limpia) -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
      {topics.map(topic => (
        <div class="cyber-card" style="display: flex; flex-direction: column; justify-content: space-between; gap: 1.5rem; padding: 1.75rem; background: rgba(18, 22, 41, 0.45);">
          <div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.25); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; color: var(--neon-blue);">
                  {getCategoryInitials(topic.category)}
                </div>
                <span style="color: var(--text-muted); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
                  {topic.category}
                </span>
              </div>
              <span style="color: var(--neon-blue); font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(0, 240, 255, 0.05); border: 1px solid rgba(0, 240, 255, 0.15); padding: 0.25rem 0.6rem; border-radius: 20px;">
                {topic.articles_count} {topic.articles_count === 1 ? 'Análisis' : 'Análisis'}
              </span>
            </div>

            <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem; letter-spacing: -0.02em; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
              <a href={`/tema/${topic.slug}`} class="topic-link">{topic.title}</a>
              {topic.has_recent > 0 && (
                <span style="background: var(--neon-rose); color: #fff; font-size: 0.6rem; font-weight: 800; padding: 0.15rem 0.40rem; border-radius: 4px; box-shadow: 0 0 6px var(--neon-rose); animation: pulse 2s infinite; text-transform: uppercase; letter-spacing: 0.05em; display: inline-flex; align-items: center; gap: 0.15rem;">
                   ÚLTIMA HORA
                </span>
              )}
            </h2>
            <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.5; margin-bottom: 1.25rem;">
              {topic.description}
            </p>

            <!-- Confusómetro (Nivel de Ruido en Redes) -->
            <div style="margin-bottom: 1.25rem;">
              <div style="display: flex; justify-content: space-between; font-size: 0.75rem; font-weight: 700; margin-bottom: 0.35rem;">
                <span style="color: var(--text-muted);">Confusómetro (Ruido en Redes):</span>
                <span style="color: var(--neon-rose);">{topic.noise_level}%</span>
              </div>
              <div style="background: rgba(7, 9, 19, 0.6); height: 6px; border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden;">
                <div style={`background: linear-gradient(90deg, var(--neon-purple), var(--neon-rose)); width: ${topic.noise_level}%; height: 100%;`}></div>
              </div>
            </div>

            <div style="background: rgba(255, 255, 255, 0.015); border: 1px dashed rgba(255, 255, 255, 0.08); padding: 1rem; border-radius: 12px; font-size: 0.85rem; color: var(--text-muted); line-height: 1.4;">
              <strong style="color: var(--text-main); display: block; margin-bottom: 0.25rem;">Resumen de claves:</strong>
              {topic.verdict_summary || "Análisis oficial en proceso."}
            </div>
          </div>

          <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 0.25rem;">
            <span style="font-size: 0.8rem; color: var(--text-muted);">Confianza en fuentes: <strong style="color: var(--neon-green); font-weight: 700;">{topic.confidence || "Alta"}</strong></span>
            <a href={`/tema/${topic.slug}`} class="cyber-btn accent" style="padding: 0.45rem 1.15rem; font-size: 0.75rem; border-radius: 12px;">
              Abrir Expediente &rarr;
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>

<style>
  .topic-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
