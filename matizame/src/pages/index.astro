    <!-- Advertencia Metodológica -->
    <div style="margin-top: 2.5rem; background: rgba(255, 183, 3, 0.03); border: 1px dashed rgba(255, 183, 3, 0.2); border-radius: 12px; padding: 1.25rem 1.5rem; text-align: left;">
