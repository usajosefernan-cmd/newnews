                      {art.verdict}
                    </span>
                  </div>

                  <div style="margin-bottom: 1.25rem;">
                    <a href={`${cleanBase}/noticia/${art.slug}`}>
                      <h4 style="font-size: 1.2rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.5rem; color: var(--text-main); font-family: var(--font-title);">
                        {art.title}
                      </h4>
                    </a>
                    <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.45; margin-bottom: 1rem;">
                      {art.subtitle}
                    </p>
                    {art.multimedia_url && (
                      <div style="margin-bottom: 1rem; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); max-height: 180px; background: #000; display: flex; align-items: center; justify-content: center;">
                        <img src={art.multimedia_url} alt="Portada" style="width: 100%; height: 100%; object-fit: cover; max-height: 180px;" />
                      </div>
                    )}
                  </div>
                </div>

                <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 0.75rem; font-size: 0.7rem;">
                  <span style="color: var(--text-muted);">
                    Vía: <strong style="color: var(--text-main);">{art.origin_platform}</strong>
                  </span>
                  <a href={`${cleanBase}/noticia/${art.slug}`} class="cyber-btn" style="padding: 0.35rem 0.85rem; font-size: 0.7rem; border-radius: 10px; color: var(--neon-blue); border-color: rgba(0, 240, 255, 0.15); text-decoration: none;">
                    Verificar &rarr;
                  </a>
                </div>
              </div>
            ))}
          </div>
        </>
      ) : (
        <div style="text-align: center; padding: 3rem; background: rgba(18,22,41,0.2); border-radius: 16px; border: 1px dashed rgba(255,255,255,0.05);">
          <h3 style="color: #ffffff; font-family: var(--font-title); font-size: 1.2rem; margin-bottom: 0.5rem;">El Radar está Limpio</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; max-width: 480px; margin: 0 auto 1.5rem auto;">
            No hay verificaciones publicadas en este momento. El radar está monitorizando redes en busca de afirmaciones virales.
          </p>
          <a href={`${cleanBase}/temas`} class="cyber-btn accent" style="padding: 0.6rem 1.25rem; font-size: 0.8rem; border-radius: 8px; text-decoration: none; color: #fff;">
            Explorar Expedientes Vivos
          </a>
        </div>
      )}

    </div>
  </section>

  <!-- 9. ═══ CONFUSÓMETRO / ALERTAS DE RUIDO ═══ -->
  <section class="landing-section">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
      
      <!-- Confusómetro -->
      <div class="cyber-card" style="padding: 1.5rem; background: linear-gradient(135deg, rgba(157, 78, 221, 0.05) 0%, rgba(7, 9, 19, 0.95) 100%); flex: 1;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--neon-purple); margin-bottom: 1rem; font-family: var(--font-title); letter-spacing: -0.01em;">
          Confusómetro: Alerta de Ruido por Tema
        </h3>
        <div style="display: flex; flex-direction: column; gap: 1.1rem;">
          {topics.slice(0, 5).map(t => (
            <div>
              <div style="display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 0.35rem;">
                <span style="font-weight: 700; color: var(--text-main);">{t.title}</span>
                <span style="font-weight: 800; color: var(--neon-rose);">{t.noise_level}%</span>
              </div>
              <div style="background: rgba(7, 9, 19, 0.6); height: 6px; border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden;">
                <div style={`background: linear-gradient(90deg, var(--neon-purple), var(--neon-rose)); width: ${t.noise_level}%; height: 100%;`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Buzón de Intercepción Teaser -->
      <div class="cyber-card" style="padding: 1.65rem; background: linear-gradient(185deg, rgba(7, 9, 19, 0.95) 0%, rgba(18, 22, 41, 0.8) 100%); border-color: var(--neon-blue); flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <span style="font-size: 1.5rem;">📥</span>
            <h3 style="font-size: 1.2rem; font-weight: 800; color: var(--neon-blue); margin: 0; letter-spacing: -0.01em; font-family: var(--font-title);">Buzón de Intercepción</h3>
          </div>
          <p style="color: var(--text-muted); font-size: 0.82rem; line-height: 1.5; margin-bottom: 1.5rem;">
            ¿Has detectado un bulo sospechoso o una publicación viral en TikTok, YouTube, Instagram o X? Envía el enlace al radar. Nuestro motor contrastará los hechos con las leyes vigentes del BOE y los datos macroeconómicos del INE de forma neutral.
          </p>
        </div>
        <a href={`${cleanBase}/interceptor`} class="cyber-btn accent" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem; border-radius: 8px; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; text-decoration: none; text-align: center; color: #fff;">
          Acceder al Interceptor &rarr;
        </a>
      </div>

    </div>
  </section>

  <!-- 10. ═══ CTA FINAL ═══ -->
  <section class="landing-section" style="text-align: center; padding: 5rem 1.5rem; border-bottom: none;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h2 style="font-size: 2.2rem; font-weight: 900; letter-spacing: -0.03em; color: #ffffff; font-family: var(--font-title); margin-bottom: 1rem; line-height: 1.15;">
        Antes de creerlo, compartirlo o firmarlo, matízalo.
      </h2>
      <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.5; margin-bottom: 2.5rem;">
        Pega una afirmación o activa MATIZA Live y descubre qué sabes realmente.
      </p>

      <div style="display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap;">
        <button onclick="window.scrollTo({ top: 0, behavior: 'smooth' }); document.getElementById('hero-radar-input').focus();" class="cyber-btn accent" style="padding: 0.8rem 1.75rem; font-size: 0.85rem; font-weight: 800; border-radius: 8px; cursor: pointer; color: #fff;">
          MATIZA ESTO
        </button>
        <a href="#live" class="cyber-btn" style="padding: 0.8rem 1.75rem; font-size: 0.85rem; font-weight: 800; border-radius: 8px; text-decoration: none; color: var(--neon-purple); border-color: rgba(157, 78, 221, 0.45);">
          PROBAR MATIZA LIVE
        </a>
      </div>
    </div>
  </section>

</Layout>
