---
export const prerender = true;
import { getDatabase } from '../lib/db.js';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import { modulesConfig } from '../config/modules.js';

const db = getDatabase();



// Obtener categorías dinámicas
const rawCategories = db.prepare("SELECT DISTINCT category FROM topics WHERE status = 'activo'").all() as any[];
const categories = rawCategories.map(c => {
  const cat = c.category;
  const slug = cat.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
  return { name: cat, slug };
}).filter(c => c.name);

// Obtener todos los temas activos con indicadores dinámicos
const topics = db.prepare(`
  SELECT t.*, 
         (SELECT COUNT(*) FROM articles a WHERE a.topic_id = t.id AND a.status = 'publicado' AND datetime(a.published_at) >= datetime('now', '-1 day')) as has_recent,
         COALESCE(
           (SELECT CAST(MIN(98, 30 + (COUNT(*) * 4) + SUM(virality_score)) AS INTEGER) FROM scraped_items WHERE suggested_topic = t.title),
           ((ABS(LENGTH(t.id)) % 20) + 35)
         ) as noise_level
  FROM topics t 
  WHERE t.status = 'activo' 
  ORDER BY t.title
`).all();

// Obtener las piezas publicadas ordenadas por fecha
const articles = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug 
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'publicado'
  ORDER BY a.published_at DESC
`).all();

// Obtener últimos items del radar
const radarItems = db.prepare(`
  SELECT * FROM scraped_items 
  WHERE status = 'pendiente' 
  ORDER BY virality_score DESC
  LIMIT 6
`).all();

// Obtener fuentes oficiales
const officialSourceCount = (() => {
  try { return db.prepare("SELECT COUNT(*) as c FROM official_sources WHERE status = 'activo'").get().c; } 
  catch(e) { return 0; }
})();

db.close();

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;

const featuredArticle = articles.length > 0 ? articles[0] : null;
const remainingArticles = articles.length > 1 ? articles.slice(1) : [];
const hasArticles = articles.length > 0;

function getVerdictClass(verdict) {
  const v = (verdict || '').toLowerCase();
  if (v.includes('confirmado') || v.includes('respaldado')) return 'green';
  if (v.includes('falta contexto') || v.includes('versiones contradictorias') || v.includes('no verificable')) return 'amber';
  if (v.includes('engañoso') || v.includes('sin pruebas') || v.includes('acusación no probada')) return 'rose';
  return 'purple';
}

function getVerdictColor(verdict) {
  const v = (verdict || '').toLowerCase();
  if (v.includes('confirmado') || v.includes('respaldado')) return 'var(--neon-green)';
  if (v.includes('falta contexto') || v.includes('versiones contradictorias') || v.includes('no verificable')) return 'var(--neon-amber)';
  if (v.includes('engañoso') || v.includes('sin pruebas') || v.includes('acusación no probada')) return 'var(--neon-rose)';
  return 'var(--neon-purple)';
}

function getCategoryInitials(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('inmigr') || c.includes('delin')) return 'MIG';
  if (c.includes('emple') || c.includes('paro')) return 'EMP';
  if (c.includes('vivien') || c.includes('okup') || c.includes('vida imposible')) return 'VIV';
  if (c.includes('infla') || c.includes('ipc') || c.includes('vida')) return 'IPC';
  if (c.includes('auto') || c.includes('fisc') || c.includes('haci')) return 'AUT';
  if (c.includes('historia') || c.includes('memo')) return 'HIS';
  if (c.includes('corrupc') || c.includes('transpa')) return 'COR';
  if (c.includes('sanid')) return 'SAN';
  if (c.includes('justic')) return 'JUS';
  if (c.includes('consumo')) return 'CON';
  if (c.includes('segurid') || c.includes('ciberestafa')) return 'SEC';
  if (c.includes('catalu') || c.includes('independ')) return 'CAT';
  if (c.includes('eco')) return 'ECO';
  return 'GEN';
}

function getCategorySlug(category) {
  return (category || '').toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
}

function getRelativeTime(dateStr) {
  if (!dateStr) return 'Reciente';
  try {
    const pub = new Date(dateStr.replace(' ', 'T'));
    const diffMs = Date.now() - pub.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    if (diffMins < 60) return `Hace ${diffMins} min`;
    const diffHours = Math.floor(diffMins / 60);
    if (diffHours < 24) return `Hace ${diffHours} h`;
    return pub.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  } catch (e) {
    return 'Reciente';
  }
}

function formatOriginalDate(dateStr) {
  if (!dateStr) return '';
  try {
    const d = new Date(dateStr);
    return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  } catch(e) {
    return dateStr;
  }
}

const getModuleStatusLabel = (status) => {
  switch (status) {
    case 'available': return 'Disponible';
    case 'beta': return 'Beta';
    case 'internal': return 'Interno';
    case 'coming_soon': return 'Próximamente';
    case 'disabled': return 'Desactivado';
    default: return '';
  }
};
