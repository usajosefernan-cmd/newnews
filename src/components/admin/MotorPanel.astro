---
interface Props {
  draftsWithDetails: any[];
  topicCaches: any[];
  claimCaches: any[];
  pipelineConfigJson: string;
}
const { draftsWithDetails, topicCaches, claimCaches, pipelineConfigJson } = Astro.props;

// Parsear la configuración del pipeline para rellenar los campos semánticos
let config: any = { global: {}, phases: {} };
try {
  config = JSON.parse(pipelineConfigJson || '{}');
} catch (e) {
  console.error('[MotorPanel] Error parseando JSON de configuración:', e.message);
}

// Asegurar que existan secciones para evitar errores de null
if (!config.global) config.global = {};
if (!config.phases) config.phases = {};

const phasesList = [
  { id: '00', name: 'Fase 00: Hot Topics', script: '00-hot-topics-cron.js', desc: 'Analiza tendencias virales en RSS y Reddit para crear expedientes vivos.' },
  { id: '01', name: 'Fase 01: Filtro Relevancia', script: '01-relevance-gate.js', desc: 'Determina si la afirmación tiene suficiente interés sociopolítico público.' },
  { id: '02', name: 'Fase 02: Enrutador Semántico', script: '02-semantic-router.js', desc: 'Clasifica el claim en una categoría y lo asocia al expediente correspondiente.' },
  { id: '03', name: 'Fase 03: Planificador de Fuentes', script: '03-source-strategy-planner.js', desc: 'Diseña la estrategia de fuentes oficiales (BOE, INE, ministerios).' },
  { id: '04', name: 'Fase 04: Filtro de Ruido', script: '04-noise-filter.js', desc: 'Filtra spam, cotilleo o desinformación inverosímil menor.' },
  { id: '05', name: 'Fase 05: Extractor de Claims', script: '05-claim-extractor.js', desc: 'Aísla el sujeto y la afirmación fáctica explícita a verificar.' },
  { id: '06', name: 'Fase 06: Buscador de Evidencias', script: '06-evidence-finder.js', desc: 'Realiza búsquedas web DuckDuckGo en vivo y selecciona los enlaces oficiales más fiables.' },
  { id: '07', name: 'Fase 07: Verificador', script: '07-verifier.js', desc: 'Analiza contradicciones lógicas entre el claim y las evidencias recopiladas.' },
  { id: '08', name: 'Fase 08: Redactor del Artículo', script: '08-article-writer.js', desc: 'Escribe el artículo detallado en lenguaje formal y periodístico.' },
  { id: '09', name: 'Fase 09: Calidad Deontológica', script: '09-quality-gate.js', desc: 'Filtro deontológico (Defensor del Lector) que audita que el tono sea neutral y libre de sesgos.' },
  { id: '10', name: 'Fase 10: Cola de Revisión', script: '10-review-queue.js', desc: 'Encola el borrador y genera la checklist recomendada de moderación rápida humana.' },
  { id: '11', name: 'Fase 11: Copies de Redes', script: '11-social-writer.js', desc: 'Redacta los copys promocionales hilos optimizados para Twitter y Telegram.' }
];
---

<h2 class="section-title" style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.35rem; color: #fff;"> Consola de Reprocesado e Inteligencia de Caché</h2>
<p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 2rem; margin-top: 0;">
  Control granular de las fases del motor modular de desmentidos y sumario de la Caché Semántica del portal.
</p>

<div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; align-items: start;" class="redactor-split-grid">
  <!-- Reprocesado de fases -->
  <div class="cyber-card" style="padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 12px; background: rgba(18, 22, 41, 0.25);">
    <h3 class="card-title" style="margin-top: 0; margin-bottom: 0.5rem; font-size: 1.1rem; color: #fff;">🛠️ Reprocesado de Fases Aisladas</h3>
    <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1rem;">
      Si deseas corregir o volver a generar únicamente la redacción del desmentido o los copies de redes sin volver a buscar evidencias ni gastar tokens adicionales.
    </p>

    <div class="scroller-list" style="max-height: 380px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.75rem;">
      {draftsWithDetails.map(art => (
        <div class="scroller-item" style="border: 1px solid var(--border-color); padding: 0.75rem; border-radius: 8px; background: rgba(0,0,0,0.15);">
          <div style="font-size: 0.85rem; font-weight: bold; margin-bottom: 0.5rem; color: #fff; line-height: 1.3;">
            {art.title}
          </div>
          <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
            <form method="POST" style="margin: 0;">
              <input type="hidden" name="action" value="reprocess_phase" />
              <input type="hidden" name="article_id" value={art.id} />
              <input type="hidden" name="phase" value="08-article-writer" />
              <button type="submit" class="cyber-btn" style="border-color: var(--neon-blue); color: var(--neon-blue); font-size: 0.7rem; padding: 0.3rem 0.6rem; border-radius: 4px; cursor: pointer; font-weight: bold;">Reprocesar Redacción (Fase 08)</button>
            </form>
            
            <form method="POST" style="margin: 0;">
              <input type="hidden" name="action" value="reprocess_phase" />
              <input type="hidden" name="article_id" value={art.id} />
              <input type="hidden" name="phase" value="11-social-writer" />
              <button type="submit" class="cyber-btn" style="border-color: var(--neon-purple); color: var(--neon-purple); font-size: 0.7rem; padding: 0.3rem 0.6rem; border-radius: 4px; cursor: pointer; font-weight: bold;">Reprocesar RRSS (Fase 11)</button>
            </form>
          </div>
        </div>
      ))}
      {draftsWithDetails.length === 0 && (
        <p class="empty-state" style="color: var(--text-muted); font-size: 0.85rem; font-style: italic;">No hay borradores disponibles para reprocesar.</p>
      )}
    </div>
  </div>

  <!-- Capa de Caché -->
  <div class="cyber-card" style="padding: 1.5rem; border: 1px solid var(--neon-amber); border-radius: 12px; background: rgba(18, 22, 41, 0.25);">
    <h3 class="card-title" style="color: var(--neon-amber); margin-top: 0; margin-bottom: 1.25rem; font-size: 1.1rem;"> Sumario de Caché Semántica</h3>
    
    <!-- Caches de Temas -->
    <div style="margin-bottom: 1.5rem;">
      <span style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 800; display: block; margin-bottom: 0.5rem;">Caché de Verticales ({topicCaches.length})</span>
      <div class="scroller-list" style="max-height: 120px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 6px; background: rgba(0,0,0,0.2);">
        {topicCaches.map(c => (
          <div class="scroller-item" style="font-size: 0.75rem; padding: 0.5rem; border-bottom: 1px solid var(--border-color);">
            <strong>ID: {c.topic_id}</strong>
            <div style="color: var(--text-muted); margin-top: 0.15rem;">Última actualización: {c.last_updated}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Caches de Claims -->
    <div>
      <span style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 800; display: block; margin-bottom: 0.5rem;">Caché de Claims Normalizados ({claimCaches.length})</span>
      <div class="scroller-list" style="max-height: 120px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 6px; background: rgba(0,0,0,0.2);">
        {claimCaches.map(c => (
          <div class="scroller-item" style="font-size: 0.75rem; padding: 0.5rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: start; gap: 0.5rem;">
            <div>
              <strong style="color: var(--neon-amber);">{c.previous_verdict}</strong>
              <div style="color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 140px;">Hash: {c.normalized_claim_hash}</div>
            </div>
            <span style="font-size: 0.65rem; color: var(--text-muted); white-space: nowrap;">{new Date(c.last_seen).toLocaleDateString('es-ES')}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- EDITOR SEMÁNTICO DE PIPELINE EN VIVO (CERO JSON CRUDO) -->
  <div class="cyber-card" style="grid-column: span 2; padding: 1.5rem; border-color: var(--neon-amber); background: rgba(18, 22, 41, 0.35); margin-top: 1rem; text-align: left;">
    <h3 class="card-title" style="color: var(--neon-amber); margin-top: 0; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
      ⚙️ Editor Semántico de Modelos y Agentes del Motor (Sin Código)
    </h3>
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.45;">
      Personaliza de forma visual las directrices, proveedores de IA, modelos y comportamientos de las fases del pipeline. El sistema generará y actualizará la configuración técnica de forma automática.
    </p>

    <form method="POST" style="margin: 0; display: flex; flex-direction: column; gap: 1.5rem;">
      <input type="hidden" name="action" value="save_pipeline_config" />
      
      <!-- Parámetros Globales del Servidor -->
      <div style="background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 8px; border: 1px solid rgba(255, 176, 32, 0.15); display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <span style="grid-column: 1 / -1; font-size: 0.75rem; font-weight: 800; color: var(--neon-amber); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: -0.25rem;">Parámetros de Servidor y Fallback Global:</span>
        
        <div class="form-group">
          <label style="display: block; font-size: 0.7rem; color: var(--text-muted); margin-bottom: 0.3rem; font-weight: bold;">Proveedor IA por Defecto:</label>
          <select name="global_provider" style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.45rem; border-radius: 4px; font-size: 0.8rem;">
            <option value="gemini" selected={config.global.default_provider === 'gemini'}>Gemini (Google DeepMind)</option>
            <option value="nous" selected={config.global.default_provider === 'nous'}>Nous Research (Inferencia Libre)</option>
          </select>
        </div>

        <div class="form-group">
          <label style="display: block; font-size: 0.7rem; color: var(--text-muted); margin-bottom: 0.3rem; font-weight: bold;">Proveedor de Fallback (Respaldo):</label>
          <select name="fallback_provider" style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.45rem; border-radius: 4px; font-size: 0.8rem;">
            <option value="nous" selected={config.global.fallback_provider === 'nous'}>Nous Research (Recomendado)</option>
            <option value="gemini" selected={config.global.fallback_provider === 'gemini'}>Gemini</option>
          </select>
        </div>

        <div class="form-group">
          <label style="display: block; font-size: 0.7rem; color: var(--text-muted); margin-bottom: 0.3rem; font-weight: bold;">Modelo de Fallback (Respaldo):</label>
          <input type="text" name="fallback_model" value={config.global.fallback_model || 'stepfun/step-3.7-flash:free'} style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.45rem; border-radius: 4px; font-size: 0.8rem;" />
        </div>

        <div class="form-group">
          <label style="display: block; font-size: 0.7rem; color: var(--text-muted); margin-bottom: 0.3rem; font-weight: bold;">Timeout Máximo (ms):</label>
          <input type="number" name="global_timeout" value={config.global.timeout_ms || 180000} style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.45rem; border-radius: 4px; font-size: 0.8rem;" />
        </div>

        <div class="form-group" style="grid-column: span 2;">
          <label style="display: block; font-size: 0.7rem; color: var(--neon-amber); margin-bottom: 0.3rem; font-weight: bold;">⚡ Piloto Automático (Publicación Directa en Vivo):</label>
          <select name="autopilot" style="width: 100%; background: #05070e; border: 1px solid var(--neon-amber); color: #ffb020; padding: 0.45rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold;">
            <option value="false" selected={!config.global.autopilot}>DESACTIVADO (Guardar borradores para moderar)</option>
            <option value="true" selected={!!config.global.autopilot}>ACTIVADO (Publicar desmentidos directos en vivo)</option>
          </select>
        </div>
      </div>

      <!-- Configuración por Fases de la IA -->
      <div style="display: flex; flex-direction: column; gap: 1rem; max-height: 480px; overflow-y: auto; padding-right: 0.5rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem;">
        {phasesList.map(ph => {
          const phConf = config.phases[ph.id] || {};
          return (
            <div style="background: rgba(255,255,255,0.01); border: 1px solid rgba(255,255,255,0.04); padding: 1rem; border-radius: 8px; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.75rem; align-items: start;">
              <div style="grid-column: span 4; border-bottom: 1px solid rgba(255,255,255,0.03); padding-bottom: 0.35rem; margin-bottom: 0.25rem; display: flex; justify-content: space-between; align-items: center;">
                <span style="font-weight: bold; font-size: 0.85rem; color: #fff;">{ph.name} <span style="font-weight: normal; font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">({ph.script})</span></span>
                <span style="font-size: 0.75rem; color: var(--text-muted); font-style: italic;">{ph.desc}</span>
              </div>
              
              <div class="form-group" style="grid-column: span 1;">
                <label style="display: block; font-size: 0.65rem; color: var(--text-muted); margin-bottom: 0.25rem;">Proveedor:</label>
                <select name={`phase_${ph.id}_provider`} style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.35rem; border-radius: 4px; font-size: 0.75rem;">
                  <option value="gemini" selected={phConf.provider === 'gemini'}>Gemini</option>
                  <option value="nous" selected={phConf.provider === 'nous'}>Nous (Free)</option>
                </select>
              </div>

              <div class="form-group" style="grid-column: span 2;">
                <label style="display: block; font-size: 0.65rem; color: var(--text-muted); margin-bottom: 0.25rem;">Modelo a usar:</label>
                <input type="text" name={`phase_${ph.id}_model`} value={phConf.model || 'gemini-2.5-flash'} style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.35rem; border-radius: 4px; font-size: 0.75rem;" />
              </div>

              <div class="form-group" style="grid-column: span 1;">
                <label style="display: block; font-size: 0.65rem; color: var(--text-muted); margin-bottom: 0.25rem;">Temperatura:</label>
                <input type="number" step="0.1" min="0" max="1" name={`phase_${ph.id}_temp`} value={phConf.temperature !== undefined ? phConf.temperature : 0.2} style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #fff; padding: 0.35rem; border-radius: 4px; font-size: 0.75rem;" />
              </div>

              <div class="form-group" style="grid-column: span 4;">
                <label style="display: block; font-size: 0.65rem; color: var(--text-muted); margin-bottom: 0.25rem;">Instrucciones / Rol del Agente (System Prompt):</label>
                <textarea name={`phase_${ph.id}_prompt`} rows="2" style="width: 100%; background: #05070e; border: 1px solid var(--border-color); color: #a9b2c3; padding: 0.5rem; border-radius: 4px; font-size: 0.75rem; font-family: monospace; resize: vertical; line-height: 1.4;">{phConf.system_prompt || ''}</textarea>
              </div>
            </div>
          )
        })}
      </div>

      <div style="display: flex; justify-content: flex-end; align-items: center; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem;">
        <button type="submit" class="cyber-btn" style="border-color: var(--neon-amber); color: var(--neon-amber); font-weight: bold; cursor: pointer; padding: 0.6rem 1.5rem; border-radius: 6px; font-size: 0.8rem;">
          💾 Guardar Configuración de los Agentes
        </button>
      </div>
    </form>
  </div>

  <!-- DESGLOSE DE PIPELINE MODULAR DE IA (12 FASES GRANULARES) -->
  <div class="cyber-card" style="grid-column: span 2; padding: 1.5rem; margin-top: 1rem; border-color: var(--neon-blue); background: rgba(18, 22, 41, 0.25);">
    <h3 class="card-title" style="color: #fff; margin-top: 0; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
      🧠 Arquitectura del Pipeline de IA: Ejecución Granular por Fases
    </h3>
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">
      Cada una de las 12 fases del motor de Newnews puede ser ejecutada de forma aislada y en caliente. Pulsa sobre el botón de ejecución de cualquier fase para iniciar el stream de logs de terminal detallados en vivo.
    </p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem; max-height: 480px; overflow-y: auto; padding-right: 0.5rem;">
      
      {phasesList.map(ph => (
        <div style="background: rgba(255,255,255,0.015); border: 1px solid rgba(0, 240, 255, 0.15); padding: 1rem; border-radius: 10px; text-align: left; display: flex; flex-direction: column; justify-content: space-between; min-height: 140px;">
          <div>
            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.4rem;">
              <strong style="color: var(--neon-blue); font-size: 0.85rem;">{ph.name}</strong>
              <span style="font-family: monospace; font-size: 0.65rem; color: var(--text-muted);">{ph.script}</span>
            </div>
            <p style="font-size: 0.75rem; color: var(--text-muted); margin: 0 0 1rem 0; line-height: 1.4;">
              {ph.desc}
            </p>
          </div>
          <button onclick={`runAdminJob('ai-phase-${ph.id}')`} class="cyber-btn" style="width: 100%; font-size: 0.7rem; padding: 0.45rem; border-radius: 4px; border-color: #00ffc4; color: #00ffc4; font-weight: bold; cursor: pointer;">Ejecutar {ph.name.split(':')[0]} (En vivo)</button>
        </div>
      ))}

    </div>
  </div>
</div>
