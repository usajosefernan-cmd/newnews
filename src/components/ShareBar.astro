const mediaOutlets: Network[] = [
  { key: 'elpais',     label: 'El País',       color: '#C0392B', path: 'M21 4.5H3c-.55 0-1 .45-1 1v13c0 .55.45 1 1 1h18c.55 0 1-.45 1-1v-13c0-.55-.45-1-1-1zm-9 3.2l-3 7.6h2.1l.7-1.9h3l.7 1.9h2.1l-3-7.6h-2.6zm.2 4.6l.9-2.4.9 2.4h-1.8z' },
  { key: 'elmundo',    label: 'El Mundo',      color: '#E2001A', path: 'M12 2L2 7v2h20V7L12 2zM4 11v8H2v2h20v-2h-2v-8h-3v8h-3v-6h-3v6H7v-8H4z' },
  { key: 'lavanguardia', label: 'La Vanguardia', color: '#1B6CA8', path: 'M3 4h18a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5a1 1 0 0 1-1-1zm3.5 4v8h2.2v-2.6h2.4V16h2.2v-8h-2.2v2.4H8.7V8H6.5zm9 0v8h2.2v-8h-2.2z' },
  { key: 'abc',        label: 'ABC',           color: '#0A3D62', path: 'M12 3L2 8v3h20V8L12 3zm-6 7v6H4v2h16v-2h-2v-6h-2v6h-3v-6H9v6H6v-6z' },
  { key: 'laser',      label: 'Cadena SER',    color: '#E30613', path: 'M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zm3 3v8h2V8.8L12 13l3-4.2V16h2V8h-2l-3 4.3L9 8H7z' },
  { key: '20minutos',  label: '20minutos',     color: '#F39C12', path: 'M3 4h18a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1zm3 4v8h3a3 3 0 0 0 3-3v-2a3 3 0 0 0-3-3H6zm10 0v8h3v-2h-1.5V10H19V8h-1.5z' },
];

const copyIcon =
  'M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z';
const shareIcon =
  'M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z';
---

{
  variant === 'card' ? (
    <div class="cyber-card sharebar-card" style="padding: 1.5rem; border-color: rgba(0, 240, 255, 0.15); background: rgba(18, 22, 41, 0.3); display: flex; flex-direction: column; gap: 0.85rem;">
      <div>
        <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-blue); font-size: 0.75rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">
          {label}
        </span>
        <div class="sharebar-grid">
          {networks.map((n) => (
            <button
              class="share-btn"
              data-share={n.key}
              data-title={title}
              data-text={text}
              style={`--brand:${n.color};`}
              title={`Compartir en ${n.label}`}
              aria-label={`Compartir en ${n.label}`}
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={n.path} /></svg>
              <span>{n.label}</span>
            </button>
          ))}
          <button class="share-btn" data-share="copy" data-title={title} data-text={text} style="--brand:var(--neon-green);" title="Copiar enlace" aria-label="Copiar enlace">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={copyIcon} /></svg>
            <span>Copiar</span>
          </button>
          <button class="share-btn" data-share="native" data-title={title} data-text={text} style="--brand:var(--neon-purple);" title="Compartir (menú del dispositivo)" aria-label="Compartir">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={shareIcon} /></svg>
            <span>Compartir</span>
          </button>
        </div>
      </div>

      <div style="border-top: 1px dashed rgba(255, 255, 255, 0.08); padding-top: 0.85rem;">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.68rem; letter-spacing: 0.08em; display: block; margin-bottom: 0.75rem;">
          También en los medios
        </span>
        <div class="sharebar-grid">
          {mediaOutlets.map((m) => (
            <button
              class="share-btn"
              data-share="media"
              data-handle={m.key}
              data-title={title}
              data-text={text}
              style={`--brand:${m.color};`}
              title={`Difundir vía ${m.label} (X)`}
              aria-label={`Difundir vía ${m.label}`}
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={m.path} /></svg>
              <span>{m.label}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  ) : (
    <div class="sharebar-inline" style="border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); padding: 1rem 0; margin: 1.25rem 0; display: flex; flex-direction: column; gap: 0.75rem;">
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
        <span style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 800; font-family: var(--font-title);">
          {label}
        </span>
        <div class="sharebar-row">
          {networks.map((n) => (
            <button
              class="share-icon-btn"
              data-share={n.key}
              data-title={title}
              data-text={text}
              style={`--brand:${n.color};`}
              title={`Compartir en ${n.label}`}
              aria-label={`Compartir en ${n.label}`}
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={n.path} /></svg>
            </button>
          ))}
          <button class="share-icon-btn" data-share="copy" data-title={title} data-text={text} style="--brand:var(--neon-green);" title="Copiar enlace" aria-label="Copiar enlace">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={copyIcon} /></svg>
          </button>
          <button class="share-icon-btn" data-share="native" data-title={title} data-text={text} style="--brand:var(--neon-purple);" title="Compartir" aria-label="Compartir">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={shareIcon} /></svg>
          </button>
        </div>
      </div>

      <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; border-top: 1px dashed rgba(255, 255, 255, 0.06); padding-top: 0.65rem;">
        <span style="font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-weight: 800; font-family: var(--font-title);">
          También en los medios
        </span>
        <div class="sharebar-row">
          {mediaOutlets.map((m) => (
            <button
              class="share-icon-btn"
              data-share="media"
              data-handle={m.key}
              data-title={title}
              data-text={text}
              style={`--brand:${m.color};`}
              title={`Difundir vía ${m.label} (X)`}
              aria-label={`Difundir vía ${m.label}`}
            >
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d={m.path} /></svg>
            </button>
          ))}
        </div>
      </div>
    </div>
  )
}

<style>
  .sharebar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.65rem;
  }
  .sharebar-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-btn,
  .share-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 0.6rem 0.85rem;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .share-icon-btn {
    width: 42px;
    height: 42px;
    padding: 0;
    flex-shrink: 0;
  }

  .share-btn svg,
  .share-icon-btn svg {
    fill: currentColor;
    flex-shrink: 0;
    transition: fill 0.2s ease;
  }

  .share-btn:hover,
  .share-icon-btn:hover {
    color: var(--brand);
    border-color: var(--brand);
    background: color-mix(in srgb, var(--brand) 10%, transparent);
    box-shadow: 0 0 14px color-mix(in srgb, var(--brand) 35%, transparent);
    transform: translateY(-2px);
  }
  .share-btn:active,
  .share-icon-btn:active {
    transform: scale(0.96);
  }
  .share-btn.copied,
  .share-icon-btn.copied {
    color: var(--neon-green);
    border-color: var(--neon-green);
    box-shadow: 0 0 14px var(--glow-green);
  }
</style>

<script>
  function buildShareUrl(key: string, url: string, text: string, title: string): string {
    const t = encodeURIComponent(text);
    const u = encodeURIComponent(url);
    switch (key) {
      case 'whatsapp':
        return `https://wa.me/?text=${t}%20${u}`;
      case 'telegram':
        return `https://t.me/share/url?url=${u}&text=${t}`;
      case 'x':
        return `https://twitter.com/intent/tweet?text=${t}&url=${u}`;
      case 'facebook':
        return `https://www.facebook.com/sharer/sharer.php?u=${u}`;
      case 'linkedin':
        return `https://www.linkedin.com/sharing/share-offsite/?url=${u}`;
      case 'bluesky':
        return `https://bsky.app/intent/compose?text=${t}%20${u}`;
      case 'email':
        return `mailto:?subject=${encodeURIComponent(title)}&body=${t}%20${u}`;
      default:
        return '';
    }
  }

  function flashCopied(btn: HTMLElement) {
    btn.classList.add('copied');
    const label = btn.querySelector('span');
    const original = label ? label.textContent : null;
    if (label) label.textContent = '¡Copiado!';
    setTimeout(() => {
      btn.classList.remove('copied');
      if (label && original) label.textContent = original;
    }, 1600);
  }

  document.querySelectorAll<HTMLElement>('[data-share]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.share;
      const title = btn.dataset.title || '';
      const text = btn.dataset.text || '';
      const url = window.location.href;

      if (key === 'copy') {
        try {
          await navigator.clipboard.writeText(url);
          flashCopied(btn);
        } catch (e) {
          console.error('No se pudo copiar:', e);
        }
        return;
      }

      if (key === 'native') {
        if (navigator.share) {
          try {
            await navigator.share({ title, text, url });
          } catch (e) {
            /* cancelado por el usuario */
          }
        } else {
          // Fallback: copiar enlace
          try {
            await navigator.clipboard.writeText(url);
            flashCopied(btn);
          } catch (e) {
            console.error('No se pudo copiar:', e);
          }
        }
        return;
      }

      const shareUrl = buildShareUrl(key!, url, text, title);
      if (shareUrl) {
        window.open(shareUrl, '_blank', 'noopener,noreferrer,width=620,height=620');
      }
    });
  });
</script>
