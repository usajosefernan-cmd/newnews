---
/**
 * ShareBar — Barra de compartir para artículos de desmentido (NEWNEWS).
 * Iconos SVG inline de los principales medios/redes, con glow de color de marca,
 * copiado al portapapeles con feedback y Web Share API nativa en móvil.
 *
 * Props:
 *  - title:  string  -> título del artículo (se usa en email/native share)
 *  - text:   string  -> mensaje de acompañamiento (p.ej. "Título — FALSO · Verificado por NEWNEWS")
 *  - variant:'card' | 'inline'  -> 'card' envuelve en .cyber-card; 'inline' lo integra sin marco
 *  - label:  string  -> texto del encabezado (por defecto "Compartir este desmentido")
 */
interface Props {
  title: string;
  text: string;
  variant?: 'card' | 'inline';
  label?: string;
}

const { title, text, variant = 'card', label = 'Compartir este desmentido' } = Astro.props;

type Network = {
  key: string;
  label: string;
  color: string;
  path: string;
};

// Logos reales (SVG paths 24x24) de los principales medios/redes en España.
const networks: Network[] = [
  {
    key: 'whatsapp',
    label: 'WhatsApp',
    color: '#25D366',
    path: 'M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.515 5.26l-.999 3.648 3.984-1.607z',
  },
