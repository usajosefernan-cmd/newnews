---
import Layout from '../../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

export async function getStaticPaths() {
  const dbPath = path.resolve('data/newnews.db');
  const db = new DatabaseSync(dbPath);
  db.exec('PRAGMA busy_timeout = 5000;');
  db.exec('PRAGMA journal_mode = WAL;');
  const articles = db.prepare("SELECT slug FROM articles WHERE status = 'publicado'").all();
  db.close();

  return articles.map(art => ({
    params: { slug: art.slug }
  }));
}

const { slug } = Astro.params;

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);
db.exec('PRAGMA busy_timeout = 5000;');
db.exec('PRAGMA journal_mode = WAL;');

// Cargar artículo
const article = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.slug = ? AND a.status = 'publicado'
`).get(slug);

// Cargar fuentes
const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(article.id);

// Cargar posts sociales
const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(article.id);

// Cargar item del radar correspondiente para extraer métricas y scores reales (código cero simulador)
const scrapedItem = db.prepare("SELECT metrics_json, virality_score, risk_score FROM scraped_items WHERE url = ?").get(article.origin_url) as any;

db.close();

let realMetrics = { likes: null, reposts: null, comments: null, views: null };
if (scrapedItem && scrapedItem.metrics_json) {
  try {
    const parsed = JSON.parse(scrapedItem.metrics_json);
    realMetrics.likes = parsed.likes || parsed.likeCount || parsed.likes_count || null;
    realMetrics.reposts = parsed.reposts || parsed.retweetCount || parsed.shareCount || parsed.reposts_count || null;
    realMetrics.comments = parsed.comments || parsed.commentCount || parsed.comments_count || null;
    realMetrics.views = parsed.views || parsed.viewCount || parsed.views_count || null;
  } catch (e) {}
}
const viralityScore = scrapedItem?.virality_score || null;
const riskScore = scrapedItem?.risk_score || null;

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

function getRelativeTime(dateString) {
  if (!dateString) return 'hace un momento';
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  if (isNaN(diffMs)) return 'hace un momento';
  const diffMin = Math.floor(diffMs / (1000 * 60));
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffMin < 1) return 'hace unos segundos';
  if (diffMin < 60) return `hace ${diffMin} min`;
  if (diffHours < 24) return `hace ${diffHours} h`;
  return `hace ${diffDays} días`;
}

function formatOriginalDate(dateString) {
  if (!dateString) return 'Reciente';
  const date = new Date(dateString);
  if (isNaN(date.getTime())) return dateString;
  return date.toLocaleDateString('es-ES', { 
    day: '2-digit', 
    month: '2-digit', 
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

// Helpers auxiliares de metadatos sociales
const getDeterministicGradient = (username) => {
  const gradients = [
    'linear-gradient(135deg, #0088cc 0%, #005580 100%)', // Azul Telegram
    'linear-gradient(135deg, #7b2cbf 0%, #3c096c 100%)', // Morado cyberpunk
    'linear-gradient(135deg, #e63946 0%, #1d3557 100%)', // Rojo coral
    'linear-gradient(135deg, #2a9d8f 0%, #264653 100%)', // Verde petróleo
    'linear-gradient(135deg, #f5a623 0%, #d0021b 100%)', // Naranja/Fuego
    'linear-gradient(135deg, #1d9bf0 0%, #0a66c2 100%)', // Azul social
    'linear-gradient(135deg, #833ab4 0%, #fd1d1d 50%, #fcb045 100%)' // Sunset
  ];
  let sum = 0;
  for (let i = 0; i < username.length; i++) {
    sum += username.charCodeAt(i);
  }
  return gradients[sum % gradients.length];
};

const formatDisplayName = (username) => {
  const u = username.toLowerCase();
  if (u === 'alviseperez') return 'Alvise Pérez';
  if (u === 'alvsjng') return 'Alvisjng';
  if (u === 'vox_es') return 'VOX España';
  if (u === 'ppopular') return 'Partido Popular';
  if (u === 'psoe') return 'PSOE';
  if (u === 'empleo_es') return 'Ministerio de Trabajo';
  if (u === 'comisioneuropea') return 'Comisión Europea';
  return username
    .replace(/[_\-]/g, ' ')
    .split(' ')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
};

const getInitials = (displayName) => {
  return displayName
    .split(' ')
    .map(w => w[0])
    .join('')
    .substring(0, 2)
    .toUpperCase();
};

const getSocialPostMeta = (url, platform) => {
  if (!url) return null;
  const lowerPlat = platform.toLowerCase();
  
  // Usar la fecha original de publicacion (origin_date) si está disponible, si no published_at
  const dateObj = article.origin_date ? new Date(article.origin_date) : new Date(article.published_at);
  const dateStr = dateObj.toLocaleString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });

  const verifiedAccounts = ['alviseperez', 'vox_es', 'ppopular', 'psoe', 'empleo_es', 'comisioneuropea'];
  const metrics = realMetrics;

  // 1. TELEGRAM
  if (lowerPlat.includes('telegram') || url.includes('t.me') || url.includes('telegram.me')) {
    const match = url.match(/telegram\.me\/s\/([^\/]+)\/(\d+)/i) || url.match(/t\.me\/([^\/]+)\/(\d+)/i);
    const rawUser = match ? match[1] : 'canal_telegram';
    const postId = match ? match[2] : '0';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = getDeterministicGradient(rawUser);
    
    return {
      type: 'telegram',
      username: `@${rawUser}`,
      postId: `#${postId}`,
      displayName,
      verified: verifiedAccounts.includes(rawUser.toLowerCase()),
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url,
      metrics
    };
  }

  // 2. TWITTER / X
  if (lowerPlat.includes('x') || lowerPlat.includes('twitter') || url.includes('x.com') || url.includes('twitter.com')) {
    const match = url.match(/(?:x|twitter)\.com\/([^\/]+)\/status\/(\d+)/i);
    const rawUser = match ? match[1] : 'usuario_x';
    const postId = match ? match[2] : '';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = getDeterministicGradient(rawUser);
    
    return {
      type: 'x',
      username: `@${rawUser}`,
      postId: postId ? `post: ${postId.substring(0, 8)}...` : '',
      displayName,
      verified: verifiedAccounts.includes(rawUser.toLowerCase()),
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url,
      metrics
    };
  }

  // 3. INSTAGRAM
  if (lowerPlat.includes('instagram') || url.includes('instagram.com')) {
    const match = url.match(/instagram\.com\/p\/([^\/]+)/i) || url.match(/instagram\.com\/([^\/]+)/i);
    const rawUser = match ? match[1] : 'usuario_instagram';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = 'linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%)';
    
    return {
      type: 'instagram',
      username: `@${rawUser}`,
      postId: 'Post',
      displayName,
      verified: verifiedAccounts.includes(rawUser.toLowerCase()),
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url,
      metrics
    };
  }

  // 4. YOUTUBE
  if (lowerPlat.includes('youtube') || url.includes('youtube.com') || url.includes('youtu.be')) {
    let youtubeId = '';
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    if (match && match[2].length === 11) {
      youtubeId = match[2];
    }
    
    return {
      type: 'youtube',
      youtubeId,
      url,
      dateStr,
      metrics
    };
  }

  // 5. TIKTOK
  if (lowerPlat.includes('tiktok') || url.includes('tiktok.com')) {
    let tiktokVideoId = '';
    const match = url.match(/\/video\/(\d+)/);
    if (match) {
      tiktokVideoId = match[1];
    }

    return {
      type: 'tiktok',
      tiktokVideoId,
      url,
      dateStr,
      metrics
    };
  }

  // Fallback genérico para cualquier URL
  return {
    type: 'generic',
    url,
    dateStr,
    metrics
  };
};

const socialMeta = getSocialPostMeta(article.origin_url, article.origin_platform);
---

<Layout title={article.title} description={article.subtitle} category={article.category}>
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem;">
    
    <!-- Miga de Pan -->
    <div style="margin-bottom: 1.5rem; font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">
      <a href="/" style="text-decoration: none;">Radar</a> / <a href="/temas" style="text-decoration: none;">Expedientes</a> / <a href={`/tema/${article.topic_slug}`} style="text-decoration: none;">{article.topic_title.split(' ')[0]}</a> / <span style="color: var(--neon-blue);">{article.title.substring(0, 20)}...</span>
    </div>

    <!-- Título y Veredicto Principal -->
    <section style="margin-bottom: 2.5rem;">
      <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
          <span style="background: rgba(255,255,255,0.04); color: var(--text-muted); font-size: 0.7rem; font-weight: 800; padding: 0.25rem 0.6rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em;">
            {article.category}
          </span>
          <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">
            Incorporado a la web: <strong style="color: var(--neon-blue);">{getRelativeTime(article.published_at)}</strong>
          </span>
          {article.origin_date && (
            <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">
              &bull; Publicación original: <strong style="color: var(--text-main);">{formatOriginalDate(article.origin_date)}</strong>
            </span>
          )}
        </div>
        <h1 style="font-size: 2.2rem; line-height: 1.2; font-weight: 800; letter-spacing: -0.03em; color: var(--text-main);">
          {article.title}
        </h1>
        <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.5;">
          {article.subtitle}
        </p>
      </div>

      <!-- Veredicto Box Cyberpunk -->
      <div class={`cyber-card ${getVerdictClass(article.verdict)}`} style="padding: 1.75rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%); display: flex; flex-direction: column; gap: 1.25rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
          <span style="font-family: var(--font-title); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em;">
            Veredicto Oficial
          </span>
          <span class={`verdict-badge ${article.verdict.toLowerCase().replace(' ', '-')}`} style="font-size: 0.95rem; padding: 0.4rem 1rem;">
            {article.verdict}
          </span>
        </div>

        <div>
          <span style="font-weight: 800; text-transform: uppercase; color: var(--text-main); font-size: 0.75rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.35rem;">Conclusión de la Auditoría</span>
          <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">
            {article.summary}
          </p>
        </div>
      </div>
    </section>

    <!-- Ficha del Claim y el Origen -->
    <section style="margin-bottom: 2.5rem; display: flex; flex-direction: column; gap: 1.5rem;">
      
      <!-- Detalle Técnico de la Afirmación y Caja de Origen (Mockups) -->
      {socialMeta ? (
        <div class="cyber-card" style={{ padding: '1.5rem', background: 'rgba(7, 9, 19, 0.75)', borderColor: socialMeta.type === 'telegram' ? '#0088cc' : socialMeta.type === 'x' ? '#ffffff' : socialMeta.type === 'instagram' ? '#dc2743' : socialMeta.type === 'youtube' ? '#ff0000' : socialMeta.type === 'tiktok' ? '#00f2fe' : 'var(--neon-blue)' }}>
          
          {/* Cabecera del Post (Estilo Social Media) */}
          <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 0.85rem; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 0.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              {/* Avatar circular con iniciales y gradiente */}
              <div style={{ width: '42px', height: '42px', borderRadius: '50%', background: socialMeta.type === 'instagram' ? 'linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%)' : socialMeta.avatarColor || 'var(--neon-blue)', display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#ffffff', fontWeight: '800', fontSize: '0.9rem', border: '1px solid rgba(255,255,255,0.1)' }}>
                {socialMeta.initials || 'SP'}
              </div>
              
              <div style="display: flex; flex-direction: column;">
                <div style="display: flex; align-items: center; gap: 0.35rem;">
                  <span style="color: #ffffff; font-weight: 800; font-size: 0.95rem; line-height: 1.2;">
                    {socialMeta.displayName || article.origin_platform}
                  </span>
                  {socialMeta.verified && (
                    <span style={{ color: socialMeta.type === 'x' ? '#1d9bf0' : socialMeta.type === 'telegram' ? '#0088cc' : '#3897f0', fontSize: '0.85rem' }} title="Cuenta Verificada Oficial">✓</span>
                  )}
                </div>
                <span style="color: var(--text-muted); font-size: 0.8rem; font-family: monospace;">
                  {socialMeta.username || `@${article.origin_platform.toLowerCase()}`}
                </span>
              </div>
            </div>
            
            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem;">
              <span style={{ background: socialMeta.type === 'telegram' ? 'rgba(0, 136, 204, 0.1)' : socialMeta.type === 'x' ? 'rgba(255,255,255,0.05)' : 'rgba(220, 39, 67, 0.1)', color: socialMeta.type === 'telegram' ? '#0088cc' : '#ffffff', padding: '0.2rem 0.5rem', borderRadius: '4px', fontSize: '0.7rem', fontWeight: 'bold', textTransform: 'uppercase', border: '1px solid rgba(255,255,255,0.03)' }}>
                {article.origin_platform}
              </span>
              <span style="font-size: 0.75rem; color: var(--text-muted);">
                {socialMeta.dateStr}
              </span>
            </div>
          </div>

          {/* Contenido / Claim Original (Resaltado con advertencia de Bulo) */}
          <div style="background: rgba(220, 39, 67, 0.03); border: 1px solid rgba(220, 39, 67, 0.2); border-radius: 12px; padding: 1.25rem; margin-bottom: 1.25rem; position: relative; margin-top: 0.5rem;">
            <span style="position: absolute; top: -0.5rem; left: 1rem; background: #070913; padding: 0 0.5rem; font-size: 0.65rem; color: var(--neon-rose); font-weight: 800; letter-spacing: 0.05em; border: 1px solid rgba(220, 39, 67, 0.2); border-radius: 4px;">
              ⚠️ AFIRMACIÓN VIRAL DETECTADA
            </span>
            <p style="font-style: italic; color: #ffffff; font-size: 1.05rem; line-height: 1.45; font-weight: 600; margin: 0.5rem 0 0.5rem 0;">
              "{article.claim}"
            </p>
            {article.origin_summary && (
              <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin: 0;">
                {article.origin_summary}
              </p>
            )}

            {/* Evidencia multimedia desmentida (Foto/Video adjunto) */}
            {article.multimedia_url && (
              <div style="margin-top: 1.25rem; border-top: 1px solid rgba(220, 39, 67, 0.15); padding-top: 1rem; text-align: center;">
                <span style="display: block; font-size: 0.7rem; color: var(--neon-rose); font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem; text-align: left;">
                  🖼️ Archivo Adjunto Desmentido:
                </span>
                
                {article.multimedia_type === 'video' || article.multimedia_url.includes('.mp4') ? (
                  <video src={article.multimedia_url} controls style="width: 100%; max-height: 320px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); background: #000;"></video>
                ) : (
                  <div style="overflow: hidden; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); max-height: 320px; display: flex; justify-content: center; align-items: center; background: rgba(0,0,0,0.25);">
                    <img src={article.multimedia_url} alt="Evidencia desmentida" style="max-width: 100%; max-height: 320px; object-fit: contain; cursor: zoom-in; transition: transform 0.2s;" onclick="this.style.transform = this.style.transform === 'scale(1.3)' ? 'scale(1)' : 'scale(1.3)';" />
                  </div>
                )}
              </div>
            )}
          </div>

          {/* Sección interactiva: Embeds si están habilitados */}
          <div style="margin-bottom: 1.25rem;">
            {/* EMBED: YOUTUBE */}
            {socialMeta.type === 'youtube' && socialMeta.youtubeId && (
              <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); background: #000;">
                <iframe 
                  src={`https://www.youtube.com/embed/${socialMeta.youtubeId}`} 
                  style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;" 
                  frameborder="0" 
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                  allowfullscreen
                ></iframe>
              </div>
            )}

            {/* EMBED: TELEGRAM */}
            {socialMeta.type === 'telegram' && (
              <iframe 
                src={`${socialMeta.url.replace('t.me/', 't.me/s/')}?embed=1`} 
                style="width: 100%; border: none; height: 320px; background: rgba(7, 9, 19, 0.7); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);"
                title="Telegram Embed"
              ></iframe>
            )}

            {/* EMBED: TWITTER / X */}
            {socialMeta.type === 'x' && (
              <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; background: rgba(0,0,0,0.2); padding: 0.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); max-height: 380px; overflow-y: auto;">
                <blockquote class="twitter-tweet" data-theme="dark" data-align="center" style="margin: 0 auto; max-width: 100%;">
                  <a href={socialMeta.url}>Cargando tweet oficial interactivo...</a>
                </blockquote>
                <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
              </div>
            )}

            {/* EMBED: TIKTOK */}
            {socialMeta.type === 'tiktok' && socialMeta.tiktokVideoId && (
              <div style="display: flex; justify-content: center; width: 100%; max-height: 380px; overflow-y: auto; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); padding: 0.5rem; background: rgba(0,0,0,0.2);">
                <blockquote class="tiktok-embed" data-video-id={socialMeta.tiktokVideoId} style="max-width: 605px; min-width: 325px; margin: 0 auto;">
                  <section>
                    <a target="_blank" title="TikTok" href={socialMeta.url}>Cargando vídeo oficial de TikTok...</a>
                  </section>
                </blockquote>
                <script async src="https://www.tiktok.com/embed.js"></script>
              </div>
            )}

            {/* EMBED: INSTAGRAM */}
            {socialMeta.type === 'instagram' && (
              <div style="display: flex; justify-content: center; width: 100%; max-height: 380px; overflow-y: auto; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); padding: 0.5rem; background: rgba(0,0,0,0.2);">
                <blockquote class="instagram-media" data-instgrm-permalink={socialMeta.url} data-instgrm-version="14" style="background:#FFF; border:0; border-radius:12px; box-shadow:0 0 1px 0 rgba(0,0,0,0.5),0 1px 10px 0 rgba(0,0,0,0.15); margin: 1px; max-width:540px; min-width:326px; padding:0; width:99.375%;">
                  <div style="padding:16px;">
                    <a href={socialMeta.url} target="_blank" style="background:#FFFFFF; line-height:0; padding:0 0; text-align:center; text-decoration:none; width:100%; display:block;">
                      Cargando post oficial de Instagram...
                    </a>
                  </div>
                </blockquote>
                <script async src="https://www.instagram.com/embed.js"></script>
              </div>
            )}
          </div>

          {/* Fila de Métricas / Viralidad (Código Cero Simulador) */}
          <div style="display: flex; justify-content: space-around; align-items: center; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 0.85rem; margin-top: 0.85rem; font-family: monospace; font-size: 0.85rem; color: var(--text-muted); flex-wrap: wrap; gap: 0.75rem;">
            {socialMeta.metrics && (socialMeta.metrics.views || socialMeta.metrics.likes || socialMeta.metrics.reposts || socialMeta.metrics.comments) ? (
              <>
                {socialMeta.metrics.views && (
                  <div style="display: flex; align-items: center; gap: 0.35rem;" title="Visualizaciones reales">
                    👁️ <strong>{socialMeta.metrics.views}</strong> <span style="font-size: 0.7rem; color: rgba(255,255,255,0.3);">Vistas</span>
                  </div>
                )}
                {socialMeta.metrics.likes && (
                  <div style="display: flex; align-items: center; gap: 0.35rem;" title="Me Gusta">
                    ❤️ <strong>{socialMeta.metrics.likes}</strong> <span style="font-size: 0.7rem; color: rgba(255,255,255,0.3);">Likes</span>
                  </div>
                )}
                {socialMeta.metrics.reposts && (
                  <div style="display: flex; align-items: center; gap: 0.35rem;" title="Compartidos">
                    🔁 <strong>{socialMeta.metrics.reposts}</strong> <span style="font-size: 0.7rem; color: rgba(255,255,255,0.3);">Compartidos</span>
                  </div>
                )}
                {socialMeta.metrics.comments && (
                  <div style="display: flex; align-items: center; gap: 0.35rem;" title="Comentarios">
                    💬 <strong>{socialMeta.metrics.comments}</strong> <span style="font-size: 0.7rem; color: rgba(255,255,255,0.3);">Comentarios</span>
                  </div>
                )}
              </>
            ) : (
              <div style="font-size: 0.8rem; color: var(--text-muted); display: flex; gap: 1.5rem; width: 100%; justify-content: center;">
                <span>🔥 Score de Viralidad: <strong style="color: var(--neon-purple);">{viralityScore !== null ? `${viralityScore}/10` : 'Pendiente'}</strong></span>
                <span>⚠️ Nivel de Alerta: <strong style="color: var(--neon-rose);">{riskScore !== null ? `${riskScore}/10` : 'Pendiente'}</strong></span>
              </div>
            )}
          </div>

          {/* Link Real y Directo al Post/Noticia */}
          <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px dashed rgba(255,255,255,0.06); padding-top: 0.85rem; margin-top: 0.85rem; font-size: 0.8rem; flex-wrap: wrap; gap: 0.5rem;">
            <span style="color: var(--text-muted);">Enlace Oficial:</span>
            <a href={socialMeta.url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: none; font-weight: 800; display: inline-flex; align-items: center; gap: 0.35rem; transition: color 0.15s;">
              <span>Ver publicación original en {article.origin_platform}</span>
              <span style="font-size: 0.95rem;">&rarr;</span>
            </a>
          </div>

        </div>
      ) : (
        <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45);">
          <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Afirmación Detectada</span>
          <p style="font-style: italic; color: var(--text-main); font-size: 1rem; font-weight: 500; line-height: 1.4; margin-bottom: 1.25rem; border-left: 2px solid var(--neon-rose); padding-left: 0.75rem;">
            "{article.claim}"
          </p>
          
          <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem;">Origen del bulo:</span>
          <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; margin-bottom: 1rem;">
            {article.origin_summary}
          </p>

          <div style="display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
            <span>Plataforma: <strong style="color: var(--text-main);">{article.origin_platform}</strong></span>
            {article.origin_url && (
              <a href={article.origin_url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: none; font-weight: 700;">
                Ver post original &rarr;
              </a>
            )}
          </div>

          {/* Evidencia multimedia desmentida en fallback */}
          {article.multimedia_url && (
            <div style="margin-top: 1.25rem; border-top: 1px solid var(--border-color); padding-top: 1rem; text-align: center;">
              <span style="display: block; font-size: 0.7rem; color: var(--neon-rose); font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem; text-align: left;">
                🖼️ Archivo Multimedia Desmentido:
              </span>
              {article.multimedia_type === 'video' || article.multimedia_url.includes('.mp4') ? (
                <video src={article.multimedia_url} controls style="width: 100%; max-height: 320px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); background: #000;"></video>
              ) : (
                <div style="overflow: hidden; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); max-height: 320px; display: flex; justify-content: center; align-items: center; background: rgba(0,0,0,0.25);">
                  <img src={article.multimedia_url} alt="Evidencia desmentida" style="max-width: 100%; max-height: 320px; object-fit: contain; cursor: zoom-in;" onclick="this.style.transform = this.style.transform === 'scale(1.3)' ? 'scale(1)' : 'scale(1.3)';" />
                </div>
              )}
            </div>
          )}
        </div>
      )}

      <!-- Auditoría del Bulómetro -->
      <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.25);">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-purple); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 1rem;">Métricas de Auditoría</span>
        
        <div style="display: flex; flex-direction: column; gap: 0.85rem; font-size: 0.85rem;">
          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
            <span style="color: var(--text-muted);">Revisión Humana:</span>
            <span style="color: var(--neon-green); font-weight: 700;">Verificada</span>
          </div>
          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
            <span style="color: var(--text-muted);">Riesgo de Desinformación:</span>
            <span style="color: var(--neon-rose); font-weight: 700;">Alto</span>
          </div>
          <div style="display: flex; justify-content: space-between;">
            <span style="color: var(--text-muted);">Fuentes Indexadas:</span>
            <span style="color: var(--text-main); font-weight: 700;">{sources.length} oficiales</span>
          </div>
        </div>
      </div>

    </section>

    <!-- Caja de Datos Desglosados -->
    <section style="margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: 1rem;">Desglose de Hechos</span>

      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        
        <div class="cyber-card" style="padding: 1.25rem; border-color: rgba(0, 245, 160, 0.15); background: rgba(0, 245, 160, 0.01);">
          <span style="color: var(--neon-green); font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Qué es real</span>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45;">
            {article.what_is_true || "No hay hechos ciertos en la afirmación."}
          </p>
        </div>

        <div class="cyber-card" style="padding: 1.25rem; border-color: rgba(255, 51, 102, 0.15); background: rgba(255, 51, 102, 0.01);">
          <span style="color: var(--neon-rose); font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Qué es falso</span>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45;">
            {article.what_is_false || "No se han detectado falsedades explícitas."}
          </p>
        </div>

        <div class="cyber-card" style="padding: 1.25rem; border-color: rgba(255, 176, 32, 0.15); background: rgba(255, 176, 32, 0.01);">
          <span style="color: var(--neon-amber); font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Falta de contexto</span>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45;">
            {article.what_lacks_context || "No se requiere contexto adicional."}
          </p>
        </div>

      </div>
    </section>

    <!-- Explicación de los Hechos (Cuerpo del Artículo) -->
    <section style="margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: 1rem;">Análisis Detallado</span>
      <div style="font-size: 0.95rem; line-height: 1.7; color: #E2E8F0; white-space: pre-wrap; background: rgba(18, 22, 41, 0.45);" class="cyber-card">
        {article.explanation}
      </div>
    </section>

    <!-- Fuentes Oficiales Indexadas (Plegables) -->
    <details class="cyber-card" style="padding: 1.75rem; border-color: rgba(0, 245, 160, 0.15); background: rgba(18, 22, 41, 0.3); margin-bottom: 2.5rem; border-radius: 12px;">
      <summary style="font-weight: 800; text-transform: uppercase; color: var(--neon-green); font-size: 0.75rem; letter-spacing: 0.05em; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; outline: none; user-select: none;">
        <span>📚 VER FUENTES OFICIALES E INFORME TÉCNICO ({sources.length})</span>
        <span style="color: var(--neon-blue); font-size: 0.7rem;">+ DESPLEGAR DOCUMENTOS</span>
      </summary>

      <div style="margin-top: 1.5rem; border-top: 1px dashed rgba(0, 245, 160, 0.2); padding-top: 1.25rem;">
        <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1.5rem; line-height: 1.4;">
          Respaldamos esta verificación en registros primarios oficiales y públicos. Pulsa en el enlace para auditar el documento tú mismo.
        </p>

        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          {sources.map(src => (
            <div style="border: 1px solid var(--border-color); padding: 1rem; background: rgba(7, 9, 19, 0.5); border-radius: 12px;">
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.4rem; flex-wrap: wrap; gap: 0.5rem;">
                <strong style="color: var(--text-main); font-size: 0.9rem;">{src.title}</strong>
                <span style="background: rgba(0, 240, 255, 0.08); color: var(--neon-blue); font-size: 0.6rem; font-weight: 800; padding: 0.15rem 0.5rem; text-transform: uppercase; border-radius: 4px; border: 1px solid rgba(0,240,255,0.15);">
                  Rango: {src.authority_level}
                </span>
              </div>
              <p style="color: var(--text-muted); font-size: 0.8rem; line-height: 1.4; margin-bottom: 0.75rem;">
                {src.quote_or_summary}
              </p>
              <a href={src.url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); font-size: 0.75rem; font-weight: 700; text-decoration: none;">
                Acceder al documento oficial &rarr;
              </a>
            </div>
          ))}

          {sources.length === 0 && (
            <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center;">No se han indexado fuentes en la base de datos.</p>
          )}
        </div>
      </div>
    </details>

    <!-- Compartir en Redes (Contracampaña) -->
    <section class="cyber-card" style="padding: 1.75rem; border-color: rgba(0, 240, 255, 0.15); background: rgba(18, 22, 41, 0.3); margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-blue); font-size: 0.75rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Compartir en Redes</span>
      <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1.5rem; line-height: 1.4;">
        Copia respuestas o hilos generados automáticamente para desmontar el bulo en redes sociales cuando lo veas en canales públicos.
      </p>

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        {socialPosts.map((post, idx) => (
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <strong style="color: var(--text-main); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">
              Formato: {post.platform} ({post.format})
            </strong>
            <div 
              id={`social-content-${idx}`} 
              style="background: rgba(7, 9, 19, 0.6); border: 1px solid var(--border-color); padding: 1rem; font-size: 0.8rem; color: var(--text-muted); font-family: monospace; white-space: pre-wrap; max-height: 150px; overflow-y: auto; border-radius: 12px; line-height: 1.45;"
            >{post.content}</div>
            
            <button 
              class="cyber-btn copy-btn" 
              data-target={`social-content-${idx}`}
              style="width: 100%; padding: 0.6rem; font-size: 0.75rem; border-radius: 12px; text-transform: uppercase; font-weight: 800;"
            >
              Copiar Mensaje
            </button>
          </div>
        ))}

        {socialPosts.length === 0 && (
          <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center;">No hay copys sociales sugeridos para este artículo.</p>
        )}
      </div>

      <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
        <a href="/" class="cyber-btn" style="width: 100%; text-align: center; border-radius: 12px; padding: 0.75rem;">
          Volver al Radar
        </a>
      </div>
    </section>

  </div>
</Layout>

<!-- Script interactivo de copiado rápido al portapapeles con feedback visual en el botón -->
<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const text = document.getElementById(targetId).innerText;
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.innerText;
        btn.innerText = '¡Copiado con éxito!';
        btn.style.borderColor = 'var(--neon-green)';
        btn.style.color = 'var(--neon-green)';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.borderColor = 'var(--border-color)';
          btn.style.color = 'var(--text-main)';
        }, 1500);
      }).catch(err => {
        console.error('Error al copiar al portapapeles:', err);
      });
    });
  });
</script>

<style>
  .nav-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
