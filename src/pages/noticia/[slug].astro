---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import ShareBar from '../../components/ShareBar.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

const { slug } = Astro.params;

const dbPath = process.env.SQLITE_DB_PATH || import.meta.env.SQLITE_DB_PATH || path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);
db.exec('PRAGMA busy_timeout = 5000;');
db.exec('PRAGMA journal_mode = WAL;');

// Cargar artículo
const article = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.slug = ? AND a.status = 'publicado'
`).get(slug) as any;

if (!article) {
  db.close();
  return Astro.redirect('/404');
}

// Cargar todos los temas asociados al artículo (muchos-a-muchos)
let articleTopics = [] as any[];
if (article) {
  articleTopics = db.prepare(`
    SELECT t.title, t.slug 
    FROM article_topics at
    JOIN topics t ON at.topic_id = t.id
    WHERE at.article_id = ? AND t.status = 'activo'
  `).all(article.id) as any[];
  
  // Si por alguna razón está vacía, usar el tema principal del artículo como fallback
  if (articleTopics.length === 0 && article.topic_title) {
    articleTopics.push({ title: article.topic_title, slug: article.topic_slug });
  }
}

// Cargar fuentes
const sources = article ? db.prepare("SELECT * FROM sources WHERE article_id = ?").all(article.id) as any[] : [];

// Cargar posts sociales
const socialPosts = article ? db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(article.id) as any[] : [];

// Cargar artículos relacionados (mismo tema)
const relatedSameTopic = db.prepare(`
  SELECT * FROM articles 
  WHERE topic_id = ? AND id != ? AND status = 'publicado' 
  ORDER BY published_at DESC 
  LIMIT 2
`).all(article.topic_id, article.id) as any[];

// Cargar artículos relacionados (otros temas)
const relatedOtherTopics = db.prepare(`
  SELECT * FROM articles 
  WHERE topic_id != ? AND status = 'publicado' 
  ORDER BY published_at DESC 
  LIMIT 2
`).all(article.topic_id) as any[];

// Cargar item del radar correspondiente para extraer mátricas y scores reales (código cero simulador)
const scrapedItem = db.prepare("SELECT metrics_json, virality_score, risk_score FROM scraped_items WHERE url = ?").get(article.origin_url) as any;

db.close();

// Extraer YouTube ID directamente de forma blindada para el reproductor de video
let directYoutubeId = '';
if (article && article.origin_url) {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|\/shorts\/)([^#\&\?]*).*/;
  const match = article.origin_url.match(regExp);
  if (match && match[2].length === 11) {
    directYoutubeId = match[2];
  }
}

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;

let realMetrics = { likes: null, reposts: null, comments: null, views: null };
if (scrapedItem && scrapedItem.metrics_json) {
  try {
    const parsed = JSON.parse(scrapedItem.metrics_json);
    realMetrics.likes = parsed.likes || parsed.likeCount || parsed.likes_count || null;
    realMetrics.reposts = parsed.reposts || parsed.retweetCount || parsed.shareCount || parsed.reposts_count || null;
    realMetrics.comments = parsed.comments || parsed.commentCount || parsed.comments_count || null;
    realMetrics.views = parsed.views || parsed.viewCount || parsed.views_count || null;
  } catch (e) {}
}
const viralityScore = scrapedItem?.virality_score || null;
const riskScore = scrapedItem?.risk_score || null;


// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

function getRelativeTime(dateString) {
  if (!dateString) return 'hace un momento';
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  if (isNaN(diffMs)) return 'hace un momento';
  const diffMin = Math.floor(diffMs / (1000 * 60));
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffMin < 1) return 'hace unos segundos';
  if (diffMin < 60) return `hace ${diffMin} min`;
  if (diffHours < 24) return `hace ${diffHours} h`;
  return `hace ${diffDays} días`;
}

function formatOriginalDate(dateString) {
  if (!dateString) return 'Reciente';
  const date = new Date(dateString);
  if (isNaN(date.getTime())) return dateString;
  return date.toLocaleDateString('es-ES', { 
    day: '2-digit', 
    month: '2-digit', 
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

// Helpers auxiliares de metadatos sociales
const getDeterministicGradient = (username) => {
  const gradients = [
    'linear-gradient(135deg, #0088cc 0%, #005580 100%)', // Azul Telegram
    'linear-gradient(135deg, #7b2cbf 0%, #3c096c 100%)', // Morado cyberpunk
    'linear-gradient(135deg, #e63946 0%, #1d3557 100%)', // Rojo coral
    'linear-gradient(135deg, #2a9d8f 0%, #264653 100%)', // Verde petróleo
    'linear-gradient(135deg, #f5a623 0%, #d0021b 100%)', // Naranja/Fuego
    'linear-gradient(135deg, #1d9bf0 0%, #0a66c2 100%)', // Azul social
    'linear-gradient(135deg, #833ab4 0%, #fd1d1d 50%, #fcb045 100%)' // Sunset
  ];
  let sum = 0;
  for (let i = 0; i < username.length; i++) {
    sum += username.charCodeAt(i);
  }
  return gradients[sum % gradients.length];
};

const formatDisplayName = (username) => {
  const u = username.toLowerCase();
  if (u === 'alviseperez') return 'Alvise Pérez';
  if (u === 'alvsjng') return 'Alvisjng';
  if (u === 'vox_es') return 'VOX España';
  if (u === 'ppopular') return 'Partido Popular';
  if (u === 'psoe') return 'PSOE';
  if (u === 'empleo_es') return 'Ministerio de Trabajo';
  if (u === 'comisioneuropea') return 'Comisión Europea';
  return username
    .replace(/[_\-]/g, ' ')
    .split(' ')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
};

const getInitials = (displayName) => {
  return displayName
    .split(' ')
    .map(w => w[0])
    .join('')
    .substring(0, 2)
    .toUpperCase();
};

const getSocialPostMeta = (url, platform) => {
  if (!url) return null;
  const lowerPlat = platform.toLowerCase();
  
  // Usar la fecha original de publicacion (origin_date) si está disponible, si no published_at
  const dateObj = article.origin_date ? new Date(article.origin_date) : new Date(article.published_at);
  const dateStr = dateObj.toLocaleString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });

  const verifiedAccounts = ['alviseperez', 'vox_es', 'ppopular', 'psoe', 'empleo_es', 'comisioneuropea'];
  const metrics = realMetrics;

  // 1. TELEGRAM
  if (lowerPlat.includes('telegram') || url.includes('t.me') || url.includes('telegram.me')) {
    const match = url.match(/telegram\.me\/s\/([^\/]+)\/(\d+)/i) || url.match(/t\.me\/([^\/]+)\/(\d+)/i);
    const rawUser = match ? match[1] : 'canal_telegram';
    const postId = match ? match[2] : '0';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = getDeterministicGradient(rawUser);
    
    return {
      type: 'telegram',
      username: `@${rawUser}`,
      postId: `#${postId}`,
      displayName,
      verified: verifiedAccounts.includes(rawUser.toLowerCase()),
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url,
      metrics
    };
  }

  // 2. TWITTER / X
  if (lowerPlat.includes('x') || lowerPlat.includes('twitter') || url.includes('x.com') || url.includes('twitter.com')) {
    const match = url.match(/(?:x|twitter)\.com\/([^\/]+)\/status\/(\d+)/i);
    const rawUser = match ? match[1] : 'usuario_x';
    const postId = match ? match[2] : '';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = getDeterministicGradient(rawUser);
    
    return {
      type: 'x',
      username: `@${rawUser}`,
      postId: postId ? `post: ${postId.substring(0, 8)}...` : '',
      displayName,
      verified: verifiedAccounts.includes(rawUser.toLowerCase()),
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url,
      metrics
    };
  }

  // 3. INSTAGRAM
  if (lowerPlat.includes('instagram') || url.includes('instagram.com')) {
    const match = url.match(/instagram\.com\/p\/([^\/]+)/i) || url.match(/instagram\.com\/([^\/]+)/i);
    const rawUser = match ? match[1] : 'usuario_instagram';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = 'linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%)';
    
    return {
      type: 'instagram',
      username: `@${rawUser}`,
      postId: 'Post',
      displayName,
      verified: verifiedAccounts.includes(rawUser.toLowerCase()),
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url,
      metrics
    };
  }

  // 4. YOUTUBE
  if (lowerPlat.includes('youtube') || url.includes('youtube.com') || url.includes('youtu.be')) {
    let youtubeId = '';
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|\/shorts\/)([^#\&\?]*).*/;
    const match = url.match(regExp);
    if (match && match[2].length === 11) {
      youtubeId = match[2];
    }
    
    return {
      type: 'youtube',
      youtubeId,
      url,
      dateStr,
      metrics
    };
  }

  // 5. TIKTOK
  if (lowerPlat.includes('tiktok') || url.includes('tiktok.com')) {
    let tiktokVideoId = '';
    const match = url.match(/\/video\/(\d+)/);
    if (match) {
      tiktokVideoId = match[1];
    }

    return {
      type: 'tiktok',
      tiktokVideoId,
      url,
      dateStr,
      metrics
    };
  }

  // Fallback genárico para cualquier URL
  return {
    type: 'generic',
    url,
    dateStr,
    metrics
  };
};

const socialMeta = getSocialPostMeta(article.origin_url, article.origin_platform);

// Unificación estética de metadatos sociales (Código Cero Simulador)
const resolvedSocialMeta = socialMeta || {
  displayName: article.origin_platform === 'YouTube' ? 'Canal de YouTube' : article.origin_platform === 'TikTok' ? 'Perfil de TikTok' : article.origin_platform === 'Telegram' ? 'Canal de Telegram' : article.origin_platform === 'X' ? 'Publicación de X' : 'Publicación de Redes',
  username: `@${article.origin_platform.toLowerCase().replace(/[^a-z0-9]/g, '')}`,
  initials: article.origin_platform === 'YouTube' ? 'YT' : article.origin_platform === 'TikTok' ? 'TT' : article.origin_platform === 'Telegram' ? 'TG' : article.origin_platform === 'X' ? 'X' : 'RD',
  avatarColor: article.origin_platform === 'YouTube' ? '#ff0000' : article.origin_platform === 'TikTok' ? '#00f2fe' : article.origin_platform === 'Telegram' ? '#0088cc' : article.origin_platform === 'X' ? '#000000' : 'var(--neon-blue)',
  type: article.origin_platform.toLowerCase(),
  verified: false,
  dateStr: formatOriginalDate(article.origin_date),
  metrics: realMetrics
};

// Precalculados para el termómetro
const termometroScore = article.newnews_score || 50;
let termometroLabel = 'Confuso';
if (termometroScore <= 20) {
  termometroLabel = 'Ruido bajo';
} else if (termometroScore <= 40) {
  termometroLabel = 'Dudoso';
} else if (termometroScore <= 60) {
  termometroLabel = 'Confuso';
} else if (termometroScore <= 80) {
  termometroLabel = 'Viral y preocupante';
} else {
  termometroLabel = 'Prioridad alta / Alarma';
}

// Precalculados para el truco usado
const trickUsed = (article.trick_used || '').toLowerCase();
let trickDesc = 'Se utilizan afirmaciones genéricas descontextualizadas del marco legal oficial del BOE o del INE para generar desinformación.';
if (trickUsed === 'cherry-picking') {
  trickDesc = 'Se seleccionan únicamente datos parciales o favorables al sesgo para omitir el contexto general completo que desmiente la afirmación.';
} else if (trickUsed === 'falso dilema') {
  trickDesc = 'Se presenta la situación como si solo existieran dos opciones extremas excluyentes, ocultando la existencia de matices intermedios o terceras vías jurídicas.';
} else if (trickUsed === 'culpa colectiva') {
  trickDesc = 'Se atribuye a todo un grupo social (por origen, nacionalidad o religión) la responsabilidad directa o indirecta por el acto delictivo de un individuo aislado.';
} else if (trickUsed === 'dato sin base') {
  trickDesc = 'Se lanzan porcentajes alarmantes o cifras absolutas elevadas sin contextualizar la base demográfica, el denominador o el marco de comparación estadística real.';
} else if (trickUsed === 'vídeo recortado') {
  trickDesc = 'Se extrae un fragmento de audio o vídeo de pocos segundos para descontextualizar las declaraciones completas o la fecha real del suceso.';
} else if (trickUsed === 'autoridad falsa') {
  trickDesc = 'Se atribuye la información a supuestos portales de investigación, expertos autodeclarados o fuentes no oficiales para forzar veracidad.';
} else if (trickUsed === 'miedo/urgencia') {
  trickDesc = 'Se recurre a llamadas de pánico moral o urgencia ("lo ocultan", "secreto", "últimas unidades") para activar una creencia emocional irracional.';
} else if (trickUsed === 'promoción encubierta') {
  trickDesc = 'Se recomienda un producto o inversión con enlaces de referidos camuflados de recomendación sincera, ocultando el incentivo económico detrás.';
}

---

<Layout title={article.title} description={article.subtitle} category={article.category}>
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem; max-width: 680px; margin: 0 auto;">
    
    <!-- Migas de pan cyberpunk -->
    <div style="margin-bottom: 2rem; font-size: 0.8rem; color: var(--text-muted); font-weight: 700; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
      <a href="/" style="text-decoration: none; color: var(--text-muted); transition: color 0.2s;" class="nav-link">Radar</a>
      <span style="color: rgba(255,255,255,0.15);">/</span>
      <a href="/temas" style="text-decoration: none; color: var(--text-muted); transition: color 0.2s;" class="nav-link">Expedientes</a>
      <span style="color: rgba(255,255,255,0.15);">/</span>
      {articleTopics.map((topic, tIdx) => (
        <span key={topic.slug} style="display: inline-flex; align-items: center; gap: 0.25rem; margin-right: 0.25rem;">
          {tIdx > 0 && <span style="color: rgba(255,255,255,0.15);">+</span>}
          <a href={`/tema/${topic.slug}`} style="text-decoration: none; color: var(--neon-blue); font-weight: 800;" class="hover-link">{topic.title}</a>
        </span>
      ))}
    </div>

    <!-- Título principal elegante (Igual que la Web) -->
    <header style="margin-bottom: 2.5rem; text-align: center;">
      <h1 style="font-size: 2.3rem; line-height: 1.2; font-weight: 900; color: #ffffff; font-family: var(--font-title); margin-bottom: 0.5rem; letter-spacing: -0.03em;">
        {article.title}
      </h1>
      <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-muted); font-weight: bold; margin-top: 0.75rem;">
        {article.category.toUpperCase()} • IMPACTO SOCIAL VERIFICADO
      </div>
    </header>

    <!-- Gran Banner de Veredicto Sólido -->
    <div style="margin-bottom: 1.5rem; text-align: center;">
      <div class={`verdict-banner ${article.verdict.toLowerCase().replace(' ', '-')}`} style={`display: inline-block; width: 100%; padding: 1.25rem; border-radius: 12px; font-size: 1.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; font-family: var(--font-title); text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.3); color: #ffffff; background: ${article.verdict.toLowerCase().includes('verdadero') ? 'rgba(0, 245, 160, 0.15)' : article.verdict.toLowerCase().includes('falso') ? 'rgba(220, 39, 67, 0.15)' : 'rgba(255, 183, 3, 0.15)'}; border: 2px solid ${article.verdict.toLowerCase().includes('verdadero') ? 'var(--neon-green)' : article.verdict.toLowerCase().includes('falso') ? 'var(--neon-rose)' : 'var(--neon-amber)'};`}>
        {article.verdict}
      </div>
    </div>

    <!-- Barra de Compartir Tras Veredicto (Inline) -->
    <div style="margin-bottom: 2rem;">
      <ShareBar 
        title={article.title} 
        text={`NEWNEWS califica de ${article.verdict.toLowerCase()} la declaración: "${article.claim}"`} 
        variant="inline"
        label="Compartir este desmentido"
      />
    </div>

    <!-- Panel: Conclusión de la Auditoría -->
    <div class="cyber-card" style="padding: 1.75rem; background: rgba(18, 22, 41, 0.35); border-color: rgba(255,255,255,0.06); border-radius: 12px; margin-bottom: 1.75rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; color: #ffffff; font-family: var(--font-title); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">
        <svg style="width: 18px; height: 18px; color: var(--neon-blue);" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <span>Conclusión de la Auditoría</span>
      </div>
      <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin: 0; font-weight: 500;">
        {article.summary || article.explanation.substring(0, 200) + '...'}
      </p>
    </div>

    <!-- Panel: El Truco -->
    <div class="cyber-card" style="padding: 1.75rem; background: rgba(18, 22, 41, 0.35); border-color: rgba(255,255,255,0.06); border-radius: 12px; margin-bottom: 2rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #ffffff; font-family: var(--font-title); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">
        <svg style="width: 18px; height: 18px; color: var(--neon-purple);" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <span>El Truco</span>
      </div>
      <span style="background: rgba(157, 78, 221, 0.12); color: var(--neon-purple); border: 1px solid rgba(157, 78, 221, 0.25); font-size: 0.65rem; font-weight: 800; padding: 0.2rem 0.5rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; font-family: monospace; display: inline-block; margin-bottom: 0.75rem;">
        {article.trick_used ? article.trick_used.toUpperCase() : 'SESGO DE DATOS'}
      </span>
      <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
        {trickDesc}
      </p>
    </div>

    <!-- PANELES COMPARATIVOS DIRECTOS: EL MITO vs EL HECHO REAL -->
    <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
      
      <!-- EL MITO (Borde Rojo / Rosa) -->
      <div class="cyber-card" style="padding: 1.5rem; border: 1px solid rgba(220, 39, 67, 0.25); background: rgba(220, 39, 67, 0.02); border-radius: 12px;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: var(--neon-rose); font-family: var(--font-title); font-size: 0.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em;">
          <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>EL MITO</span>
        </div>
        <p style="font-size: 1.05rem; color: #ffffff; font-weight: 600; line-height: 1.5; margin: 0; font-style: italic;">
          "{article.claim}"
        </p>
      </div>

      <!-- EL HECHO REAL (Borde Azul / Verde) -->
      <div class="cyber-card" style="padding: 1.5rem; border: 1px solid rgba(0, 240, 255, 0.25); background: rgba(0, 240, 255, 0.02); border-radius: 12px;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: var(--neon-blue); font-family: var(--font-title); font-size: 0.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em;">
          <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>EL HECHO REAL</span>
        </div>
        <p style="font-size: 1.05rem; color: #ffffff; line-height: 1.5; margin: 0;">
          {article.what_is_true || "Los datos oficiales comparados desmienten las afirmaciones sin base."}
        </p>
      </div>

    </div>

    <!-- Explicación de los Hechos (Cuerpo del Artículo) -->
    {article.explanation && (
      <section style="margin-bottom: 2.5rem;">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Análisis Detallado y Datos Oficiales</span>
        <div style="font-size: 0.95rem; line-height: 1.65; color: #E2E8F0; white-space: pre-wrap; background: rgba(18, 22, 41, 0.2); padding: 1.5rem;" class="cyber-card">
          {article.explanation}
        </div>
      </section>
    )}

    <!-- Fuentes y Evidencia -->
    <section style="margin-bottom: 2.5rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; margin-bottom: 1rem;">Fuentes y Evidencia</span>
      
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {sources.map(src => (
          <div class="cyber-card" style="padding: 0.85rem 1.25rem; display: flex; justify-content: space-between; align-items: center; background: rgba(18, 22, 41, 0.35); border-color: rgba(255,255,255,0.04); border-radius: 8px;">
            <div style="display: flex; align-items: center; gap: 0.75rem; text-align: left; flex: 1; min-width: 0;">
              <svg style="width: 16px; height: 16px; color: var(--neon-blue); flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <div style="min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <strong style="color: var(--text-main); font-size: 0.88rem;">{src.title}</strong>
              </div>
            </div>
            
            <a href={src.url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); display: flex; align-items: center; justify-content: center; padding: 0.25rem; margin-left: 1rem; transition: color 0.2s;" class="hover-link" title="Visitar documento oficial">
              <svg style="width: 18px; height: 18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Barra de Compartir al Final (Card) -->
    <div style="margin-top: 3rem; margin-bottom: 3rem;">
      <ShareBar 
        title={article.title} 
        text={`NEWNEWS califica de ${article.verdict.toLowerCase()} la declaración: "${article.claim}"`} 
        variant="card"
        label="Difunde la Verdad"
      />
    </div>

    <!-- Artículos Relacionados (Siguiente lectura) -->
    <section style="margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.15em; display: block; padding-left: 0.25rem; margin-bottom: 1.25rem;">Casos e Informes Relacionados</span>
      
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        
        {relatedSameTopic.length > 0 && (
          <div>
            <h4 style="font-size: 0.8rem; font-weight: 800; color: var(--neon-blue); text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em; display: flex; align-items: center; gap: 0.4rem;">
              <span></span> Del mismo expediente
            </h4>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
              {relatedSameTopic.map(art => (
                <a href={`${cleanBase}/noticia/${art.slug}`} class="cyber-card" style="padding: 0.75rem; display: flex; gap: 0.75rem; text-decoration: none; align-items: center; border-color: rgba(255,255,255,0.04); background: rgba(18, 22, 41, 0.35);">
                  <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: #000; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;">
                    <img src={art.multimedia_url || 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=120&q=80'} alt="Portada" style="width: 100%; height: 100%; object-fit: cover;" />
                  </div>
                  <div style="flex: 1; min-width: 0;">
                    <h5 style="font-size: 0.8rem; font-weight: 750; color: var(--text-main); margin: 0 0 0.15rem 0; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                      {art.title}
                    </h5>
                    <span style="font-size: 0.65rem; color: var(--text-muted); display: block;">
                      {getRelativeTime(art.published_at)}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        {relatedOtherTopics.length > 0 && (
          <div>
            <h4 style="font-size: 0.8rem; font-weight: 800; color: var(--neon-purple); text-transform: uppercase; margin-bottom: 0.75rem; letter-spacing: 0.05em; display: flex; align-items: center; gap: 0.4rem;">
              <span></span> Otros Expedientes Vivos
            </h4>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
              {relatedOtherTopics.map(art => (
                <a href={`${cleanBase}/noticia/${art.slug}`} class="cyber-card" style="padding: 0.75rem; display: flex; gap: 0.75rem; text-decoration: none; align-items: center; border-color: rgba(255,255,255,0.04); background: rgba(18, 22, 41, 0.35);">
                  <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: #000; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;">
                    <img src={art.multimedia_url || 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?auto=format&fit=crop&w=120&q=80'} alt="Portada" style="width: 100%; height: 100%; object-fit: cover;" />
                  </div>
                  <div style="flex: 1; min-width: 0;">
                    <h5 style="font-size: 0.8rem; font-weight: 750; color: var(--text-main); margin: 0 0 0.15rem 0; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                      {art.title}
                    </h5>
                    <span style="font-size: 0.65rem; color: var(--text-muted); display: block;">
                      {getRelativeTime(art.published_at)}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </div>
    </section>

    <!-- Botán Volver -->
    <div style="margin-bottom: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
      <a href="/" class="cyber-btn" style="width: 100%; text-align: center; border-radius: 12px; padding: 0.75rem;">
        Volver al Radar Principal
      </a>
    </div>

  </div>
</Layout>

<!-- Script interactivo de copiado rápido al portapapeles con feedback visual en el botón -->
<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const text = document.getElementById(targetId).innerText;
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.innerText;
        btn.innerText = 'áCopiado con áxito!';
        btn.style.borderColor = 'var(--neon-green)';
        btn.style.color = 'var(--neon-green)';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.borderColor = 'var(--border-color)';
          btn.style.color = 'var(--text-main)';
        }, 1500);
      }).catch(err => {
        console.error('Error al copiar al portapapeles:', err);
      });
    });
  });
</script>

<style>
  .nav-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
