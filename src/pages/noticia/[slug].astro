---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import ShareBar from '../../components/ShareBar.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

const { slug } = Astro.params;

const dbPath = process.env.SQLITE_DB_PATH || import.meta.env.SQLITE_DB_PATH || path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);
db.exec('PRAGMA busy_timeout = 5000;');
db.exec('PRAGMA journal_mode = WAL;');

// Cargar artículo
const article = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.slug = ? AND a.status = 'publicado'
`).get(slug) as any;

if (!article) {
  db.close();
  return Astro.redirect('/404');
}

// Cargar todos los temas asociados al artículo (muchos-a-muchos)
let articleTopics = [] as any[];
if (article) {
  articleTopics = db.prepare(`
    SELECT t.title, t.slug 
    FROM article_topics at
    JOIN topics t ON at.topic_id = t.id
    WHERE at.article_id = ? AND t.status = 'activo'
  `).all(article.id) as any[];
  
  if (articleTopics.length === 0 && article.topic_title) {
    articleTopics.push({ title: article.topic_title, slug: article.topic_slug });
  }
}

// Cargar fuentes
const sources = article ? db.prepare("SELECT * FROM sources WHERE article_id = ?").all(article.id) as any[] : [];

// Cargar posts sociales
const socialPosts = article ? db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(article.id) as any[] : [];

// Cargar tags reales asociados
const tags = article ? db.prepare(`
  SELECT t.name, t.slug 
  FROM tags t
  JOIN article_tags at ON t.id = at.tag_id
  WHERE at.article_id = ?
`).all(article.id) as any[] : [];

// Cargar artículos relacionados (mismo tema)
const relatedSameTopic = db.prepare(`
  SELECT * FROM articles 
  WHERE topic_id = ? AND id != ? AND status = 'publicado' 
  ORDER BY published_at DESC 
  LIMIT 2
`).all(article.topic_id, article.id) as any[];

// Cargar artículos relacionados (otros temas)
const relatedOtherTopics = db.prepare(`
  SELECT * FROM articles 
  WHERE topic_id != ? AND status = 'publicado' 
  ORDER BY published_at DESC 
  LIMIT 2
`).all(article.topic_id) as any[];

// Cargar item del radar correspondiente para extraer métricas y scores reales (código cero simulador)
const scrapedItem = db.prepare("SELECT metrics_json, virality_score, risk_score FROM scraped_items WHERE url = ?").get(article.origin_url) as any;

db.close();

// Extraer YouTube ID directamente de forma blindada para el reproductor de video
let directYoutubeId = '';
if (article && article.origin_url) {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|\/shorts\/)([^#\&\?]*).*/;
  const match = article.origin_url.match(regExp);
  if (match && match[2].length === 11) {
    directYoutubeId = match[2];
  }
}

// Extraer TikTok Video ID si es aplicable
let tiktokVideoId = '';
if (article && article.origin_url && (article.origin_platform === 'TikTok' || article.origin_url.includes('tiktok.com'))) {
  const match = article.origin_url.match(/\/video\/(\d+)/);
  if (match) {
    tiktokVideoId = match[1];
  }
}

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;

let realMetrics = { likes: null, reposts: null, comments: null, views: null };
if (scrapedItem && scrapedItem.metrics_json) {
  try {
    const parsed = JSON.parse(scrapedItem.metrics_json);
    realMetrics.likes = parsed.likes || parsed.likeCount || parsed.likes_count || null;
    realMetrics.reposts = parsed.reposts || parsed.retweetCount || parsed.shareCount || parsed.reposts_count || null;
    realMetrics.comments = parsed.comments || parsed.commentCount || parsed.comments_count || null;
    realMetrics.views = parsed.views || parsed.viewCount || parsed.views_count || null;
  } catch (e) {}
}

const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

function getRelativeTime(dateString) {
  if (!dateString) return 'hace un momento';
  const date = new Date(dateString);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  if (isNaN(diffMs)) return 'hace un momento';
  const diffMin = Math.floor(diffMs / (1000 * 60));
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffMin < 1) return 'hace unos segundos';
  if (diffMin < 60) return `hace ${diffMin} min`;
  if (diffHours < 24) return `hace ${diffHours} h`;
  return `hace ${diffDays} días`;
}

function formatOriginalDate(dateString) {
  if (!dateString) return 'Reciente';
  const date = new Date(dateString);
  if (isNaN(date.getTime())) return dateString;
  return date.toLocaleDateString('es-ES', { 
    day: '2-digit', 
    month: '2-digit', 
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
}

// Mapa de veredicto a color
const trickUsed = (article.trick_used || '').toLowerCase();
let trickDesc = 'Se utilizan afirmaciones genéricas descontextualizadas del marco legal oficial del BOE o del INE para generar desinformación.';
if (trickUsed === 'cherry-picking') {
  trickDesc = 'Se seleccionan únicamente datos parciales o favorables al sesgo para omitir el contexto general completo que desmiente la afirmación.';
} else if (trickUsed === 'falso dilema') {
  trickDesc = 'Se presenta la situación como si solo existieran dos opciones extremas excluyentes, ocultando la existencia de matices intermedios o terceras vías jurídicas.';
} else if (trickUsed === 'culpa colectiva') {
  trickDesc = 'Se atribuye a todo un grupo social (por origen, nacionalidad o religión) la responsabilidad directa o indirecta por el acto delictivo de un individuo aislado.';
} else if (trickUsed === 'dato sin base') {
  trickDesc = 'Se lanzan porcentajes alarmantes o cifras absolutas elevadas sin contextualizar la base demográfica, el denominador o el marco de comparación estadística real.';
} else if (trickUsed === 'vídeo recortado') {
  trickDesc = 'Se extrae un fragmento de audio o vídeo de pocos segundos para descontextualizar las declaraciones completas o la fecha real del suceso.';
} else if (trickUsed === 'autoridad falsa') {
  trickDesc = 'Se atribuye la información a supuestos portales de investigación, expertos autodeclarados o fuentes no oficiales para forzar veracidad.';
} else if (trickUsed === 'miedo/urgencia') {
  trickDesc = 'Se recurre a llamadas de pánico moral o urgencia ("lo ocultan", "secreto", "últimas unidades") para activar una creencia emocional irracional.';
} else if (trickUsed === 'promoción encubierta') {
  trickDesc = 'Se recomienda un producto o inversión con enlaces de referidos camuflados de recomendación sincera, ocultando el incentivo económico detrás.';
}

// Formateador Markdown a HTML estructurado
function renderMarkdown(md) {
  if (!md) return '';
  let html = md;
  // Escapar HTML básico
  html = html
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
    
  // Convertir cabeceras
  html = html.replace(/^### (.*?)$/gm, '<h3 style="font-size: 1.15rem; font-weight: 800; color: #ffffff; margin-top: 1.5rem; margin-bottom: 0.5rem; font-family: var(--font-title); letter-spacing: -0.02em;">$1</h3>');
  html = html.replace(/^#### (.*?)$/gm, '<h4 style="font-size: 1.0rem; font-weight: 800; color: var(--neon-blue); margin-top: 1.25rem; margin-bottom: 0.5rem; font-family: var(--font-title);">$1</h4>');

  // Convertir negritas (**texto**)
  html = html.replace(/\*\*(.*?)\*\*/g, '<strong style="color: #ffffff; font-weight: 700;">$1</strong>');

  // Convertir cursivas (*texto*)
  html = html.replace(/\*(.*?)\*/g, '<em style="font-style: italic;">$1</em>');

  // Convertir listas con guiones
  html = html.replace(/^- (.*?)$/gm, '<li style="margin-left: 1.25rem; list-style-type: square; margin-bottom: 0.35rem; color: var(--text-muted);">$1</li>');
  
  // Convertir saltos de línea dobles en párrafos
  const paragraphs = html.split(/\n\s*\n/);
  html = paragraphs.map(p => {
    const trimmed = p.trim();
    if (!trimmed) return '';
    if (trimmed.startsWith('<h3') || trimmed.startsWith('<h4') || trimmed.startsWith('<li')) {
      return trimmed;
    }
    return `<p style="margin-bottom: 1rem; line-height: 1.65; color: #E2E8F0;">${trimmed}</p>`;
  }).join('\n');

  return html;
}
---

<Layout title={article.title} description={article.subtitle} category={article.category}>
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem; max-width: 680px; margin: 0 auto;">
    
    <!-- Migas de pan cyberpunk -->
    <div style="margin-bottom: 1.5rem; font-size: 0.8rem; color: var(--text-muted); font-weight: 700; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
      <a href="/" style="text-decoration: none; color: var(--text-muted); transition: color 0.2s;" class="nav-link">Radar</a>
      <span style="color: rgba(255,255,255,0.15);">/</span>
      <a href="/temas" style="text-decoration: none; color: var(--text-muted); transition: color 0.2s;" class="nav-link">Expedientes</a>
      <span style="color: rgba(255,255,255,0.15);">/</span>
      {articleTopics.map((topic, tIdx) => (
        <span style="display: inline-flex; align-items: center; gap: 0.25rem; margin-right: 0.25rem;">
          {tIdx > 0 && <span style="color: rgba(255,255,255,0.15);">+</span>}
          <a href={`/tema/${topic.slug}`} style="text-decoration: none; color: var(--neon-blue); font-weight: 800;" class="hover-link">{topic.title}</a>
        </span>
      ))}
    </div>

    <!-- Título principal elegante (Igual que la Web) -->
    <header style="margin-bottom: 2rem; text-align: center;">
      <h1 style="font-size: 2.2rem; line-height: 1.2; font-weight: 900; color: #ffffff; font-family: var(--font-title); margin-bottom: 0.5rem; letter-spacing: -0.03em;">
        {article.title}
      </h1>
      <div style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-muted); font-weight: bold; margin-top: 0.75rem;">
        {article.category.toUpperCase()} • IMPACTO SOCIAL VERIFICADO
      </div>
      
      <!-- Tags Cyberpunk en Cabecera -->
      {tags.length > 0 && (
        <div style="margin-top: 1rem; display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
          {tags.map(t => (
            <a href={`/tag/${t.slug}`} style="text-decoration: none; font-size: 0.7rem; font-family: monospace; font-weight: 800; color: var(--neon-blue); background: rgba(0, 240, 255, 0.08); border: 1px solid rgba(0, 240, 255, 0.2); padding: 0.2rem 0.55rem; border-radius: 4px; transition: all 0.2s;" class="hover-link">
              #{t.name}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Caja de Origen de la Publicación y Captura Real -->
    {article.origin_url && (
      <div class="cyber-card" style="padding: 1.2rem; background: rgba(18, 22, 41, 0.35); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; margin-bottom: 2rem; display: grid; grid-template-columns: 1fr auto; gap: 1.5rem; align-items: center;">
        <div style="text-align: left;">
          <span style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--neon-rose); display: block; margin-bottom: 0.4rem; letter-spacing: 0.08em; font-family: monospace;">
            🚨 ORIGEN DE LA DECLARACIÓN DETECTADA:
          </span>
          <p style="font-size: 0.88rem; margin: 0 0 0.75rem 0; line-height: 1.5; color: var(--text-muted); font-style: italic;">
            "{article.claim || 'Publicación en redes sociales.'}"
          </p>
          <div style="font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
            <span>Plataforma: <strong style="color: #fff;">{article.origin_platform || 'Instagram'}</strong></span>
            <span style="color: rgba(255,255,255,0.15);">|</span>
            <a href={article.origin_url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: underline; font-weight: 800; display: inline-flex; align-items: center; gap: 0.25rem;" class="hover-link">
              Ver post original en {article.origin_platform || 'Instagram'} 
              <svg style="width: 12px; height: 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
        </div>
        {article.multimedia_url && !article.multimedia_url.includes('unsplash.com/photo-1541872703-74c5e44368f9') && (
          <div style="width: 80px; height: 80px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.08); overflow: hidden; background: rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <img src={article.multimedia_url} alt="Captura original" style="max-width: 100%; max-height: 100%; object-fit: cover;" />
          </div>
        )}
      </div>
    )}

    <!-- Portada Multimedia / Captura de Vídeo del Artículo -->
    {article.multimedia_url && !article.multimedia_url.includes('unsplash.com/photo-1541872703-74c5e44368f9') && (
      <div style="margin-bottom: 2rem; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); background: #000; box-shadow: 0 8px 30px rgba(0,0,0,0.5);">
        <img src={article.multimedia_url} alt="Evidencia o captura original del debate" style="width: 100%; height: auto; max-height: 380px; object-fit: cover; display: block;" />
      </div>
    )}

    <!-- Gran Banner de Veredicto Sólido -->
    <div style="margin-bottom: 1.5rem; text-align: center;">
      <div class={`verdict-banner ${article.verdict.toLowerCase().replace(' ', '-')}`} style={`display: inline-block; width: 100%; padding: 1.2rem; border-radius: 12px; font-size: 1.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; font-family: var(--font-title); text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.3); color: #ffffff; background: ${article.verdict.toLowerCase().includes('verdadero') ? 'rgba(0, 245, 160, 0.15)' : article.verdict.toLowerCase().includes('falso') ? 'rgba(220, 39, 67, 0.15)' : 'rgba(255, 183, 3, 0.15)'}; border: 2px solid ${article.verdict.toLowerCase().includes('verdadero') ? 'var(--neon-green)' : article.verdict.toLowerCase().includes('falso') ? 'var(--neon-rose)' : 'var(--neon-amber)'};`}>
        {article.verdict}
      </div>
    </div>

    <!-- Barra de Compartir Tras Veredicto (Inline) -->
    <div style="margin-bottom: 2rem;">
      <ShareBar 
        title={article.title} 
        text={`NEWNEWS califica de ${article.verdict.toLowerCase()} la declaración: "${article.claim}"`} 
        variant="inline"
        label="Compartir este desmentido"
      />
    </div>

    <!-- Panel: Conclusión de la Auditoría -->
    <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.35); border-color: rgba(255,255,255,0.06); border-radius: 12px; margin-bottom: 1.5rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: #ffffff; font-family: var(--font-title); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">
        <svg style="width: 18px; height: 18px; color: var(--neon-blue);" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <span>Conclusión de la Auditoría</span>
      </div>
      <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin: 0; font-weight: 500;">
        {article.summary || article.explanation.substring(0, 200) + '...'}
      </p>
    </div>

    <!-- Panel: El Truco -->
    <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.35); border-color: rgba(255,255,255,0.06); border-radius: 12px; margin-bottom: 2rem;">
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; color: #ffffff; font-family: var(--font-title); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">
        <svg style="width: 18px; height: 18px; color: var(--neon-purple);" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
        <span>El Truco</span>
      </div>
      <span style="background: rgba(157, 78, 221, 0.12); color: var(--neon-purple); border: 1px solid rgba(157, 78, 221, 0.25); font-size: 0.65rem; font-weight: 800; padding: 0.2rem 0.5rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; font-family: monospace; display: inline-block; margin-bottom: 0.75rem;">
        {article.trick_used ? article.trick_used.toUpperCase() : 'SESGO DE DATOS'}
      </span>
      <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
        {trickDesc}
      </p>
    </div>

    <!-- PANELES COMPARATIVOS DIRECTOS: EL MITO vs EL HECHO REAL -->
    <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem;">
      <!-- EL MITO (Borde Rojo / Rosa) -->
      <div class="cyber-card" style="padding: 1.5rem; border: 1px solid rgba(220, 39, 67, 0.25); background: rgba(220, 39, 67, 0.02); border-radius: 12px;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: var(--neon-rose); font-family: var(--font-title); font-size: 0.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em;">
          <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>EL MITO</span>
        </div>
        <p style="font-size: 1.05rem; color: #ffffff; font-weight: 600; line-height: 1.5; margin: 0; font-style: italic;">
          "{article.claim}"
        </p>
      </div>

      <!-- EL HECHO REAL (Borde Azul / Verde) -->
      <div class="cyber-card" style="padding: 1.5rem; border: 1px solid rgba(0, 240, 255, 0.25); background: rgba(0, 240, 255, 0.02); border-radius: 12px;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; color: var(--neon-blue); font-family: var(--font-title); font-size: 0.8rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em;">
          <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>EL HECHO REAL</span>
        </div>
        <p style="font-size: 1.05rem; color: #ffffff; line-height: 1.5; margin: 0;">
          {article.what_is_true || "Los datos oficiales comparados desmienten las afirmaciones sin base."}
        </p>
      </div>
    </div>

    <!-- ═══ INFOGRAFÍA SVG DE HERMES CON DESCARGADOR PNG 3X ═══ -->
    {article.infographic_svg && (
      <div style="margin-bottom: 2.5rem;">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem; text-align: left;">Infografía de Auditoría Rápida</span>
        
        <div class="cyber-card infographic-wrapper" style="padding: 1.25rem; background: rgba(18, 22, 41, 0.45); border-color: rgba(0, 240, 255, 0.15); border-radius: 12px; display: flex; flex-direction: column; align-items: center; gap: 1rem;">
          <div id="infographic-container" style="width: 100%; max-width: 420px; display: block; filter: drop-shadow(0px 0px 10px rgba(0, 240, 255, 0.1));">
            <Fragment set:html={article.infographic_svg} />
          </div>
          
          <div style="display: flex; width: 100%; justify-content: center; border-top: 1px dashed rgba(255,255,255,0.06); padding-top: 0.85rem;">
            <button id="download-png-btn" class="cyber-btn" style="padding: 0.5rem 1rem; font-size: 0.75rem; border-radius: 8px; font-weight: 800; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; transition: all 0.2s;">
              <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
              </svg>
              Descargar PNG (Retina 3x para Historias)
            </button>
          </div>
        </div>
      </div>
    )}

    <!-- Reproductor de Video Original (YouTube / TikTok) -->
    {directYoutubeId && (
      <div style="margin-bottom: 2.5rem;">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem;">Vídeo de la Declaración (YouTube)</span>
        <div style="position: relative; width: 100%; padding-bottom: 56.25%; height: 0; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 8px 30px rgba(0,0,0,0.5);">
