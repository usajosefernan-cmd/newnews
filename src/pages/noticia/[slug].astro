    </div>

  </div>
</Layout>

<!-- Script para el descargador interactivo PNG retina (3x) -->
<script is:inline>
  document.getElementById('download-png-btn')?.addEventListener('click', () => {
    const svgEl = document.querySelector('#infographic-container svg');
    if (!svgEl) return;

    const viewBox = svgEl.getAttribute('viewBox') || '0 0 390 1000';
    const [, , w, h] = viewBox.split(' ').map(Number);
    
    // Escala 3x retina para Stories
    const scale = 3;
    const canvas = document.createElement('canvas');
    canvas.width = w * scale;
    canvas.height = h * scale;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Serialización SVG limpia
    const svgString = new XMLSerializer().serializeToString(svgEl);
    const svgBlob = new Blob([svgString], { type: 'image/svg+xml;charset=utf-8' });
    const blobUrl = URL.createObjectURL(svgBlob);
    
    const img = new Image();
    img.onload = () => {
      // Fondo transparente
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      
      const link = document.createElement('a');
      link.download = `newnews-auditoria-${Date.now()}.png`;
      link.href = canvas.toDataURL('image/png');
      link.click();
      
      URL.revokeObjectURL(blobUrl);
    };
    img.src = blobUrl;
  });
</script>

