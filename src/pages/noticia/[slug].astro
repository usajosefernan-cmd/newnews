      <a href="/" class="cyber-btn" style="width: 100%; text-align: center; border-radius: 12px; padding: 0.75rem;">
        Volver al Radar Principal
      </a>
    </div>

  </div>
</Layout>

<!-- Script interactivo de copiado r丘뙖잺pido al portapapeles con feedback visual en el bot丘뙖잺n -->
<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const text = document.getElementById(targetId).innerText;
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.innerText;
        btn.innerText = '丘뙖잺Copiado con 丘뙖잺xito!';
        btn.style.borderColor = 'var(--neon-green)';
        btn.style.color = 'var(--neon-green)';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.borderColor = 'var(--border-color)';
          btn.style.color = 'var(--text-main)';
        }, 1500);
      }).catch(err => {
        console.error('Error al copiar al portapapeles:', err);
      });
    });
  });
</script>

<style>
  .nav-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
