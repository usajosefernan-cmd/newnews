---
import Layout from '../../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

export async function getStaticPaths() {
  const dbPath = path.resolve('data/newnews.db');
  const db = new DatabaseSync(dbPath);
  const articles = db.prepare("SELECT slug FROM articles WHERE status = 'publicado'").all();
  db.close();

  return articles.map(art => ({
    params: { slug: art.slug }
  }));
}

const { slug } = Astro.params;

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// Cargar artículo
const article = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.slug = ? AND a.status = 'publicado'
`).get(slug);

// Cargar fuentes
const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(article.id);

// Cargar posts sociales
const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(article.id);

db.close();

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

// Helpers auxiliares de metadatos sociales
const getDeterministicGradient = (username) => {
  const gradients = [
    'linear-gradient(135deg, #0088cc 0%, #005580 100%)', // Azul Telegram
    'linear-gradient(135deg, #7b2cbf 0%, #3c096c 100%)', // Morado cyberpunk
    'linear-gradient(135deg, #e63946 0%, #1d3557 100%)', // Rojo coral
    'linear-gradient(135deg, #2a9d8f 0%, #264653 100%)', // Verde petróleo
    'linear-gradient(135deg, #f5a623 0%, #d0021b 100%)', // Naranja/Fuego
    'linear-gradient(135deg, #1d9bf0 0%, #0a66c2 100%)', // Azul social
    'linear-gradient(135deg, #833ab4 0%, #fd1d1d 50%, #fcb045 100%)' // Sunset
  ];
  let sum = 0;
  for (let i = 0; i < username.length; i++) {
    sum += username.charCodeAt(i);
  }
  return gradients[sum % gradients.length];
};

const formatDisplayName = (username) => {
  if (username.toLowerCase() === 'alviseperez') return 'Alvise Pérez';
  if (username.toLowerCase() === 'empleo_es') return 'Ministerio de Trabajo';
  if (username.toLowerCase() === 'comisioneuropea') return 'Comisión Europea';
  return username
    .replace(/[_\-]/g, ' ')
    .split(' ')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
};

const getInitials = (displayName) => {
  return displayName
    .split(' ')
    .map(w => w[0])
    .join('')
    .substring(0, 2)
    .toUpperCase();
};

const getSocialPostMeta = (url, platform) => {
  if (!url) return null;
  const lowerPlat = platform.toLowerCase();
  const dateStr = new Date(article.published_at).toLocaleString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });

  // 1. TELEGRAM
  if (lowerPlat.includes('telegram') || url.includes('t.me') || url.includes('telegram.me')) {
    const match = url.match(/telegram\.me\/s\/([^\/]+)\/(\d+)/i) || url.match(/t\.me\/([^\/]+)\/(\d+)/i);
    const rawUser = match ? match[1] : 'canal_telegram';
    const postId = match ? match[2] : '0';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = getDeterministicGradient(rawUser);
    
    return {
      type: 'telegram',
      username: `@${rawUser}`,
      postId: `#${postId}`,
      displayName,
      verified: rawUser.toLowerCase() === 'alviseperez',
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url
    };
  }

  // 2. TWITTER / X
  if (lowerPlat.includes('x') || lowerPlat.includes('twitter') || url.includes('x.com') || url.includes('twitter.com')) {
    const match = url.match(/(?:x|twitter)\.com\/([^\/]+)\/status\/(\d+)/i);
    const rawUser = match ? match[1] : 'usuario_x';
    const postId = match ? match[2] : '';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = getDeterministicGradient(rawUser);
    
    return {
      type: 'x',
      username: `@${rawUser}`,
      postId: postId ? `post: ${postId.substring(0, 8)}...` : '',
      displayName,
      verified: rawUser.toLowerCase() === 'empleo_es' || rawUser.toLowerCase() === 'comisioneuropea',
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url
    };
  }

  // 3. INSTAGRAM
  if (lowerPlat.includes('instagram') || url.includes('instagram.com')) {
    const match = url.match(/instagram\.com\/p\/([^\/]+)/i) || url.match(/instagram\.com\/([^\/]+)/i);
    const rawUser = match ? match[1] : 'usuario_instagram';
    const displayName = formatDisplayName(rawUser);
    const avatarColor = 'linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%)';
    
    return {
      type: 'instagram',
      username: `@${rawUser}`,
      postId: 'Post',
      displayName,
      verified: false,
      avatarColor,
      initials: getInitials(displayName),
      dateStr,
      url
    };
  }

  return null;
};

const socialMeta = getSocialPostMeta(article.origin_url, article.origin_platform);
---

<Layout title={article.title} description={article.subtitle} category={article.category}>
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem;">
    
    <!-- Miga de Pan -->
    <div style="margin-bottom: 1.5rem; font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">
      <a href="/" style="text-decoration: none;">Radar</a> / <a href="/temas" style="text-decoration: none;">Expedientes</a> / <a href={`/tema/${article.topic_slug}`} style="text-decoration: none;">{article.topic_title.split(' ')[0]}</a> / <span style="color: var(--neon-blue);">{article.title.substring(0, 20)}...</span>
    </div>

    <!-- Título y Veredicto Principal -->
    <section style="margin-bottom: 2.5rem;">
      <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1.5rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
          <span style="background: rgba(255,255,255,0.04); color: var(--text-muted); font-size: 0.7rem; font-weight: 800; padding: 0.25rem 0.6rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em;">
            {article.category}
          </span>
          <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">
            Publicado el {new Date(article.published_at).toLocaleDateString('es-ES')}
          </span>
        </div>
        <h1 style="font-size: 2.2rem; line-height: 1.2; font-weight: 800; letter-spacing: -0.03em; color: var(--text-main);">
          {article.title}
        </h1>
        <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.5;">
          {article.subtitle}
        </p>
      </div>

      <!-- Veredicto Box Cyberpunk -->
      <div class={`cyber-card ${getVerdictClass(article.verdict)}`} style="padding: 1.75rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%); display: flex; flex-direction: column; gap: 1.25rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem;">
          <span style="font-family: var(--font-title); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--text-muted); letter-spacing: 0.05em;">
            Veredicto Oficial
          </span>
          <span class={`verdict-badge ${article.verdict.toLowerCase().replace(' ', '-')}`} style="font-size: 0.95rem; padding: 0.4rem 1rem;">
            {article.verdict}
          </span>
        </div>

        <div>
          <span style="font-weight: 800; text-transform: uppercase; color: var(--text-main); font-size: 0.75rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.35rem;">Conclusión de la Auditoría</span>
          <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">
            {article.summary}
          </p>
        </div>
      </div>
    </section>

    <!-- Ficha del Claim y el Origen -->
    <section style="margin-bottom: 2.5rem; display: flex; flex-direction: column; gap: 1.5rem;">
      
      <!-- Detalle Técnico de la Afirmación y Caja de Origen (Mockups Fidedignos) -->
      {socialMeta ? (
        <div class="cyber-card" style={{ padding: '1.5rem', background: 'rgba(18, 22, 41, 0.45)', borderColor: socialMeta.type === 'telegram' ? 'rgba(0, 136, 204, 0.25)' : socialMeta.type === 'x' ? 'rgba(255,255,255,0.1)' : 'rgba(220, 39, 67, 0.25)' }}>
          <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 1rem;">Publicación Viral Identificada (Captura de Origen)</span>
          
          {/* MOCKUP: TELEGRAM */}
          {socialMeta.type === 'telegram' && (
            <div style="background: rgba(10, 15, 30, 0.6); border: 1px solid rgba(0, 136, 204, 0.3); border-radius: 12px; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; margin-bottom: 1.25rem;">
              <!-- Cabecera de Telegram Canal -->
              <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(0, 136, 204, 0.06); padding: 0.75rem 1rem; border-bottom: 1px solid rgba(0, 136, 204, 0.15);">
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                  <!-- Avatar Circular -->
                  <div style={{ width: '40px', height: '40px', borderRadius: '50%', background: socialMeta.avatarColor, display: 'flex', alignItems: 'center', justifyContent: 'center', color: 'white', fontWeight: '700', fontSize: '0.95rem', boxShadow: '0 0 10px rgba(0, 136, 204, 0.25)' }}>
                    {socialMeta.initials}
                  </div>
                  <!-- Información del Canal -->
                  <div style="display: flex; flex-direction: column;">
                    <div style="display: flex; align-items: center; gap: 0.25rem;">
                      <span style="color: #ffffff; font-weight: 700; font-size: 0.9rem; line-height: 1.2;">{socialMeta.displayName}</span>
                      {socialMeta.verified && (
                        <span style="color: #0088cc; font-size: 0.8rem; font-weight: bold; cursor: default;" title="Canal Verificado">✓</span>
                      )}
                    </div>
                    <span style="color: #0088cc; font-size: 0.75rem; font-weight: 500;">{socialMeta.username}</span>
                  </div>
                </div>
                <div style="display: flex; flex-direction: column; align-items: flex-end; font-size: 0.7rem; color: #a0aec0;">
                  <span style="font-weight: 600; color: rgba(0, 136, 204, 0.85);">{socialMeta.postId}</span>
                  <span>{socialMeta.dateStr}</span>
                </div>
              </div>
              <!-- Mensaje y Claim -->
              <div style="padding: 1.25rem; background: rgba(7, 9, 19, 0.4); border-bottom: 1px solid rgba(255,255,255,0.03);">
                <span style="color: var(--neon-rose); font-weight: 800; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Afirmación Textual:</span>
                <p style="font-style: italic; color: #e2e8f0; font-size: 0.95rem; font-weight: 500; line-height: 1.5; margin: 0; padding-left: 0.75rem; border-left: 2px solid var(--neon-rose);">
                  "{article.claim}"
                </p>
              </div>
              <!-- Contexto del Origen -->
              <div style="padding: 1rem 1.25rem; font-size: 0.85rem; color: #a0aec0; line-height: 1.5;">
                <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem;">Contexto de Difusión:</span>
                <p style="margin: 0;">{article.origin_summary}</p>
              </div>
            </div>
          )}

          {/* MOCKUP: TWITTER / X */}
          {socialMeta.type === 'x' && (
            <div style="background: #000000; border: 1px solid #2f3336; border-radius: 12px; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; padding: 1rem; margin-bottom: 1.25rem; position: relative;">
              <!-- Logo X flotante -->
              <div style="position: absolute; top: 1rem; right: 1rem; color: #ffffff; font-size: 1.1rem; font-weight: 900; opacity: 0.8;">𝕏</div>
              
              <!-- Cabecera -->
              <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.85rem;">
                <!-- Avatar Circular -->
                <div style={{ width: '40px', height: '40px', borderRadius: '50%', background: socialMeta.avatarColor, display: 'flex', alignItems: 'center', justifycontent: 'center', color: 'white', fontWeight: '700', fontSize: '0.95rem' }}>
                  {socialMeta.initials}
                </div>
                <!-- Handles -->
                <div style="display: flex; flex-direction: column;">
                  <div style="display: flex; align-items: center; gap: 0.25rem;">
                    <span style="color: #ffffff; font-weight: 700; font-size: 0.9rem; line-height: 1.2;">{socialMeta.displayName}</span>
                    {socialMeta.verified && (
                      <span style="color: #1d9bf0; font-size: 0.8rem;" title="Cuenta Oficial Verificada">✓</span>
                    )}
                  </div>
                  <span style="color: #6e767d; font-size: 0.8rem;">{socialMeta.username}</span>
                </div>
              </div>

              <!-- Mensaje / Claim -->
              <div style="margin-bottom: 0.85rem;">
                <p style="color: #e7e9ea; font-size: 0.95rem; line-height: 1.5; margin: 0; font-style: italic; border-left: 2px solid var(--neon-rose); padding-left: 0.75rem;">
                  "{article.claim}"
                </p>
              </div>

              <!-- Fecha, hora y metadata de visualización -->
              <div style="font-size: 0.75rem; color: #6e767d; border-bottom: 1px solid #2f3336; padding-bottom: 0.75rem; margin-bottom: 0.75rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <span>{socialMeta.dateStr.split(',')[1]?.trim() || '12:00'}</span>
                <span>·</span>
                <span>{socialMeta.dateStr.split(',')[0]}</span>
                <span>·</span>
                <span style="color: #1d9bf0; font-weight: 600;">Visualizaciones en Redes</span>
              </div>

              <!-- Fila de interacciones de X (Like, Retweet, etc.) -->
              <div style="display: flex; justify-content: space-around; font-size: 0.75rem; color: #6e767d; padding-top: 0.25rem;">
                <span style="display: flex; align-items: center; gap: 0.3rem;">💬 <strong style="color: #e7e9ea;">1.2K</strong></span>
                <span style="display: flex; align-items: center; gap: 0.3rem;">🔁 <strong style="color: #e7e9ea;">4.8K</strong></span>
                <span style="display: flex; align-items: center; gap: 0.3rem;">❤️ <strong style="color: #e7e9ea;">12.5K</strong></span>
                <span style="display: flex; align-items: center; gap: 0.3rem;">📊 <strong style="color: #e7e9ea;">180K</strong></span>
              </div>
            </div>
          )}

          {/* MOCKUP: INSTAGRAM */}
          {socialMeta.type === 'instagram' && (
            <div style="background: #000000; border: 1px solid #262626; border-radius: 12px; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; margin-bottom: 1.25rem;">
              <!-- Cabecera -->
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem;">
                <div style="display: flex; align-items: center; gap: 0.6rem;">
                  <!-- Borde gradiente de historias de Instagram -->
                  <div style="padding: 2px; background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <div style={{ width: '32px', height: '32px', borderRadius: '50%', background: '#000000', display: 'flex', alignItems: 'center', justifyContent: 'center', color: 'white', fontWeight: '700', fontSize: '0.8rem' }}>
                      {socialMeta.initials}
                    </div>
                  </div>
                  <div style="display: flex; flex-direction: column;">
                    <span style="color: #ffffff; font-weight: 700; font-size: 0.85rem; line-height: 1.2;">{socialMeta.displayName}</span>
                    <span style="color: #a8a8a8; font-size: 0.7rem;">{socialMeta.username}</span>
                  </div>
                </div>
                <div style="color: #ffffff; font-size: 1rem; cursor: pointer; letter-spacing: 1px;">•••</div>
              </div>

              <!-- Cuadro de Imagen Simulada (Premium Gradient Post) -->
              <div style="width: 100%; aspect-ratio: 1; background: linear-gradient(135deg, rgba(220, 39, 67, 0.15) 0%, rgba(7, 9, 19, 0.95) 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; border-top: 1px solid #262626; border-bottom: 1px solid #262626; text-align: center; box-sizing: border-box; position: relative;">
                <!-- Icono de advertencia de bulo -->
                <div style="font-size: 3rem; margin-bottom: 0.75rem; text-shadow: 0 0 20px rgba(220, 39, 67, 0.4);">⚠️</div>
                <span style="color: var(--neon-rose); font-weight: 800; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 0.5rem;">Afirmación Detectada</span>
                <p style="color: #ffffff; font-size: 0.95rem; font-style: italic; line-height: 1.4; margin: 0; font-weight: 600; max-width: 320px;">
                  "{article.claim}"
                </p>
                <div style="position: absolute; bottom: 0.75rem; right: 0.75rem; background: rgba(0,0,0,0.7); color: #fff; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.65rem; font-weight: 600;">1 / 1</div>
              </div>

              <!-- Fila de botones de interacción -->
              <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem 0.5rem 1rem;">
                <div style="display: flex; gap: 0.85rem; font-size: 1.1rem;">
                  <span style="cursor: pointer;">❤️</span>
                  <span style="cursor: pointer;">💬</span>
                  <span style="cursor: pointer;">📤</span>
                </div>
                <div style="font-size: 1.1rem; cursor: pointer;">🔖</div>
              </div>

              <!-- Likes y Pie del Post -->
              <div style="padding: 0 1rem 1rem 1rem; font-size: 0.8rem; line-height: 1.4; font-family: -apple-system, sans-serif;">
                <span style="color: #ffffff; font-weight: 700; display: block; margin-bottom: 0.25rem;">Les gusta a 14.820 personas</span>
                <p style="color: #f5f5f5; margin: 0;">
                  <strong style="color: #ffffff; margin-right: 0.4rem;">{socialMeta.username}</strong>
                  {article.origin_summary}
                </p>
                <span style="color: #a8a8a8; font-size: 0.65rem; text-transform: uppercase; display: block; margin-top: 0.5rem;">{socialMeta.dateStr.split(',')[0]}</span>
              </div>
            </div>
          )}

          <div style="display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
            <span>Plataforma: <strong style={{ color: socialMeta.type === 'telegram' ? '#0088cc' : socialMeta.type === 'x' ? '#ffffff' : '#cc2366' }}>{article.origin_platform}</strong></span>
            <a href={socialMeta.url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: none; font-weight: 700; display: inline-flex; align-items: center; gap: 0.25rem;">
              Ver publicación original <span style="font-size: 0.9rem;">&rarr;</span>
            </a>
          </div>
        </div>
      ) : (
        <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45);">
          <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Afirmación Detectada</span>
          <p style="font-style: italic; color: var(--text-main); font-size: 1rem; font-weight: 500; line-height: 1.4; margin-bottom: 1.25rem; border-left: 2px solid var(--neon-rose); padding-left: 0.75rem;">
            "{article.claim}"
          </p>
          
          <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem;">Origen del bulo:</span>
          <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; margin-bottom: 1rem;">
            {article.origin_summary}
          </p>

          <div style="display: flex; align-items: center; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
            <span>Plataforma: <strong style="color: var(--text-main);">{article.origin_platform}</strong></span>
            {article.origin_url && (
              <a href={article.origin_url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); text-decoration: none; font-weight: 700;">
                Ver post original &rarr;
              </a>
            )}
          </div>
        </div>
      )}

      <!-- Auditoría del Bulómetro -->
      <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.25);">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-purple); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 1rem;">Métricas de Auditoría</span>
        
        <div style="display: flex; flex-direction: column; gap: 0.85rem; font-size: 0.85rem;">
          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
            <span style="color: var(--text-muted);">Revisión Humana:</span>
            <span style="color: var(--neon-green); font-weight: 700;">Verificada</span>
          </div>
          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
            <span style="color: var(--text-muted);">Riesgo de Desinformación:</span>
            <span style="color: var(--neon-rose); font-weight: 700;">Alto</span>
          </div>
          <div style="display: flex; justify-content: space-between;">
            <span style="color: var(--text-muted);">Fuentes Indexadas:</span>
            <span style="color: var(--text-main); font-weight: 700;">{sources.length} oficiales</span>
          </div>
        </div>
      </div>

    </section>

    <!-- Caja de Datos Desglosados -->
    <section style="margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: 1rem;">Desglose de Hechos</span>

      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        
        <div class="cyber-card" style="padding: 1.25rem; border-color: rgba(0, 245, 160, 0.15); background: rgba(0, 245, 160, 0.01);">
          <span style="color: var(--neon-green); font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Qué es real</span>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45;">
            {article.what_is_true || "No hay hechos ciertos en la afirmación."}
          </p>
        </div>

        <div class="cyber-card" style="padding: 1.25rem; border-color: rgba(255, 51, 102, 0.15); background: rgba(255, 51, 102, 0.01);">
          <span style="color: var(--neon-rose); font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Qué es falso</span>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45;">
            {article.what_is_false || "No se han detectado falsedades explícitas."}
          </p>
        </div>

        <div class="cyber-card" style="padding: 1.25rem; border-color: rgba(255, 176, 32, 0.15); background: rgba(255, 176, 32, 0.01);">
          <span style="color: var(--neon-amber); font-weight: 800; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Falta de contexto</span>
          <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45;">
            {article.what_lacks_context || "No se requiere contexto adicional."}
          </p>
        </div>

      </div>
    </section>

    <!-- Explicación de los Hechos (Cuerpo del Artículo) -->
    <section style="margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: 1rem;">Análisis Detallado</span>
      <div style="font-size: 0.95rem; line-height: 1.7; color: #E2E8F0; white-space: pre-wrap; background: rgba(18, 22, 41, 0.45);" class="cyber-card">
        {article.explanation}
      </div>
    </section>

    <!-- Fuentes Oficiales Indexadas -->
    <section class="cyber-card" style="padding: 1.75rem; border-color: rgba(0, 245, 160, 0.15); background: rgba(18, 22, 41, 0.3); margin-bottom: 2.5rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-green); font-size: 0.75rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Fuentes Originales</span>
      <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1.5rem; line-height: 1.4;">
        Respaldamos esta verificación en registros primarios oficiales y públicos. Pulsa en el enlace para auditar el documento tú mismo.
      </p>

      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        {sources.map(src => (
          <div style="border: 1px solid var(--border-color); padding: 1rem; background: rgba(7, 9, 19, 0.5); border-radius: 12px;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.4rem; flex-wrap: wrap; gap: 0.5rem;">
              <strong style="color: var(--text-main); font-size: 0.9rem;">{src.title}</strong>
              <span style="background: rgba(0, 240, 255, 0.08); color: var(--neon-blue); font-size: 0.6rem; font-weight: 800; padding: 0.15rem 0.5rem; text-transform: uppercase; border-radius: 4px; border: 1px solid rgba(0,240,255,0.15);">
                Rango: {src.authority_level}
              </span>
            </div>
            <p style="color: var(--text-muted); font-size: 0.8rem; line-height: 1.4; margin-bottom: 0.75rem;">
              {src.quote_or_summary}
            </p>
            <a href={src.url} target="_blank" rel="noopener noreferrer" style="color: var(--neon-blue); font-size: 0.75rem; font-weight: 700; text-decoration: none;">
              Acceder al documento oficial &rarr;
            </a>
          </div>
        ))}

        {sources.length === 0 && (
          <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center;">No se han indexado fuentes en la base de datos.</p>
        )}
      </div>
    </section>

    <!-- Compartir en Redes (Contracampaña) -->
    <section class="cyber-card" style="padding: 1.75rem; border-color: rgba(0, 240, 255, 0.15); background: rgba(18, 22, 41, 0.3); margin-bottom: 3rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-blue); font-size: 0.75rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">Compartir en Redes</span>
      <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1.5rem; line-height: 1.4;">
        Copia respuestas o hilos generados automáticamente para desmontar el bulo en redes sociales cuando lo veas en canales públicos.
      </p>

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        {socialPosts.map((post, idx) => (
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <strong style="color: var(--text-main); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">
              Formato: {post.platform} ({post.format})
            </strong>
            <div 
              id={`social-content-${idx}`} 
              style="background: rgba(7, 9, 19, 0.6); border: 1px solid var(--border-color); padding: 1rem; font-size: 0.8rem; color: var(--text-muted); font-family: monospace; white-space: pre-wrap; max-height: 150px; overflow-y: auto; border-radius: 12px; line-height: 1.45;"
            >{post.content}</div>
            
            <button 
              class="cyber-btn copy-btn" 
              data-target={`social-content-${idx}`}
              style="width: 100%; padding: 0.6rem; font-size: 0.75rem; border-radius: 12px; text-transform: uppercase; font-weight: 800;"
            >
              Copiar Mensaje
            </button>
          </div>
        ))}

        {socialPosts.length === 0 && (
          <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center;">No hay copys sociales sugeridos para este artículo.</p>
        )}
      </div>

      <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
        <a href="/" class="cyber-btn" style="width: 100%; text-align: center; border-radius: 12px; padding: 0.75rem;">
          Volver al Radar
        </a>
      </div>
    </section>

  </div>
</Layout>

<!-- Script interactivo de copiado rápido al portapapeles con feedback visual en el botón -->
<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const text = document.getElementById(targetId).innerText;
      
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.innerText;
        btn.innerText = '¡Copiado con éxito!';
        btn.style.borderColor = 'var(--neon-green)';
        btn.style.color = 'var(--neon-green)';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.borderColor = 'var(--border-color)';
          btn.style.color = 'var(--text-main)';
        }, 1500);
      }).catch(err => {
        console.error('Error al copiar al portapapeles:', err);
      });
    });
  });
</script>

<style>
  .nav-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
