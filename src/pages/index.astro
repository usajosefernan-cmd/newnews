---
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// Obtener todos los temas activos
const topics = db.prepare("SELECT * FROM topics WHERE status = 'activo' LIMIT 4").all();

// Obtener todas las piezas publicadas ordenadas por fecha
const articles = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug 
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'publicado'
  ORDER BY a.published_at DESC
`).all();

db.close();

const featuredArticle = articles.length > 0 ? articles[0] : null;
const remainingArticles = articles.length > 1 ? articles.slice(1) : [];

function getVerdictClass(verdict) {
  const v = (verdict || '').toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
}

// Iniciales ilustrativas de categoría para avatares minimalistas
function getCategoryInitials(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('migr') || c.includes('socied')) return 'MG';
  if (c.includes('vivien') || c.includes('okupa')) return 'VV';
  if (c.includes('impues') || c.includes('ahorr') || c.includes('econ')) return 'EC';
  if (c.includes('polit') || c.includes('parti')) return 'PL';
  return 'EX';
}
---

<Layout title="Radar de Desinformación - España">
  <!-- Radar Ticker de Noticias -->
  <div class="radar-ticker">
    <div class="radar-content">
      <span class="pulse-icon"></span>
      <div class="ticker-wrapper" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
        <div class="ticker-track">
          <span>RADAR: El bulo sobre el impuesto a cuentas bancarias...</span>
          <span>&bull;</span>
          <span>DESMENTIDO: Prestaciones de 4.200€ al mes para menores extranjeros tutelados es falso...</span>
          <span>&bull;</span>
          <span>VIVIENDA: Diferencias legales entre usurpación y allanamiento explicadas con datos...</span>
        </div>
      </div>
    </div>
  </div>

  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem;">
    
    <!-- Instagram Stories Bar (Expedientes Rápidos) -->
    <section style="margin-bottom: 2rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem; padding-left: 0.25rem;">Expedientes Activos</span>
      <div class="no-scrollbar" style="display: flex; gap: 1.25rem; overflow-x: auto; padding: 0.25rem; scroll-behavior: smooth; -webkit-overflow-scrolling: touch;">
        
        {topics.map(topic => (
          <a href={"/tema/" + topic.slug} style="display: flex; flex-direction: column; align-items: center; gap: 0.4rem; min-width: 72px;">
            <div class="story-circle">
              <div class="story-inner" style="font-size: 0.85rem; letter-spacing: 0.05em; font-weight: 800;">
                {getCategoryInitials(topic.category)}
              </div>
            </div>
            <span style="font-size: 0.7rem; font-weight: 700; color: var(--text-main); text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 75px;">
              {topic.title.split(' ')[0]}
            </span>
          </a>
        ))}

        <a href="/temas" style="display: flex; flex-direction: column; align-items: center; gap: 0.4rem; min-width: 72px;">
          <div class="story-circle" style="background: linear-gradient(135deg, var(--border-color), rgba(255,255,255,0.2));">
            <div class="story-inner" style="color: var(--text-muted); font-size: 0.85rem; font-weight: 800;">
              ALL
            </div>
          </div>
          <span style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted); text-align: center; white-space: nowrap;">
            Ver Todos
          </span>
        </a>

      </div>
    </section>

    <!-- Fichas Móviles / Feed Principal (Tipo Instagram/TikTok) -->
    <div style="display: flex; flex-direction: column; gap: 2rem;">
      
      <!-- Ficha Destacada (Hero Post) -->
      {featuredArticle && (
        <section>
          <div class={"cyber-card " + getVerdictClass(featuredArticle.verdict)} style="padding: 1.75rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%);">
            
            <!-- Cabecera de la Ficha (Estilo Red Social) -->
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
              <div style="display: flex; align-items: center; gap: 0.75rem;">
                <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.25); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 800; color: var(--neon-blue);">
                  {getCategoryInitials(featuredArticle.category)}
                </div>
                <div>
                  <a href={"/tema/" + featuredArticle.topic_slug} style="font-size: 0.85rem; font-weight: 700; color: var(--text-main); display: block;">
                    {featuredArticle.topic_title}
                  </a>
                  <span style="font-size: 0.7rem; color: var(--text-muted); display: block;">
                    Radar &bull; {new Date(featuredArticle.published_at).toLocaleDateString('es-ES')}
                  </span>
                </div>
              </div>
              <span class={"verdict-badge " + getVerdictClass(featuredArticle.verdict)}>
                {featuredArticle.verdict}
              </span>
            </div>

            <!-- Titular de la Ficha -->
            <div style="margin-bottom: 1.5rem;">
              <a href={"/noticia/" + featuredArticle.slug}>
                <h2 style="font-size: 1.75rem; line-height: 1.2; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.75rem; color: var(--text-main);">
                  {featuredArticle.title}
                </h2>
              </a>
              <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5;">
                {featuredArticle.subtitle}
              </p>
            </div>

            <!-- Ficha de la Reclamación (El bulo) -->
            <div style="background: rgba(255, 51, 102, 0.02); border-left: 2px solid var(--neon-rose); padding: 1rem 1.25rem; border-radius: 0 12px 12px 0; margin-bottom: 1.5rem;">
              <span style="font-weight: 800; color: var(--neon-rose); text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem;">Declaración viral:</span>
              <p style="font-style: italic; color: var(--text-main); font-size: 0.95rem; font-weight: 500; line-height: 1.4;">
                "{featuredArticle.claim}"
              </p>
            </div>

            <!-- Footer de la Ficha -->
            <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 1rem;">
              <span style="font-size: 0.75rem; color: var(--text-muted);">
                Origen: <strong style="color: var(--text-main);">{featuredArticle.origin_platform}</strong>
              </span>
              <a href={"/noticia/" + featuredArticle.slug} class="cyber-btn accent" style="padding: 0.5rem 1.25rem; font-size: 0.75rem; border-radius: 12px;">
                Verificar &rarr;
              </a>
            </div>

          </div>
        </section>
      )}

      <!-- Selector Deslizante de Píldoras Rápidas (Interactivo) -->
      <section style="margin: 0.5rem 0;">
        <div class="no-scrollbar" style="display: flex; gap: 0.5rem; overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 0.25rem;">
          <a href="/temas" class="cyber-btn" style="padding: 0.4rem 1rem; font-size: 0.75rem; border-radius: 30px; background: rgba(0, 240, 255, 0.06); border-color: rgba(0,240,255,0.2); color: var(--neon-blue); white-space: nowrap;">Todos los Expedientes</a>
          {topics.map(t => (
            <a href={"/tema/" + t.slug} class="cyber-btn" style="padding: 0.4rem 1rem; font-size: 0.75rem; border-radius: 30px; white-space: nowrap;">
              {t.category}
            </a>
          ))}
        </div>
      </section>

      <!-- Feed de Verificaciones (Posts Secundarios) -->
      <section style="display: flex; flex-direction: column; gap: 1.5rem;">
        <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: -0.5rem;">Radar de Última Hora</span>
        
        {remainingArticles.map(art => (
          <div class={"cyber-card " + getVerdictClass(art.verdict)} style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45);">
            
            <!-- Cabecera Corta del Post -->
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; color: var(--text-muted);">
                  {getCategoryInitials(art.category)}
                </div>
                <a href={"/tema/" + art.topic_slug} style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted);">
                  {art.topic_title}
                </a>
              </div>
              <span class={"verdict-badge " + getVerdictClass(art.verdict)} style="padding: 0.25rem 0.6rem; font-size: 0.65rem;">
                {art.verdict}
              </span>
            </div>

            <!-- Contenido del Post -->
            <div style="margin-bottom: 1.25rem;">
              <a href={"/noticia/" + art.slug}>
                <h3 style="font-size: 1.35rem; font-weight: 700; line-height: 1.25; margin-bottom: 0.5rem; color: var(--text-main);">
                  {art.title}
                </h3>
              </a>
              <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; margin-bottom: 0.75rem;">
                {art.subtitle}
              </p>
              <div style="font-size: 0.8rem; font-style: italic; color: var(--text-muted); background: rgba(255,255,255,0.015); padding: 0.75rem; border-left: 2px solid var(--border-color); border-radius: 0 6px 6px 0;">
                "{art.claim}"
              </div>
            </div>

            <!-- Footer del Post -->
            <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
              <span style="font-size: 0.7rem; color: var(--text-muted);">
                Vía: <strong style="color: var(--text-main);">{art.origin_platform}</strong>
              </span>
              <a href={"/noticia/" + art.slug} class="cyber-btn" style="padding: 0.35rem 0.85rem; font-size: 0.7rem; border-radius: 10px; color: var(--neon-blue); border-color: rgba(0, 240, 255, 0.15);">
                Verificar &rarr;
              </a>
            </div>

          </div>
        ))}

        {remainingArticles.length === 0 && (
          <p style="color: var(--text-muted); text-align: center; padding: 2.5rem; background: var(--bg-card); border-radius: 20px; border: 1px dashed var(--border-color); font-size: 0.9rem;">
            No hay más desmentidos registrados hoy.
          </p>
        )}
      </section>

      <!-- Ruido en Redes (Widget Móvil Estilizado) -->
      <section class="cyber-card" style="padding: 1.5rem; background: linear-gradient(135deg, rgba(157, 78, 221, 0.05) 0%, rgba(7, 9, 19, 0.95) 100%); margin-top: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--neon-purple);">Ruido en Redes</h3>
          <span style="font-size: 1.75rem; font-weight: 800; color: var(--neon-rose);" class="pulse-animation">78%</span>
        </div>
        <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin-bottom: 1rem;">
          Nivel de desinformación por videos descontextualizados en el territorio español.
        </p>
        <div style="background: rgba(7, 9, 19, 0.6); height: 8px; border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden;">
          <div style="background: linear-gradient(90deg, var(--neon-purple), var(--neon-rose)); width: 78%; height: 100%;"></div>
        </div>
      </section>

      <!-- Comparador Político Móvil Promo -->
      <section class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.3); text-align: center; border-style: dashed;">
        <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--neon-green);">Comparador de Programas</h3>
        <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin-bottom: 1rem; max-width: 400px; margin-left: auto; margin-right: auto;">
          Contrasta de forma objetiva lo que prometen los partidos políticos frente a los datos reales y leyes vigentes.
        </p>
        <a href="/comparador-politico" class="cyber-btn accent" style="width: 100%; max-width: 250px; border-radius: 12px; font-size: 0.75rem;">
          Comparar Programas
        </a>
      </section>

    </div>

  </div>
</Layout>

<style>
  .featured-title:hover, .article-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
