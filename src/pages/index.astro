---
export const prerender = false;
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

const dbPath = process.env.SQLITE_DB_PATH || import.meta.env.SQLITE_DB_PATH || path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);
db.exec('PRAGMA busy_timeout = 5000;');
db.exec('PRAGMA journal_mode = WAL;');

// Obtener categorías dinámicas
const rawCategories = db.prepare("SELECT DISTINCT category FROM topics WHERE status = 'activo'").all() as any[];
const categories = rawCategories.map(c => {
  const cat = c.category;
  const slug = cat.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
  return { name: cat, slug };
}).filter(c => c.name);

// Obtener todos los temas activos con indicadores dinámicos
const topics = db.prepare(`
  SELECT t.*, 
         (SELECT COUNT(*) FROM articles a WHERE a.topic_id = t.id AND a.status = 'publicado' AND datetime(a.published_at) >= datetime('now', '-1 day')) as has_recent,
         COALESCE(
           (SELECT CAST(MIN(98, 30 + (COUNT(*) * 4) + SUM(virality_score)) AS INTEGER) FROM scraped_items WHERE suggested_topic = t.title),
           ((ABS(LENGTH(t.id)) % 20) + 35)
         ) as noise_level
  FROM topics t 
  WHERE t.status = 'activo' 
  ORDER BY t.title
`).all();

// Obtener las piezas publicadas ordenadas por fecha
const articles = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug 
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'publicado'
  ORDER BY a.published_at DESC
`).all();

// Obtener últimos items del radar
const radarItems = db.prepare(`
  SELECT * FROM scraped_items 
  WHERE status = 'pendiente' 
  ORDER BY virality_score DESC
  LIMIT 6
`).all();

// Obtener fuentes oficiales
const officialSourceCount = (() => {
  try { return db.prepare("SELECT COUNT(*) as c FROM official_sources WHERE status = 'activo'").get().c; } 
  catch(e) { return 0; }
})();

db.close();

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;

const featuredArticle = articles.length > 0 ? articles[0] : null;
const remainingArticles = articles.length > 1 ? articles.slice(1) : [];
const hasArticles = articles.length > 0;

function getVerdictClass(verdict) {
  const v = (verdict || '').toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
}

function getCategoryInitials(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('inmigr') || c.includes('delin')) return 'MIG';
  if (c.includes('emple') || c.includes('paro')) return 'EMP';
  if (c.includes('vivien') || c.includes('okup') || c.includes('vida imposible')) return 'VIV';
  if (c.includes('infla') || c.includes('ipc') || c.includes('vida')) return 'IPC';
  if (c.includes('auto') || c.includes('fisc') || c.includes('haci')) return 'AUT';
  if (c.includes('historia') || c.includes('memo')) return 'HIS';
  if (c.includes('corrupc') || c.includes('transpa')) return 'COR';
  if (c.includes('sanid')) return 'SAN';
  if (c.includes('justic')) return 'JUS';
  if (c.includes('consumo')) return 'CON';
  if (c.includes('segurid') || c.includes('ciberestafa')) return 'SEC';
  if (c.includes('catalu') || c.includes('independ')) return 'CAT';
  if (c.includes('eco')) return 'ECO';
  return 'GEN';
}

function getCategorySlug(category) {
  return (category || '').toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
}

function getRelativeTime(dateStr) {
  if (!dateStr) return 'Reciente';
  try {
    const pub = new Date(dateStr.replace(' ', 'T'));
    const diffMs = Date.now() - pub.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    if (diffMins < 60) return `Hace ${diffMins} min`;
    const diffHours = Math.floor(diffMins / 60);
    if (diffHours < 24) return `Hace ${diffHours} h`;
    return pub.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  } catch (e) {
    return 'Reciente';
  }
}

function formatOriginalDate(dateStr) {
  if (!dateStr) return '';
  try {
    const d = new Date(dateStr);
    return d.toLocaleDateString('es-ES', { day: 'numeric', month: 'short' });
  } catch(e) {
    return dateStr;
  }
}
---

<Layout title="Radar de Desmentidos y Auditoría en Vivo">
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 3rem; max-width: 1000px;">
    
    <!-- ═══ HEADER DEL PORTAL ═══ -->
    <section style="margin-bottom: 2rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
        <span class="pulse-dot" style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--neon-blue); letter-spacing: 0.15em; display: inline-flex; align-items: center; gap: 0.5rem;">
          <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--neon-blue); display: inline-block;"></span>
          Radar de Actividad en Vivo
        </span>
        <span style="font-size: 0.7rem; color: var(--text-muted); font-family: var(--font-title); font-weight: 700;">
          {officialSourceCount} Fuentes Primarias Indexadas
        </span>
      </div>
      <h1 style="font-size: 1.6rem; font-weight: 900; letter-spacing: -0.03em; margin: 0; line-height: 1.2; color: #ffffff;">
        ¿Es información real, opinión sesgada o promoción oculta?
      </h1>
      <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.45; margin-top: 0.5rem;">
        Nuestros motores analizan la viralidad de las afirmaciones que circulan en TikTok, YouTube y X, evaluando la presencia de enlaces de afiliados y contrastando los datos con registros oficiales de España.
      </p>
    </section>

    <!-- Buscador Grande del Radar (guia02.md) -->
    <section style="margin-bottom: 2rem;">
      <div class="cyber-card" style="padding: 1rem 1.25rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.45) 0%, rgba(7, 9, 19, 0.8) 100%); border-color: rgba(0, 240, 255, 0.25);">
        <form action={`${cleanBase}/radar`} method="GET" style="display: flex; gap: 0.75rem; align-items: center; width: 100%;">
          <div style="position: relative; flex: 1;">
            <span style="position: absolute; left: 0.85rem; top: 50%; transform: translateY(-50%); font-size: 1.1rem; pointer-events: none;"></span>
            <input 
              type="text" 
              name="text" 
              placeholder="Pega un enlace de TikTok, YouTube, X o escribe una frase para auditar..." 
              required 
              style="width: 100%; background: rgba(0,0,0,0.4); border: 1px solid var(--border-color); color: #fff; padding: 0.75rem 1rem 0.75rem 2.6rem; border-radius: 8px; font-size: 0.85rem; outline: none; transition: border-color 0.2s;" 
            />
          </div>
          <button type="submit" class="cyber-btn" style="padding: 0.75rem 1.25rem; font-size: 0.85rem; border-radius: 8px; font-weight: 800; text-transform: uppercase; cursor: pointer; border-color: var(--neon-blue); color: var(--neon-blue);">
            Interceptar
          </button>
        </form>
      </div>
    </section>

    <!-- Selector de Categorías -->
    <section style="margin: 0.5rem 0 1.5rem;">
      <div class="no-scrollbar" style="display: flex; gap: 0.5rem; overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 0.25rem;">
        <a href={cleanBase || "/"} class="cyber-btn" style="padding: 0.4rem 1rem; font-size: 0.75rem; border-radius: 30px; background: rgba(0, 240, 255, 0.06); border-color: rgba(0,240,255,0.2); color: var(--neon-blue); white-space: nowrap;">Todos los Expedientes</a>
        {categories.map(c => (
          <a href={`${cleanBase}/categoria/${c.slug}`} class="cyber-btn" style="padding: 0.4rem 1rem; font-size: 0.75rem; border-radius: 30px; white-space: nowrap; color: var(--text-main); border-color: rgba(255,255,255,0.1);">
            📁 {c.name}
          </a>
        ))}
      </div>
    </section>

    {/* ═══ CONTENIDO PRINCIPAL ═══ */}
    <div style="display: flex; flex-direction: column; gap: 2rem;">

      {hasArticles ? (
        <>
          {/* Ficha Destacada */}
          {featuredArticle && (
            <section>
              <div class={"cyber-card " + getVerdictClass(featuredArticle.verdict)} style="padding: 1.75rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%);">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
                  <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <a href={`${cleanBase}/categoria/${getCategorySlug(featuredArticle.category)}`} style="text-decoration: none;" title={`Categoría: ${featuredArticle.category}`}>
                      <div style="width: 36px; height: 36px; border-radius: 50%; background: rgba(0, 240, 255, 0.1); border: 1px solid rgba(0, 240, 255, 0.25); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 800; color: var(--neon-blue);">
                        {getCategoryInitials(featuredArticle.category)}
                      </div>
                    </a>
                    <div>
                      <a href={`${cleanBase}/tema/${featuredArticle.topic_slug}`} style="font-size: 0.85rem; font-weight: 700; color: var(--text-main); display: block;">
                        {featuredArticle.topic_title}
                      </a>
                      <span style="font-size: 0.7rem; color: var(--text-muted); display: block;">
                        Categoría: <a href={`${cleanBase}/categoria/${getCategorySlug(featuredArticle.category)}`} style="color: var(--neon-blue); text-decoration: none; font-weight: 700;">{featuredArticle.category}</a> &bull; Incorporado: <strong style="color: var(--neon-blue);">{getRelativeTime(featuredArticle.published_at)}</strong>
                      </span>
                      <div style="margin-top: 0.25rem; font-size: 0.7rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                        <span style="background: rgba(157, 78, 221, 0.12); border: 1px solid rgba(157, 78, 221, 0.3); border-radius: 4px; padding: 0.1rem 0.4rem; color: #ffffff; font-weight: bold;">
                          {featuredArticle.emoji_tag || '🧊 Falta contexto'}
                        </span>
                        <span style="font-family: monospace; color: var(--neon-amber); font-weight: 800;">
                          🌡️ Termómetro: {featuredArticle.newnews_score || 50}%
                        </span>
                      </div>
                    </div>
                  </div>
                  <span class={"verdict-badge " + getVerdictClass(featuredArticle.verdict)}>
                    {featuredArticle.verdict}
                  </span>
                </div>

                <div style="margin-bottom: 1.5rem;">
                  <a href={`${cleanBase}/noticia/${featuredArticle.slug}`}>
                    <h2 style="font-size: 1.75rem; line-height: 1.2; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.75rem; color: var(--text-main);">
                      {featuredArticle.title}
                    </h2>
                  </a>
                  <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.25rem;">
                    {featuredArticle.subtitle}
                  </p>
                  {featuredArticle.multimedia_url && (
                    <div style="margin-bottom: 1.25rem; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.08); max-height: 360px; background: #000; display: flex; align-items: center; justify-content: center;">
                      <img src={featuredArticle.multimedia_url} alt="Portada" style="width: 100%; height: 100%; object-fit: cover; max-height: 360px;" />
                    </div>
                  )}
                </div>

                <div style="background: rgba(255, 51, 102, 0.02); border-left: 2px solid var(--neon-rose); padding: 1rem 1.25rem; border-radius: 0 12px 12px 0; margin-bottom: 1.5rem;">
                  <span style="font-weight: 800; color: var(--neon-rose); text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.25rem;">Declaración viral:</span>
                  <p style="font-style: italic; color: var(--text-main); font-size: 0.95rem; font-weight: 500; line-height: 1.4;">
                    "{featuredArticle.claim}"
                  </p>
                </div>

                <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                  <span style="font-size: 0.75rem; color: var(--text-muted);">
                    Origen: <strong style="color: var(--text-main);">{featuredArticle.origin_platform}</strong>
                    {featuredArticle.origin_date && (
                      <span> &bull; Post original: <strong style="color: var(--text-main);">{formatOriginalDate(featuredArticle.origin_date)}</strong></span>
                    )}
                  </span>
                  <a href={`${cleanBase}/noticia/${featuredArticle.slug}`} class="cyber-btn accent" style="padding: 0.5rem 1.25rem; font-size: 0.75rem; border-radius: 12px;">
                    Verificar &rarr;
                  </a>
                </div>
              </div>
            </section>
          )}

          {/* Feed de Verificaciones */}
          <section style="display: flex; flex-direction: column; gap: 1.5rem;">
            <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: -0.5rem;">Radar de Última Hora</span>
            {remainingArticles.map(art => (
              <div class={"cyber-card " + getVerdictClass(art.verdict)} style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45);">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                  <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <a href={`${cleanBase}/categoria/${getCategorySlug(art.category)}`} style="text-decoration: none;" title={`Categoría: ${art.category}`}>
                      <div style="width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; color: var(--text-muted);">
                        {getCategoryInitials(art.category)}
                      </div>
                    </a>
                    <div>
                      <a href={`${cleanBase}/tema/${art.topic_slug}`} style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); display: block;">
                        {art.topic_title}
                      </a>
                      <span style="font-size: 0.65rem; color: var(--text-muted); display: block;">
                        Categoría: <a href={`${cleanBase}/categoria/${getCategorySlug(art.category)}`} style="color: var(--neon-purple); text-decoration: none; font-weight: 700;">{art.category}</a> &bull; {getRelativeTime(art.published_at)}
                      </span>
                      <div style="margin-top: 0.2rem; font-size: 0.65rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;">
                        <span style="background: rgba(157, 78, 221, 0.1); border: 1px solid rgba(157, 78, 221, 0.2); border-radius: 4px; padding: 0.05rem 0.3rem; color: #ffffff; font-weight: bold;">
                          {art.emoji_tag || '🧊 Falta contexto'}
                        </span>
                        <span style="font-family: monospace; color: var(--neon-amber); font-weight: 700;">
                          🌡️ {art.newnews_score || 50}%
                        </span>
                      </div>
                    </div>
                  </div>
                  <span class={"verdict-badge " + getVerdictClass(art.verdict)} style="padding: 0.25rem 0.6rem; font-size: 0.65rem;">
                    {art.verdict}
                  </span>
                </div>
                <div style="margin-bottom: 1.25rem;">
                  <a href={`${cleanBase}/noticia/${art.slug}`}>
                    <h3 style="font-size: 1.35rem; font-weight: 700; line-height: 1.25; margin-bottom: 0.5rem; color: var(--text-main);">
                      {art.title}
                    </h3>
                  </a>
                  <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; margin-bottom: 1rem;">
                    {art.subtitle}
                  </p>
                  {art.multimedia_url && (
                    <div style="margin-bottom: 1rem; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); max-height: 220px; background: #000; display: flex; align-items: center; justify-content: center;">
                      <img src={art.multimedia_url} alt="Portada" style="width: 100%; height: 100%; object-fit: cover; max-height: 220px;" />
                    </div>
                  )}
                </div>
                 <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
                  <span style="font-size: 0.7rem; color: var(--text-muted);">
                    Vía: <strong style="color: var(--text-main);">{art.origin_platform}</strong>
                    {art.origin_date && (
                      <span> &bull; Post: <strong style="color: var(--text-main);">{formatOriginalDate(art.origin_date)}</strong></span>
                    )}
                  </span>
                  <a href={`${cleanBase}/noticia/${art.slug}`} class="cyber-btn" style="padding: 0.35rem 0.85rem; font-size: 0.7rem; border-radius: 10px; color: var(--neon-blue); border-color: rgba(0, 240, 255, 0.15);">
                    Verificar &rarr;
                  </a>
                </div>
              </div>
            ))}
          </section>
        </>
      ) : (
        <>
          {/* ═══ ESTADO VACÍO — Sin artículos ═══ */}
          <section class="empty-state">
            <div class="empty-state-icon"></div>
            <h2>El Radar está Limpio</h2>
            <p>
              No hay verificaciones publicadas en este momento. 
              El radar está monitorizando redes en busca de bulos virales. Mientras tanto, explora los expedientes temáticos.
            </p>
            <div class="empty-state-actions">
              <a href={`${cleanBase}/temas`} class="cyber-btn accent" style="border-radius: 12px; padding: 0.75rem 1.5rem;">
                Explorar Expedientes
              </a>
              <a href={`${cleanBase}/comparador-politico`} class="cyber-btn" style="border-radius: 12px; padding: 0.75rem 1.5rem;">
                Comparador Político
              </a>
            </div>
          </section>

          {/* Últimos del Radar (si los hay) */}
          {radarItems.length > 0 && (
            <section>
              <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: 1rem;">En el Radar (sin verificar)</span>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                {radarItems.map(item => (
                  <div class="cyber-card" style="padding: 1rem; background: rgba(18, 22, 41, 0.35);">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;">
                      <span style="font-size: 0.7rem; font-weight: 700; color: var(--neon-purple); text-transform: uppercase;">{item.platform}</span>
                      <span style="font-size: 0.65rem; color: var(--text-muted);">Viralidad: {item.virality_score?.toFixed(1)}</span>
                    </div>
                    <p style="font-size: 0.85rem; color: var(--text-main); line-height: 1.4; font-weight: 600;">
                      {(item.detected_claim || item.text || '').substring(0, 120)}...
                    </p>
                    <a href={item.url} target="_blank" rel="noopener noreferrer" style="font-size: 0.7rem; color: var(--neon-blue); font-weight: 700; display: block; margin-top: 0.5rem;">
                      Ver en origen &rarr;
                    </a>
                  </div>
                ))}
                
                <!--  TEASER DEL BUZÓN DE INTERCEPCIÓN -->
                <section class="cyber-card" style="padding: 1.75rem; background: linear-gradient(185deg, rgba(7, 9, 19, 0.95) 0%, rgba(18, 22, 41, 0.8) 100%); border-color: var(--neon-blue); margin-top: 1rem; text-align: left; position: relative; overflow: hidden; transition: all 0.3s ease;">
                  <div style="position: absolute; top: -20px; right: -20px; font-size: 5rem; opacity: 0.05; pointer-events: none;"></div>
                  <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
                    <span style="font-size: 1.5rem;"></span>
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--neon-blue); margin: 0; letter-spacing: -0.01em;">Buzón de Intercepción</h3>
                  </div>
                  <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.45; margin-bottom: 1.25rem; max-width: 95%;">
                    ¿Has detectado un bulo sospechoso o una publicación viral en TikTok, YouTube, Instagram o X? Envía el enlace al radar. Nuestro motor contrastará los hechos con las leyes vigentes del BOE y los datos macroeconómicos del INE de forma neutral.
                  </p>
                  <a href={`${cleanBase}/interceptor`} class="cyber-btn accent" style="display: inline-flex; align-items: center; justify-content: center; width: 100%; padding: 0.75rem; border-radius: 8px; font-weight: 800; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; text-decoration: none; box-sizing: border-box; text-align: center;">
                    Acceder al Interceptor &rarr;
                  </a>
                </section>
              </div>
            </section>
          )}
        </>
      )}

      <!--  COMPROMISO DEONTOLÓGICO Y CÓDIGO DE PERIODISMO -->
      <section class="cyber-card" style="padding: 1.65rem; background: linear-gradient(180deg, rgba(7, 9, 19, 0.95) 0%, rgba(18, 22, 41, 0.8) 100%); border-color: var(--neon-blue); margin-top: 1rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; border-bottom: 1px solid rgba(0, 240, 255, 0.15); padding-bottom: 0.5rem;">
          <span style="font-size: 1.4rem;"></span>
          <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--neon-blue); margin: 0; letter-spacing: -0.01em; font-family: var(--font-title);">Código Deontológico NEWNEWS</h3>
        </div>
        <p style="color: var(--text-muted); font-size: 0.8rem; line-height: 1.45; margin-bottom: 1.25rem;">
          Nuestros motores de búsqueda de radar y auditorías de IA se rigen estrictamente bajo los principios deontológicos de la FAPE (Federación de Asociaciones de Periodistas de España). La verdad e independencia son nuestras únicas guías.
        </p>
        
        <div style="display: grid; grid-template-columns: 1fr; gap: 1rem; text-align: left;">
          <div style="background: rgba(0,0,0,0.2); padding: 0.85rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.03);">
            <strong style="color: #ffffff; font-size: 0.85rem; display: block; margin-bottom: 0.25rem;">1. Neutralidad Absoluta</strong>
            <span style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.4; display: block;">
              Diferenciamos rigurosamente entre información objetiva contrastable y la mera opinión sesgada o publicitaria. Desvelamos de forma explícita el contenido patrocinado y los enlaces de afiliados ocultos.
            </span>
          </div>

          <div style="background: rgba(0,0,0,0.2); padding: 0.85rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.03);">
            <strong style="color: #ffffff; font-size: 0.85rem; display: block; margin-bottom: 0.25rem;">2. Fuentes Primarias Directas</strong>
            <span style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.4; display: block;">
              No delegamos la verificación en terceros o agencias de fact-checking secundarias. Contrastamos cada afirmación directamente con el BOE, el INE y los registros de patentes oficiales del Estado.
            </span>
          </div>

          <div style="background: rgba(0,0,0,0.2); padding: 0.85rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.03);">
            <strong style="color: #ffffff; font-size: 0.85rem; display: block; margin-bottom: 0.25rem;">3. Desvelado de Sesgo Comercial</strong>
            <span style="font-size: 0.75rem; color: var(--text-muted); line-height: 1.4; display: block;">
              En análisis de productos o novedades tecnológicas, identificamos si los creadores de contenido tienen incentivos económicos directos o indirectos (como enlaces de referidos) que comprometan su objetividad.
            </span>
          </div>
        </div>
      </section>

      <!-- Confusómetro -->
      <section class="cyber-card" style="padding: 1.5rem; background: linear-gradient(135deg, rgba(157, 78, 221, 0.05) 0%, rgba(7, 9, 19, 0.95) 100%); margin-top: 1rem;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--neon-purple); margin-bottom: 1rem;">Confusómetro: Alerta de Ruido por Tema</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {topics.map(t => (
            <div>
              <div style="display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 0.25rem;">
                <span style="font-weight: 700; color: var(--text-main);">{t.title}</span>
                <span style="font-weight: 800; color: var(--neon-rose);">{t.noise_level}%</span>
              </div>
              <div style="background: rgba(7, 9, 19, 0.6); height: 6px; border: 1px solid var(--border-color); border-radius: 10px; overflow: hidden;">
                <div style={`background: linear-gradient(90deg, var(--neon-purple), var(--neon-rose)); width: ${t.noise_level}%; height: 100%;`}></div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Comparador Político Promo -->
      <section class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.3); text-align: center; border-style: dashed;">
        <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--neon-green);">Comparador de Programas</h3>
        <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin-bottom: 1rem; max-width: 400px; margin-left: auto; margin-right: auto;">
          Contrasta de forma objetiva lo que prometen los partidos políticos frente a los datos reales y leyes vigentes.
        </p>
        <a href={`${cleanBase}/comparador-politico`} class="cyber-btn accent" style="width: 100%; max-width: 250px; border-radius: 12px; font-size: 0.75rem;">
          Comparar Programas
        </a>
      </section>

    </div>

  </div>
</Layout>
