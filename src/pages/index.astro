---
import Layout from '../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// Obtener todos los temas activos
const topics = db.prepare("SELECT * FROM topics WHERE status = 'activo' LIMIT 4").all();

// Obtener todas las piezas publicadas ordenadas por fecha
const articles = db.prepare(`
  SELECT a.*, t.title as topic_title, t.slug as topic_slug 
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'publicado'
  ORDER BY a.published_at DESC
`).all();

db.close();

// Destacar el artículo más relevante para la cabecera
let featuredArticle = null;
if (articles && articles.length > 0) {
  featuredArticle = articles[0];
}

let remainingArticles = [];
if (articles && articles.length > 1) {
  remainingArticles = articles.slice(1);
}

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};
---

<Layout title="Portada - Radar de Bulos y Desmentidos">
  <div class="container">
    
    <!-- Hero Banner Cyberpunk (Destacado) -->
    {featuredArticle && (
      <section style="margin-bottom: 3rem;">
        <div class={`cyber-card ${getVerdictClass(featuredArticle.verdict)}`} style="padding: 2.5rem; display: flex; flex-direction: column; gap: 1.5rem; background: linear-gradient(135deg, var(--bg-card), #171E2E);">
          <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <span class={`verdict-badge ${featuredArticle.verdict.toLowerCase().replace(' ', '-')}`}>
                {featuredArticle.verdict}
              </span>
              <span style="color: var(--text-muted); font-size: 0.9rem;">
                Tema: <a href={`/tema/${featuredArticle.topic_slug}`} style="color: var(--neon-blue); text-decoration: underline;">{featuredArticle.topic_title}</a>
              </span>
            </div>
            <span style="color: var(--neon-rose); font-weight: 800; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 0.5rem;" class="pulse-animation">
              🚨 Bulo Destacado del Día
            </span>
          </div>

          <a href={`/noticia/${featuredArticle.slug}`}>
            <h1 class="featured-title" style="font-size: 2.5rem; line-height: 1.2; margin-bottom: 0.5rem; transition: color 0.2s;">
              {featuredArticle.title}
            </h1>
          </a>
          <p style="font-size: 1.2rem; color: var(--text-muted); max-width: 800px;">
            {featuredArticle.subtitle}
          </p>

          <div style="border-left: 4px solid var(--border-color); padding-left: 1rem; margin: 0.5rem 0;">
            <span style="font-weight: bold; color: var(--text-main); display: block; margin-bottom: 0.25rem;">Afirmación viral:</span>
            <p style="font-style: italic; color: var(--text-muted); font-size: 1.1rem;">"{featuredArticle.claim}"</p>
          </div>

          <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-top: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted);">
              <span>Origen: <strong>{featuredArticle.origin_platform}</strong></span>
              <span>•</span>
              <span>Detección: {new Date(featuredArticle.published_at).toLocaleDateString('es-ES')}</span>
            </div>
            <a href={`/noticia/${featuredArticle.slug}`} class="cyber-btn accent">
              Ver Análisis Completo
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Sección de Temas Candentes (Expedientes Vivos) -->
    <section style="margin-bottom: 4rem;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">
        <h2 style="font-size: 1.8rem; display: flex; align-items: center; gap: 0.5rem;">
          📁 Expedientes <span class="text-gradient-blue">Vivos</span>
        </h2>
        <a href="/temas" class="read-more-link" style="color: var(--neon-blue); font-weight: bold;">Ver todos los temas →</a>
      </div>

      <div class="grid-cols-2">
        {topics.map(topic => (
          <div class="cyber-card" style="display: flex; flex-direction: column; justify-content: space-between; gap: 1rem;">
            <div>
              <span style="background: var(--border-color); color: var(--text-muted); font-size: 0.75rem; font-weight: 800; padding: 0.2rem 0.5rem; text-transform: uppercase;">
                {topic.category}
              </span>
              <h3 style="font-size: 1.4rem; margin-top: 0.5rem; margin-bottom: 0.5rem;">
                <a href={`/tema/${topic.slug}`} class="topic-link">{topic.title}</a>
              </h3>
              <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1rem;">
                {topic.description}
              </p>
              <div style="background: rgba(0, 240, 255, 0.02); border: 1px dashed var(--border-color); padding: 0.75rem; font-size: 0.85rem; color: var(--text-muted);">
                <strong>Resumen de Veredictos:</strong> {topic.verdict_summary || "Bulos recurrentes y análisis institucional."}
              </div>
            </div>

            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 1rem; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
              <span style="font-size: 0.8rem; color: var(--text-muted);">Confianza general: <strong style="color: var(--neon-green);">{topic.confidence || "Alta"}</strong></span>
              <a href={`/tema/${topic.slug}`} class="cyber-btn" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--border-color);">
                Abrir Expediente
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Grill de Últimas Verificaciones e Widget Lateral -->
    <div class="main-grid">
      
      <!-- Listado de Noticias -->
      <section>
        <div style="margin-bottom: 1.5rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem;">
          <h2 style="font-size: 1.8rem;">
            🔍 Últimas <span class="text-gradient-green">Verificaciones</span>
          </h2>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {remainingArticles.map(art => (
            <div class={`cyber-card ${getVerdictClass(art.verdict)}`} style="display: grid; grid-template-columns: 1fr; gap: 1rem; padding: 1.5rem;">
              <div style="display: flex; align-items: center; justify-content: space-between;">
                <span class={`verdict-badge ${art.verdict.toLowerCase().replace(' ', '-')}`}>
                  {art.verdict}
                </span>
                <span style="color: var(--text-muted); font-size: 0.8rem;">
                  {new Date(art.published_at).toLocaleDateString('es-ES')}
                </span>
              </div>
              <div>
                <h3 style="font-size: 1.3rem; margin-bottom: 0.25rem;">
                  <a href={`/noticia/${art.slug}`} class="article-link">{art.title}</a>
                </h3>
                <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 0.75rem;">
                  {art.subtitle}
                </p>
                <div style="font-size: 0.85rem; font-style: italic; color: var(--text-muted); background: rgba(0,0,0,0.1); padding: 0.5rem; border-left: 3px solid var(--border-color);">
                  <strong>Afirmación:</strong> "{art.claim}"
                </div>
              </div>
              <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 0.5rem; font-size: 0.8rem; color: var(--text-muted);">
                <span>Vía: {art.origin_platform}</span>
                <a href={`/noticia/${art.slug}`} class="read-more-link" style="color: var(--neon-blue); font-weight: bold;">Leer análisis →</a>
              </div>
            </div>
          ))}

          {remainingArticles.length === 0 && (
            <p style="color: var(--text-muted); text-align: center; padding: 2rem;">No hay más artículos publicados en esta versión.</p>
          )}
        </div>
      </section>

      <!-- Barra Lateral / Widgets -->
      <aside style="display: flex; flex-direction: column; gap: 2rem;">
        
        <!-- Buscador Rápido -->
        <div class="cyber-card blue" style="background: linear-gradient(180deg, var(--bg-card), #0d1624);">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-blue);">🔍 Radar de Búsqueda</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
            ¿Has visto un titular, tweet o cadena de WhatsApp sospechosa? Pégala aquí para ver si ya la hemos verificado.
          </p>
          <form action="/buscador" method="GET" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <input 
              type="text" 
              name="q" 
              placeholder="Ej: Franco creó la seguridad social..." 
              required 
              style="width: 100%; padding: 0.75rem; background: var(--bg-dark); border: 2px solid var(--border-color); color: var(--text-main); font-family: var(--font-body); font-size: 0.9rem;"
            />
            <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main);">
              Buscar Claim
            </button>
          </form>
        </div>

        <!-- Termómetro de Confusión del Día -->
        <div class="cyber-card purple">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-purple);">📈 Confusión del Día</h3>
          <div style="margin: 1rem 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem;">
            <div style="font-size: 3rem; font-weight: 800; font-family: var(--font-title); color: var(--neon-rose);" class="pulse-animation">
              78%
            </div>
            <span style="font-size: 0.8rem; font-weight: bold; text-transform: uppercase; color: var(--text-muted);">
              Nivel de Ruido en Redes
            </span>
          </div>
          <p style="color: var(--text-muted); font-size: 0.85rem;">
            Hoy se registra un nivel alto de confusión social en España motivado por la difusión de vídeos antiguos recortados sobre inmigración y debates históricos sobre pensiones.
          </p>
          <div style="background: var(--bg-dark); height: 8px; border: 1px solid var(--border-color); margin-top: 1rem; position: relative;">
            <div style="background: var(--neon-rose); width: 78%; height: 100%;"></div>
          </div>
        </div>

        <!-- Comparador Político Promo -->
        <div class="cyber-card">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;">🗳️ ¿Votas Informado?</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
            ¿Sabes qué proponen realmente los partidos sobre vivienda, impuestos o sanidad y qué votaron en el Parlamento?
          </p>
          <a href="/comparador-politico" class="cyber-btn" style="width: 100%; text-align: center; box-shadow: 2px 2px 0px 0px var(--border-color);">
            Comparar Programas
          </a>
        </div>

      </aside>

    </div>

  </div>
</Layout>

<style>
  .main-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 900px) {
    .main-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .featured-title:hover, .topic-link:hover, .article-link:hover {
    color: var(--neon-blue) !important;
  }

  .read-more-link:hover {
    text-decoration: underline !important;
  }
</style>
