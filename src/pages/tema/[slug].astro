    bars: [
      { label: 'Búsqueda financiada por el Estado', percentage: '100%', color: 'var(--neon-blue)', desc: 'Asumido por la Ley 20/2022' },
      { label: 'Exhumaciones completadas', percentage: '25%', color: 'var(--neon-amber)', desc: 'En fase de análisis genético y forense' }
    ]
  },
