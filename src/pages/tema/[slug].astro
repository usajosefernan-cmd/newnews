const info = infographicData[slug];
const didactic = topicDidacticData[slug];
const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
---

<Layout title={topic.title} description={topic.description}>
    <!-- ═══ HERO DEL TEMA ═══ -->
    <section class="topic-hero" style="margin-bottom: 2rem;">
      <div class="cyber-card" style="padding: 2.5rem 2rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%); overflow: hidden; border-color: rgba(0, 240, 255, 0.25);">
        
        <!-- Background Glow -->
        <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: var(--neon-blue); filter: blur(80px); opacity: 0.15; pointer-events: none;"></div>

        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; position: relative; z-index: 2;">
          <span style="background: rgba(0, 240, 255, 0.06); color: var(--neon-blue); font-size: 0.65rem; font-weight: 800; padding: 0.35rem 0.85rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(0, 240, 255, 0.15);">
            Expediente: {topic.category}
          </span>
          <span style="color: var(--neon-green); font-weight: 800; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; display: inline-flex; align-items: center; gap: 0.4rem;">
            <span class="pulse-icon" style="margin-right: 0;"></span>
            Seguimiento Activo
          </span>
        </div>

        <h1 style="font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 1rem; color: var(--text-main); font-family: var(--font-title); position: relative; z-index: 2;">
          {topic.title}
        </h1>

        <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 2rem; max-width: 580px; position: relative; z-index: 2;">
          {topic.description}
        </p>

        <!-- Stat Cards Grid -->
        {info && (
          <div class="topic-stat-grid" style="position: relative; z-index: 2;">
            <div class="topic-stat-card">
              <div class="topic-stat-value" style="color: var(--neon-blue);">{info.metric}</div>
              <div class="topic-stat-label">{info.metricLabel.split(' ').slice(0, 3).join(' ')}</div>
            </div>
            <div class="topic-stat-card">
              <div class="topic-stat-value" style="color: var(--neon-purple);">{cards.length}</div>
              <div class="topic-stat-label">Apartados Legales</div>
            </div>
            <div class="topic-stat-card">
              <div class="topic-stat-value" style="color: var(--neon-green);">{articles.length}</div>
              <div class="topic-stat-label">Desmentidos</div>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- ═══ BOTONES DE APARTADOS (TABS) ═══ -->
    <nav class="topic-tabs-nav">
      <button class="tab-btn active" data-target="panel-magnitud">
        📊 <span>Cifras</span>
      </button>
      <button class="tab-btn" data-target="panel-legal">
        ⚖️ <span>Marco Legal</span>
      </button>
      <button class="tab-btn" data-target="panel-radar">
        🛡️ <span>Expedientes ({articles.length})</span>
      </button>
      <button class="tab-btn" data-target="panel-politica">
        🏛️ <span>Enfoque Político ({policyMeasures.length})</span>
      </button>
    </nav>

    <!-- ═══ PANEL 1: MAGNITUD Y CIFRAS ═══ -->
    <div id="panel-magnitud" class="topic-tab-panel active">
      {info && (
        <section class="topic-section">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue);">📊</div>
            <h2 class="topic-section-title">Magnitud y Cifras Oficiales</h2>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <!-- Métrica Detallada -->
            <div style="background: linear-gradient(135deg, rgba(0, 240, 255, 0.03) 0%, rgba(7, 9, 19, 0.8) 100%); border: 1px solid rgba(0, 240, 255, 0.15); padding: 1.5rem; border-radius: 20px; text-align: center;">
              <span style="font-size: 3.5rem; font-weight: 800; font-family: var(--font-title); color: var(--neon-blue); line-height: 1; display: block; margin-bottom: 0.25rem; text-shadow: 0 0 15px rgba(0, 240, 255, 0.2);">{info.metric}</span>
              <span style="font-size: 0.8rem; font-weight: 700; color: var(--text-main); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">{info.metricLabel}</span>
              <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin: 0; max-width: 550px; margin-left: auto; margin-right: auto;">{info.subText}</p>
            </div>

            <!-- Indicadores de barras -->
            <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45); display: flex; flex-direction: column; gap: 1.25rem;">
              <strong style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); display: block; letter-spacing: 0.05em;">Indicadores y Contexto de Datos</strong>
              {info.bars.map(bar => (
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                  <div style="display: flex; justify-content: space-between; font-size: 0.8rem;">
                    <span style="color: var(--text-main); font-weight: 700;">{bar.label}</span>
                    <strong style={`color: ${bar.color}`}>{bar.percentage}</strong>
                  </div>
                  <div style="width: 100%; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,255,255,0.02);">
                    <div style={`width: ${bar.percentage}; height: 100%; background: ${bar.color}; border-radius: 4px;`} class="topic-bar-fill"></div>
                  </div>
                  <span style="font-size: 0.7rem; color: var(--text-muted);">{bar.desc}</span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}
    </div>

    <!-- ═══ PANEL 2: MARCO LEGAL Y DIDÁCTICA ═══ -->
    <div id="panel-legal" class="topic-tab-panel">
      <!-- 1. ¿Qué está pasando? -->
      {didactic && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue);">📡</div>
            <h2 class="topic-section-title">¿Qué está pasando con este tema?</h2>
          </div>
          <div class="cyber-card" style="padding: 1.75rem; background: linear-gradient(135deg, rgba(0, 240, 255, 0.03) 0%, rgba(7, 9, 19, 0.9) 100%); line-height: 1.6; font-size: 0.95rem; color: var(--text-main);">
            {didactic.what_is_happening}
          </div>
        </section>
      )}

      <!-- 2. ¿Qué sabemos y qué no sabemos? -->
      {didactic && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;" class="redactor-split-grid">
            <!-- Qué sabemos -->
            <div class="cyber-card" style="padding: 1.5rem; border-color: rgba(0, 245, 160, 0.25); background: rgba(0, 245, 160, 0.01);">
              <span style="font-size: 0.72rem; text-transform: uppercase; color: var(--neon-green); font-weight: 800; display: block; margin-bottom: 0.5rem; letter-spacing: 0.05em;">✔️ Hechos Probados (¿Qué sabemos?)</span>
              <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
                {didactic.what_we_know}
              </p>
            </div>

            <!-- Qué no sabemos -->
            <div class="cyber-card" style="padding: 1.5rem; border-color: rgba(255, 176, 32, 0.25); background: rgba(255, 176, 32, 0.01);">
              <span style="font-size: 0.72rem; text-transform: uppercase; color: var(--neon-amber); font-weight: 800; display: block; margin-bottom: 0.5rem; letter-spacing: 0.05em;">⚠️ Incertidumbres (¿Qué no sabemos?)</span>
              <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
                {didactic.what_we_do_not_know}
              </p>
            </div>
          </div>
        </section>
      )}

      <!-- Fichas didácticas clásicas (Fichas BOE) -->
      <section class="topic-section" style="margin-bottom: 2.5rem;">
        <div class="topic-section-header">
          <div class="topic-section-icon" style="background: rgba(157, 78, 221, 0.1); color: var(--neon-purple);">⚖️</div>
          <h2 class="topic-section-title">Marco Legal y Normativo (BOE)</h2>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {cards.map((card) => (
            <div class="topic-edu-card">
              <h4>{card.title}</h4>
              <div style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.6;" set:html={card.htmlContent || card.text} />
            </div>
          ))}
        </div>
      </section>

      <!-- 4. Datos clave -->
      {didactic && didactic.key_facts && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 245, 160, 0.1); color: var(--neon-green);">🔑</div>
            <h2 class="topic-section-title">Puntos y Cifras Clave</h2>
          </div>
          <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.4);">
            <ul style="padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.5;">
              {didactic.key_facts.map(fact => (
                <li style="list-style-type: none; position: relative; padding-left: 1.5rem;">
                  <span style="position: absolute; left: 0; color: var(--neon-green); font-weight: bold;">✓</span>
                  {fact}
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      <!-- 5. Confusiones Frecuentes y Desmentidos rápidos -->
      {didactic && didactic.frequent_confusions && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(255, 0, 85, 0.1); color: var(--neon-rose);">🧠</div>
            <h2 class="topic-section-title">Confusiones Frecuentes (Bulos Desmentidos)</h2>
          </div>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {didactic.frequent_confusions.map(item => (
              <div class="cyber-card" style="padding: 1.5rem; border-color: rgba(255, 0, 85, 0.2); background: rgba(255, 0, 85, 0.015);">
                <div style="display: flex; gap: 0.5rem; align-items: start; margin-bottom: 0.5rem;">
                  <span style="font-size: 1rem; line-height: 1;">❌</span>
                  <strong style="color: var(--neon-rose); font-size: 0.9rem; line-height: 1.3;">Bulo: "{item.confusion}"</strong>
                </div>
                <div style="display: flex; gap: 0.5rem; align-items: start; padding-left: 1.5rem; font-size: 0.88rem; color: var(--text-muted); line-height: 1.5;">
                  <span style="color: var(--neon-green); font-weight: bold; font-family: monospace;">REALIDAD:</span>
                  <span>{item.reality}</span>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- 6. Respuestas rápidas para redes con botón de Copiar -->
      {didactic && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(157, 78, 221, 0.1); color: var(--neon-purple);">💬</div>
            <h2 class="topic-section-title">Respuestas Rápidas para Redes</h2>
          </div>
          <div class="cyber-card" style="padding: 1.5rem; border-color: var(--neon-purple); background: rgba(157, 78, 221, 0.01); display: flex; flex-direction: column; gap: 1rem;">
            <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0; line-height: 1.4;">
              Usa este resumen verificado para responder de forma neutral y didáctica en debates o hilos virales:
            </p>
            <div style="background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05); padding: 1rem; border-radius: 8px; font-family: monospace; font-size: 0.82rem; line-height: 1.5; color: var(--text-main); position: relative;">
              <span id="quick-copy-text">{didactic.quick_replies}</span>
            </div>
            <button class="cyber-btn" onclick="navigator.clipboard.writeText(document.getElementById('quick-copy-text').innerText); alert('¡Copiado al portapapeles!');" style="align-self: flex-end; font-size: 0.72rem; padding: 0.4rem 1rem; border-color: var(--neon-purple); color: var(--neon-purple); border-radius: 8px;">
              📋 Copiar Copy
            </button>
          </div>
        </section>
      )}

      <!-- 7. Cronología -->
      {didactic && didactic.chronology && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(255, 176, 32, 0.1); color: var(--neon-amber);">📅</div>
            <h2 class="topic-section-title">Cronología de Acontecimientos</h2>
          </div>
          <div class="cyber-card" style="padding: 1.5rem 1.5rem 0.5rem 1.5rem; background: rgba(18, 22, 41, 0.4);">
            <div style="display: flex; flex-direction: column; border-left: 2px solid rgba(255, 255, 255, 0.05); margin-left: 0.5rem; padding-left: 1.25rem; gap: 1.5rem;">
              {didactic.chronology.map(item => (
                <div style="position: relative;">
                  <!-- Timeline Node -->
                  <div style="position: absolute; left: calc(-1.25rem - 6px); top: 3px; width: 10px; height: 10px; border-radius: 50%; background: var(--neon-amber); box-shadow: 0 0 8px var(--neon-amber);"></div>
                  <strong style="color: var(--neon-amber); font-size: 0.8rem; display: block; margin-bottom: 0.25rem; font-family: var(--font-title);">{item.date}</strong>
                  <span style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.5; display: block;">{item.event}</span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- 8. Preguntas pendientes -->
      {didactic && didactic.pending_questions && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue);">❓</div>
            <h2 class="topic-section-title">Preguntas Pendientes y Desafíos</h2>
          </div>
          <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.4); border-color: rgba(0, 240, 255, 0.15);">
            <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.5; margin: 0; font-style: italic;">
              {didactic.pending_questions}
            </p>
          </div>
        </section>
      )}

      <!-- 9. Fuentes oficiales de referencia -->
      {didactic && didactic.main_sources && (
        <section class="topic-section" style="margin-bottom: 1.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue);">🔗</div>
            <h2 class="topic-section-title">Fuentes Oficiales y Enlaces de Interés</h2>
          </div>
          <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.3);">
            <div style="display: grid; grid-template-columns: 1fr; gap: 0.85rem;">
              {didactic.main_sources.map(src => (
                <a href={src.url} target="_blank" rel="noopener noreferrer" style="display: flex; align-items: center; justify-content: space-between; text-decoration: none; font-size: 0.85rem; font-weight: bold; color: var(--neon-blue); padding: 0.65rem 1rem; background: rgba(255,255,255,0.015); border: 1px solid rgba(255,255,255,0.03); border-radius: 12px; transition: all 0.25s;">
                  <span>📂 {src.name}</span>
                  <span style="font-size: 0.75rem;">Visitar Web Oficial &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </div>

    <!-- ═══ PANEL 3: EXPEDIENTES Y CASOS AUDITADOS ═══ -->
    <div id="panel-radar" class="topic-tab-panel">
      <section class="topic-section">
        <div class="topic-section-header">
          <div class="topic-section-icon" style="background: rgba(0, 245, 160, 0.1); color: var(--neon-green);">🛡️</div>
          <h2 class="topic-section-title">Casos Auditados en el Radar</h2>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {articles.map(art => (
            <div class={"cyber-card " + getVerdictClass(art.verdict)} style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; background: rgba(18, 22, 41, 0.45);">
              <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
                <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                  <span class={"verdict-badge " + getVerdictClass(art.verdict)}>
                    {art.verdict}
                  </span>
                  <span style="background: rgba(157, 78, 221, 0.1); border: 1px solid rgba(157, 78, 221, 0.2); border-radius: 4px; padding: 0.1rem 0.35rem; color: #ffffff; font-size: 0.7rem; font-weight: bold;">
                    {art.emoji_tag || '🧊 Falta contexto'}
                  </span>
                  <span style="font-family: monospace; color: var(--neon-amber); font-weight: 700; font-size: 0.7rem;">
                    🌡️ {art.newnews_score || 50}%
                  </span>
                </div>
                <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">
                  Auditoría: {new Date(art.published_at).toLocaleDateString('es-ES')}
                </span>
              </div>

              <div>
                <h3 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.02em; line-height: 1.25;">
                  <a href={`${cleanBase}/noticia/${art.slug}`} class="article-link">{art.title}</a>
                </h3>
                <p style="color: var(--text-muted); font-size: 0.9rem; line-height: 1.4; margin-bottom: 1rem;">
                  {art.subtitle}
                </p>
                {art.multimedia_url && (
                  <div style="margin-top: 0.5rem; margin-bottom: 1rem; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); max-height: 220px; background: #000; display: flex; align-items: center; justify-content: center;">
                    <img src={art.multimedia_url} alt="Portada" style="width: 100%; height: 100%; object-fit: cover; max-height: 220px;" />
                  </div>
                )}
                <div style="background: rgba(255,255,255,0.015); border-left: 2px solid var(--border-color); padding: 0.85rem 1rem; font-size: 0.8rem; font-style: italic; color: var(--text-muted); border-radius: 0 8px 8px 0; line-height: 1.45;">
                  <strong>Afirmación viral:</strong> "{art.claim}"
                </div>
              </div>

              <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 1rem; font-size: 0.8rem; color: var(--text-muted);">
                <span>Origen: <strong style="color: var(--text-main);">{art.origin_platform}</strong></span>
                <a href={`${cleanBase}/noticia/${art.slug}`} class="cyber-btn" style="padding: 0.35rem 0.85rem; font-size: 0.7rem; border-radius: 10px; color: var(--neon-blue); border-color: rgba(0, 240, 255, 0.15); text-decoration: none;">
                  Auditar Datos &rarr;
                </a>
              </div>
            </div>
          ))}

          {articles.length === 0 && (
            <div class="cyber-card" style="text-align: center; padding: 3.5rem; color: var(--text-muted); background: rgba(18, 22, 41, 0.3); border-radius: 20px; border: 1px dashed var(--border-color); font-size: 0.9rem;">
              No hay desmentidos publicados en esta sección. El radar sigue escaneando.
            </div>
          )}
        </div>
      </section>

      <!-- FAQ del Tema -->
      <section class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.4); margin-bottom: 2rem;">
        <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--neon-purple); letter-spacing: -0.01em;">Preguntas Frecuentes</h3>
        <div style="display: flex; flex-direction: column; gap: 1.25rem; font-size: 0.85rem; line-height: 1.5;">
          <div>
            <strong style="color: var(--text-main); display: block; margin-bottom: 0.25rem;">¿De dónde proceden los datos contrastados?</strong>
            <p style="color: var(--text-muted);">
              Se contrastan directamente con el articulado oficial de las leyes vigentes publicadas en el BOE, bases de datos estadísticas oficiales (INE, SEPE) y memorias de la Fiscalía General del Estado.
            </p>
          </div>
          <div style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
            <strong style="color: var(--text-main); display: block; margin-bottom: 0.25rem;">¿Hay fuentes oficiales fiables para auditar?</strong>
            <p style="color: var(--text-muted);">
              Sí, puedes consultar el catálogo completo de fuentes del Estado y enlaces del BOE al pie de cada artículo de verificación individual.
            </p>
          </div>
        </div>
      </section>
    </div>

    <!-- ═══ PANEL 4: ENFOQUE POLÍTICO ═══ -->
    <div id="panel-politica" class="topic-tab-panel">
      <section class="topic-section">
        <div class="topic-section-header">
          <div class="topic-section-icon" style="background: rgba(157, 78, 221, 0.1); color: var(--neon-purple);">🏛️</div>
          <h2 class="topic-section-title">Programas y Propuestas Políticas</h2>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {policyMeasures.map(pm => (
            <div class="cyber-card" style="padding: 1.75rem; background: rgba(18, 22, 41, 0.45); display: flex; flex-direction: column; gap: 1.25rem;">
              <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 0.75rem;">
                <span style="background: rgba(0, 240, 255, 0.06); color: var(--neon-blue); border: 1px solid rgba(0, 240, 255, 0.2); font-size: 0.7rem; font-weight: 800; padding: 0.3rem 0.65rem; border-radius: 8px; text-transform: uppercase; letter-spacing: 0.04em;">
                  Propuesta electoral {pm.party_name}
                </span>
                <span style="color: var(--text-muted); font-size: 0.8rem;">
                  Área: <strong>{pm.area}</strong>
                </span>
              </div>

              <div>
                <h4 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-main); font-family: var(--font-title);">
                  {pm.title}
                </h4>
                <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem;">
                  {pm.plain_language_summary}
                </p>

                <div style="background: rgba(255, 255, 255, 0.015); border-left: 3px solid var(--neon-blue); padding: 0.75rem 1rem; border-radius: 0 8px 8px 0; margin-bottom: 0.75rem;">
                  <strong style="font-size: 0.75rem; text-transform: uppercase; color: var(--neon-blue); display: block; margin-bottom: 0.25rem;">Texto del Programa:</strong>
                  <span style="font-size: 0.82rem; color: var(--text-muted); font-style: italic; line-height: 1.5; display: block;">
                    "{pm.original_text}"
                  </span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr; gap: 0.75rem; margin-top: 1rem;">
                  <div style="background: rgba(0, 245, 160, 0.02); border: 1px solid rgba(0, 245, 160, 0.08); padding: 0.75rem 1rem; border-radius: 12px;">
                    <strong style="font-size: 0.72rem; text-transform: uppercase; color: var(--neon-green); display: block; margin-bottom: 0.15rem;">Impacto Estimado:</strong>
                    <span style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; display: block;">
                      {pm.possible_impact}
                    </span>
                  </div>
                  <div style="background: rgba(255, 176, 32, 0.02); border: 1px solid rgba(255, 176, 32, 0.08); padding: 0.75rem 1rem; border-radius: 12px;">
                    <strong style="font-size: 0.72rem; text-transform: uppercase; color: var(--neon-amber); display: block; margin-bottom: 0.15rem;">Colectivos Afectados:</strong>
                    <span style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; display: block;">
                      {pm.target_groups}
                    </span>
                  </div>
                </div>
              </div>

              <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 0.85rem; font-size: 0.78rem; color: var(--text-muted);">
                <span>Programa 2023</span>
                {pm.source_page && (
                  <span style="color: var(--neon-blue);">Página {pm.source_page}</span>
                )}
              </div>
            </div>
          ))}

          {policyMeasures.length === 0 && (
            <div class="cyber-card" style="text-align: center; padding: 3.5rem; color: var(--text-muted); background: rgba(18, 22, 41, 0.3); border-radius: 20px; border: 1px dashed var(--border-color); font-size: 0.9rem;">
              No hay propuestas electorales o medidas gubernamentales específicas registradas para este tema en la base de datos.
            </div>
          )}
        </div>
      </section>
    </div>

    <!-- Buscador Rápido -->
    <section class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.3); text-align: center; border-style: dashed; margin-bottom: 2rem;">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-main);">¿Has detectado bulos sobre este tema?</h3>
      <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin-bottom: 1.25rem; max-width: 400px; margin-left: auto; margin-right: auto;">
        Ayúdanos a recopilar evidencias enviando capturas de publicaciones de redes al buzón del radar.
      </p>
      <a href="/buscador" class="cyber-btn accent" style="width: 100%; max-width: 250px; border-radius: 12px; font-size: 0.75rem;">
        Buscar o reportar bulo
      </a>
    </section>

  </div>
</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabButtons = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.topic-tab-panel');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remover clase activa de todos los botones y paneles
        tabButtons.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));

        // Activar el botón actual
        btn.classList.add('active');

        // Activar el panel correspondiente
        const targetId = btn.getAttribute('data-target');
        const targetPanel = document.getElementById(targetId);
        if (targetPanel) {
          targetPanel.classList.add('active');
        }
      });
    });
  });
</script>

<style>
  .article-link:hover {
    color: var(--neon-blue) !important;
  }
  
  /* Estilos de pestañas (Tabs) */
  .topic-tabs-nav {
    display: flex;
    gap: 0.6rem;
    margin: 1.5rem 0;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
  }
  .topic-tabs-nav::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }
  .tab-btn {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    padding: 0.65rem 1.15rem;
    border-radius: 12px;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.82rem;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .tab-btn:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-main);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .tab-btn.active {
    background: rgba(0, 240, 255, 0.08);
    color: var(--neon-blue);
    border-color: var(--neon-blue);
    box-shadow: 0 0 12px rgba(0, 240, 255, 0.15);
  }
  
  .topic-tab-panel {
    display: none;
    animation: tabFadeIn 0.35s ease-out forwards;
  }
  .topic-tab-panel.active {
    display: block;
  }
  
  @keyframes tabFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
