const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
---

<Layout title={topic.title} description={topic.description}>
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 3rem; max-width: 680px;">
    <!-- 💡?💡 HERO DEL TEMA 💡?💡 -->
    <section class="topic-hero" style="margin-bottom: 2rem;">
      <div class="cyber-card" style="padding: 2.5rem 2rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%); overflow: hidden; border-color: rgba(0, 240, 255, 0.25);">
        
        <!-- Background Glow -->
        <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: var(--neon-blue); filter: blur(80px); opacity: 0.15; pointer-events: none;"></div>

        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; position: relative; z-index: 2;">
          <span style="background: rgba(0, 240, 255, 0.06); color: var(--neon-blue); font-size: 0.65rem; font-weight: 800; padding: 0.35rem 0.85rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.08em; border: 1px solid rgba(0, 240, 255, 0.15);">
            Expediente: {topic.category}
          </span>
          <span style="color: var(--neon-green); font-weight: 800; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; display: inline-flex; align-items: center; gap: 0.4rem;">
            <span class="pulse-icon" style="margin-right: 0;"></span>
            Seguimiento Activo
          </span>
        </div>

        <h1 style="font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 1rem; color: var(--text-main); font-family: var(--font-title); position: relative; z-index: 2;">
          {topic.title}
        </h1>

        <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 2rem; max-width: 580px; position: relative; z-index: 2;">
          {topic.description}
        </p>

        <!-- Stat Cards Grid -->
        {info && (
          <div class="topic-stat-grid" style="position: relative; z-index: 2;">
            <div class="topic-stat-card">
              <div class="topic-stat-value" style="color: var(--neon-blue);">{info.metric}</div>
              <div class="topic-stat-label">{info.metricLabel.split(' ').slice(0, 3).join(' ')}</div>
            </div>
            <div class="topic-stat-card">
              <div class="topic-stat-value" style="color: var(--neon-purple);">{cards.length}</div>
              <div class="topic-stat-label">Apartados Legales</div>
            </div>
            <div class="topic-stat-card">
              <div class="topic-stat-value" style="color: var(--neon-green);">{articles.length}</div>
              <div class="topic-stat-label">Desmentidos</div>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- 💡?💡 BOTONES DE APARTADOS (TABS) 💡?💡 -->
    <nav class="topic-tabs-nav">
      <button class="tab-btn active" data-target="panel-legal">
        💡 <span>Didáctica y Hechos</span>
      </button>
      <button class="tab-btn" data-target="panel-magnitud">
        💡 <span>Cifras y Datos</span>
      </button>
      <button class="tab-btn" data-target="panel-radar">
        💡💡 <span>Casos en el Radar ({articles.length})</span>
      </button>
      <button class="tab-btn" data-target="panel-politica">
        💡💡 <span>Enfoque Político ({policyMeasures.length})</span>
      </button>
    </nav>

    <!-- 💡?💡 PANEL 1: MAGNITUD Y CIFRAS 💡?💡 -->
    <div id="panel-magnitud" class="topic-tab-panel">
      {info && (
        <section class="topic-section">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue);">💡</div>
            <h2 class="topic-section-title">Magnitud y Cifras Oficiales</h2>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1.25rem;">
            <!-- Métrica Detallada -->
            <div style="background: linear-gradient(135deg, rgba(0, 240, 255, 0.03) 0%, rgba(7, 9, 19, 0.8) 100%); border: 1px solid rgba(0, 240, 255, 0.15); padding: 1.5rem; border-radius: 20px; text-align: center;">
              <span style="font-size: 3.5rem; font-weight: 800; font-family: var(--font-title); color: var(--neon-blue); line-height: 1; display: block; margin-bottom: 0.25rem; text-shadow: 0 0 15px rgba(0, 240, 255, 0.2);">{info.metric}</span>
              <span style="font-size: 0.8rem; font-weight: 700; color: var(--text-main); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">{info.metricLabel}</span>
              <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin: 0; max-width: 550px; margin-left: auto; margin-right: auto;">{info.subText}</p>
            </div>

            <!-- Indicadores de barras -->
            <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45); display: flex; flex-direction: column; gap: 1.25rem;">
              <strong style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); display: block; letter-spacing: 0.05em;">Indicadores y Contexto de Datos</strong>
              {info.bars.map(bar => (
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                  <div style="display: flex; justify-content: space-between; font-size: 0.8rem;">
                    <span style="color: var(--text-main); font-weight: 700;">{bar.label}</span>
                    <strong style={`color: ${bar.color}`}>{bar.percentage}</strong>
                  </div>
                  <div style="width: 100%; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,255,255,0.02);">
                    <div style={`width: ${bar.percentage}; height: 100%; background: ${bar.color}; border-radius: 4px;`} class="topic-bar-fill"></div>
                  </div>
                  <span style="font-size: 0.7rem; color: var(--text-muted);">{bar.desc}</span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}
    </div>

    <!-- 💡?💡 PANEL 2: MARCO LEGAL Y DID💡⚙️CTICA 💡?💡 -->
    <div id="panel-legal" class="topic-tab-panel active">
      <!-- 1. 💡⚙️Qu⚙️💡 est⚙️💡 pasando? -->
      {didactic && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue);">💡</div>
            <h2 class="topic-section-title">💡⚙️Qu⚙️💡 est⚙️💡 pasando con este tema?</h2>
          </div>
          <div class="cyber-card" style="padding: 1.75rem; background: linear-gradient(135deg, rgba(0, 240, 255, 0.03) 0%, rgba(7, 9, 19, 0.9) 100%); line-height: 1.6; font-size: 0.95rem; color: var(--text-main);">
            {didactic.what_is_happening}
          </div>
        </section>
      )}

      <!-- 2. 💡⚙️Qu⚙️💡 sabemos y qu⚙️💡 no sabemos? -->
      {didactic && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;" class="redactor-split-grid">
            <!-- Qu⚙️💡 sabemos -->
            <div class="cyber-card" style="padding: 1.5rem; border-color: rgba(0, 245, 160, 0.25); background: rgba(0, 245, 160, 0.01);">
              <span style="font-size: 0.72rem; text-transform: uppercase; color: var(--neon-green); font-weight: 800; display: block; margin-bottom: 0.5rem; letter-spacing: 0.05em;">💡⚙️💡 Hechos Probados (💡⚙️Qu⚙️💡 sabemos?)</span>
              <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
                {didactic.what_we_know}
              </p>
            </div>

            <!-- Qu⚙️💡 no sabemos -->
            <div class="cyber-card" style="padding: 1.5rem; border-color: rgba(255, 176, 32, 0.25); background: rgba(255, 176, 32, 0.01);">
              <span style="font-size: 0.72rem; text-transform: uppercase; color: var(--neon-amber); font-weight: 800; display: block; margin-bottom: 0.5rem; letter-spacing: 0.05em;">💡⚙️💡 Incertidumbres (💡⚙️Qu⚙️💡 no sabemos?)</span>
              <p style="font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin: 0;">
                {didactic.what_we_do_not_know}
              </p>
            </div>
          </div>
        </section>
      )}

      <!-- Fichas didácticas cl💡⚙️sicas (Fichas BOE) -->
      <section class="topic-section" style="margin-bottom: 2.5rem;">
        <div class="topic-section-header">
          <div class="topic-section-icon" style="background: rgba(157, 78, 221, 0.1); color: var(--neon-purple);">💡💡⚙️</div>
          <h2 class="topic-section-title">Marco Legal y Normativo (BOE)</h2>
        </div>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {cards.map((card) => (
            <div class="topic-edu-card">
              <h4>{card.title}</h4>
              <div style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.6;" set:html={card.htmlContent || card.text} />
            </div>
          ))}
        </div>
      </section>

      <!-- 4. Datos clave -->
      {didactic && didactic.key_facts && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
            <div class="topic-section-icon" style="background: rgba(0, 245, 160, 0.1); color: var(--neon-green);">💡</div>
            <h2 class="topic-section-title">Puntos y Cifras Clave</h2>
          </div>
          <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.4);">
            <ul style="padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.5;">
              {didactic.key_facts.map(fact => (
                <li style="list-style-type: none; position: relative; padding-left: 1.5rem;">
                  <span style="position: absolute; left: 0; color: var(--neon-green); font-weight: bold;">💡</span>
                  {fact}
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      <!-- 5. Confusiones Frecuentes y Desmentidos rápidos -->
      {didactic && didactic.frequent_confusions && (
        <section class="topic-section" style="margin-bottom: 2.5rem;">
          <div class="topic-section-header">
