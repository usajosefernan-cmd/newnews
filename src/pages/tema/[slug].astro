---
import Layout from '../../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

export async function getStaticPaths() {
  const dbPath = path.resolve('data/newnews.db');
  const db = new DatabaseSync(dbPath);
  const topics = db.prepare("SELECT slug FROM topics WHERE status = 'activo'").all();
  db.close();

  return topics.map(topic => ({
    params: { slug: topic.slug }
  }));
}

const { slug } = Astro.params;

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// Cargar información del tema
const topic = db.prepare("SELECT * FROM topics WHERE slug = ?").get(slug);

// Cargar artículos relacionados publicados
const articles = db.prepare(`
  SELECT * FROM articles 
  WHERE topic_id = ? AND status = 'publicado' 
  ORDER BY published_at DESC
`).all(topic.id);

// Obtener propuestas políticas del área correspondiente al tema
let areaMapping = null;
const lowerSlug = slug.toLowerCase();
if (lowerSlug.includes('vivienda')) {
  areaMapping = 'Vivienda';
} else if (lowerSlug.includes('fiscalidad') || lowerSlug.includes('impuestos') || lowerSlug.includes('ahorro') || lowerSlug.includes('catalunya') || lowerSlug.includes('autonomos')) {
  areaMapping = 'Fiscalidad';
}

let policyMeasures = [];
if (areaMapping) {
  policyMeasures = db.prepare(`
    SELECT pm.*, p.name as party_name, p.slug as party_slug
    FROM policy_measures pm
    JOIN parties p ON pm.party_id = p.id
    WHERE pm.area = ?
  `).all(areaMapping);
}

db.close();

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

// Iniciales ilustrativas de categoría para avatares minimalistas
function getCategoryInitials(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('migr') || c.includes('socied')) return 'MG';
  if (c.includes('vivien') || c.includes('okupa')) return 'VV';
  if (c.includes('impues') || c.includes('ahorr') || c.includes('econ')) return 'EC';
  if (c.includes('polit') || c.includes('parti')) return 'PL';
  return 'EX';
}

