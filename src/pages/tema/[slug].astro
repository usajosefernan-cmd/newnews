---
import Layout from '../../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

export async function getStaticPaths() {
  const dbPath = path.resolve('data/newnews.db');
  const db = new DatabaseSync(dbPath);
  const topics = db.prepare("SELECT slug FROM topics WHERE status = 'activo'").all();
  db.close();

  return topics.map(topic => ({
    params: { slug: topic.slug }
  }));
}

const { slug } = Astro.params;

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// Cargar información del tema
const topic = db.prepare("SELECT * FROM topics WHERE slug = ?").get(slug);

// Cargar artículos relacionados publicados
const articles = db.prepare(`
  SELECT * FROM articles 
  WHERE topic_id = ? AND status = 'publicado' 
  ORDER BY published_at DESC
`).all(topic.id);

db.close();

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

// Iniciales ilustrativas de categoría para avatares minimalistas
function getCategoryInitials(category) {
  const c = (category || '').toLowerCase();
  if (c.includes('migr') || c.includes('socied')) return 'MG';
  if (c.includes('vivien') || c.includes('okupa')) return 'VV';
  if (c.includes('impues') || c.includes('ahorr') || c.includes('econ')) return 'EC';
  if (c.includes('polit') || c.includes('parti')) return 'PL';
  return 'EX';
}
---

<Layout title={topic.title} description={topic.description}>
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem;">
    
    <!-- Miga de Pan -->
    <div style="margin-bottom: 1.5rem; font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">
      <a href="/" style="text-decoration: none;">Radar</a> / <a href="/temas" style="text-decoration: none;">Expedientes</a> / <span style="color: var(--neon-blue);">{topic.title.split(' ')[0]}</span>
    </div>

    <!-- Cabecera Viva del Tema -->
    <section style="margin-bottom: 2.5rem;">
      <div class="cyber-card" style="padding: 2rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%);">
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.25rem;">
          <span style="background: rgba(255,255,255,0.04); color: var(--text-muted); font-size: 0.7rem; font-weight: 800; padding: 0.25rem 0.6rem; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em;">
            Expediente: {topic.category}
          </span>
          <span style="color: var(--neon-blue); font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; display: inline-flex; align-items: center; gap: 0.4rem;">
            <span style="display: inline-block; width: 6px; height: 6px; background-color: var(--neon-blue); border-radius: 50%; box-shadow: 0 0 6px var(--neon-blue);"></span>
            ACTIVO
          </span>
        </div>

        <h1 style="font-size: 2.2rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 1rem; color: var(--text-main);">
          {topic.title}
        </h1>

        <p style="font-size: 1rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 2rem;">
          {topic.description}
        </p>

        <!-- Bloque informativo consolidado -->
        <div style="display: flex; flex-direction: column; gap: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
          <div>
            <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-amber); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Estado del Debate</span>
            <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.55;">
              {topic.header_summary || "Bulos recurrentes en redes sociales y medios de comunicación."}
            </p>
          </div>
          <div>
            <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-green); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.4rem;">Conclusión de los Datos</span>
            <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.55;">
              {topic.verdict_summary || "Verificación contrastada en base a estadísticas y marcos legales vigentes."}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Listado de Desmentidos específicos -->
    <section style="display: flex; flex-direction: column; gap: 2rem;">
      <span style="font-weight: 800; text-transform: uppercase; color: var(--text-muted); font-size: 0.65rem; letter-spacing: 0.1em; display: block; padding-left: 0.25rem; margin-bottom: -1rem;">Desmentidos Archivados</span>

      {articles.map(art => (
        <div class={"cyber-card " + getVerdictClass(art.verdict)} style="padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; background: rgba(18, 22, 41, 0.45);">
          <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
            <span class={"verdict-badge " + getVerdictClass(art.verdict)}>
              {art.verdict}
            </span>
            <span style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">
              Detección: {new Date(art.published_at).toLocaleDateString('es-ES')}
            </span>
          </div>

          <div>
            <h3 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.02em; line-height: 1.25;">
              <a href={`/noticia/${art.slug}`} class="article-link">{art.title}</a>
            </h3>
            <p style="color: var(--text-muted); font-size: 0.95rem; line-height: 1.4; margin-bottom: 1rem;">
              {art.subtitle}
            </p>
            <div style="background: rgba(255,255,255,0.02); border-left: 2px solid var(--border-color); padding: 0.85rem 1rem; font-size: 0.85rem; font-style: italic; color: var(--text-muted); border-radius: 0 8px 8px 0; line-height: 1.4;">
              <strong>Afirmación:</strong> "{art.claim}"
            </div>
          </div>

          <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 1rem; font-size: 0.8rem; color: var(--text-muted);">
            <span>Vía: <strong style="color: var(--text-main);">{art.origin_platform}</strong></span>
            <a href={`/noticia/${art.slug}`} class="cyber-btn" style="padding: 0.4rem 0.9rem; font-size: 0.75rem; border-radius: 12px; color: var(--neon-blue); border-color: rgba(0, 240, 255, 0.15);">
              Auditar Datos &rarr;
            </a>
          </div>
        </div>
      ))}

      {articles.length === 0 && (
        <div class="cyber-card" style="text-align: center; padding: 3rem; color: var(--text-muted); background: var(--bg-card); border-radius: 20px; border: 1px dashed var(--border-color); font-size: 0.9rem;">
          No se han publicado desmentidos para este tema todavía.
        </div>
      )}
    </section>

    <!-- FAQ del Tema (Integrado en el Feed de forma minimalista) -->
    <section class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.4); margin-top: 3rem;">
      <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--neon-purple); letter-spacing: -0.01em;">Preguntas Frecuentes</h3>
      
      <div style="display: flex; flex-direction: column; gap: 1.25rem; font-size: 0.85rem; line-height: 1.5;">
        <div>
          <strong style="color: var(--text-main); display: block; margin-bottom: 0.25rem;">¿Por qué se viraliza esto ahora?</strong>
          <p style="color: var(--text-muted);">
            Suele dispararse en períodos pre-electorales o tras debates parlamentarios acalorados sobre memoria democrática o migración.
          </p>
        </div>
        <div style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
          <strong style="color: var(--text-main); display: block; margin-bottom: 0.25rem;">¿Hay fuentes oficiales fiables?</strong>
          <p style="color: var(--text-muted);">
            Sí, los registros del Boletín Oficial del Estado (BOE), el Instituto Nacional de Estadística (INE) y bases de datos históricas académicas.
          </p>
        </div>
      </div>
    </section>

    <!-- Buscador Rápido -->
    <section class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.3); text-align: center; border-style: dashed; margin-top: 2rem;">
      <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-main);">¿Has detectado otro bulo?</h3>
      <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin-bottom: 1.25rem; max-width: 400px; margin-left: auto; margin-right: auto;">
        Si tienes capturas o links sobre este tema que no estén en la lista, envíanoslos para auditar.
      </p>
      <a href="/buscador" class="cyber-btn accent" style="width: 100%; max-width: 250px; border-radius: 12px; font-size: 0.75rem;">
        Enviar al Radar
      </a>
    </section>

  </div>
</Layout>

<style>
  .article-link:hover {
    color: var(--neon-blue) !important;
  }
</style>
