---
import Layout from '../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// Cargar partidos
const parties = db.prepare("SELECT * FROM parties ORDER BY name").all() as any[];

// Cargar todas las medidas de programas electorales
const measures = db.prepare(`
  SELECT pm.*, p.name as party_name, p.slug as party_slug, p.current_leader
  FROM policy_measures pm
  LEFT JOIN parties p ON pm.party_id = p.id
`).all() as any[];

// Obtener todas las áreas/temáticas únicas disponibles
const areas = [...new Set(measures.map(m => m.area))];

db.close();
---

<Layout title="Comparador Político de Medidas" description="Compara de forma objetiva las propuestas electorales e impactos de los partidos políticos en España por temáticas.">
  <div class="container">
    
    <div style="margin-bottom: 2.5rem; text-align: center; max-width: 800px; margin-left: auto; margin-right: auto;">
      <span style="background: var(--neon-rose); color: var(--bg-dark); font-weight: 800; font-size: 0.8rem; padding: 0.2rem 0.6rem; text-transform: uppercase; border-radius: 2px;">
        AUDITORÍA ELECTORAL COMPARADA
      </span>
      <h1 style="font-size: 2.8rem; line-height: 1.1; margin-top: 0.5rem; margin-bottom: 1rem;">
        Comparador <span class="text-gradient-blue">Político</span>
      </h1>
      <p style="color: var(--text-muted); font-size: 1.1rem;">
        Selecciona un área temática para contrastar cara a cara lo que propone cada partido en su programa electoral, la traducción a lenguaje claro, el impacto estimado y sus fuentes.
      </p>
    </div>

    <!-- Botones de Filtro Temático (Neobrutalistas) -->
    <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem;" id="area-filters">
      {areas.map((area, idx) => (
        <button 
          class={`cyber-btn ${idx === 0 ? 'active accent' : ''}`}
          data-area={area}
          style="box-shadow: 2px 2px 0px 0px var(--border-color); font-size: 0.95rem; min-width: 120px;"
        >
          {area}
        </button>
      ))}
    </div>

    <!-- Tabla Comparativa Cyberpunk -->
    <div class="cyber-card blue" style="background: var(--bg-card); overflow-x: auto; padding: 1.5rem;">
      <table style="width: 100%; border-collapse: collapse; min-width: 800px; text-align: left;">
        <thead>
          <tr style="border-bottom: 2px solid var(--border-color);">
            <th style="padding: 1rem; color: var(--neon-blue); font-family: var(--font-title); font-size: 1.1rem; width: 15%;">Partido</th>
            <th style="padding: 1rem; color: var(--neon-blue); font-family: var(--font-title); font-size: 1.1rem; width: 35%;">Propuesta (Cita y Lenguaje Claro)</th>
            <th style="padding: 1rem; color: var(--neon-blue); font-family: var(--font-title); font-size: 1.1rem; width: 30%;">Impacto Estimado</th>
            <th style="padding: 1rem; color: var(--neon-blue); font-family: var(--font-title); font-size: 1.1rem; width: 20%;">Ficha</th>
          </tr>
        </thead>
        <tbody id="comparison-rows">
          {measures.map(m => (
            <tr 
              class="comparison-row" 
              data-area={m.area}
              style="border-bottom: 1px solid var(--border-color); transition: background-color 0.2s;"
            >
              <!-- Partido -->
              <td style="padding: 1.5rem 1rem; vertical-align: top;">
                <strong style="font-size: 1.2rem; color: var(--text-main); display: block;">{m.party_slug.toUpperCase()}</strong>
                <span style="font-size: 0.8rem; color: var(--text-muted);">{m.current_leader}</span>
              </td>
              
              <!-- Propuesta -->
              <td style="padding: 1.5rem 1rem; vertical-align: top; display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="background: rgba(0,0,0,0.15); border-left: 3px solid var(--border-color); padding: 0.5rem; font-style: italic; font-size: 0.85rem; color: var(--text-muted);">
                  "{m.original_text}"
                </div>
                <div>
                  <strong style="color: var(--neon-blue); font-size: 0.85rem; text-transform: uppercase; display: block; margin-bottom: 0.15rem;">Traducción clara:</strong>
                  <p style="font-size: 0.95rem; color: var(--text-main);">{m.plain_language_summary}</p>
                </div>
              </td>
              
              <!-- Impacto -->
              <td style="padding: 1.5rem 1rem; vertical-align: top;">
                <strong style="color: var(--neon-purple); font-size: 0.85rem; text-transform: uppercase; display: block; margin-bottom: 0.25rem;">Impacto en la sociedad:</strong>
                <p style="font-size: 0.9rem; color: var(--text-muted);">{m.possible_impact}</p>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">
                  Afecta a: <strong style="color: var(--text-main);">{m.target_groups}</strong>
                </div>
              </td>
              
              <!-- Enlaces -->
              <td style="padding: 1.5rem 1rem; vertical-align: top;">
                <a href={`/partido/${m.party_slug}`} class="cyber-btn" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--border-color); width: 100%; text-align: center; display: block; margin-bottom: 0.5rem;">
                  Ficha Partido
                </a>
                <span style="font-size: 0.75rem; color: var(--text-muted); display: block; text-align: center;">pág. {m.source_page}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Comparador para perfiles de votante (Tarjetas Rápidas) -->
    <section style="margin-top: 5rem; margin-bottom: 4rem;">
      <h2 style="font-size: 1.6rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem; text-align: center;">
        👤 ¿Cómo me afecta según mi perfil?
      </h2>

      <div class="grid-cols-3">
        
        <div class="cyber-card green">
          <h3 style="color: var(--neon-green); font-size: 1.2rem; margin-bottom: 0.5rem; font-family: var(--font-title);">Si eres JOVEN</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">
            El acceso a la vivienda es tu principal foco. Te afecta el plan de avales públicos de hipotecas del 20% (PSOE/PP) frente al tope de precios de alquileres y aumento de vivienda social (Sumar) o la desregulación de suelo urbanizable (VOX).
          </p>
          <button onclick="filterByArea('Vivienda')" class="cyber-btn" style="width: 100%; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--border-color);">
            Ver Medidas Vivienda
          </button>
        </div>

        <div class="cyber-card purple">
          <h3 style="color: var(--neon-purple); font-size: 1.2rem; margin-bottom: 0.5rem; font-family: var(--font-title);">Si eres AUTÓNOMO</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">
            Las cargas de cotizaciones y la burocracia son clave. Las reformas fiscales del IVA, la cuota progresiva por ingresos y las deducciones a la inversión cambian según el partido y sus acuerdos en el Parlamento.
          </p>
          <button onclick="alert('Sección en desarrollo: Datos fiscales en el próximo cron de actualización.');" class="cyber-btn" style="width: 100%; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--border-color);">
            Ver Medidas Fiscales
          </button>
        </div>

        <div class="cyber-card amber">
          <h3 style="color: var(--neon-amber); font-size: 1.2rem; margin-bottom: 0.5rem; font-family: var(--font-title);">Si eres INQUILINO</h3>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1rem;">
            El precio del alquiler de viviendas en las zonas tensionadas de las ciudades. Compara el mantenimiento estricto de topes de alquiler (PSOE/Sumar) frente a la derogación de la ley para liberalizar el mercado (PP/VOX).
          </p>
          <button onclick="filterByArea('Vivienda')" class="cyber-btn" style="width: 100%; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--border-color);">
            Ver Medidas Alquiler
          </button>
        </div>

      </div>
    </section>

  </div>
</Layout>

<script is:inline>
  // Lógica de filtrado en el cliente para la tabla comparativa
  const buttons = document.querySelectorAll('#area-filters button');
  const rows = document.querySelectorAll('#comparison-rows tr');

  function filterByArea(area) {
    // Actualizar botones activos
    buttons.forEach(btn => {
      if (btn.getAttribute('data-area') === area) {
        btn.classList.add('active', 'accent');
      } else {
        btn.classList.remove('active', 'accent');
      }
    });

    // Mostrar/ocultar filas correspondientes
    rows.forEach(row => {
      const rowArea = row.getAttribute('data-area');
      if (rowArea === area) {
        row.style.display = 'table-row';
      } else {
        row.style.display = 'none';
      }
    });
  }

  // Escuchar clicks de botones de filtrado
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const area = btn.getAttribute('data-area');
      filterByArea(area);
    });
  });

  // Inicializar mostrando la primera área disponible
  if (buttons.length > 0) {
    const firstArea = buttons[0].getAttribute('data-area');
    filterByArea(firstArea);
  }
</script>

<style>
  /* Clases temporales para resaltar los botones activos */
  .cyber-btn.active.accent {
    background: var(--neon-blue) !important;
    color: var(--bg-dark) !important;
    border-color: var(--bg-dark) !important;
  }
  
  tr.comparison-row:hover {
    background-color: rgba(36, 47, 71, 0.2);
  }
</style>
