                          <input type="hidden" name="action" value="edit_promise" />
                          <input type="hidden" name="promise_id" value={prom.id} />
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Texto Promesa:</label>
                            <input type="text" name="promise_text" value={prom.promise_text} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
