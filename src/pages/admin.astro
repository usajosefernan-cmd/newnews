                <div>
                  <strong style="color: var(--text-main); font-size: 0.95rem;">{party.name}</strong>
                  <span style="font-size: 0.8rem; color: var(--text-muted); display: block;">Líder: {party.current_leader} | Ideología: {party.ideology_summary}</span>
                </div>
                <div style="display: flex; gap: 0.5rem; align-items: center;">
                  <!-- Editar en línea -->
                  <details style="margin: 0; position: relative;">
                    <summary style="list-style: none; cursor: pointer; padding: 0.25rem 0.5rem; background: rgba(255,255,255,0.05); font-size: 0.75rem; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);">Editar</summary>
                    <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.75rem; background: rgba(18, 22, 41, 0.95); padding: 1.25rem; border: 1px solid var(--border-color); border-radius: 6px; position: absolute; right: 0; z-index: 100; width: 280px; box-shadow: 0 4px 25px rgba(0,0,0,0.8);">
                      <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin: 0;">
                        <input type="hidden" name="action" value="edit_party" />
                        <input type="hidden" name="party_id" value={party.id} />
                        <div>
                          <label class="edit-label" style="font-size: 0.65rem;">Nombre:</label>
                          <input type="text" name="name" value={party.name} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                        </div>
                        <div>
                          <label class="edit-label" style="font-size: 0.65rem;">Líder:</label>
                          <input type="text" name="leader" value={party.current_leader} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                        </div>
                        <div>
                          <label class="edit-label" style="font-size: 0.65rem;">Web:</label>
                          <input type="url" name="website" value={party.official_website} class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                        </div>
                        <div>
                          <label class="edit-label" style="font-size: 0.65rem;">Ideología:</label>
                          <input type="text" name="ideology" value={party.ideology_summary} class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
