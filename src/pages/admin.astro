                        <button type="submit" class="cyber-btn accent" style="padding: 0.4rem; font-size: 0.75rem; font-weight: bold; width: 100%;">Actualizar</button>
                      </form>
                    </div>
                  </details>
                  <!-- Eliminar -->
                  <form method="POST" style="margin: 0; display: inline-block;">
                    <input type="hidden" name="action" value="delete_party" />
                    <input type="hidden" name="party_id" value={party.id} />
                    <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.95rem;" onclick="return confirm('¿Seguro que deseas eliminar el partido de la base de datos?')">🗑️</button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- SECCIÓN 2: MEDIDAS Y PROPUESTAS DE PROGRAMAS -->
