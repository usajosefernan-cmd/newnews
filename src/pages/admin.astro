---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';
import { analyzeUrl } from '../../scripts/check-url.js';
import { execSync } from 'node:child_process';

const baseRoute = Astro.url.pathname.includes('/pro/newnews') ? '/pro/newnews' : '/';
const cleanBase = baseRoute.endsWith('/') ? baseRoute.slice(0, -1) : baseRoute;

let message = '';
let messageType = 'info';
let urlCheckResult = null;
let commandOutput = '';

// Obtener la pestaña activa
const currentTab = Astro.url.searchParams.get('tab') || 'aprobacion';

// Manejo de peticiones POST (acciones de administración)
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString() || '';

    const dbPath = path.resolve('data/newnews.db');
    const db = new DatabaseSync(dbPath);
    db.exec('PRAGMA foreign_keys = ON;');

    if (action === 'approve') {
      const articleId = data.get('article_id')?.toString() || '';
      
      // Actualizar artículo a publicado
      db.prepare(`
        UPDATE articles 
        SET status = 'publicado', published_at = datetime('now'), human_review_required = 0 
        WHERE id = ?
      `).run(articleId);

      // Actualizar posts sociales asociados a programado
      db.prepare(`
        UPDATE social_posts 
        SET status = 'programado', scheduled_at = datetime('now') 
        WHERE article_id = ?
      `).run(articleId);

      message = `✓ Artículo aprobado y publicado exitosamente en el feed de noticias.`;
      messageType = 'success';
    } 
    else if (action === 'reject') {
      const articleId = data.get('article_id')?.toString() || '';
      
      db.prepare("UPDATE articles SET status = 'rechazado' WHERE id = ?").run(articleId);
      
      message = `✗ Artículo rechazado y movido a la papelera.`;
      messageType = 'error';
    } 
    else if (action === 'edit_article') {
      const articleId = data.get('article_id')?.toString() || '';
      const title = data.get('title')?.toString() || '';
      const subtitle = data.get('subtitle')?.toString() || '';
      const verdict = data.get('verdict')?.toString() || '';
      const explanation = data.get('explanation')?.toString() || '';
      const whatIsTrue = data.get('what_is_true')?.toString() || '';
      const whatIsFalse = data.get('what_is_false')?.toString() || '';
      const whatLacksContext = data.get('what_lacks_context')?.toString() || '';
      const whatIsNotProven = data.get('what_is_not_proven')?.toString() || '';
      const topicId = data.get('topic_id')?.toString() || '';
      const status = data.get('status')?.toString() || 'borrador';

      const originDate = data.get('origin_date')?.toString() || new Date().toISOString();
      db.prepare(`
        UPDATE articles 
        SET title = ?, subtitle = ?, verdict = ?, explanation = ?, 
            what_is_true = ?, what_is_false = ?, what_lacks_context = ?, what_is_not_proven = ?,
            topic_id = ?, status = ?, origin_date = ?, updated_at = datetime('now')
        WHERE id = ?
      `).run(title, subtitle, verdict, explanation, whatIsTrue, whatIsFalse, whatLacksContext, whatIsNotProven, topicId, status, originDate, articleId);

      message = `✓ Artículo "${title.substring(0, 45)}..." actualizado correctamente.`;
      messageType = 'success';
    }
    else if (action === 'delete_article') {
      const articleId = data.get('article_id')?.toString() || '';
      db.prepare("DELETE FROM articles WHERE id = ?").run(articleId);
      message = `✓ Artículo eliminado físicamente de la base de datos.`;
      messageType = 'success';
    }
    else if (action === 'create_article') {
      const title = data.get('title')?.toString() || '';
      const subtitle = data.get('subtitle')?.toString() || '';
      const verdict = data.get('verdict')?.toString() || '';
      const explanation = data.get('explanation')?.toString() || '';
      const whatIsTrue = data.get('what_is_true')?.toString() || '';
      const whatIsFalse = data.get('what_is_false')?.toString() || '';
      const whatLacksContext = data.get('what_lacks_context')?.toString() || '';
      const whatIsNotProven = data.get('what_is_not_proven')?.toString() || '';
      const topicId = data.get('topic_id')?.toString() || '';
      const status = data.get('status')?.toString() || 'borrador';
      const claim = data.get('claim')?.toString() || '';
      const originPlatform = data.get('origin_platform')?.toString() || 'Manual';
      const originUrl = data.get('origin_url')?.toString() || '';

      if (title.trim()) {
        const id = `art-manual-${Date.now()}`;
        const slug = title.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').substring(0, 60);
        const category = topicId 
          ? (db.prepare("SELECT category FROM topics WHERE id = ?").get(topicId)?.category || 'General')
          : 'General';

        const originDate = data.get('origin_date')?.toString() || new Date().toISOString();
        db.prepare(`
          INSERT INTO articles (id, topic_id, slug, title, subtitle, claim, origin_platform, origin_url, origin_summary, category, verdict, confidence, summary, explanation, what_is_true, what_is_false, what_lacks_context, what_is_not_proven, status, human_review_required, published_at, origin_date, created_at, updated_at)
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, '', ?, ?, 'Alta', ?, ?, ?, ?, ?, ?, ?, 0, ?, ?, datetime('now'), datetime('now'))
        `).run(
          id, topicId || null, slug, title, subtitle, claim, originPlatform, originUrl,
          category, verdict, subtitle, explanation, whatIsTrue, whatIsFalse, whatLacksContext, whatIsNotProven,
          status, status === 'publicado' ? new Date().toISOString() : null, originDate
        );

        message = `✓ Nuevo análisis de desmentido "${title}" guardado correctamente en la base de datos.`;
        messageType = 'success';
      }
    }
    else if (action === 'create_topic') {
      const title = data.get('title')?.toString() || '';
      const category = data.get('category')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const verdictSummary = data.get('verdict_summary')?.toString() || '';
      const confidence = data.get('confidence')?.toString() || 'Alta';

      if (title.trim()) {
        const topicId = `t-${Date.now()}`;
        const slug = title.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').substring(0, 60);

        db.prepare(`
          INSERT INTO topics (id, slug, title, description, category, verdict_summary, confidence, status, created_at, updated_at)
          VALUES (?, ?, ?, ?, ?, ?, ?, 'activo', datetime('now'), datetime('now'))
        `).run(topicId, slug, title, description, category, verdictSummary, confidence);

        message = `✓ Nuevo expediente temático "${title}" creado con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'edit_topic') {
      const topicId = data.get('topic_id')?.toString() || '';
      const title = data.get('title')?.toString() || '';
      const category = data.get('category')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const verdictSummary = data.get('verdict_summary')?.toString() || '';
      const status = data.get('status')?.toString() || 'activo';
      const confidence = data.get('confidence')?.toString() || 'Alta';

      if (topicId && title.trim()) {
        db.prepare(`
          UPDATE topics 
          SET title = ?, category = ?, description = ?, verdict_summary = ?, status = ?, confidence = ?, updated_at = datetime('now')
          WHERE id = ?
        `).run(title, category, description, verdictSummary, status, confidence, topicId);

        message = `✓ Expediente temático "${title}" actualizado correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'create_claim') {
      const claim = data.get('claim')?.toString() || '';
      const platform = data.get('platform')?.toString() || 'Admin Manual';
      const url = data.get('url')?.toString() || '';

      if (claim.trim().length > 5) {
        const id = `manual-scraped-${Date.now()}`;
        db.prepare(`
          INSERT INTO scraped_items (id, platform, url, text, author_public_name, metrics_json, detected_claim, suggested_topic, virality_score, risk_score, status, created_at)
          VALUES (?, ?, ?, ?, 'Administrador', '{}', ?, 'General', 10.0, 8.0, 'pendiente', datetime('now'))
        `).run(id, platform, url, claim, claim);

        try {
          execSync('node scripts/ai-pipeline.js', { encoding: 'utf-8', env: process.env });
          execSync('node scripts/sync.js', { encoding: 'utf-8', env: process.env });
          execSync('npm run build', { encoding: 'utf-8', env: process.env });
          message = `✓ Reclamación procesada: desmentido por IA redactado e hilo publicado directamente en la web.`;
          messageType = 'success';
        } catch (e: any) {
          message = `⚠️ Reclamación insertada, pero falló la compilación inmediata: ${e.message}`;
          messageType = 'error';
        }
      }
    }
    else if (action === 'add_radar_source') {
      const platform = data.get('platform')?.toString() || '';
      const name = data.get('name')?.toString() || '';
      const urlOrId = data.get('url_or_id')?.toString() || '';

      if (platform && name && urlOrId) {
        const id = `source-${platform.toLowerCase()}-${Date.now()}`;
        db.prepare(`
          INSERT INTO radar_sources (id, platform, name, url_or_id, status, created_at)
          VALUES (?, ?, ?, ?, 'activo', datetime('now'))
        `).run(id, platform, name, urlOrId);

        message = `✓ Nueva fuente de radar "${name}" (${platform}) añadida con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_radar_source') {
      const sourceId = data.get('source_id')?.toString() || '';
      if (sourceId) {
        db.prepare("DELETE FROM radar_sources WHERE id = ?").run(sourceId);
        message = `✓ Fuente de radar eliminada correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'check_url') {
      const url = data.get('check_url')?.toString() || '';
      if (url.trim().length > 5) {
        try {
          urlCheckResult = await analyzeUrl(url);
          if (urlCheckResult.isAccessible) {
            message = `✅ URL verificada: ${urlCheckResult.platform} — "${(urlCheckResult.title || '').substring(0, 80)}"...`;
            messageType = 'success';
          } else {
            message = `⚠️ URL no accesible: ${urlCheckResult.error || 'Sin respuesta'}`;
            messageType = 'error';
          }
        } catch (err) {
          message = `❌ Error analizando URL: ${err.message}`;
          messageType = 'error';
        }
      } else {
        message = '❌ Introduce una URL válida para analizar.';
        messageType = 'error';
      }
    }
    else if (action === 'insert_checked_url') {
      const url = data.get('url')?.toString() || '';
      const platform = data.get('platform')?.toString() || 'Manual';
      const title = data.get('title')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const author = data.get('author')?.toString() || 'Editor';
      const topicId = data.get('topic_id')?.toString() || '';
      const imageUrl = data.get('imageUrl')?.toString() || '';

      if (url.trim().length > 5) {
        const id = `manual-url-${Date.now()}`;
        const topicTitle = topicId 
          ? (db.prepare("SELECT title FROM topics WHERE id = ?").get(topicId)?.title || 'General')
          : 'General';

        const metricsJson = JSON.stringify({ score: 100, comments: 0, imageUrl: imageUrl || null });

        db.prepare(`
          INSERT INTO scraped_items (id, platform, url, text, author_public_name, metrics_json, detected_claim, suggested_topic, virality_score, risk_score, status, created_at)
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, 10.0, 8.0, 'pendiente', datetime('now'))
        `).run(id, platform, url, `${title}\n\n${description}`, author, metricsJson, title || description.substring(0, 200), topicTitle);

        try {
          execSync('node scripts/ai-pipeline.js', { encoding: 'utf-8', env: process.env });
          execSync('node scripts/sync.js', { encoding: 'utf-8', env: process.env });
          execSync('npm run build', { encoding: 'utf-8', env: process.env });
          message = `✅ URL procesada: desmentido por IA redactado e hilo publicado directamente en la web.`;
          messageType = 'success';
        } catch (e: any) {
          message = `⚠️ URL insertada, pero falló la compilación inmediata: ${e.message}`;
          messageType = 'error';
        }
        urlCheckResult = null;
      }
    }
    else if (action === 'trigger_sync') {
      try {
        commandOutput = execSync('node scripts/sync.js', { encoding: 'utf-8', stdio: 'pipe' });
        message = `✓ Proceso de Sincronización y Reconstrucción completado con éxito.`;
        messageType = 'success';
      } catch (err: any) {
        commandOutput = err.stdout || err.message;
        message = `✗ Error ejecutando sincronización: ${err.message}`;
        messageType = 'error';
      }
    }
    else if (action === 'trigger_build') {
      try {
        commandOutput = execSync('npm run build', { encoding: 'utf-8', stdio: 'pipe' });
        message = `✓ Reconstrucción estática del portal finalizada con éxito.`;
        messageType = 'success';
      } catch (err: any) {
        commandOutput = err.stdout || err.message;
        message = `✗ Error compilando el portal: ${err.message}`;
        messageType = 'error';
      }
    }
    else if (action === 'trigger_radar') {
      try {
        commandOutput = execSync('node scripts/radar-cron.js', { encoding: 'utf-8', stdio: 'pipe' });
        message = `✓ Escaneo de radar completado con éxito.`;
        messageType = 'success';
      } catch (err: any) {
        commandOutput = err.stdout || err.message;
        message = `✗ Error en el radar: ${err.message}`;
        messageType = 'error';
      }
    }
    else if (action === 'trigger_ai') {
      try {
        commandOutput = execSync('node scripts/ai-pipeline.js', { encoding: 'utf-8', stdio: 'pipe' });
        message = `✓ Pipeline de IA completado. Nuevos borradores generados.`;
        messageType = 'success';
      } catch (err: any) {
        commandOutput = err.stdout || err.message;
        message = `✗ Error en la IA: ${err.message}`;
        messageType = 'error';
      }
    }
    else if (action === 'create_party') {
      const name = data.get('name')?.toString() || '';
      const leader = data.get('leader')?.toString() || '';
      const website = data.get('website')?.toString() || '';
      const ideology = data.get('ideology')?.toString() || '';

      if (name.trim()) {
        const id = `p-${Date.now()}`;
        const slug = name.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').substring(0, 50);
        db.prepare(`
          INSERT INTO parties (id, slug, name, ideology_summary, official_website, logo_url, current_leader, created_at, updated_at)
          VALUES (?, ?, ?, ?, ?, '', ?, datetime('now'), datetime('now'))
        `).run(id, slug, name, ideology, website, leader);
        message = `✓ Partido político "${name}" creado correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'edit_party') {
      const partyId = data.get('party_id')?.toString() || '';
      const name = data.get('name')?.toString() || '';
      const leader = data.get('leader')?.toString() || '';
      const website = data.get('website')?.toString() || '';
      const ideology = data.get('ideology')?.toString() || '';

      if (partyId && name.trim()) {
        db.prepare(`
          UPDATE parties 
          SET name = ?, current_leader = ?, official_website = ?, ideology_summary = ?, updated_at = datetime('now')
          WHERE id = ?
        `).run(name, leader, website, ideology, partyId);
        message = `✓ Partido político "${name}" actualizado con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_party') {
      const partyId = data.get('party_id')?.toString() || '';
      db.prepare("DELETE FROM parties WHERE id = ?").run(partyId);
      message = `✓ Partido político eliminado físicamente.`;
      messageType = 'success';
    }
    else if (action === 'create_measure') {
      const partyId = data.get('party_id')?.toString() || '';
      const area = data.get('area')?.toString() || '';
      const title = data.get('title')?.toString() || '';
      const originalText = data.get('original_text')?.toString() || '';
      const summary = data.get('summary')?.toString() || '';
      const impact = data.get('impact')?.toString() || '';
      const targets = data.get('targets')?.toString() || '';

      // Obtener o crear un programa electoral para este partido
      let programId = '';
      const existingProg = db.prepare("SELECT id FROM electoral_programs WHERE party_id = ?").get(partyId) as any;
      if (existingProg) {
        programId = existingProg.id;
      } else {
        programId = `prog-${Date.now()}`;
        db.prepare(`
          INSERT INTO electoral_programs (id, party_id, election_name, election_date, program_url, source_file_path, status, created_at, updated_at)
          VALUES (?, ?, 'Generales 2023', '2023-07-23', '', '', 'activo', datetime('now'), datetime('now'))
        `).run(programId, partyId);
      }

      if (partyId && title.trim() && summary.trim()) {
        const id = `meas-${Date.now()}`;
        db.prepare(`
          INSERT INTO policy_measures (id, program_id, party_id, area, title, original_text, plain_language_summary, possible_impact, target_groups, source_page, confidence, created_at)
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 1, 'Alta', datetime('now'))
        `).run(id, programId, partyId, area, title, originalText, summary, impact, targets);
        message = `✓ Propuesta de programa electoral creada con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'edit_measure') {
      const measureId = data.get('measure_id')?.toString() || '';
      const area = data.get('area')?.toString() || '';
      const title = data.get('title')?.toString() || '';
      const originalText = data.get('original_text')?.toString() || '';
      const summary = data.get('summary')?.toString() || '';
      const impact = data.get('impact')?.toString() || '';
      const targets = data.get('targets')?.toString() || '';

      if (measureId && title.trim() && summary.trim()) {
        db.prepare(`
          UPDATE policy_measures 
          SET area = ?, title = ?, original_text = ?, plain_language_summary = ?, possible_impact = ?, target_groups = ?
          WHERE id = ?
        `).run(area, title, originalText, summary, impact, targets, measureId);
        message = `✓ Propuesta electoral actualizada con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_measure') {
      const measureId = data.get('measure_id')?.toString() || '';
      db.prepare("DELETE FROM policy_measures WHERE id = ?").run(measureId);
      message = `✓ Propuesta electoral eliminada.`;
      messageType = 'success';
    }
    else if (action === 'create_promise') {
      const partyId = data.get('party_id')?.toString() || '';
      const measureId = data.get('measure_id')?.toString() || null;
      const text = data.get('promise_text')?.toString() || '';
      const govLevel = data.get('government_level')?.toString() || 'Estatal';
      const status = data.get('status')?.toString() || 'prometido';
      const actionTaken = data.get('action_taken')?.toString() || '';
      const evidenceUrl = data.get('evidence_url')?.toString() || '';
      const evidenceSummary = data.get('evidence_summary')?.toString() || '';

      if (partyId && text.trim()) {
        const id = `prom-${Date.now()}`;
        db.prepare(`
          INSERT INTO promise_tracking (id, party_id, measure_id, promise_text, government_level, was_in_government, action_taken, evidence_url, evidence_summary, status, notes, updated_at)
          VALUES (?, ?, ?, ?, ?, 1, ?, ?, ?, ?, '', datetime('now'))
        `).run(id, partyId, measureId || null, text, govLevel, actionTaken, evidenceUrl, evidenceSummary, status);
        message = `✓ Promesa y seguimiento creados con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'edit_promise') {
      const promiseId = data.get('promise_id')?.toString() || '';
      const text = data.get('promise_text')?.toString() || '';
      const govLevel = data.get('government_level')?.toString() || 'Estatal';
      const status = data.get('status')?.toString() || 'prometido';
      const actionTaken = data.get('action_taken')?.toString() || '';
      const evidenceUrl = data.get('evidence_url')?.toString() || '';
      const evidenceSummary = data.get('evidence_summary')?.toString() || '';

      if (promiseId && text.trim()) {
        db.prepare(`
          UPDATE promise_tracking 
          SET promise_text = ?, government_level = ?, status = ?, action_taken = ?, evidence_url = ?, evidence_summary = ?, updated_at = datetime('now')
          WHERE id = ?
        `).run(text, govLevel, status, actionTaken, evidenceUrl, evidenceSummary, promiseId);
        message = `✓ Promesa de seguimiento actualizada con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_promise') {
      const promiseId = data.get('promise_id')?.toString() || '';
      db.prepare("DELETE FROM promise_tracking WHERE id = ?").run(promiseId);
      message = `✓ Registro de promesa eliminado.`;
      messageType = 'success';
    }
    else if (action === 'create_declaration') {
      const partyId = data.get('party_id')?.toString() || '';
      const personName = data.get('person_name')?.toString() || '';
      const role = data.get('role')?.toString() || '';
      const sourceUrl = data.get('source_url')?.toString() || '';
      const assets = data.get('declared_assets_summary')?.toString() || '';
      const debts = data.get('declared_debts_summary')?.toString() || '';

      if (partyId && personName.trim() && role.trim()) {
        const id = `decl-${Date.now()}`;
        db.prepare(`
          INSERT INTO asset_declarations (id, party_id, person_name, role, source_url, declared_assets_summary, declared_debts_summary, date_declared, notes, created_at)
          VALUES (?, ?, ?, ?, ?, ?, ?, date('now'), '', datetime('now'))
        `).run(id, partyId, personName, role, sourceUrl, assets, debts);
        message = `✓ Declaración de bienes y patrimonio creada con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'edit_declaration') {
      const declarationId = data.get('declaration_id')?.toString() || '';
      const personName = data.get('person_name')?.toString() || '';
      const role = data.get('role')?.toString() || '';
      const sourceUrl = data.get('source_url')?.toString() || '';
      const assets = data.get('declared_assets_summary')?.toString() || '';
      const debts = data.get('declared_debts_summary')?.toString() || '';

      if (declarationId && personName.trim() && role.trim()) {
        db.prepare(`
          UPDATE asset_declarations 
          SET person_name = ?, role = ?, source_url = ?, declared_assets_summary = ?, declared_debts_summary = ?
          WHERE id = ?
        `).run(personName, role, sourceUrl, assets, debts, declarationId);
        message = `✓ Declaración de bienes actualizada correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_declaration') {
      const declarationId = data.get('declaration_id')?.toString() || '';
      db.prepare("DELETE FROM asset_declarations WHERE id = ?").run(declarationId);
      message = `✓ Declaración de bienes eliminada de la base de datos.`;
      messageType = 'success';
    }

    db.close();
  } catch (err) {
    console.error('Error procesando acción de administración:', err);
    message = `❌ Error: ${err.message}`;
    messageType = 'error';
  }
}

// Cargar datos para la vista
const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// 1. Artículos en estado borrador (Cola de Aprobación)
const draftArticles = db.prepare(`
  SELECT a.*, t.title as topic_title
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'borrador'
  ORDER BY a.created_at DESC
`).all() as any[];

const draftsWithDetails = draftArticles.map(art => {
  const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(art.id) as any[];
  const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(art.id) as any[];
  return { ...art, sources, socialPosts };
});

// 2. Artículos en estado publicado
const publishedArticles = db.prepare(`
  SELECT a.*, t.title as topic_title
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'publicado'
  ORDER BY a.published_at DESC
`).all() as any[];

const publishedWithDetails = publishedArticles.map(art => {
  const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(art.id) as any[];
  const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(art.id) as any[];
  return { ...art, sources, socialPosts };
});

// 3. Elementos del radar pendientes
const pendingRadarItems = db.prepare(`
  SELECT * FROM scraped_items 
  WHERE status = 'pendiente'
  ORDER BY created_at DESC
`).all() as any[];

// 4. Fuentes del radar
const radarSources = db.prepare("SELECT * FROM radar_sources ORDER BY platform, name").all() as any[];

// 5. Todos los temas (para administración)
const allTopics = db.prepare("SELECT * FROM topics ORDER BY title").all() as any[];

// 6. Temas activos para el selector de vinculación
const activeTopics = allTopics.filter(t => t.status === 'activo');

// 7. Cargar Partidos, Propuestas, Promesas y Declaraciones de Bienes para Auditoría Política
const allParties = db.prepare("SELECT * FROM parties ORDER BY name").all() as any[];
const allMeasures = db.prepare(`
  SELECT pm.*, p.name as party_name 
  FROM policy_measures pm
  LEFT JOIN parties p ON pm.party_id = p.id
  ORDER BY p.name, pm.area
`).all() as any[];
const allPromises = db.prepare(`
  SELECT pt.*, p.name as party_name, pm.title as measure_title
  FROM promise_tracking pt
  LEFT JOIN parties p ON pt.party_id = p.id
  LEFT JOIN policy_measures pm ON pt.measure_id = pm.id
  ORDER BY p.name, pt.promise_text
`).all() as any[];
const allDeclarations = db.prepare(`
  SELECT ad.*, p.name as party_name
  FROM asset_declarations ad
  LEFT JOIN parties p ON ad.party_id = p.id
  ORDER BY ad.person_name
`).all() as any[];

const verificationLogs = db.prepare("SELECT * FROM verification_logs ORDER BY created_at DESC").all() as any[];

db.close();

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = (verdict || '').toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};
---

<Layout title="Panel de Control Editorial y Radar">
  <div class="admin-container">
    
    <!-- CABECERA PREMIUM NEÓN -->
    <header class="admin-header">
      <div class="header-main">
        <h1>⚡ Portal <span class="text-gradient-blue">Control Center</span></h1>
        <p>Consola de verificación, editor de desmentidos y control del radar inteligente de IA.</p>
      </div>
      
      <!-- KPIs / Métricas del Sistema -->
      <div class="dashboard-kpis">
        <div class="kpi-card purple" data-tab="pane-aprobacion">
          <span class="kpi-val">{draftsWithDetails.length}</span>
          <span class="kpi-label">Borradores IA</span>
        </div>
        <div class="kpi-card blue" data-tab="pane-publicados">
          <span class="kpi-val">{publishedWithDetails.length}</span>
          <span class="kpi-label">Publicados</span>
        </div>
        <div class="kpi-card green" data-tab="pane-temas">
          <span class="kpi-val">{allTopics.length}</span>
          <span class="kpi-label">Expedientes</span>
        </div>
        <div class="kpi-card orange" data-tab="pane-radar">
          <span class="kpi-val">{radarSources.length}</span>
          <span class="kpi-label">Fuentes Radar</span>
        </div>
        <div class="kpi-card red" data-tab="pane-radar">
          <span class="kpi-val">{pendingRadarItems.length}</span>
          <span class="kpi-label">En la Cola</span>
        </div>
      </div>
    </header>

    <!-- Notificaciones del Servidor -->
    {message && (
      <div class={`toast-notification ${messageType}`}>
        <div class="toast-indicator"></div>
        <p>{message}</p>
      </div>
    )}

    <!-- MENÚ DE NAVEGACIÓN SPA INSTANTÁNEO -->
    <nav class="admin-tabs-nav">
      <button class="admin-tab-btn active" data-target="pane-dashboard">📊 Dashboard</button>
      <button class="admin-tab-btn" data-target="pane-aprobacion">📥 Cola Moderación ({draftsWithDetails.length})</button>
      <button class="admin-tab-btn" data-target="pane-redactor">✍️ Plantilla Redactor</button>
      <button class="admin-tab-btn" data-target="pane-publicados">📰 Publicados ({publishedWithDetails.length})</button>
      <button class="admin-tab-btn" data-target="pane-temas">📁 Expedientes</button>
      <button class="admin-tab-btn" data-target="pane-politica">🏛️ Auditoría Política</button>
      <button class="admin-tab-btn" data-target="pane-radar">📡 Radar & Scrapers</button>
      <button class="admin-tab-btn" data-target="pane-verificaciones">🔍 Logs de Búsqueda ({verificationLogs.length})</button>
    </nav>

    <!-- CONTENEDORES DE PANELES DE PESTAÑA -->
    <div class="admin-tab-panels">

      <!-- PESTAÑA 1: DASHBOARD & CONSOLA -->
      <div id="pane-dashboard" class="admin-tab-panel active">
        <div class="dashboard-grid">
          
          <!-- Controles de Procesos en Caliente -->
          <div class="cyber-card" style="padding: 1.5rem;">
            <h3 class="card-title">⚙️ Consola de Control de Procesos en Vivo</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.25rem;">
              Ejecuta los motores del portal manualmente y observa su flujo detallado en tiempo real (proveedor de IA, pasos de compilación, etc.).
            </p>
            <div class="console-actions" style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
              <button onclick="runAdminJob('cron')" class="cyber-btn accent" id="btn-job-cron" style="cursor: pointer; border-radius: 8px; font-weight: bold; font-size: 0.75rem; padding: 0.6rem 1rem;">📦 Ciclo Completo (Cron)</button>
              <button onclick="runAdminJob('radar')" class="cyber-btn" id="btn-job-radar" style="border-color: var(--neon-blue); color: var(--neon-blue); cursor: pointer; border-radius: 8px; font-weight: bold; font-size: 0.75rem; padding: 0.6rem 1rem;">📡 Iniciar Radar</button>
              <button onclick="runAdminJob('ai')" class="cyber-btn" id="btn-job-ai" style="border-color: var(--neon-rose); color: var(--neon-rose); cursor: pointer; border-radius: 8px; font-weight: bold; font-size: 0.75rem; padding: 0.6rem 1rem;">🤖 Iniciar IA (Borradores)</button>
              <button onclick="runAdminJob('sync')" class="cyber-btn" id="btn-job-sync" style="border-color: var(--neon-amber); color: var(--neon-amber); cursor: pointer; border-radius: 8px; font-weight: bold; font-size: 0.75rem; padding: 0.6rem 1rem;">🔄 Sincronizar DB</button>
              <button onclick="runAdminJob('build')" class="cyber-btn" id="btn-job-build" style="border-color: var(--neon-purple); color: var(--neon-purple); cursor: pointer; border-radius: 8px; font-weight: bold; font-size: 0.75rem; padding: 0.6rem 1rem;">🚀 Compilar Web</button>
            </div>
          </div>

          <!-- Estado del Scraper y Reglas de Negocio -->
          <div class="cyber-card" style="padding: 1.5rem;">
            <h3 class="card-title">🛡️ Estado de Salud del Scraper</h3>
            <div class="info-list">
              <div class="info-item">
                <span>Último escaneo general:</span>
                <strong style="color: var(--neon-green);">ÉXITO (Automático)</strong>
              </div>
              <div class="info-item">
                <span>Filtro de Temporalidad:</span>
                <strong style="color: var(--neon-blue);">24h (Actualidad) / 1 Año (Temas)</strong>
              </div>
              <div class="info-item">
                <span>Motor de Base de Datos:</span>
                <strong>SQLite Sync Engine</strong>
              </div>
            </div>
          </div>
        </div>

        <!-- Terminal Cyberpunk de Output en Vivo -->
        <div class="terminal-cyberpunk" id="admin-terminal" style="display: block; margin-top: 1.5rem;">
          <div class="terminal-header" style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 1rem;">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
              <span class="terminal-dot red"></span>
              <span class="terminal-dot yellow"></span>
              <span class="terminal-dot green"></span>
              <span class="terminal-title" id="terminal-job-title" style="font-family: monospace; font-size: 0.75rem; color: #a9b2c3;">TERMINAL@NEWNEWS:~$ listo para ejecutar</span>
            </div>
            <span id="terminal-status" style="color: var(--neon-green); font-family: monospace; font-size: 0.7rem; font-weight: bold;">IDLE</span>
          </div>
          <div class="terminal-body" id="admin-terminal-body" style="background: #05070e; max-height: 400px; overflow-y: auto; padding: 1.25rem; font-family: monospace; font-size: 0.75rem; color: #a9b2c3; line-height: 1.5; border-radius: 0 0 12px 12px; scroll-behavior: smooth; text-align: left; border-top: 1px solid rgba(255,255,255,0.05);">
            <div style="color: var(--text-muted);">> Selecciona un proceso arriba para ver sus logs de ejecución en vivo...</div>
          </div>
        </div>
      </div>

      <!-- PESTAÑA 2: COLA DE MODERACIÓN (BORRADORES DE LA IA) -->
      <div id="pane-aprobacion" class="admin-tab-panel">
        <h2 class="section-title">📥 Cola de Moderación: Borradores redactados por IA</h2>
        <div class="cards-list">
          {draftsWithDetails.map(art => (
            <div class={`cyber-card ${getVerdictClass(art.verdict)}`} style="padding: 1.5rem;">
              <div class="card-meta">
                <span class={`verdict-badge ${art.verdict.toLowerCase().replace(' ', '-')}`}>
                  Veredicto sugerido: {art.verdict}
                </span>
                <span style="font-size: 0.8rem;">Tema: <strong>{art.topic_title || 'General'}</strong></span>
                <span style="font-size: 0.8rem; color: var(--text-muted);">Confianza: {art.confidence || 'Media'}</span>
              </div>
              
              <div class="card-content">
                <h3 class="article-title">{art.title}</h3>
                <p class="article-subtitle">{art.subtitle}</p>
                <div class="claim-block">
                  <strong>Reclamación original:</strong> "{art.claim}"
                </div>
              </div>

              <!-- Formulario de Edición y Aprobación en Bloque -->
              <details class="accordion-edit">
                <summary>✏️ Editar y Aprobar Borrador</summary>
                <form method="POST" class="edit-form">
                  <input type="hidden" name="action" value="edit_article" />
                  <input type="hidden" name="article_id" value={art.id} />
                  
                  <div class="form-grid">
                    <div class="form-group">
                      <label>Título del Análisis:</label>
                      <input type="text" name="title" value={art.title} required class="edit-input" />
                    </div>
                    <div class="form-group">
                      <label>Veredicto Oficial:</label>
                      <select name="verdict" class="edit-input">
                        <option value="Falso" selected={art.verdict === 'Falso'}>Falso</option>
                        <option value="Verdadero" selected={art.verdict === 'Verdadero'}>Verdadero</option>
                        <option value="Engañoso" selected={art.verdict === 'Engañoso'}>Engañoso</option>
                        <option value="Falta contexto" selected={art.verdict === 'Falta contexto'}>Falta contexto</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-group">
                    <label>Subtítulo / Copete didáctico:</label>
                    <input type="text" name="subtitle" value={art.subtitle} required class="edit-input" />
                  </div>

                  <div class="form-group">
                    <label>Explicación Detallada (Leyes/Datos oficiales):</label>
                    <textarea name="explanation" rows="5" required class="edit-input">{art.explanation}</textarea>
                  </div>

                  <div class="form-grid-4">
                    <div class="form-group">
                      <label>¿Qué es Verdad? (Cifras):</label>
                      <textarea name="what_is_true" rows="2" class="edit-input">{art.what_is_true}</textarea>
                    </div>
                    <div class="form-group">
                      <label>¿Qué es Bulo / Mentira?:</label>
                      <textarea name="what_is_false" rows="2" class="edit-input">{art.what_is_false}</textarea>
                    </div>
                    <div class="form-group">
                      <label>¿Qué falta de contexto?:</label>
                      <textarea name="what_lacks_context" rows="2" class="edit-input">{art.what_lacks_context}</textarea>
                    </div>
                    <div class="form-group">
                      <label>¿Qué no está probado?:</label>
                      <textarea name="what_is_not_proven" rows="2" class="edit-input">{art.what_is_not_proven}</textarea>
                    </div>
                  </div>

                  <div class="form-grid">
                    <div class="form-group">
                      <label>Expediente Asociado:</label>
                      <select name="topic_id" class="edit-input">
                        <option value="">— Ninguno (Noticia Suelta) —</option>
                        {activeTopics.map(t => (
                          <option value={t.id} selected={art.topic_id === t.id}>[{t.category}] {t.title}</option>
                        ))}
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Estado de publicación:</label>
                      <select name="status" class="edit-input">
                        <option value="borrador" selected>Mantener Borrador</option>
                        <option value="publicado">Publicar en Vivo</option>
                      </select>
                    </div>
                  </div>

                  <div class="form-actions">
                    <button type="submit" class="cyber-btn accent" style="width: 100%;">💾 Guardar y Publicar en Web</button>
                  </div>
                </form>
              </details>
            </div>
          ))}
          {draftsWithDetails.length === 0 && (
            <p class="empty-state">No hay borradores pendientes en la cola.</p>
          )}
        </div>
      </div>

      <!-- PESTAÑA 3: ASISTENTE REDACTOR (PLANTILLA FACT-CHECKING CON PREVISUALIZACIÓN EN VIVO) -->
      <div id="pane-redactor" class="admin-tab-panel">
        <h2 class="section-title">✍️ Asistente de Fact-Checking (Plantilla Homogénea)</h2>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start;" class="redactor-split-grid">
          
          <!-- Columna Formulario -->
          <div class="cyber-card" style="padding: 1.5rem;">
            <form method="POST" class="edit-form" id="redactor-form">
              <input type="hidden" name="action" value="create_article" />
              <input type="hidden" name="status" value="publicado" />
              
              <div class="template-instructions" style="background: rgba(0, 240, 255, 0.05); border: 1px solid rgba(0, 240, 255, 0.15); padding: 0.85rem; border-radius: 8px; margin-bottom: 1.25rem; font-size: 0.8rem;">
                <strong>💡 INSTRUCCIONES EDITORIALES:</strong>
                <p style="margin: 0.25rem 0 0 0; line-height: 1.4; color: var(--text-muted);">
                  Divide la redacción de forma estructurada. Usa datos numéricos oficiales (BOE/INE) y comprueba el veredicto. A la derecha verás cómo se maquetará en la web en caliente.
                </p>
              </div>

              <div class="form-grid">
                <div class="form-group">
                  <label>Título del Análisis (Directo e Impactante):</label>
                  <input type="text" id="inp-title" name="title" required placeholder="Ej: ¿Reciben los menores extranjeros una paga de 4.200€ al mes?" class="edit-input" />
                </div>
                <div class="form-group">
                  <label>Veredicto Oficial:</label>
                  <select id="inp-verdict" name="verdict" class="edit-input" required style="border-color: var(--neon-rose);">
                    <option value="Falso" selected>🔴 Falso (Bulo directo)</option>
                    <option value="Engañoso">🟡 Engañoso / Sesgado</option>
                    <option value="Falta contexto">🔵 Falta Contexto</option>
                    <option value="Verdadero">🟢 Verdadero / Verificado</option>
                  </select>
                </div>
              </div>

              <div class="form-group">
                <label>Subtítulo o Resumen Corto (Para jóvenes):</label>
                <input type="text" id="inp-subtitle" name="subtitle" required placeholder="Resumen rápido de por qué es falso o qué ley lo regula..." class="edit-input" />
              </div>

              <div class="form-group">
                <label>La Afirmación Viral / Claim Original:</label>
                <input type="text" id="inp-claim" name="claim" required placeholder="Ej: 'El gobierno le da 4.200 euros en metálico al mes a cada MENA'" class="edit-input" />
              </div>

              <div class="form-grid-3" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                <div class="form-group">
                  <label>Red Social / Origen:</label>
                  <input type="text" id="inp-platform" name="origin_platform" placeholder="X (Twitter), TikTok, YouTube, Telegram..." class="edit-input" />
                </div>
                <div class="form-group">
                  <label>Enlace al post original (URL real):</label>
                  <input type="url" id="inp-url" name="origin_url" placeholder="https://x.com/user/status/123" class="edit-input" />
                </div>
                <div class="form-group">
                  <label>Fecha de Publicación Original:</label>
                  <input type="datetime-local" id="inp-origdate" name="origin_date" class="edit-input" />
                </div>
              </div>

              <div class="form-group">
                <label>Explicación y Datos Contrastados (INE/BOE):</label>
                <textarea id="inp-explanation" name="explanation" rows="6" required placeholder="Redacta la argumentación citando fuentes del BOE o del INE. Recuerda citar el artículo exacto de la ley." class="edit-input"></textarea>
              </div>

              <!-- Ficha didáctica estructurada -->
              <h3 class="sub-form-title">📋 Ficha de Análisis Rápido (Desglose Didáctico)</h3>
              <div class="form-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="form-group">
                  <label>¿Qué es Verdad? (Cifras/Leyes):</label>
                  <textarea id="inp-true" name="what_is_true" rows="2" required placeholder="Qué parte de la noticia sí tiene base real..." class="edit-input"></textarea>
                </div>
                <div class="form-group">
                  <label>¿Qué es Mentira / Bulo?:</label>
                  <textarea id="inp-false" name="what_is_false" rows="2" required placeholder="Lo falso, descontextualizado o manipulado..." class="edit-input"></textarea>
                </div>
                <div class="form-group">
                  <label>¿Qué falta contextualizar?:</label>
                  <textarea id="inp-lacks" name="what_lacks_context" rows="2" placeholder="Información crucial omitida..." class="edit-input"></textarea>
                </div>
                <div class="form-group">
                  <label>¿Qué no está probado?:</label>
                  <textarea id="inp-unproven" name="what_is_not_proven" rows="2" placeholder="Rumores o especulaciones sin evidencias..." class="edit-input"></textarea>
                </div>
              </div>

              <div class="form-group">
                <label>Vincular a un Expediente Temático (Dossier):</label>
                <select name="topic_id" class="edit-input" required>
                  <option value="">— Ninguno (Noticia suelta de actualidad) —</option>
                  {activeTopics.map(t => (
                    <option value={t.id}>[{t.category}] {t.title}</option>
                  ))}
                </select>
              </div>

              <button type="submit" class="cyber-btn accent" style="width: 100%; font-weight: 800; margin-top: 1rem; padding: 0.85rem;">
                🚀 Publicar Análisis en el Portal
              </button>
            </form>
          </div>

          <!-- Columna Previsualización Reactiva -->
          <div class="cyber-card" style="padding: 1.5rem; position: sticky; top: 90px; max-height: calc(100vh - 120px); overflow-y: auto; border-color: var(--neon-purple);">
            <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.25rem;">
              <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-purple); font-size: 0.75rem; letter-spacing: 0.05em;">👁️ Previsualización en Vivo</span>
              <span style="font-size: 0.7rem; background: rgba(157, 78, 221, 0.1); color: var(--neon-purple); padding: 0.15rem 0.4rem; border-radius: 4px; font-weight: bold;">Mobile-First Mockup</span>
            </div>

            <!-- Cabecera de la noticia -->
            <div style="margin-bottom: 1.5rem;">
              <h1 id="prev-title" style="font-size: 1.5rem; line-height: 1.2; font-weight: 800; color: var(--text-main); margin-bottom: 0.5rem;">
                [Título del Análisis]
              </h1>
              <p id="prev-subtitle" style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; margin: 0;">
                [Subtítulo explicativo del análisis]
              </p>
            </div>

            <!-- Caja del veredicto -->
            <div id="prev-verdict-box" class="cyber-card rose" style="padding: 1rem; margin-bottom: 1.5rem; background: linear-gradient(180deg, rgba(18, 22, 41, 0.8) 0%, rgba(7, 9, 19, 0.95) 100%);">
              <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                <span style="font-size: 0.65rem; text-transform: uppercase; color: var(--text-muted); font-weight: 800;">Veredicto</span>
                <span id="prev-verdict-badge" class="verdict-badge falso" style="font-size: 0.8rem; padding: 0.25rem 0.65rem;">Falso</span>
              </div>
              <p id="prev-verdict-text" style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; margin: 0;">
                El sistema de seguros sociales en España es fruto de una evolución de más de un siglo...
              </p>
            </div>

            <!-- Embed simulado interactivo -->
            <div id="prev-embed-container" class="cyber-card" style="padding: 1rem; background: rgba(0,0,0,0.25); border-color: rgba(255,255,255,0.05); margin-bottom: 1.5rem;">
              <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.65rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">Publicación Viral de Origen</span>
              
              <!-- Tarjeta / Link del post original -->
              <div id="prev-embed-mockup" style="background: rgba(10, 15, 30, 0.6); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.85rem; margin-bottom: 0.75rem;">
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
                  <span id="prev-embed-icon" style="font-size: 1rem;">🔗</span>
                  <span id="prev-embed-platform" style="font-weight: bold; font-size: 0.8rem; color: #fff;">X (Twitter)</span>
                </div>
                <p id="prev-embed-claim" style="font-size: 0.85rem; font-style: italic; color: #e2e8f0; line-height: 1.4; margin: 0; border-left: 2px solid var(--neon-rose); padding-left: 0.5rem;">
                  "[Texto de la afirmación viral]"
                </p>
              </div>

              <div id="prev-embed-hint" style="font-size: 0.7rem; color: var(--text-muted); text-align: center;">
                El enlace incrustará un widget interactivo oficial de la red social en el portal de producción.
              </div>
            </div>

            <!-- Ficha didáctica desglosada -->
            <div class="cyber-card" style="padding: 1rem; border-color: rgba(255,255,255,0.05);">
              <h4 style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-main); margin-bottom: 0.75rem; font-weight: 800;">Detalles de la Contrastación</h4>
              <div style="display: flex; flex-direction: column; gap: 0.75rem; font-size: 0.8rem;">
                <div style="border-left: 2px solid var(--neon-green); padding-left: 0.5rem;">
                  <strong style="color: var(--neon-green); display: block; font-size: 0.7rem; text-transform: uppercase;">¿Qué es verdad?</strong>
                  <span id="prev-detail-true" style="color: var(--text-muted);">[Escribe datos que sean correctos]</span>
                </div>
                <div style="border-left: 2px solid var(--neon-rose); padding-left: 0.5rem;">
                  <strong style="color: var(--neon-rose); display: block; font-size: 0.7rem; text-transform: uppercase;">¿Qué es mentira?</strong>
                  <span id="prev-detail-false" style="color: var(--text-muted);">[Escribe datos falsificados desmentidos]</span>
                </div>
                <div style="border-left: 2px solid var(--neon-amber); padding-left: 0.5rem;">
                  <strong style="color: var(--neon-amber); display: block; font-size: 0.7rem; text-transform: uppercase;">¿Falta contexto?</strong>
                  <span id="prev-detail-lacks" style="color: var(--text-muted);">[Contexto legal omitido]</span>
                </div>
                <div style="border-left: 2px solid var(--neon-purple); padding-left: 0.5rem;">
                  <strong style="color: var(--neon-purple); display: block; font-size: 0.7rem; text-transform: uppercase;">¿No está probado?</strong>
                  <span id="prev-detail-unproven" style="color: var(--text-muted);">[Aseveraciones sin verificar]</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- PESTAÑA 4: NOTICIAS PUBLICADAS (HISTÓRICO) -->
      <div id="pane-publicados" class="admin-tab-panel">
        <h2 class="section-title">📰 Histórico de Noticias Publicadas en Vivo</h2>
        <div class="cards-list">
          {publishedWithDetails.map(art => (
            <div class={`cyber-card ${getVerdictClass(art.verdict)}`} style="padding: 1.5rem;">
              <div class="card-meta">
                <span class={`verdict-badge ${art.verdict.toLowerCase().replace(' ', '-')}`}>{art.verdict}</span>
                <span style="font-size: 0.8rem;">Dossier: <strong>{art.topic_title || 'General'}</strong></span>
                <span style="font-size: 0.8rem; color: var(--text-muted);">Publicado: {new Date(art.published_at || art.created_at).toLocaleDateString('es-ES')}</span>
              </div>
              
              <div class="card-content">
                <h3 class="article-title">{art.title}</h3>
                <p class="article-subtitle">{art.subtitle}</p>
              </div>

              <div class="row-actions">
                <details class="accordion-edit">
                  <summary>✏️ Editar Contenido</summary>
                  <form method="POST" class="edit-form" style="margin-top: 1rem;">
                    <input type="hidden" name="action" value="edit_article" />
                    <input type="hidden" name="article_id" value={art.id} />
                    
                    <div class="form-grid">
                      <div class="form-group">
                        <label>Título:</label>
                        <input type="text" name="title" value={art.title} required class="edit-input" />
                      </div>
                      <div class="form-group">
                        <label>Veredicto:</label>
                        <select name="verdict" class="edit-input">
                          <option value="Falso" selected={art.verdict === 'Falso'}>Falso</option>
                          <option value="Verdadero" selected={art.verdict === 'Verdadero'}>Verdadero</option>
                          <option value="Engañoso" selected={art.verdict === 'Engañoso'}>Engañoso</option>
                          <option value="Falta contexto" selected={art.verdict === 'Falta contexto'}>Falta contexto</option>
                        </select>
                      </div>
                    </div>

                    <div class="form-group">
                      <label>Subtítulo:</label>
                      <input type="text" name="subtitle" value={art.subtitle} required class="edit-input" />
                    </div>

                    <div class="form-group">
                      <label>Explicación:</label>
                      <textarea name="explanation" rows="6" required class="edit-input">{art.explanation}</textarea>
                    </div>

                    <div class="form-grid-4">
                      <div class="form-group">
                        <label>¿Qué es Verdad?:</label>
                        <textarea name="what_is_true" rows="2" class="edit-input">{art.what_is_true}</textarea>
                      </div>
                      <div class="form-group">
                        <label>¿Qué es Mentira?:</label>
                        <textarea name="what_is_false" rows="2" class="edit-input">{art.what_is_false}</textarea>
                      </div>
                      <div class="form-group">
                        <label>¿Qué falta de contexto?:</label>
                        <textarea name="what_lacks_context" rows="2" class="edit-input">{art.what_lacks_context}</textarea>
                      </div>
                      <div class="form-group">
                        <label>¿Qué no está probado?:</label>
                        <textarea name="what_is_not_proven" rows="2" class="edit-input">{art.what_is_not_proven}</textarea>
                      </div>
                    </div>

                    <div class="form-grid-3" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                      <div class="form-group">
                        <label>Expediente:</label>
                        <select name="topic_id" class="edit-input">
                          <option value="">— Ninguno —</option>
                          {activeTopics.map(t => (
                            <option value={t.id} selected={art.topic_id === t.id}>[{t.category}] {t.title}</option>
                          ))}
                        </select>
                      </div>
                      <div class="form-group">
                        <label>Estado:</label>
                        <select name="status" class="edit-input">
                          <option value="publicado" selected={art.status === 'publicado'}>Publicado (Visible)</option>
                          <option value="borrador" selected={art.status === 'borrador'}>Despublicar (Ocultar)</option>
                        </select>
                      </div>
                      <div class="form-group">
                        <label>Fecha de Publicación Original:</label>
                        <input type="datetime-local" name="origin_date" value={art.origin_date ? art.origin_date.replace(' ', 'T').substring(0, 16) : ''} class="edit-input" />
                      </div>
                    </div>

                    <button type="submit" class="cyber-btn accent" style="width: 100%;">💾 Guardar Cambios</button>
                  </form>
                </details>

                <form method="POST" style="margin: 0;" onsubmit="return confirm('¿Seguro que deseas eliminar definitivamente este desmentido?')">
                  <input type="hidden" name="action" value="delete_article" />
                  <input type="hidden" name="article_id" value={art.id} />
                  <button type="submit" class="cyber-btn" style="border-color: var(--neon-rose); color: var(--neon-rose); padding: 0.35rem 0.75rem;">🗑️ Eliminar</button>
                </form>
              </div>
            </div>
          ))}
          {publishedWithDetails.length === 0 && (
            <p class="empty-state">No hay noticias publicadas todavía.</p>
          )}
        </div>
      </div>

      <!-- PESTAÑA 5: EXPEDIENTES TEMÁTICOS (DOSSIERS) -->
      <div id="pane-temas" class="admin-tab-panel">
        <h2 class="section-title">📁 Gestión de Expedientes Temáticos (Dossiers)</h2>
        
        <!-- Crear nuevo tema -->
        <div class="cyber-card" style="padding: 1.5rem; margin-bottom: 2rem; border-color: var(--neon-purple);">
          <h3 class="card-title">📁 Registrar Nuevo Expediente</h3>
          <form method="POST" class="edit-form">
            <input type="hidden" name="action" value="create_topic" />
            
            <div class="form-grid">
              <div class="form-group">
                <label>Título del Expediente:</label>
                <input type="text" name="title" required placeholder="Ej: Ley de Amnistía y Procés" class="edit-input" />
              </div>
              <div class="form-group">
                <label>Categoría (Área):</label>
                <input type="text" name="category" required placeholder="Ej: Política" class="edit-input" />
              </div>
              <div class="form-group">
                <label>Grado de Confianza:</label>
                <select name="confidence" class="edit-input">
                  <option value="Alta">Alta</option>
                  <option value="Media">Media</option>
                  <option value="Baja">Baja</option>
                  <option value="Oficial">Oficial</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label>Descripción del Dossier (Público):</label>
              <textarea name="description" rows="3" required placeholder="Explica resumidamente el marco de investigación del expediente..." class="edit-input"></textarea>
            </div>

            <div class="form-group">
              <label>Resumen del Veredicto General:</label>
              <input type="text" name="verdict_summary" required placeholder="Ej: Falso que la amnistía sea inconstitucional según la UE..." class="edit-input" />
            </div>

            <button type="submit" class="cyber-btn" style="border-color: var(--neon-purple); color: var(--neon-purple); width: 100%;">+ Registrar Expediente</button>
          </form>
        </div>

        <!-- Listado de temas -->
        <div class="cards-list">
          {allTopics.map(topic => (
            <div class="cyber-card" style="padding: 1.5rem;">
              <div class="card-meta">
                <span style="font-size: 0.7rem; font-weight: bold; background: rgba(255,255,255,0.05); padding: 0.15rem 0.4rem; color: var(--neon-blue); border-radius: 3px;">{topic.category}</span>
                <strong style="font-size: 1.1rem; color: var(--text-main);">{topic.title}</strong>
                <span style="font-size: 0.75rem; color: var(--text-muted);">Estado: {topic.status}</span>
              </div>
              <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; margin: 0.5rem 0;">{topic.description}</p>
              
              <details class="accordion-edit">
                <summary>✏️ Editar Expediente</summary>
                <form method="POST" class="edit-form" style="margin-top: 1rem;">
                  <input type="hidden" name="action" value="edit_topic" />
                  <input type="hidden" name="topic_id" value={topic.id} />
                  
                  <div class="form-grid">
                    <div class="form-group">
                      <label>Título:</label>
                      <input type="text" name="title" value={topic.title} required class="edit-input" />
                    </div>
                    <div class="form-group">
                      <label>Categoría:</label>
                      <input type="text" name="category" value={topic.category} required class="edit-input" />
                    </div>
                  </div>

                  <div class="form-group">
                    <label>Descripción:</label>
                    <textarea name="description" rows="3" required class="edit-input">{topic.description}</textarea>
                  </div>

                  <div class="form-group">
                    <label>Resumen de Veredictos:</label>
                    <input type="text" name="verdict_summary" value={topic.verdict_summary || ''} required class="edit-input" />
                  </div>

                  <div class="form-grid">
                    <div class="form-group">
                      <label>Estado:</label>
                      <select name="status" class="edit-input">
                        <option value="activo" selected={topic.status === 'activo'}>Activo</option>
                        <option value="pausado" selected={topic.status === 'pausado'}>Pausado</option>
                      </select>
                    </div>
                    <div class="form-group">
                      <label>Confianza:</label>
                      <select name="confidence" class="edit-input">
                        <option value="Alta" selected={topic.confidence === 'Alta'}>Alta</option>
                        <option value="Media" selected={topic.confidence === 'Media'}>Media</option>
                        <option value="Baja" selected={topic.confidence === 'Baja'}>Baja</option>
                        <option value="Oficial" selected={topic.confidence === 'Oficial'}>Oficial</option>
                      </select>
                    </div>
                  </div>

                  <button type="submit" class="cyber-btn" style="border-color: var(--neon-purple); color: var(--neon-purple); width: 100%;">💾 Guardar Cambios</button>
                </form>
              </details>
            </div>
          ))}
        </div>
      </div>

      <!-- PESTAÑA 6: AUDITORÍA POLÍTICA -->
      <div id="pane-politica" class="admin-tab-panel">
        <h2 class="section-title">🏛️ Auditoría Política: Partidos, Propuestas y Bienes</h2>
        
        <!-- Partidos -->
        <div class="cyber-card" style="padding: 1.5rem; margin-bottom: 2rem;">
          <h3 class="card-title">🏛️ Partidos Registrados ({allParties.length})</h3>
          
          <details class="accordion-edit" style="margin-bottom: 1rem;">
            <summary>+ Añadir Partido Político</summary>
            <form method="POST" class="edit-form" style="margin-top: 1rem;">
              <input type="hidden" name="action" value="create_party" />
              <div class="form-grid">
                <div class="form-group">
                  <label>Nombre:</label>
                  <input type="text" name="name" required placeholder="Ej: PSOE" class="edit-input" />
                </div>
                <div class="form-group">
                  <label>Líder:</label>
                  <input type="text" name="leader" required placeholder="Ej: Pedro Sánchez" class="edit-input" />
                </div>
              </div>
              <div class="form-grid">
                <div class="form-group">
                  <label>Web Oficial:</label>
                  <input type="url" name="website" placeholder="https://..." class="edit-input" />
                </div>
                <div class="form-group">
                  <label>Resumen Ideológico:</label>
                  <input type="text" name="ideology" placeholder="Socialdemocracia, Federalismo..." class="edit-input" />
                </div>
              </div>
              <button type="submit" class="cyber-btn accent" style="width: 100%;">Guardar Partido</button>
            </form>
          </details>

          <div class="table-container">
            {allParties.map(p => (
              <div class="table-row">
                <div>
                  <strong>{p.name}</strong> - <span style="font-size: 0.8rem; color: var(--text-muted);">Líder: {p.current_leader}</span>
                </div>
                <form method="POST" style="margin: 0;" onsubmit="return confirm('¿Eliminar partido?')">
                  <input type="hidden" name="action" value="delete_party" />
                  <input type="hidden" name="party_id" value={p.id} />
                  <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer;">🗑️</button>
                </form>
              </div>
            ))}
          </div>
        </div>

        <!-- Propuestas y Medidas -->
        <div class="cyber-card" style="padding: 1.5rem; margin-bottom: 2rem;">
          <h3 class="card-title">📋 Medidas de Programas Electorales ({allMeasures.length})</h3>
          
          <details class="accordion-edit" style="margin-bottom: 1rem;">
            <summary>+ Registrar Nueva Propuesta</summary>
            <form method="POST" class="edit-form" style="margin-top: 1rem;">
              <input type="hidden" name="action" value="create_measure" />
              <div class="form-grid">
                <div class="form-group">
                  <label>Partido Promotor:</label>
                  <select name="party_id" required class="edit-input">
                    {allParties.map(p => <option value={p.id}>{p.name}</option>)}
                  </select>
                </div>
                <div class="form-group">
                  <label>Área Temática:</label>
                  <input type="text" name="area" required placeholder="Ej: Vivienda" class="edit-input" />
                </div>
              </div>
              <div class="form-group">
                <label>Título Corto:</label>
                <input type="text" name="title" required placeholder="Ej: Construcción de 20.000 viviendas públicas..." class="edit-input" />
              </div>
              <div class="form-group">
                <label>Resumen Sencillo (Plain Language):</label>
                <textarea name="summary" rows="3" required placeholder="Qué significa esta propuesta en un lenguaje sencillo..." class="edit-input"></textarea>
              </div>
              <div class="form-grid">
                <div class="form-group">
                  <label>Impacto Estimado:</label>
                  <textarea name="impact" rows="2" class="edit-input"></textarea>
                </div>
                <div class="form-group">
                  <label>Colectivos Beneficiados:</label>
                  <textarea name="targets" rows="2" class="edit-input"></textarea>
                </div>
              </div>
              <div class="form-group">
                <label>Texto Original:</label>
                <textarea name="original_text" rows="2" class="edit-input"></textarea>
              </div>
              <button type="submit" class="cyber-btn" style="border-color: var(--neon-blue); color: var(--neon-blue); width: 100%;">Guardar Propuesta</button>
            </form>
          </details>

          <div class="scroller-list" style="max-height: 250px; overflow-y: auto;">
            {allMeasures.map(m => (
              <div class="scroller-item">
                <div style="display: flex; justify-content: space-between; font-size: 0.8rem; margin-bottom: 0.25rem;">
                  <span style="color: var(--neon-purple); font-weight: bold;">{m.party_name} ({m.area})</span>
                  <form method="POST" style="margin:0;">
                    <input type="hidden" name="action" value="delete_measure" />
                    <input type="hidden" name="measure_id" value={m.id} />
                    <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.8rem;">🗑️</button>
                  </form>
                </div>
                <strong>{m.title}</strong>
              </div>
            ))}
          </div>
        </div>

        <!-- Promesas -->
        <div class="cyber-card" style="padding: 1.5rem; margin-bottom: 2rem;">
          <h3 class="card-title">📈 Seguimiento de Promesas Electorales ({allPromises.length})</h3>
          <details class="accordion-edit" style="margin-bottom: 1rem;">
            <summary>+ Registrar Seguimiento de Promesa</summary>
            <form method="POST" class="edit-form" style="margin-top: 1rem;">
              <input type="hidden" name="action" value="create_promise" />
              <div class="form-grid">
                <div class="form-group">
                  <label>Partido Responsable:</label>
                  <select name="party_id" required class="edit-input">
                    {allParties.map(p => <option value={p.id}>{p.name}</option>)}
                  </select>
                </div>
                <div class="form-group">
                  <label>Vincular a Medida (Opcional):</label>
                  <select name="measure_id" class="edit-input">
                    <option value="">— Ninguna —</option>
                    {allMeasures.map(m => <option value={m.id}>[{m.party_name}] {m.title.substring(0, 45)}...</option>)}
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label>Texto de la Promesa:</label>
                <input type="text" name="promise_text" required placeholder="Ej: Reducir la jornada laboral a 37.5 horas" class="edit-input" />
              </div>
              <div class="form-grid">
                <div class="form-group">
                  <label>Nivel de Gob.:</label>
                  <select name="government_level" class="edit-input">
                    <option value="Estatal">Estatal</option>
                    <option value="Autonómico">Autonómico</option>
                    <option value="Municipal">Municipal</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Estado de Cumplimiento:</label>
                  <select name="status" class="edit-input">
                    <option value="prometido">Prometido</option>
                    <option value="en_progreso">En Progreso</option>
                    <option value="cumplido">Cumplido ✓</option>
                    <option value="incumplido">Incumplido ✗</option>
                  </select>
                </div>
              </div>
              <div class="form-group">
                <label>Acción tomada:</label>
                <textarea name="action_taken" rows="2" class="edit-input"></textarea>
              </div>
              <button type="submit" class="cyber-btn" style="border-color: var(--neon-green); color: var(--neon-green); width: 100%;">Guardar Promesa</button>
            </form>
          </details>
        </div>

        <!-- Declaraciones de Bienes -->
        <div class="cyber-card" style="padding: 1.5rem;">
          <h3 class="card-title">💼 Declaraciones de Bienes y Patrimonio ({allDeclarations.length})</h3>
          <details class="accordion-edit" style="margin-bottom: 1rem;">
            <summary>+ Registrar Declaración de Patrimonio</summary>
            <form method="POST" class="edit-form" style="margin-top: 1rem;">
              <input type="hidden" name="action" value="create_declaration" />
              <div class="form-grid">
                <div class="form-group">
                  <label>Partido Político:</label>
                  <select name="party_id" required class="edit-input">
                    {allParties.map(p => <option value={p.id}>{p.name}</option>)}
                  </select>
                </div>
                <div class="form-group">
                  <label>Nombre del Político:</label>
                  <input type="text" name="person_name" required placeholder="Ej: Pedro Sánchez" class="edit-input" />
                </div>
              </div>
              <div class="form-group">
                <label>Cargo / Rol:</label>
                <input type="text" name="role" required placeholder="Ej: Diputado y Presidente..." class="edit-input" />
              </div>
              <div class="form-grid">
                <div class="form-group">
                  <label>Bienes / Activos Declarados:</label>
                  <textarea name="declared_assets_summary" rows="3" required placeholder="Viviendas, cuentas corrientes..." class="edit-input"></textarea>
                </div>
                <div class="form-group">
                  <label>Deudas / Pasivos:</label>
                  <textarea name="declared_debts_summary" rows="3" placeholder="Créditos hipotecarios..." class="edit-input"></textarea>
                </div>
              </div>
              <button type="submit" class="cyber-btn accent" style="width: 100%;">Guardar Declaración</button>
            </form>
          </details>
        </div>
      </div>

      <!-- PESTAÑA 7: RADAR & SCRAPERS -->
      <div id="pane-radar" class="admin-tab-panel">
        <h2 class="section-title">📡 Radar & Scrapers de Monitoreo</h2>
        
        <div class="radar-split">
          
          <!-- Columna Izquierda: Comprobador de URL y Cola del Radar -->
          <div class="radar-col">
            
            <!-- Comprobador en vivo -->
            <div class="cyber-card" style="padding: 1.5rem; border-color: var(--neon-blue);">
              <h3 class="card-title">🔍 Comprobador de URL en Vivo</h3>
              <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1rem;">
                Pega la URL de una red (TikTok, X, Telegram). El sistema simulará el acceso y extraerá datos del post.
              </p>
              <form method="POST" class="edit-form">
                <input type="hidden" name="action" value="check_url" />
                <input type="url" name="check_url" required placeholder="https://youtube.com/... o t.me/canal/123" class="edit-input" style="margin-bottom: 0.75rem;" />
                <button type="submit" class="cyber-btn" style="border-color: var(--neon-blue); color: var(--neon-blue); width: 100%;">⚡ Verificar URL en Vivo</button>
              </form>

              {urlCheckResult && urlCheckResult.isAccessible && (
                <div class="url-result-box">
                  <span class="result-title">✅ Datos de URL Extraídos</span>
                  <div style="font-size: 0.8rem; display: flex; flex-direction: column; gap: 0.35rem; margin-top: 0.5rem;">
                    <div>Plataforma: <strong>{urlCheckResult.platform}</strong></div>
                    <div>Autor: <strong>{urlCheckResult.author}</strong></div>
                    {urlCheckResult.views !== undefined && urlCheckResult.views > 0 && (
                      <div>Visualizaciones: <strong style="color: var(--neon-blue);">{urlCheckResult.views.toLocaleString('es-ES')}</strong></div>
                    )}
                    <div>Título/Texto: <em>"{urlCheckResult.title}"</em></div>
                  </div>
                  
                  <form method="POST" style="margin-top: 1rem; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
                    <input type="hidden" name="action" value="insert_checked_url" />
                    <input type="hidden" name="url" value={urlCheckResult.rawUrl} />
                    <input type="hidden" name="platform" value={urlCheckResult.platform} />
                    <input type="hidden" name="title" value={urlCheckResult.title || ''} />
                    <input type="hidden" name="description" value={urlCheckResult.description || ''} />
                    <input type="hidden" name="author" value={urlCheckResult.author || 'Editor'} />
                    <input type="hidden" name="imageUrl" value={urlCheckResult.imageUrl || ''} />
                    <button type="submit" class="cyber-btn accent" style="width: 100%;">Confirmar y Publicar Desmentido</button>
                  </form>
                </div>
              )}
            </div>

            <!-- Cola de radar items -->
            <div class="cyber-card" style="padding: 1.5rem;">
              <h3 class="card-title">📡 Cola de Intercepción ({pendingRadarItems.length})</h3>
              <div class="scroller-list" style="max-height: 350px;">
                {pendingRadarItems.map(item => (
                  <div class="scroller-item">
                    <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">
                      <span>{item.platform} ({item.author_public_name})</span>
                      <span style="color: var(--neon-rose);">Vir: {item.virality_score}/10</span>
                    </div>
                    <p style="font-size: 0.8rem; line-height: 1.3; margin: 0 0 0.5rem 0;">"{item.detected_claim || item.text.substring(0, 80)}..."</p>
                    <a href={item.url} target="_blank" style="font-size: 0.7rem; color: var(--neon-blue); text-decoration: none;">Ver fuente original 🔗</a>
                  </div>
                ))}
                {pendingRadarItems.length === 0 && (
                  <p class="empty-state">No hay items en la cola esperando revisión.</p>
                )}
              </div>
            </div>
          </div>

          <!-- Columna Derecha: Fuentes Registradas y Glosario del Radar -->
          <div class="radar-col">
            
            <!-- Fuentes Registradas -->
            <div class="cyber-card" style="padding: 1.5rem;">
              <h3 class="card-title">📡 Fuentes de Monitorización</h3>
              
              <!-- Registrar nueva fuente -->
              <details class="accordion-edit" style="margin-bottom: 1rem;">
                <summary>+ Registrar Nueva Fuente</summary>
                <form method="POST" class="edit-form" style="margin-top: 1rem;">
                  <input type="hidden" name="action" value="add_radar_source" />
                  <div class="form-group">
                    <label>Plataforma:</label>
                    <select name="platform" class="edit-input" required>
                      <option value="Telegram">Telegram (Canal)</option>
                      <option value="Reddit">Reddit (Subreddit JSON)</option>
                      <option value="RSS">RSS Feed</option>
                      <option value="X">X (Twitter vía Nitter)</option>
                      <option value="YouTube">YouTube (Búsqueda o Canal)</option>
                      <option value="TikTok">TikTok (Usuario o Hashtag)</option>
                      <option value="Instagram">Instagram (Usuario o Hashtag)</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label>Nombre:</label>
                    <input type="text" name="name" required placeholder="Ej: Alvise Pérez" class="edit-input" />
                  </div>
                  <div class="form-group">
                    <label>Usuario o URL:</label>
                    <input type="text" name="url_or_id" required placeholder="Ej: Alviseperez" class="edit-input" />
                  </div>
