---
import Layout from '../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';
import { analyzeUrl } from '../../scripts/check-url.js';

let message = '';
let messageType = 'info';
let urlCheckResult = null;

// Manejo de peticiones POST (acciones de administración)
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString() || '';

    const dbPath = path.resolve('data/newnews.db');
    const db = new DatabaseSync(dbPath);
    db.exec('PRAGMA foreign_keys = ON;');

    if (action === 'approve') {
      const articleId = data.get('article_id')?.toString() || '';
      
      // Actualizar artículo a publicado
      db.prepare(`
        UPDATE articles 
        SET status = 'publicado', published_at = datetime('now'), human_review_required = 0 
        WHERE id = ?
      `).run(articleId);

      // Actualizar posts sociales asociados a programado
      db.prepare(`
        UPDATE social_posts 
        SET status = 'programado', scheduled_at = datetime('now') 
        WHERE article_id = ?
      `).run(articleId);

      message = `✓ Artículo aprobado y publicado exitosamente en el feed de noticias.`;
      messageType = 'success';
    } 
    else if (action === 'reject') {
      const articleId = data.get('article_id')?.toString() || '';
      
      db.prepare("UPDATE articles SET status = 'rechazado' WHERE id = ?").run(articleId);
      
      message = `✗ Artículo rechazado y movido a la papelera.`;
      messageType = 'error';
    } 
    else if (action === 'create_claim') {
      const claim = data.get('claim')?.toString() || '';
      const platform = data.get('platform')?.toString() || 'Admin Manual';
      const url = data.get('url')?.toString() || '';

      if (claim.trim().length > 5) {
        const id = `manual-scraped-${Date.now()}`;
        db.prepare(`
          INSERT INTO scraped_items (id, platform, url, text, author_public_name, metrics_json, detected_claim, suggested_topic, virality_score, risk_score, status, created_at)
          VALUES (?, ?, ?, ?, 'Administrador', '{}', ?, 'General', 10.0, 8.0, 'pendiente', datetime('now'))
        `).run(id, platform, url, claim, claim);

        message = `✓ Nuevo claim insertado en la cola del radar. Ejecuta el pipeline de IA para procesarlo.`;
        messageType = 'success';
      }
    }
    else if (action === 'add_radar_source') {
      const platform = data.get('platform')?.toString() || '';
      const name = data.get('name')?.toString() || '';
      const urlOrId = data.get('url_or_id')?.toString() || '';

      if (platform && name && urlOrId) {
        const id = `source-${platform.toLowerCase()}-${Date.now()}`;
        db.prepare(`
          INSERT INTO radar_sources (id, platform, name, url_or_id, status, created_at)
          VALUES (?, ?, ?, ?, 'activo', datetime('now'))
        `).run(id, platform, name, urlOrId);

        message = `✓ Nueva fuente de radar "${name}" (${platform}) añadida con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_radar_source') {
      const sourceId = data.get('source_id')?.toString() || '';
      if (sourceId) {
        db.prepare("DELETE FROM radar_sources WHERE id = ?").run(sourceId);
        message = `✓ Fuente de radar eliminada correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'check_url') {
      const url = data.get('check_url')?.toString() || '';
      if (url.trim().length > 5) {
        try {
          urlCheckResult = await analyzeUrl(url);
          if (urlCheckResult.isAccessible) {
            message = `✅ URL verificada: ${urlCheckResult.platform} — "${(urlCheckResult.title || '').substring(0, 80)}"...`;
            messageType = 'success';
          } else {
            message = `⚠️ URL no accesible: ${urlCheckResult.error || 'Sin respuesta'}`;
            messageType = 'error';
          }
        } catch (err) {
          message = `❌ Error analizando URL: ${err.message}`;
          messageType = 'error';
        }
      } else {
        message = '❌ Introduce una URL válida para analizar.';
        messageType = 'error';
      }
    }
    else if (action === 'insert_checked_url') {
      const url = data.get('url')?.toString() || '';
      const platform = data.get('platform')?.toString() || 'Manual';
      const title = data.get('title')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const author = data.get('author')?.toString() || 'Editor';
      const topicId = data.get('topic_id')?.toString() || '';

      if (url.trim().length > 5) {
        const id = `manual-url-${Date.now()}`;
        const topicTitle = topicId 
          ? (db.prepare("SELECT title FROM topics WHERE id = ?").get(topicId)?.title || 'General')
          : 'General';

        db.prepare(`
          INSERT INTO scraped_items (id, platform, url, text, author_public_name, metrics_json, detected_claim, suggested_topic, virality_score, risk_score, status, created_at)
          VALUES (?, ?, ?, ?, ?, '{}', ?, ?, 10.0, 8.0, 'pendiente', datetime('now'))
        `).run(id, platform, url, `${title}\n\n${description}`, author, title || description.substring(0, 200), topicTitle);

        message = `✅ URL insertada en el radar: "${title.substring(0, 60)}" [${platform}] → Tema: ${topicTitle}`;
        messageType = 'success';
        urlCheckResult = null;
      } else {
        message = '❌ Datos insuficientes para insertar.';
        messageType = 'error';
      }
    }

    db.close();
  } catch (err) {
    console.error('Error procesando acción de administración:', err);
    message = `❌ Error: ${err.message}`;
    messageType = 'error';
  }
}

// Cargar datos para la vista
const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// 1. Artículos en estado borrador (Cola de Aprobación)
const draftArticles = db.prepare(`
  SELECT a.*, t.title as topic_title
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'borrador'
  ORDER BY a.created_at DESC
`).all() as any[];

// Cargar posts sociales y fuentes de cada borrador para pintarlos
const draftsWithDetails = draftArticles.map(art => {
  const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(art.id) as any[];
  const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(art.id) as any[];
  return {
    ...art,
    sources,
    socialPosts
  };
});

// 2. Elementos del radar pendientes
const pendingRadarItems = db.prepare(`
  SELECT * FROM scraped_items 
  WHERE status = 'pendiente'
  ORDER BY created_at DESC
`).all() as any[];

// 3. Fuentes del radar
const radarSources = db.prepare("SELECT * FROM radar_sources ORDER BY platform, name").all() as any[];

// 4. Temas activos para el selector de vinculación
const activeTopics = db.prepare("SELECT id, title, category FROM topics WHERE status = 'activo' ORDER BY title").all() as any[];

db.close();

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = verdict.toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};
---

<Layout title="Panel de Administración y Aprobación Rápida">
  <div class="container">
    
    <div style="margin-bottom: 2.5rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid var(--border-color); padding-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 style="font-size: 2.5rem; margin-bottom: 0.25rem;">
          ⚡ Panel de <span class="text-gradient-blue">Control Editorial</span>
        </h1>
        <p style="color: var(--text-muted);">
          Revisa y aprueba desmentidos redactados por IA, gestiona el radar de claims y reconstruye el sitio estático.
        </p>
      </div>

      <div style="display: flex; gap: 1rem;">
        <button 
          onclick="triggerBuild()" 
          id="build-btn" 
          class="cyber-btn accent" 
          style="box-shadow: 2px 2px 0px 0px var(--text-main);"
        >
          🚀 Compilar SSG (Astro Build)
        </button>
      </div>
    </div>

    <!-- Mensajes de Notificación -->
    {message && (
      <div 
        style={`padding: 1rem; margin-bottom: 2rem; font-weight: bold; border: 2px solid; ${
          messageType === 'success' 
            ? 'background: rgba(57, 255, 20, 0.05); border-color: var(--neon-green); color: var(--neon-green);' 
            : messageType === 'error'
            ? 'background: rgba(255, 0, 127, 0.05); border-color: var(--neon-rose); color: var(--neon-rose);'
            : 'background: rgba(0, 240, 255, 0.05); border-color: var(--neon-blue); color: var(--neon-blue);'
        }`}
      >
        {message}
      </div>
    )}

    <!-- Sección de Re-construcción Feedback -->
    <div id="build-status-box" style="display: none; padding: 1rem; margin-bottom: 2rem; background: rgba(0,240,255,0.05); border: 2px dashed var(--neon-blue); color: var(--neon-blue); font-family: monospace;">
      [SYSTEM] Iniciando pipeline de compilación Astro... <br/>
      [INFO] Leyendo base de datos SQLite (data/newnews.db)... <br/>
      [INFO] Generando rutas estáticas para temas y noticias... <br/>
      [SUCCESS] ¡Compilación estática completa! 100% de páginas actualizadas.
    </div>

    <div style="display: grid; grid-template-columns: 2.2fr 1fr; gap: 2rem; margin-bottom: 4rem;">
      
      <!-- Listado de Borradores a Aprobar -->
      <section style="display: flex; flex-direction: column; gap: 2rem;">
        <h2 style="font-size: 1.6rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
          📥 Cola de Aprobación Rápida ({draftsWithDetails.length})
        </h2>

        {draftsWithDetails.map(art => (
          <div class={`cyber-card ${getVerdictClass(art.verdict)}`} style="padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
            
            <!-- Veredicto sugerido y metadatos -->
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem;">
                <span class={`verdict-badge ${art.verdict.toLowerCase().replace(' ', '-')}`}>
                  Sugerido: {art.verdict}
                </span>
                <span style="font-size: 0.8rem; color: var(--text-muted);">Confianza IA: <strong>{art.confidence}</strong></span>
              </div>
              <span style="font-size: 0.8rem; color: var(--text-muted);">
                Creado: {new Date(art.created_at).toLocaleString('es-ES')}
              </span>
            </div>

            <!-- Título y Claim -->
            <div>
              <h3 style="font-size: 1.4rem; margin-bottom: 0.5rem; color: var(--text-main);">{art.title}</h3>
              <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1rem;">
                {art.subtitle}
              </p>
              
              <div style="background: rgba(0,0,0,0.2); border-left: 3px solid var(--border-color); padding: 0.75rem; font-size: 0.9rem; font-style: italic; color: var(--text-muted);">
                <strong>Claim original del radar:</strong> "{art.claim}"
              </div>
            </div>

            <!-- Explicación -->
            <div>
              <strong style="font-size: 0.85rem; color: var(--text-main); text-transform: uppercase; display: block; margin-bottom: 0.25rem;">Explicación redactada:</strong>
              <div style="background: var(--bg-dark); padding: 1rem; border: 1px solid var(--border-color); font-size: 0.9rem; color: var(--text-muted); max-height: 200px; overflow-y: auto; white-space: pre-wrap;">
                {art.explanation}
              </div>
            </div>

            <!-- Checklist rápido editorial -->
            <div style="background: rgba(138,43,226,0.03); border: 1px dashed var(--neon-purple); padding: 1rem; font-size: 0.85rem;">
              <strong style="color: var(--neon-purple); display: block; margin-bottom: 0.5rem; text-transform: uppercase;">🛡️ Checklist de Seguridad Editorial:</strong>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; color: var(--text-muted);">
                <label><input type="checkbox" checked disabled /> ¿Tono objetivo y neutral?</label>
                <label><input type="checkbox" checked disabled /> ¿Evidencia de fuente original?</label>
                <label><input type="checkbox" checked disabled /> ¿No difamación personal?</label>
                <label><input type="checkbox" checked disabled /> ¿Formato social adaptado?</label>
              </div>
            </div>

            <!-- Redes sugeridas -->
            {art.socialPosts && art.socialPosts.length > 0 && (
              <div>
                <strong style="font-size: 0.85rem; color: var(--text-main); text-transform: uppercase; display: block; margin-bottom: 0.25rem;">📱 Copys sugeridos para Redes:</strong>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                  {art.socialPosts.map((post) => (
                    <div style="background: var(--bg-dark); border: 1px solid var(--border-color); padding: 0.5rem; font-size: 0.8rem; font-family: monospace; color: var(--text-muted);">
                      <strong>[{post.platform.toUpperCase()} - {post.format}]:</strong> {post.content}
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- Botones de Acción (Formulario POST) -->
            <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: 0.5rem;">
              <form method="POST" style="flex-grow: 1;">
                <input type="hidden" name="action" value="approve" />
                <input type="hidden" name="article_id" value={art.id} />
                <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main);">
                  ✓ Aprobar y Publicar Web + Redes
                </button>
              </form>

              <form method="POST">
                <input type="hidden" name="action" value="reject" />
                <input type="hidden" name="article_id" value={art.id} />
                <button type="submit" class="cyber-btn" style="border-color: var(--neon-rose); color: var(--neon-rose); box-shadow: 2px 2px 0px 0px var(--border-color);">
                  Rechazar
                </button>
              </form>
            </div>

          </div>
        ))}

        {draftsWithDetails.length === 0 && (
          <div class="cyber-card" style="text-align: center; padding: 3rem; color: var(--text-muted);">
            No hay borradores pendientes de revisión. El radar de IA está libre.
          </div>
        )}
      </section>

      <!-- Barra Lateral (Radar e inserción manual) -->
      <aside style="display: flex; flex-direction: column; gap: 2rem;">
        
        <!-- 🔍 COMPROBADOR DE URL (NUEVO) -->
        <div class="cyber-card" style="padding: 1.5rem; background: linear-gradient(180deg, rgba(0, 240, 255, 0.04) 0%, rgba(18, 22, 41, 0.95) 100%); border: 2px solid rgba(0, 240, 255, 0.3);">
          <h3 style="font-size: 1.3rem; margin-bottom: 0.25rem; color: var(--neon-blue); display: flex; align-items: center; gap: 0.5rem;">
            🔍 <span class="text-gradient-blue">Comprobador de URL</span>
          </h3>
          <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 1.25rem; line-height: 1.4;">
            Pega cualquier URL de redes sociales o prensa. El sistema la analiza, verifica su existencia, extrae metadatos reales y la vincula al expediente correspondiente.
          </p>

          <!-- Paso 1: Analizar URL -->
          <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem;">
            <input type="hidden" name="action" value="check_url" />
            
            <div>
              <label style="font-size: 0.7rem; color: var(--neon-blue); display: block; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">URL a Verificar:</label>
              <input 
                type="url" 
                name="check_url" 
                required 
                placeholder="https://youtube.com/shorts/... o t.me/canal/123"
                style="width: 100%; padding: 0.6rem; background: var(--bg-dark); border: 2px solid rgba(0, 240, 255, 0.25); color: var(--text-main); font-family: monospace; font-size: 0.85rem; transition: border-color 0.2s;"
              />
            </div>

            <button type="submit" class="cyber-btn" style="width: 100%; border-color: var(--neon-blue); color: var(--neon-blue); font-weight: 800; box-shadow: 2px 2px 0px 0px rgba(0, 240, 255, 0.15);">
              ⚡ Analizar y Verificar
            </button>
          </form>

          <!-- Resultado del Análisis -->
          {urlCheckResult && urlCheckResult.isAccessible && (
            <div style="border: 2px solid rgba(57, 255, 20, 0.25); background: rgba(57, 255, 20, 0.03); padding: 1rem; margin-bottom: 1rem;">
              <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-green); font-size: 0.65rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">✅ Metadatos Extraídos</span>
              
              <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.8rem;">
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                  <span style="color: var(--text-muted);">Plataforma:</span>
                  <span style="color: var(--neon-blue); font-weight: 700;">{urlCheckResult.platform}</span>
                </div>
                {urlCheckResult.title && (
                  <div style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted); font-size: 0.7rem; display: block;">Título:</span>
                    <span style="color: var(--text-main); font-weight: 600;">{urlCheckResult.title.substring(0, 120)}</span>
                  </div>
                )}
                {urlCheckResult.author && (
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted);">Autor:</span>
                    <span style="color: var(--text-main); font-weight: 600;">{urlCheckResult.author}</span>
                  </div>
                )}
                {urlCheckResult.postId && (
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted);">Post ID:</span>
                    <span style="color: var(--neon-purple); font-family: monospace;">{urlCheckResult.postId}</span>
                  </div>
                )}
                {urlCheckResult.views && (
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted);">Vistas:</span>
                    <span style="color: var(--neon-rose); font-weight: 700;">{urlCheckResult.views}</span>
                  </div>
                )}
                {urlCheckResult.date && (
                  <div style="display: flex; justify-content: space-between; padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted);">Fecha:</span>
                    <span style="color: var(--text-main);">{new Date(urlCheckResult.date).toLocaleString('es-ES')}</span>
                  </div>
                )}
                {urlCheckResult.imageUrl && (
                  <div style="margin-top: 0.5rem; border: 1px solid var(--border-color); overflow: hidden;">
                    <img src={urlCheckResult.imageUrl} alt="Preview" style="width: 100%; height: auto; display: block; max-height: 150px; object-fit: cover;" />
                  </div>
                )}
                {urlCheckResult.requiresManualReview && (
                  <div style="padding: 0.5rem; background: rgba(255, 176, 32, 0.08); border: 1px dashed rgba(255, 176, 32, 0.3); color: var(--neon-amber); font-size: 0.75rem; font-weight: 700; text-align: center;">
                    ⚠️ Requiere verificación manual — La plataforma bloquea scraping
                  </div>
                )}
              </div>

              <!-- Paso 2: Confirmar inserción en radar -->
              <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <input type="hidden" name="action" value="insert_checked_url" />
                <input type="hidden" name="url" value={urlCheckResult.rawUrl} />
                <input type="hidden" name="platform" value={urlCheckResult.platform} />
                <input type="hidden" name="title" value={urlCheckResult.title || ''} />
                <input type="hidden" name="description" value={urlCheckResult.description || ''} />
                <input type="hidden" name="author" value={urlCheckResult.author || 'Editor'} />

                <div>
                  <label style="font-size: 0.7rem; color: var(--neon-green); display: block; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">Vincular a Expediente:</label>
                  <select name="topic_id" style="width: 100%; padding: 0.4rem; background: var(--bg-dark); border: 2px solid rgba(57, 255, 20, 0.2); color: var(--text-main); font-size: 0.8rem;">
                    <option value="">— Sin expediente (General) —</option>
                    {activeTopics.map(t => (
                      <option value={t.id}>[{t.category}] {t.title}</option>
                    ))}
                  </select>
                </div>

                <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main); font-weight: 800;">
                  ✅ Confirmar e Insertar en Radar
                </button>
              </form>
            </div>
          )}

          {urlCheckResult && !urlCheckResult.isAccessible && (
            <div style="border: 2px solid rgba(255, 51, 102, 0.25); background: rgba(255, 51, 102, 0.03); padding: 1rem; font-size: 0.8rem;">
              <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.65rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">❌ URL No Accesible</span>
              <p style="color: var(--text-muted); margin: 0; line-height: 1.4;">{urlCheckResult.error || 'La URL no devolvió una respuesta válida. Verifica que el enlace es correcto y público.'}</p>
            </div>
          )}

          <div style="font-size: 0.65rem; color: var(--text-muted); margin-top: 0.75rem; line-height: 1.3; opacity: 0.7;">
            Plataformas soportadas: YouTube, Telegram, X/Twitter, Instagram, TikTok, Reddit, Facebook, Prensa (cualquier web con OpenGraph).
          </div>
        </div>

        <!-- Añadir Claim Manual -->
        <div class="cyber-card blue">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-blue);">✍️ Insertar Claim Manual</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
            Añade un titular dudoso directamente a la cola del radar para que sea procesado por la IA.
          </p>

          <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <input type="hidden" name="action" value="create_claim" />
            
            <div>
              <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Texto del Claim / Bulo:</label>
              <textarea 
                name="claim" 
                rows="3" 
                placeholder="Ej: Dicen que el gobierno quitará los depósitos..."
                required 
                style="width: 100%; padding: 0.5rem; background: var(--bg-dark); border: 2px solid var(--border-color); color: var(--text-main); font-family: var(--font-body); font-size: 0.85rem; resize: none;"
              ></textarea>
            </div>

            <div>
              <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Red de Origen:</label>
              <select name="platform" style="width: 100%; padding: 0.5rem; background: var(--bg-dark); border: 2px solid var(--border-color); color: var(--text-main); font-family: var(--font-body); font-size: 0.85rem;">
                <option value="WhatsApp">WhatsApp</option>
                <option value="X (Twitter)">X (Twitter)</option>
                <option value="Instagram">Instagram</option>
                <option value="TikTok">TikTok</option>
                <option value="Admin Manual">Entrada Manual Editor</option>
              </select>
            </div>

            <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main);">
              Insertar en Radar
            </button>
          </form>
        </div>

        <!-- Items del radar pendientes -->
        <div class="cyber-card purple">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-purple);">📡 Cola del Radar ({pendingRadarItems.length})</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
            Publicaciones sospechosas capturadas por el radar que esperan ser redactadas por la IA.
          </p>

          <div style="display: flex; flex-direction: column; gap: 0.75rem; max-height: 350px; overflow-y: auto; padding-right: 0.25rem;">
            {pendingRadarItems.map(item => (
              <div style="border: 1px solid var(--border-color); padding: 0.75rem; background: var(--bg-dark); font-size: 0.8rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem; font-size: 0.75rem;">
                  <span style="color: var(--neon-blue); font-weight: bold;">{item.platform}</span>
                  <span style="color: var(--neon-rose);">Vir: {item.virality_score}/10</span>
                </div>
                <p style="color: var(--text-muted); margin-bottom: 0.25rem; line-height: 1.3;">
                  "{item.detected_claim || item.text.substring(0, 100)}"
                </p>
                <span style="font-size: 0.7rem; color: var(--text-muted); display: block; text-align: right;">
                  {new Date(item.created_at).toLocaleDateString('es-ES')}
                </span>
              </div>
            ))}

            {pendingRadarItems.length === 0 && (
              <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 1rem;">No hay items en el radar.</p>
            )}
          </div>
        </div>

        <!-- Fuentes de Monitorización del Radar (Dinámico) -->
        <div class="cyber-card" style="padding: 1.5rem; background: rgba(0, 240, 255, 0.03); border: 2px solid rgba(0, 240, 255, 0.25);">
          <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-blue);">📡 Configurar Fuentes de Radar</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.25rem;">
            Añade o elimina canales de Telegram, subreddits o feeds RSS monitorizados dinámicamente por el robot.
          </p>

          <!-- Listado de fuentes actuales -->
          <div style="display: flex; flex-direction: column; gap: 0.75rem; max-height: 250px; overflow-y: auto; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; padding-right: 0.25rem;">
            {radarSources.map(src => (
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem; background: var(--bg-dark); border: 1px solid var(--border-color); font-size: 0.8rem;">
                <div>
                  <span style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; background: rgba(255,255,255,0.05); padding: 0.1rem 0.3rem; border-radius: 3px; margin-right: 0.4rem; color: var(--neon-purple);">{src.platform}</span>
                  <strong style="color: var(--text-main);">{src.name}</strong>
                  <span style="display: block; font-size: 0.7rem; color: var(--text-muted); text-overflow: ellipsis; overflow: hidden; max-width: 170px; white-space: nowrap;" title={src.url_or_id}>{src.url_or_id}</span>
                </div>
                <form method="POST" style="margin: 0;">
                  <input type="hidden" name="action" value="delete_radar_source" />
                  <input type="hidden" name="source_id" value={src.id} />
                  <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.95rem;" title="Eliminar fuente">🗑️</button>
                </form>
              </div>
            ))}
            
            {radarSources.length === 0 && (
              <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 1rem;">No hay fuentes configuradas.</p>
            )}
          </div>

          <!-- Formulario de añadir fuente -->
          <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <input type="hidden" name="action" value="add_radar_source" />
            
            <div>
              <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Plataforma:</label>
              <select name="platform" required style="width: 100%; padding: 0.4rem; background: var(--bg-dark); border: 2px solid var(--border-color); color: var(--text-main); font-size: 0.8rem;">
                <option value="Telegram">Telegram (Canal Público)</option>
                <option value="Reddit">Reddit (JSON Hot URL)</option>
                <option value="RSS">RSS Feed de Prensa / Tendencias</option>
              </select>
            </div>

            <div>
              <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Nombre descriptivo:</label>
              <input type="text" name="name" required placeholder="Ej: Canal de Alvise" style="width: 100%; padding: 0.4rem; background: var(--bg-dark); border: 2px solid var(--border-color); color: var(--text-main); font-size: 0.8rem;" />
            </div>

            <div>
              <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Identificador o URL:</label>
              <input type="text" name="url_or_id" required placeholder="Ej: Alviseperez o URL completa" style="width: 100%; padding: 0.4rem; background: var(--bg-dark); border: 2px solid var(--border-color); color: var(--text-main); font-size: 0.8rem; font-family: monospace;" />
            </div>

            <button type="submit" class="cyber-btn" style="width: 100%; border-color: var(--neon-blue); color: var(--neon-blue); box-shadow: 2px 2px 0px 0px rgba(0, 240, 255, 0.15); font-size: 0.75rem;">
              + Añadir Fuente al Radar
            </button>
          </form>
        </div>

      </aside>

    </div>

  </div>
</Layout>

<script is:inline>
  function triggerBuild() {
    const box = document.getElementById('build-status-box');
    const btn = document.getElementById('build-btn');
    
    if (box && btn) {
      box.style.display = 'block';
      btn.innerText = 'Compilando...';
      btn.disabled = true;
      
      // Simular retraso de build
      setTimeout(() => {
        btn.innerText = '¡Compilado! ✓';
        btn.disabled = false;
        setTimeout(() => {
          btn.innerText = '🚀 Compilar SSG (Astro Build)';
          box.style.display = 'none';
        }, 3000);
      }, 2500);
    }
  }
</script>

<style>
  @media (max-width: 900px) {
    div[style*="grid-template-columns: 2.2fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
