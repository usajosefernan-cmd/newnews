                  <input type="text" name="leader" required placeholder="Ej: Alberto Núñez Feijóo" class="edit-input" />
                </div>
              </div>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                  <label class="edit-label">Web Oficial:</label>
                  <input type="url" name="website" placeholder="https://..." class="edit-input" />
                </div>
                <div>
                  <label class="edit-label">Resumen Ideológico:</label>
                  <input type="text" name="ideology" placeholder="Ej: Conservadurismo, Liberalismo económico" class="edit-input" />
                </div>
              </div>
              <button type="submit" class="cyber-btn" style="border-color: var(--neon-blue); color: var(--neon-blue); font-size: 0.8rem; font-weight: 800;">
