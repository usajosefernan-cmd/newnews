                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Original:</label>
                            <textarea name="original_text" rows="2" class="edit-input" style="font-size: 0.8rem; line-height: 1.35; padding: 0.35rem;">{meas.original_text}</textarea>
                          </div>
                          <button type="submit" class="cyber-btn accent" style="padding: 0.4rem; font-size: 0.75rem; font-weight: bold; width: 100%;">Actualizar</button>
                        </form>
                      </div>
                    </details>
                    <form method="POST" style="margin: 0; display: inline-block;">
                      <input type="hidden" name="action" value="delete_measure" />
                      <input type="hidden" name="measure_id" value={meas.id} />
                      <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.95rem;" onclick="return confirm('¿Seguro que deseas eliminar esta propuesta?')">🗑️</button>
