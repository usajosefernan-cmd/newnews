<!-- SCRIPT SPA INTERACTIVO EN EL CLIENTE -->
<script is:inline>
  // Gestión de pestañas instantánea
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.admin-tab-btn');
    const panels = document.querySelectorAll('.admin-tab-panel');
    const kpiCards = document.querySelectorAll('.kpi-card');

    function switchTab(targetId) {
      // Desactivar botones de tab
      tabs.forEach(btn => {
        if (btn.getAttribute('data-target') === targetId) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Alternar visibilidad de paneles
      panels.forEach(panel => {
        if (panel.id === targetId) {
          panel.classList.add('active');
        } else {
          panel.classList.remove('active');
        }
      });
      
      // Actualizar parámetro en la URL sin recargar
      const newUrl = new URL(window.location.href);
      newUrl.searchParams.set('tab', targetId.replace('pane-', ''));
      window.history.pushState({}, '', newUrl);
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        switchTab(target);
      });
    });

    // Enlazar clics en tarjetas de KPIs
    kpiCards.forEach(card => {
      card.addEventListener('click', () => {
        const target = card.getAttribute('data-tab');
        switchTab(target);
      });
    });

    // Cargar pestaña inicial basada en URL
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam) {
      const panelId = 'pane-' + tabParam;
      if (document.getElementById(panelId)) {
        switchTab(panelId);
      }
    }

    // Lógica de previsualización en vivo para el redactor
    const inpTitle = document.getElementById('inp-title');
    const inpSubtitle = document.getElementById('inp-subtitle');
    const inpVerdict = document.getElementById('inp-verdict');
    const inpClaim = document.getElementById('inp-claim');
    const inpPlatform = document.getElementById('inp-platform');
    const inpUrl = document.getElementById('inp-url');
    const inpTrue = document.getElementById('inp-true');
    const inpFalse = document.getElementById('inp-false');
    const inpLacks = document.getElementById('inp-lacks');
    const inpUnproven = document.getElementById('inp-unproven');

    const prevTitle = document.getElementById('prev-title');
    const prevSubtitle = document.getElementById('prev-subtitle');
    const prevVerdictBox = document.getElementById('prev-verdict-box');
    const prevVerdictBadge = document.getElementById('prev-verdict-badge');
    const prevVerdictText = document.getElementById('prev-verdict-text');
    const prevEmbedPlatform = document.getElementById('prev-embed-platform');
    const prevEmbedClaim = document.getElementById('prev-embed-claim');
    const prevDetailTrue = document.getElementById('prev-detail-true');
    const prevDetailFalse = document.getElementById('prev-detail-false');
    const prevDetailLacks = document.getElementById('prev-detail-lacks');
    const prevDetailUnproven = document.getElementById('prev-detail-unproven');

    function updatePreview() {
      if (prevTitle && inpTitle) prevTitle.innerText = inpTitle.value || '[Título del Análisis]';
      if (prevSubtitle && inpSubtitle) prevSubtitle.innerText = inpSubtitle.value || '[Subtítulo explicativo del análisis]';
      if (prevEmbedClaim && inpClaim) prevEmbedClaim.innerText = inpClaim.value ? '"' + inpClaim.value + '"' : '"[Texto de la afirmación viral]"';
      if (prevEmbedPlatform && inpPlatform) prevEmbedPlatform.innerText = inpPlatform.value || 'Red Social';
      
      if (prevDetailTrue && inpTrue) prevDetailTrue.innerText = inpTrue.value || '[Escribe datos que sean correctos]';
      if (prevDetailFalse && inpFalse) prevDetailFalse.innerText = inpFalse.value || '[Escribe datos falsificados desmentidos]';
      if (prevDetailLacks && inpLacks) prevDetailLacks.innerText = inpLacks.value || '[Contexto legal omitido]';
      if (prevDetailUnproven && inpUnproven) prevDetailUnproven.innerText = inpUnproven.value || '[Aseveraciones sin verificar]';

      if (inpVerdict && prevVerdictBadge && prevVerdictBox) {
        const val = inpVerdict.value;
        prevVerdictBadge.innerText = val;
        prevVerdictBadge.className = 'verdict-badge ' + val.toLowerCase().replace(' ', '-');
        
        // Quitar clases previas del box
        prevVerdictBox.className = 'cyber-card';
        if (val === 'Falso') {
          prevVerdictBox.classList.add('rose');
          if (prevVerdictText) prevVerdictText.innerText = 'Este claim contradice los datos oficiales y registros públicos disponibles.';
        } else if (val === 'Verdadero') {
          prevVerdictBox.classList.add('green');
          if (prevVerdictText) prevVerdictText.innerText = 'Los datos y documentos oficiales respaldan plenamente esta afirmación.';
        } else if (val === 'Engañoso') {
          prevVerdictBox.classList.add('amber');
          if (prevVerdictText) prevVerdictText.innerText = 'La afirmación mezcla datos reales con interpretaciones sesgadas para desinformar.';
        } else {
          prevVerdictBox.classList.add('blue');
          if (prevVerdictText) prevVerdictText.innerText = 'La información presentada carece de los datos de contexto necesarios para entenderla.';
        }
      }
    }

    const inputs = [inpTitle, inpSubtitle, inpVerdict, inpClaim, inpPlatform, inpUrl, inpTrue, inpFalse, inpLacks, inpUnproven];
    inputs.forEach(input => {
      if (input) {
        input.addEventListener('input', updatePreview);
        input.addEventListener('change', updatePreview);
      }
    });

    updatePreview();
  });
</script>

<script is:inline>
  function triggerBuild() {
    const box = document.getElementById('build-status-box');
    const btn = document.getElementById('build-btn');
    
    if (box && btn) {
      box.style.display = 'block';
      btn.innerText = 'Compilando...';
      btn.disabled = true;
      
      // Simular retraso de build
      setTimeout(() => {
        btn.innerText = '¡Compilado! ✓';
        btn.disabled = false;
        setTimeout(() => {
          btn.innerText = '🚀 Compilar SSG (Astro Build)';
          box.style.display = 'none';
        }, 3000);
      }, 2500);
    }
  }

  window.runAdminJob = async function(jobName) {
    const terminal = document.getElementById('admin-terminal-body');
    const termTitle = document.getElementById('terminal-job-title');
    const termStatus = document.getElementById('terminal-status');
    
    if (!terminal || !termTitle || !termStatus) return;
    
    const cleanBase = window.location.pathname.includes('/pro/newnews') ? '/pro/newnews' : '';
    
    // Bloquear botones
    const btnNames = ['cron', 'radar', 'ai', 'sync', 'build'];
    btnNames.forEach(n => {
      const btn = document.getElementById(`btn-job-${n}`);
      if (btn) btn.disabled = true;
    });
    
    termTitle.innerText = `TERMINAL@NEWNEWS:~$ running ${jobName.toUpperCase()}...`;
    termStatus.innerText = 'EJECUTANDO';
    termStatus.style.color = 'var(--neon-amber)';
    
    terminal.innerHTML = '<div style="color: var(--neon-blue);">> Conectando con el motor de la VPS y preparando flujo...</div>';
    
    try {
      const response = await fetch(`${cleanBase}/api/run-job`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ job: jobName })
      });
      
      if (!response.body) {
        terminal.innerHTML += '<div style="color: var(--neon-rose);">> Error: El servidor no devolvió un flujo de datos.</div>';
        return;
      }
      
      const reader = response.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        
        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop();
        
        for (const line of lines) {
          if (line.trim()) {
            try {
              const data = JSON.parse(line);
              const row = document.createElement('div');
              row.style.wordBreak = 'break-all';
              
              if (data.status === 'success') {
                row.style.color = '#00ffc4'; // neon green
                termStatus.innerText = 'ÉXITO';
                termStatus.style.color = '#00ffc4';
              } else if (data.status === 'error') {
                row.style.color = '#ff3366'; // neon rose
                termStatus.innerText = 'ERROR';
                termStatus.style.color = '#ff3366';
              } else if (data.status === 'warn') {
                row.style.color = '#ffb020'; // neon amber
              } else {
                row.style.color = '#a9b2c3';
              }
              
              row.innerText = `> ${data.message}`;
              terminal.appendChild(row);
              terminal.scrollTop = terminal.scrollHeight;
            } catch (jsonErr) {
              const row = document.createElement('div');
              row.innerText = line;
              terminal.appendChild(row);
              terminal.scrollTop = terminal.scrollHeight;
            }
          }
        }
      }
    } catch (err) {
      terminal.innerHTML += `<div style="color: var(--neon-rose);">> Error de conexión con la API de la VPS: ${err.message}</div>`;
      termStatus.innerText = 'ERROR';
      termStatus.style.color = '#ff3366';
    } finally {
      btnNames.forEach(n => {
        const btn = document.getElementById(`btn-job-${n}`);
        if (btn) btn.disabled = false;
      });
    }
  };
</script>

