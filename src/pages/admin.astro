                    IP/Origen: {log.ip_address}
                  </span>
                </div>
                <span style="font-size: 0.8rem; color: var(--text-muted);">
                  {new Date(log.created_at).toLocaleString('es-ES')}
                </span>
              </div>

              <div style="margin-bottom: 1rem;">
                <span style="font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); display: block; font-weight: bold; margin-bottom: 0.25rem;">Consulta del usuario:</span>
                <strong style="font-size: 1.15rem; color: var(--text-main); font-family: var(--font-title);">{log.query_text}</strong>
              </div>

              {log.verdict && (
                <div style="margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
                  <span style="font-size: 0.85rem; color: var(--text-muted);">Veredicto IA:</span>
                  <span class={`verdict-badge ${log.verdict.toLowerCase().replace(' ', '-')}`}>
                    {log.verdict}
                  </span>
                </div>
              )}

              <details class="accordion-edit" style="background: rgba(0,0,0,0.15); border-radius: 6px; border: 1px solid rgba(255,255,255,0.03);">
                <summary style="font-family: monospace; font-size: 0.85rem; color: var(--neon-blue); padding: 0.5rem 1rem; cursor: pointer;">
                  📟 Ver Log de Ejecución del Servidor ({log.execution_log ? log.execution_log.split('\n').length : 0} líneas)
                </summary>
                <div style="background: #020308; padding: 1rem; border-radius: 0 0 6px 6px; font-family: monospace; font-size: 0.8rem; color: #a5b4fc; line-height: 1.5; max-height: 300px; overflow-y: auto; white-space: pre-wrap; border-top: 1px solid rgba(255,255,255,0.05);">
                  {log.execution_log}
                </div>
              </details>
            </div>
          ))}

          {verificationLogs.length === 0 && (
            <p class="empty-state">No hay registros de verificación manual todavía.</p>
          )}
        </div>
      </div>

    </div>
  </div>
</Layout>

