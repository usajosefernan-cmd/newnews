---
import Layout from '../layouts/Layout.astro';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';
import { analyzeUrl } from '../../scripts/check-url.js';

let message = '';
let messageType = 'info';
let urlCheckResult = null;

// Obtener la pestaña activa
const currentTab = Astro.url.searchParams.get('tab') || 'aprobacion';

// Manejo de peticiones POST (acciones de administración)
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action')?.toString() || '';

    const dbPath = path.resolve('data/newnews.db');
    const db = new DatabaseSync(dbPath);
    db.exec('PRAGMA foreign_keys = ON;');

    if (action === 'approve') {
      const articleId = data.get('article_id')?.toString() || '';
      
      // Actualizar artículo a publicado
      db.prepare(`
        UPDATE articles 
        SET status = 'publicado', published_at = datetime('now'), human_review_required = 0 
        WHERE id = ?
      `).run(articleId);

      // Actualizar posts sociales asociados a programado
      db.prepare(`
        UPDATE social_posts 
        SET status = 'programado', scheduled_at = datetime('now') 
        WHERE article_id = ?
      `).run(articleId);

      message = `✓ Artículo aprobado y publicado exitosamente en el feed de noticias.`;
      messageType = 'success';
    } 
    else if (action === 'reject') {
      const articleId = data.get('article_id')?.toString() || '';
      
      db.prepare("UPDATE articles SET status = 'rechazado' WHERE id = ?").run(articleId);
      
      message = `✗ Artículo rechazado y movido a la papelera.`;
      messageType = 'error';
    } 
    else if (action === 'edit_article') {
      const articleId = data.get('article_id')?.toString() || '';
      const title = data.get('title')?.toString() || '';
      const subtitle = data.get('subtitle')?.toString() || '';
      const verdict = data.get('verdict')?.toString() || '';
      const explanation = data.get('explanation')?.toString() || '';
      const whatIsTrue = data.get('what_is_true')?.toString() || '';
      const whatIsFalse = data.get('what_is_false')?.toString() || '';
      const whatLacksContext = data.get('what_lacks_context')?.toString() || '';
      const whatIsNotProven = data.get('what_is_not_proven')?.toString() || '';
      const topicId = data.get('topic_id')?.toString() || '';
      const status = data.get('status')?.toString() || 'borrador';

      db.prepare(`
        UPDATE articles 
        SET title = ?, subtitle = ?, verdict = ?, explanation = ?, 
            what_is_true = ?, what_is_false = ?, what_lacks_context = ?, what_is_not_proven = ?,
            topic_id = ?, status = ?, updated_at = datetime('now')
        WHERE id = ?
      `).run(title, subtitle, verdict, explanation, whatIsTrue, whatIsFalse, whatLacksContext, whatIsNotProven, topicId, status, articleId);

      message = `✓ Artículo "${title.substring(0, 45)}..." actualizado correctamente.`;
      messageType = 'success';
    }
    else if (action === 'delete_article') {
      const articleId = data.get('article_id')?.toString() || '';
      db.prepare("DELETE FROM articles WHERE id = ?").run(articleId);
      message = `✓ Artículo eliminado físicamente de la base de datos.`;
      messageType = 'success';
    }
    else if (action === 'create_topic') {
      const title = data.get('title')?.toString() || '';
      const category = data.get('category')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const verdictSummary = data.get('verdict_summary')?.toString() || '';
      const confidence = data.get('confidence')?.toString() || 'Alta';

      if (title.trim()) {
        const topicId = `t-${Date.now()}`;
        const slug = title.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').substring(0, 60);

        db.prepare(`
          INSERT INTO topics (id, slug, title, description, category, verdict_summary, confidence, status, created_at, updated_at)
          VALUES (?, ?, ?, ?, ?, ?, ?, 'activo', datetime('now'), datetime('now'))
        `).run(topicId, slug, title, description, category, verdictSummary, confidence);

        message = `✓ Nuevo expediente temático "${title}" creado con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'edit_topic') {
      const topicId = data.get('topic_id')?.toString() || '';
      const title = data.get('title')?.toString() || '';
      const category = data.get('category')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const verdictSummary = data.get('verdict_summary')?.toString() || '';
      const status = data.get('status')?.toString() || 'activo';
      const confidence = data.get('confidence')?.toString() || 'Alta';

      if (topicId && title.trim()) {
        db.prepare(`
          UPDATE topics 
          SET title = ?, category = ?, description = ?, verdict_summary = ?, status = ?, confidence = ?, updated_at = datetime('now')
          WHERE id = ?
        `).run(title, category, description, verdictSummary, status, confidence, topicId);

        message = `✓ Expediente temático "${title}" actualizado correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'create_claim') {
      const claim = data.get('claim')?.toString() || '';
      const platform = data.get('platform')?.toString() || 'Admin Manual';
      const url = data.get('url')?.toString() || '';

      if (claim.trim().length > 5) {
        const id = `manual-scraped-${Date.now()}`;
        db.prepare(`
          INSERT INTO scraped_items (id, platform, url, text, author_public_name, metrics_json, detected_claim, suggested_topic, virality_score, risk_score, status, created_at)
          VALUES (?, ?, ?, ?, 'Administrador', '{}', ?, 'General', 10.0, 8.0, 'pendiente', datetime('now'))
        `).run(id, platform, url, claim, claim);

        message = `✓ Nuevo claim insertado en la cola del radar. Ejecuta el pipeline de IA para procesarlo.`;
        messageType = 'success';
      }
    }
    else if (action === 'add_radar_source') {
      const platform = data.get('platform')?.toString() || '';
      const name = data.get('name')?.toString() || '';
      const urlOrId = data.get('url_or_id')?.toString() || '';

      if (platform && name && urlOrId) {
        const id = `source-${platform.toLowerCase()}-${Date.now()}`;
        db.prepare(`
          INSERT INTO radar_sources (id, platform, name, url_or_id, status, created_at)
          VALUES (?, ?, ?, ?, 'activo', datetime('now'))
        `).run(id, platform, name, urlOrId);

        message = `✓ Nueva fuente de radar "${name}" (${platform}) añadida con éxito.`;
        messageType = 'success';
      }
    }
    else if (action === 'delete_radar_source') {
      const sourceId = data.get('source_id')?.toString() || '';
      if (sourceId) {
        db.prepare("DELETE FROM radar_sources WHERE id = ?").run(sourceId);
        message = `✓ Fuente de radar eliminada correctamente.`;
        messageType = 'success';
      }
    }
    else if (action === 'check_url') {
      const url = data.get('check_url')?.toString() || '';
      if (url.trim().length > 5) {
        try {
          urlCheckResult = await analyzeUrl(url);
          if (urlCheckResult.isAccessible) {
            message = `✅ URL verificada: ${urlCheckResult.platform} — "${(urlCheckResult.title || '').substring(0, 80)}"...`;
            messageType = 'success';
          } else {
            message = `⚠️ URL no accesible: ${urlCheckResult.error || 'Sin respuesta'}`;
            messageType = 'error';
          }
        } catch (err) {
          message = `❌ Error analizando URL: ${err.message}`;
          messageType = 'error';
        }
      } else {
        message = '❌ Introduce una URL válida para analizar.';
        messageType = 'error';
      }
    }
    else if (action === 'insert_checked_url') {
      const url = data.get('url')?.toString() || '';
      const platform = data.get('platform')?.toString() || 'Manual';
      const title = data.get('title')?.toString() || '';
      const description = data.get('description')?.toString() || '';
      const author = data.get('author')?.toString() || 'Editor';
      const topicId = data.get('topic_id')?.toString() || '';

      if (url.trim().length > 5) {
        const id = `manual-url-${Date.now()}`;
        const topicTitle = topicId 
          ? (db.prepare("SELECT title FROM topics WHERE id = ?").get(topicId)?.title || 'General')
          : 'General';

        db.prepare(`
          INSERT INTO scraped_items (id, platform, url, text, author_public_name, metrics_json, detected_claim, suggested_topic, virality_score, risk_score, status, created_at)
          VALUES (?, ?, ?, ?, ?, '{}', ?, ?, 10.0, 8.0, 'pendiente', datetime('now'))
        `).run(id, platform, url, `${title}\n\n${description}`, author, title || description.substring(0, 200), topicTitle);

        message = `✅ URL insertada en el radar: "${title.substring(0, 60)}" [${platform}] → Tema: ${topicTitle}`;
        messageType = 'success';
        urlCheckResult = null;
      } else {
        message = '❌ Datos insuficientes para insertar.';
        messageType = 'error';
      }
    }

    db.close();
  } catch (err) {
    console.error('Error procesando acción de administración:', err);
    message = `❌ Error: ${err.message}`;
    messageType = 'error';
  }
}

// Cargar datos para la vista
const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);

// 1. Artículos en estado borrador (Cola de Aprobación)
const draftArticles = db.prepare(`
  SELECT a.*, t.title as topic_title
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'borrador'
  ORDER BY a.created_at DESC
`).all() as any[];

const draftsWithDetails = draftArticles.map(art => {
  const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(art.id) as any[];
  const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(art.id) as any[];
  return { ...art, sources, socialPosts };
});

// 2. Artículos en estado publicado
const publishedArticles = db.prepare(`
  SELECT a.*, t.title as topic_title
  FROM articles a
  LEFT JOIN topics t ON a.topic_id = t.id
  WHERE a.status = 'publicado'
  ORDER BY a.published_at DESC
`).all() as any[];

const publishedWithDetails = publishedArticles.map(art => {
  const sources = db.prepare("SELECT * FROM sources WHERE article_id = ?").all(art.id) as any[];
  const socialPosts = db.prepare("SELECT * FROM social_posts WHERE article_id = ?").all(art.id) as any[];
  return { ...art, sources, socialPosts };
});

// 3. Elementos del radar pendientes
const pendingRadarItems = db.prepare(`
  SELECT * FROM scraped_items 
  WHERE status = 'pendiente'
  ORDER BY created_at DESC
`).all() as any[];

// 4. Fuentes del radar
const radarSources = db.prepare("SELECT * FROM radar_sources ORDER BY platform, name").all() as any[];

// 5. Todos los temas (para administración)
const allTopics = db.prepare("SELECT * FROM topics ORDER BY title").all() as any[];

// 6. Temas activos para el selector de vinculación
const activeTopics = allTopics.filter(t => t.status === 'activo');

db.close();

// Mapa de veredicto a color neón
const getVerdictClass = (verdict) => {
  const v = (verdict || '').toLowerCase();
  if (v.includes('verdadero')) return 'green';
  if (v.includes('falso')) return 'rose';
  if (v.includes('engañoso') || v.includes('contexto')) return 'amber';
  return 'purple';
};

const currentTab = Astro.url.searchParams.get('tab') || 'aprobacion';
---

<Layout title="Panel de Administración y Aprobación Rápida">
  <div class="container" style="padding-top: 1.5rem; padding-bottom: 5rem; max-width: 900px;">
    
    <div style="margin-bottom: 2.5rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid var(--border-color); padding-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 style="font-size: 2.5rem; margin-bottom: 0.25rem; font-family: var(--font-title); font-weight: 850; letter-spacing: -0.02em;">
          ⚡ Panel de <span class="text-gradient-blue">Control Editorial</span>
        </h1>
        <p style="color: var(--text-muted); font-size: 0.9rem;">
          Edita y aprueba desmentidos, gestiona los expedientes temáticos, configura las fuentes del radar y compila el portal.
        </p>
      </div>

      <div style="display: flex; gap: 1rem;">
        <button 
          onclick="triggerBuild()" 
          id="build-btn" 
          class="cyber-btn accent" 
          style="box-shadow: 2px 2px 0px 0px var(--text-main); font-weight: 800;"
        >
          🚀 Compilar SSG (Astro Build)
        </button>
      </div>
    </div>

    <!-- Mensajes de Notificación -->
    {message && (
      <div 
        style={{
          padding: '1rem',
          marginBottom: '2rem',
          fontWeight: 'bold',
          border: '2px solid',
          borderRadius: '4px',
          background: messageType === 'success' 
            ? 'rgba(57, 255, 20, 0.03)' 
            : messageType === 'error'
            ? 'rgba(255, 0, 127, 0.03)'
            : 'rgba(0, 240, 255, 0.03)',
          borderColor: messageType === 'success' 
            ? 'var(--neon-green)' 
            : messageType === 'error'
            ? 'var(--neon-rose)'
            : 'var(--neon-blue)',
          color: messageType === 'success' 
            ? 'var(--neon-green)' 
            : messageType === 'error'
            ? 'var(--neon-rose)'
            : 'var(--neon-blue)'
        }}
      >
        {message}
      </div>
    )}

    <!-- Sección de Re-construcción Feedback -->
    <div id="build-status-box" style="display: none; padding: 1.25rem; margin-bottom: 2rem; background: rgba(7,9,19,0.9); border: 2px dashed var(--neon-blue); color: var(--neon-blue); font-family: monospace; font-size: 0.85rem; line-height: 1.5; border-radius: 6px;">
      [SYSTEM] Iniciando pipeline de compilación Astro... <br/>
      [INFO] Leyendo base de datos SQLite (data/newnews.db)... <br/>
      [INFO] Generando rutas estáticas para temas y noticias... <br/>
      [SUCCESS] ¡Compilación estática completa! 100% de páginas actualizadas.
    </div>

    <!-- Menú de Pestañas Horizontal Premium -->
    <div class="tabs-navigation">
      <a href="?tab=aprobacion" class={`tab-link-btn ${currentTab === 'aprobacion' ? 'active' : ''}`}>
        📥 Cola Aprobación ({draftsWithDetails.length})
      </a>
      <a href="?tab=publicados" class={`tab-link-btn ${currentTab === 'publicados' ? 'active' : ''}`}>
        📰 Publicados ({publishedWithDetails.length})
      </a>
      <a href="?tab=temas" class={`tab-link-btn ${currentTab === 'temas' ? 'active' : ''}`}>
        📁 Expedientes ({allTopics.length})
      </a>
      <a href="?tab=fuentes" class={`tab-link-btn ${currentTab === 'fuentes' ? 'active' : ''}`}>
        📡 Radar y Fuentes ({pendingRadarItems.length})
      </a>
    </div>

    <!-- PESTAÑA 1: COLA DE APROBACIÓN -->
    {currentTab === 'aprobacion' && (
      <section style="display: flex; flex-direction: column; gap: 2rem;">
        <h2 class="section-title">📥 Borradores redactados por la IA</h2>

        {draftsWithDetails.map(art => (
          <div class={`cyber-card ${getVerdictClass(art.verdict)}`} style="padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; position: relative;">
            
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem;">
                <span class={`verdict-badge ${art.verdict.toLowerCase().replace(' ', '-')}`}>
                  Veredicto sugerido: {art.verdict}
                </span>
                <span style="font-size: 0.8rem; color: var(--text-muted);">Confianza: <strong>{art.confidence || 'Media'}</strong></span>
              </div>
              <span style="font-size: 0.8rem; color: var(--text-muted);">
                Creado: {new Date(art.created_at).toLocaleString('es-ES')}
              </span>
            </div>

            <div>
              <h3 style="font-size: 1.4rem; margin-bottom: 0.5rem; color: var(--text-main); font-weight: 700;">{art.title}</h3>
              <p style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1rem; line-height: 1.4;">{art.subtitle}</p>
              <div style="background: rgba(0,0,0,0.25); border-left: 3px solid var(--border-color); padding: 0.75rem; font-size: 0.85rem; font-style: italic; color: var(--text-muted);">
                <strong>Reclamación original:</strong> "{art.claim}"
              </div>
            </div>

            <div>
              <strong style="font-size: 0.8rem; color: var(--text-main); text-transform: uppercase; display: block; margin-bottom: 0.5rem;">Explicación y Datos Contrastados (INE/BOE):</strong>
              <div style="background: var(--bg-dark); padding: 1rem; border: 1px solid var(--border-color); font-size: 0.9rem; color: var(--text-muted); max-height: 250px; overflow-y: auto; white-space: pre-wrap; line-height: 1.5; border-radius: 4px;">{art.explanation}</div>
            </div>

            <!-- Listado de fuentes del borrador -->
            {art.sources && art.sources.length > 0 && (
              <div>
                <strong style="font-size: 0.8rem; color: var(--text-main); text-transform: uppercase; display: block; margin-bottom: 0.4rem;">Fuentes Citadas:</strong>
                <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                  {art.sources.map(src => (
                    <a href={src.url} target="_blank" rel="noopener noreferrer" style="font-size: 0.8rem; color: var(--neon-blue); text-decoration: none; display: inline-flex; align-items: center; gap: 0.35rem;">
                      🔗 <strong>[{src.authority_level}]</strong> {src.title}
                    </a>
                  ))}
                </div>
              </div>
            )}

            <!-- Edición en línea mediante <details> nativo -->
            <details style="border-top: 1px dashed var(--border-color); padding-top: 1.25rem; margin-top: 0.5rem;">
              <summary style="font-weight: 800; cursor: pointer; color: var(--neon-purple); font-size: 0.85rem; outline: none; list-style: none; display: flex; align-items: center; gap: 0.25rem;">
                ✏️ Editar Borrador (Modificar Contenido / Fuentes del INE)
              </summary>
              
              <form method="POST" style="display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.25rem; background: rgba(0,0,0,0.15); padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 6px;">
                <input type="hidden" name="action" value="edit_article" />
                <input type="hidden" name="article_id" value={art.id} />
                <input type="hidden" name="status" value="borrador" />

                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">Título del Artículo:</label>
                    <input type="text" name="title" value={art.title} required class="edit-input" />
                  </div>
                  <div>
                    <label class="edit-label">Veredicto:</label>
                    <select name="verdict" class="edit-input">
                      <option value="Falso" selected={art.verdict === 'Falso'}>Falso</option>
                      <option value="Verdadero" selected={art.verdict === 'Verdadero'}>Verdadero</option>
                      <option value="Engañoso" selected={art.verdict === 'Engañoso'}>Engañoso</option>
                      <option value="Falta contexto" selected={art.verdict === 'Falta contexto'}>Falta contexto</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label class="edit-label">Subtítulo / Resumen Corto:</label>
                  <input type="text" name="subtitle" value={art.subtitle} required class="edit-input" />
                </div>

                <div>
                  <label class="edit-label">Explicación Completa y Datos Oficiales:</label>
                  <textarea name="explanation" rows="8" required class="edit-input" style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.4;">{art.explanation}</textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">¿Qué es Verdad? (Cifras/Datos):</label>
                    <textarea name="what_is_true" rows="3" class="edit-input">{art.what_is_true}</textarea>
                  </div>
                  <div>
                    <label class="edit-label">¿Qué es Mentira / Bulo?:</label>
                    <textarea name="what_is_false" rows="3" class="edit-input">{art.what_is_false}</textarea>
                  </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">¿Qué falta contextualizar?:</label>
                    <textarea name="what_lacks_context" rows="3" class="edit-input">{art.what_lacks_context}</textarea>
                  </div>
                  <div>
                    <label class="edit-label">¿Qué no está probado?:</label>
                    <textarea name="what_is_not_proven" rows="3" class="edit-input">{art.what_is_not_proven}</textarea>
                  </div>
                </div>

                <div>
                  <label class="edit-label">Vincular a Expediente Activo:</label>
                  <select name="topic_id" class="edit-input">
                    <option value="">— Sin expediente —</option>
                    {activeTopics.map(t => (
                      <option value={t.id} selected={art.topic_id === t.id}>[{t.category}] {t.title}</option>
                    ))}
                  </select>
                </div>

                <button type="submit" class="cyber-btn" style="border-color: var(--neon-purple); color: var(--neon-purple); width: 100%; box-shadow: 2px 2px 0px 0px rgba(157, 78, 221, 0.15); font-weight: 800;">
                  💾 Guardar Cambios en Borrador
                </button>
              </form>
            </details>

            <!-- Aprobación / Rechazo -->
            <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
              <form method="POST" style="flex-grow: 1; margin: 0;">
                <input type="hidden" name="action" value="approve" />
                <input type="hidden" name="article_id" value={art.id} />
                <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main); font-weight: 800;">
                  ✓ Aprobar y Publicar en Web
                </button>
              </form>

              <form method="POST" style="margin: 0;">
                <input type="hidden" name="action" value="reject" />
                <input type="hidden" name="article_id" value={art.id} />
                <button type="submit" class="cyber-btn" style="border-color: var(--neon-rose); color: var(--neon-rose); box-shadow: 2px 2px 0px 0px rgba(255, 51, 102, 0.15);">
                  Rechazar
                </button>
              </form>
            </div>

          </div>
        ))}

        {draftsWithDetails.length === 0 && (
          <p class="empty-state">No hay borradores pendientes de revisión. El radar de IA está al día.</p>
        )}
      </section>
    )}

    <!-- PESTAÑA 2: ARTÍCULOS PUBLICADOS -->
    {currentTab === 'publicados' && (
      <section style="display: flex; flex-direction: column; gap: 2rem;">
        <h2 class="section-title">📰 Histórico de Noticias Publicadas</h2>

        {publishedWithDetails.map(art => (
          <div class={`cyber-card ${getVerdictClass(art.verdict)}`} style="padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem;">
            
            <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem;">
                <span class={`verdict-badge ${art.verdict.toLowerCase().replace(' ', '-')}`}>
                  {art.verdict}
                </span>
                <span style="font-size: 0.75rem; color: var(--text-muted);">Expediente: <strong>{art.topic_title || 'General'}</strong></span>
              </div>
              <span style="font-size: 0.75rem; color: var(--text-muted);">
                Publicado: {new Date(art.published_at || art.created_at).toLocaleString('es-ES')}
              </span>
            </div>

            <div>
              <h3 style="font-size: 1.25rem; margin-bottom: 0.35rem; color: var(--text-main); font-weight: 700;">{art.title}</h3>
              <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin: 0;">{art.subtitle}</p>
            </div>

            <!-- Edición de Publicado -->
            <details style="border-top: 1px dashed var(--border-color); padding-top: 1rem; margin-top: 0.25rem;">
              <summary style="font-weight: 800; cursor: pointer; color: var(--neon-blue); font-size: 0.8rem; outline: none; list-style: none;">
                ✏️ Editar Contenido / Despublicar
              </summary>
              
              <form method="POST" style="display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1.25rem; background: rgba(0,0,0,0.15); padding: 1.5rem; border: 1px solid var(--border-color); border-radius: 6px;">
                <input type="hidden" name="action" value="edit_article" />
                <input type="hidden" name="article_id" value={art.id} />

                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">Título del Artículo:</label>
                    <input type="text" name="title" value={art.title} required class="edit-input" />
                  </div>
                  <div>
                    <label class="edit-label">Veredicto:</label>
                    <select name="verdict" class="edit-input">
                      <option value="Falso" selected={art.verdict === 'Falso'}>Falso</option>
                      <option value="Verdadero" selected={art.verdict === 'Verdadero'}>Verdadero</option>
                      <option value="Engañoso" selected={art.verdict === 'Engañoso'}>Engañoso</option>
                      <option value="Falta contexto" selected={art.verdict === 'Falta contexto'}>Falta contexto</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label class="edit-label">Subtítulo / Resumen Corto:</label>
                  <input type="text" name="subtitle" value={art.subtitle} required class="edit-input" />
                </div>

                <div>
                  <label class="edit-label">Explicación Completa y Datos Oficiales:</label>
                  <textarea name="explanation" rows="8" required class="edit-input" style="font-family: var(--font-body); font-size: 0.9rem; line-height: 1.4;">{art.explanation}</textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">¿Qué es Verdad? (Cifras/Datos):</label>
                    <textarea name="what_is_true" rows="3" class="edit-input">{art.what_is_true}</textarea>
                  </div>
                  <div>
                    <label class="edit-label">¿Qué es Mentira / Bulo?:</label>
                    <textarea name="what_is_false" rows="3" class="edit-input">{art.what_is_false}</textarea>
                  </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">¿Qué falta de contexto?:</label>
                    <textarea name="what_lacks_context" rows="3" class="edit-input">{art.what_lacks_context}</textarea>
                  </div>
                  <div>
                    <label class="edit-label">¿Qué no está probado?:</label>
                    <textarea name="what_is_not_proven" rows="3" class="edit-input">{art.what_is_not_proven}</textarea>
                  </div>
                </div>

                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                  <div>
                    <label class="edit-label">Vincular a Expediente Activo:</label>
                    <select name="topic_id" class="edit-input">
                      <option value="">— Sin expediente —</option>
                      {activeTopics.map(t => (
                        <option value={t.id} selected={art.topic_id === t.id}>[{t.category}] {t.title}</option>
                      ))}
                    </select>
                  </div>
                  <div>
                    <label class="edit-label">Estado:</label>
                    <select name="status" class="edit-input">
                      <option value="publicado" selected={art.status === 'publicado'}>Publicado (En Vivo)</option>
                      <option value="borrador" selected={art.status === 'borrador'}>Borrador (Ocultar)</option>
                    </select>
                  </div>
                </div>

                <button type="submit" class="cyber-btn" style="border-color: var(--neon-blue); color: var(--neon-blue); width: 100%; box-shadow: 2px 2px 0px 0px rgba(0, 240, 255, 0.15); font-weight: 800;">
                  💾 Actualizar y Guardar Cambios
                </button>
              </form>
            </details>

            <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
              <form method="POST" style="margin: 0; width: 100%;">
                <input type="hidden" name="action" value="delete_article" />
                <input type="hidden" name="article_id" value={art.id} />
                <button type="submit" class="cyber-btn" style="border-color: var(--neon-rose); color: var(--neon-rose); width: 100%; font-size: 0.75rem; padding: 0.35rem;" onclick="return confirm('¿Seguro que deseas eliminar definitivamente este artículo de la base de datos? Esta acción no se puede deshacer.')">
                  🗑️ Eliminar Definitivamente
                </button>
              </form>
            </div>

          </div>
        ))}

        {publishedWithDetails.length === 0 && (
          <p class="empty-state">No hay ningún artículo publicado. Ejecuta e ingresa datos.</p>
        )}
      </section>
    )}

    <!-- PESTAÑA 3: GESTIÓN DE EXPEDIENTES / TEMAS -->
    {currentTab === 'temas' && (
      <section style="display: flex; flex-direction: column; gap: 2rem;">
        
        <!-- Crear Nuevo Tema -->
        <div class="cyber-card" style="padding: 2rem; background: linear-gradient(180deg, rgba(157, 78, 221, 0.03) 0%, rgba(18, 22, 41, 0.95) 100%); border-color: rgba(157, 78, 221, 0.25);">
          <h3 style="font-size: 1.4rem; color: var(--neon-purple); margin-bottom: 0.5rem; font-weight: 700;">📁 Crear Nuevo Expediente Temático</h3>
          <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">
            Añade un nuevo dossier o categoría de investigación al portal. Esto creará una página vertical independiente en el sitio.
          </p>

          <form method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <input type="hidden" name="action" value="create_topic" />

            <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1rem;">
              <div>
                <label class="edit-label">Título del Tema:</label>
                <input type="text" name="title" required placeholder="Ej: Cotizaciones Autónomos" class="edit-input" />
              </div>
              <div>
                <label class="edit-label">Categoría:</label>
                <input type="text" name="category" required placeholder="Ej: Economía" class="edit-input" />
              </div>
              <div>
                <label class="edit-label">Confianza / Ruido:</label>
                <select name="confidence" class="edit-input">
                  <option value="Alta">Alta (Poco Ruido)</option>
                  <option value="Media">Media</option>
                  <option value="Baja">Baja (Mucho Ruido)</option>
                  <option value="Oficial">Oficial / Datos</option>
                </select>
              </div>
            </div>

            <div>
              <label class="edit-label">Descripción del Expediente (Público):</label>
              <textarea name="description" rows="3" required placeholder="Describe brevemente la controversia, bulos recurrentes y leyes de contraste..." class="edit-input"></textarea>
            </div>

            <div>
              <label class="edit-label">Resumen de Veredicto General:</label>
              <input type="text" name="verdict_summary" required placeholder="Ej: Falso sobre cuotas de 500€ generalizadas y desglose de tramos oficiales." class="edit-input" />
            </div>

            <button type="submit" class="cyber-btn" style="border-color: var(--neon-purple); color: var(--neon-purple); font-weight: 800; box-shadow: 2px 2px 0px 0px rgba(157, 78, 221, 0.15);">
              + Crear Expediente Temático
            </button>
          </form>
        </div>

        <!-- Listado de temas existentes -->
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <h3 class="section-title">📂 Expedientes y Dossiers Activos ({allTopics.length})</h3>
          
          {allTopics.map(topic => (
            <div class="cyber-card" style="padding: 1.5rem; background: rgba(18, 22, 41, 0.45); display: flex; flex-direction: column; gap: 1rem;">
              
              <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;">
                <div>
                  <span style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; background: rgba(255,255,255,0.05); padding: 0.15rem 0.4rem; border-radius: 3px; color: var(--neon-blue); border: 1px solid rgba(0, 240, 255, 0.1); margin-right: 0.5rem;">{topic.category}</span>
                  <strong style="font-size: 1.15rem; color: var(--text-main); font-family: var(--font-title);">{topic.title}</strong>
                </div>
                <span style="font-size: 0.75rem; color: topic.status === 'activo' ? 'var(--neon-green)' : 'var(--neon-rose)'; font-weight: 700; text-transform: uppercase;">
                  [{topic.status}]
                </span>
              </div>

              <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin: 0;">{topic.description}</p>
              
              <div style="font-size: 0.8rem; background: var(--bg-dark); padding: 0.5rem 0.75rem; border-left: 2px solid var(--border-color); color: var(--text-muted);">
                <strong>Resumen de Veredictos:</strong> {topic.verdict_summary || 'Sin definir.'}
              </div>

              <!-- Edición de Tema mediante <details> -->
              <details style="border-top: 1px dashed var(--border-color); padding-top: 1rem; margin-top: 0.25rem;">
                <summary style="font-weight: 800; cursor: pointer; color: var(--neon-purple); font-size: 0.8rem; outline: none; list-style: none;">
                  ✏️ Editar Expediente
                </summary>
                
                <form method="POST" style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem; background: rgba(0,0,0,0.15); padding: 1.25rem; border: 1px solid var(--border-color); border-radius: 6px;">
                  <input type="hidden" name="action" value="edit_topic" />
                  <input type="hidden" name="topic_id" value={topic.id} />

                  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                    <div>
                      <label class="edit-label">Título:</label>
                      <input type="text" name="title" value={topic.title} required class="edit-input" />
                    </div>
                    <div>
                      <label class="edit-label">Categoría:</label>
                      <input type="text" name="category" value={topic.category} required class="edit-input" />
                    </div>
                  </div>

                  <div>
                    <label class="edit-label">Descripción del Expediente:</label>
                    <textarea name="description" rows="3" required class="edit-input">{topic.description}</textarea>
                  </div>

                  <div>
                    <label class="edit-label">Resumen de Veredicto:</label>
                    <input type="text" name="verdict_summary" value={topic.verdict_summary || ''} required class="edit-input" />
                  </div>

                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                      <label class="edit-label">Estado:</label>
                      <select name="status" class="edit-input">
                        <option value="activo" selected={topic.status === 'activo'}>Activo (Visible)</option>
                        <option value="pausado" selected={topic.status === 'pausado'}>Pausado (Oculto)</option>
                      </select>
                    </div>
                    <div>
                      <label class="edit-label">Confianza / Ruido:</label>
                      <select name="confidence" class="edit-input">
                        <option value="Alta" selected={topic.confidence === 'Alta'}>Alta (Poco Ruido)</option>
                        <option value="Media" selected={topic.confidence === 'Media'}>Media</option>
                        <option value="Baja" selected={topic.confidence === 'Baja'}>Baja (Mucho Ruido)</option>
                        <option value="Oficial" selected={topic.confidence === 'Oficial'}>Oficial / Datos</option>
                      </select>
                    </div>
                  </div>

                  <button type="submit" class="cyber-btn" style="border-color: var(--neon-purple); color: var(--neon-purple); font-weight: 800; width: 100%;">
                    💾 Guardar Cambios en Expediente
                  </button>
                </form>
              </details>

            </div>
          ))}
        </div>

      </section>
    )}

    <!-- PESTAÑA 4: RADAR, FUENTES Y COMPROBADOR -->
    {currentTab === 'fuentes' && (
      <div class="radar-grid" style="display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 2rem;">
        
        <!-- Columna Izquierda: Comprobador y Cola -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Comprobador de URL -->
          <div class="cyber-card" style="padding: 2rem; background: linear-gradient(180deg, rgba(0, 240, 255, 0.04) 0%, rgba(18, 22, 41, 0.95) 100%); border: 2px solid rgba(0, 240, 255, 0.3);">
            <h3 style="font-size: 1.4rem; margin-bottom: 0.25rem; color: var(--neon-blue); font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
              🔍 <span class="text-gradient-blue">Comprobador de URL en Vivo</span>
            </h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem; line-height: 1.4;">
              Pega cualquier URL de redes o prensa. El sistema consultará la plataforma real, extraerá los metadatos verificados (títulos, autores, visualizaciones reales) y la vinculará al expediente.
            </p>

            <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem;">
              <input type="hidden" name="action" value="check_url" />
              
              <div>
                <label style="font-size: 0.7rem; color: var(--neon-blue); display: block; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">URL a Verificar:</label>
                <input 
                  type="url" 
                  name="check_url" 
                  required 
                  placeholder="https://youtube.com/shorts/... o t.me/canal/123"
                  style="width: 100%; padding: 0.65rem; background: var(--bg-dark); border: 2px solid rgba(0, 240, 255, 0.25); color: var(--text-main); font-family: monospace; font-size: 0.85rem; border-radius: 4px;"
                />
              </div>

              <button type="submit" class="cyber-btn" style="width: 100%; border-color: var(--neon-blue); color: var(--neon-blue); font-weight: 800; box-shadow: 2px 2px 0px 0px rgba(0, 240, 255, 0.15);">
                ⚡ Analizar y Verificar URL
              </button>
            </form>

            <!-- Resultado del Análisis -->
            {urlCheckResult && urlCheckResult.isAccessible && (
              <div style="border: 2px solid rgba(57, 255, 20, 0.25); background: rgba(57, 255, 20, 0.02); padding: 1.25rem; margin-top: 1.5rem; border-radius: 6px;">
                <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-green); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">✅ Metadatos Extraídos Exitosamente</span>
                
                <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem;">
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted);">Plataforma:</span>
                    <span style="color: var(--neon-blue); font-weight: 700;">{urlCheckResult.platform}</span>
                  </div>
                  {urlCheckResult.title && (
                    <div style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted); font-size: 0.75rem; display: block; margin-bottom: 0.15rem;">Título Extraído:</span>
                      <span style="color: var(--text-main); font-weight: 600; line-height: 1.3; display: block;">{urlCheckResult.title}</span>
                    </div>
                  )}
                  {urlCheckResult.author && (
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted);">Autor / Cuenta:</span>
                      <span style="color: var(--text-main); font-weight: 600;">{urlCheckResult.author}</span>
                    </div>
                  )}
                  {urlCheckResult.views && (
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted);">Vistas / Reproducciones:</span>
                      <span style="color: var(--neon-rose); font-weight: 700;">{urlCheckResult.views}</span>
                    </div>
                  )}
                  {urlCheckResult.date && (
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted);">Fecha Publicación:</span>
                      <span style="color: var(--text-main);">{new Date(urlCheckResult.date).toLocaleString('es-ES')}</span>
                    </div>
                  )}
                  {urlCheckResult.imageUrl && (
                    <div style="margin-top: 0.75rem; border: 1px solid var(--border-color); overflow: hidden; border-radius: 4px;">
                      <img src={urlCheckResult.imageUrl} alt="Preview" style="width: 100%; height: auto; display: block; max-height: 180px; object-fit: cover;" />
                    </div>
                  )}
                </div>

                <!-- Confirmar e insertar en radar -->
                <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.25rem; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
                  <input type="hidden" name="action" value="insert_checked_url" />
                  <input type="hidden" name="url" value={urlCheckResult.rawUrl} />
                  <input type="hidden" name="platform" value={urlCheckResult.platform} />
                  <input type="hidden" name="title" value={urlCheckResult.title || ''} />
                  <input type="hidden" name="description" value={urlCheckResult.description || ''} />
                  <input type="hidden" name="author" value={urlCheckResult.author || 'Editor'} />

                  <div>
                    <label style="font-size: 0.75rem; color: var(--neon-green); display: block; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">Vincular a Expediente Temático:</label>
                    <select name="topic_id" class="edit-input" style="border-color: rgba(57, 255, 20, 0.25);">
                      <option value="">— Sin expediente (General) —</option>
                      {activeTopics.map(t => (
                        <option value={t.id}>[{t.category}] {t.title}</option>
                      ))}
                    </select>
                  </div>

                  <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main); font-weight: 800;">
                    ✅ Confirmar e Insertar en la Cola del Radar
                  </button>
                </form>
              </div>
            )}

            {urlCheckResult && !urlCheckResult.isAccessible && (
              <div style="border: 2px solid rgba(255, 51, 102, 0.25); background: rgba(255, 51, 102, 0.02); padding: 1.25rem; font-size: 0.85rem; margin-top: 1.5rem; border-radius: 6px;">
                <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.7rem; display: block; margin-bottom: 0.35rem;">❌ URL No Accesible</span>
                <p style="color: var(--text-muted); margin: 0; line-height: 1.4;">{urlCheckResult.error || 'La URL no es pública o no devuelve una respuesta correcta. Puedes ingresarla manualmente en la caja inferior.'}</p>
              </div>
            )}
          </div>

          <!-- Cola de radar items -->
          <div class="cyber-card" style="padding: 1.5rem;">
            <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-purple); font-weight: 700;">📡 Cola del Radar ({pendingRadarItems.length})</h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.25rem;">
              Publicaciones capturadas automáticamente de redes esperando ser redactadas en lote.
            </p>

            <div style="display: flex; flex-direction: column; gap: 0.75rem; max-height: 400px; overflow-y: auto;">
              {pendingRadarItems.map(item => (
                <div style="border: 1px solid var(--border-color); padding: 0.75rem; background: var(--bg-dark); font-size: 0.8rem; border-radius: 4px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 0.35rem;">
                    <span style="color: var(--neon-blue); font-weight: bold;">{item.platform}</span>
                    <span style="color: var(--neon-rose); font-weight: 700;">Vir: {item.virality_score}/10</span>
                  </div>
                  <p style="color: var(--text-muted); margin: 0 0 0.35rem 0; line-height: 1.35; font-size: 0.8rem;">
                    "{item.detected_claim || item.text.substring(0, 120)}..."
                  </p>
                  {item.url && (
                    <a href={item.url} target="_blank" rel="noopener noreferrer" style="font-size: 0.7rem; color: var(--text-muted); display: block; text-decoration: none; word-break: break-all; margin-bottom: 0.25rem;">
                      🔗 Link original: {item.url}
                    </a>
                  )}
                  <span style="font-size: 0.7rem; color: var(--text-muted); display: block; text-align: right;">
                    Ingresado: {new Date(item.created_at).toLocaleDateString('es-ES')}
                  </span>
                </div>
              ))}

              {pendingRadarItems.length === 0 && (
                <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 1.5rem;">No hay items pendientes en el radar.</p>
              )}
            </div>
          </div>

        </div>

        <!-- Columna Derecha: Configurar Fuentes e Inserción manual -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Configurar fuentes de radar -->
          <div class="cyber-card" style="padding: 1.5rem; background: rgba(0, 240, 255, 0.02); border-color: rgba(0, 240, 255, 0.25);">
            <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-blue); font-weight: 700;">📡 Fuentes de Monitorización</h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.25rem;">
              Canales de Telegram, subreddits o feeds RSS monitorizados periódicamente.
            </p>

            <div style="display: flex; flex-direction: column; gap: 0.65rem; max-height: 300px; overflow-y: auto; margin-bottom: 1.25rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; padding-right: 0.25rem;">
              {radarSources.map(src => (
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem; background: var(--bg-dark); border: 1px solid var(--border-color); font-size: 0.8rem; border-radius: 4px;">
                  <div>
                    <span style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; background: rgba(255,255,255,0.05); padding: 0.1rem 0.25rem; border-radius: 2px; margin-right: 0.35rem; color: var(--neon-purple);">{src.platform}</span>
                    <strong style="color: var(--text-main);">{src.name}</strong>
                    <span style="display: block; font-size: 0.7rem; color: var(--text-muted); text-overflow: ellipsis; overflow: hidden; max-width: 170px; white-space: nowrap;" title={src.url_or_id}>{src.url_or_id}</span>
                  </div>
                  <form method="POST" style="margin: 0;">
                    <input type="hidden" name="action" value="delete_radar_source" />
                    <input type="hidden" name="source_id" value={src.id} />
                    <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.95rem;" title="Eliminar fuente">🗑️</button>
                  </form>
                </div>
              ))}
            </div>

            <!-- Formulario de añadir fuente -->
            <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
              <input type="hidden" name="action" value="add_radar_source" />
              
              <div>
                <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Plataforma:</label>
