                </div>
                <strong style="color: var(--text-main); font-size: 0.9rem; display: block; margin-bottom: 0.35rem;">"{prom.promise_text}"</strong>
                {prom.action_taken && <p style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; margin: 0 0 0.5rem 0;"><strong>Acción:</strong> {prom.action_taken}</p>}
                {prom.evidence_url && (
                  <a href={prom.evidence_url} target="_blank" rel="noopener noreferrer" style="font-size: 0.75rem; color: var(--neon-blue); text-decoration: none;">
                    🔗 Evidencia: {prom.evidence_summary || 'Ver documento oficial'}
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- SECCIÓN 4: DECLARACIONES DE BIENES (ASSET DECLARATIONS) -->
        <div class="cyber-card" style="padding: 1.5rem; border-color: rgba(255, 0, 127, 0.3);">
          <h3 style="font-size: 1.25rem; color: var(--neon-rose); margin-bottom: 1rem; font-weight: 700;">💼 Declaraciones de Bienes y Patrimonio ({allDeclarations.length})</h3>
          
          <!-- Formulario de creación de Declaración -->
          <details style="margin-bottom: 1.5rem; border: 1px dashed rgba(255,255,255,0.1); padding: 1rem; border-radius: 6px;">
            <summary style="font-weight: 800; cursor: pointer; color: var(--neon-blue); font-size: 0.82rem;">+ Registrar Declaración de Bienes</summary>
            <form method="POST" style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
              <input type="hidden" name="action" value="create_declaration" />
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                  <label class="edit-label">Partido Político:</label>
                  <select name="party_id" required class="edit-input">
                    {allParties.map(p => <option value={p.id}>{p.name}</option>)}
                  </select>
                </div>
                <div>
                  <label class="edit-label">Nombre del Cargo Público:</label>
                  <input type="text" name="person_name" required placeholder="Ej: Pedro Sánchez Pérez-Castejón" class="edit-input" />
                </div>
              </div>
              <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
                <div>
                  <label class="edit-label">Cargo / Rol Público:</label>
                  <input type="text" name="role" required placeholder="Ej: Presidente del Gobierno y Diputado" class="edit-input" />
                </div>
                <div>
                  <label class="edit-label">Link Declaración Oficial (Congreso / Senado):</label>
                  <input type="url" name="source_url" placeholder="https://www.congreso.es/..." class="edit-input" />
                </div>
              </div>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                  <label class="edit-label">Resumen de Bienes y Activos:</label>
                  <textarea name="declared_assets_summary" rows="3" required placeholder="Viviendas, saldos en cuenta corriente, acciones, vehículos..." class="edit-input"></textarea>
                </div>
                <div>
                  <label class="edit-label">Resumen de Deudas y Pasivos:</label>
                  <textarea name="declared_debts_summary" rows="3" placeholder="Préstamos hipotecarios pendientes, créditos..." class="edit-input"></textarea>
                </div>
              </div>
              <button type="submit" class="cyber-btn" style="border-color: var(--neon-blue); color: var(--neon-blue); font-size: 0.8rem; font-weight: 800;">
                Guardar Declaración
              </button>
            </form>
          </details>

          <!-- Listado de Declaraciones -->
          <div style="display: flex; flex-direction: column; gap: 0.75rem; max-height: 400px; overflow-y: auto; padding-right: 0.25rem;">
            {allDeclarations.map(decl => (
              <div style="background: var(--bg-dark); border: 1px solid var(--border-color); padding: 1rem; border-radius: 4px; position: relative;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                  <div>
                    <strong style="color: var(--text-main); font-size: 0.95rem; display: block;">{decl.person_name}</strong>
                    <span style="font-size: 0.75rem; color: var(--text-muted);">{decl.role} ({decl.party_name})</span>
                  </div>
                  <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <details style="margin: 0; position: relative;">
                      <summary style="list-style: none; cursor: pointer; padding: 0.15rem 0.35rem; background: rgba(255,255,255,0.05); font-size: 0.7rem; border-radius: 4px;">Editar</summary>
                      <div style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.75rem; background: rgba(18, 22, 41, 0.95); padding: 1.25rem; border: 1px solid var(--border-color); border-radius: 6px; position: absolute; right: 0; z-index: 100; width: 320px; box-shadow: 0 4px 25px rgba(0,0,0,0.8);">
                        <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin: 0;">
                          <input type="hidden" name="action" value="edit_declaration" />
                          <input type="hidden" name="declaration_id" value={decl.id} />
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Nombre:</label>
                            <input type="text" name="person_name" value={decl.person_name} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Rol/Cargo:</label>
                            <input type="text" name="role" value={decl.role} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">URL Oficial:</label>
                            <input type="url" name="source_url" value={decl.source_url} class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Bienes:</label>
                            <textarea name="declared_assets_summary" rows="3" required class="edit-input" style="font-size: 0.8rem; padding: 0.35rem;">{decl.declared_assets_summary}</textarea>
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Deudas:</label>
                            <textarea name="declared_debts_summary" rows="3" class="edit-input" style="font-size: 0.8rem; padding: 0.35rem;">{decl.declared_debts_summary}</textarea>
                          </div>
                          <button type="submit" class="cyber-btn accent" style="padding: 0.4rem; font-size: 0.75rem; font-weight: bold; width: 100%;">Actualizar</button>
                        </form>
                      </div>
                    </details>
                    <form method="POST" style="margin: 0; display: inline-block;">
                      <input type="hidden" name="action" value="delete_declaration" />
                      <input type="hidden" name="declaration_id" value={decl.id} />
                      <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.95rem;" onclick="return confirm('¿Seguro que deseas eliminar esta declaración de bienes?')">🗑️</button>
                    </form>
                  </div>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; font-size: 0.8rem; margin-top: 0.5rem; border-top: 1px dashed rgba(255,255,255,0.05); padding-top: 0.5rem;">
                  <div>
                    <span style="color: var(--neon-green); font-weight: bold; display: block; font-size: 0.7rem; text-transform: uppercase;">Bienes Declarados:</span>
                    <span style="color: var(--text-muted);">{decl.declared_assets_summary}</span>
                  </div>
                  <div>
                    <span style="color: var(--neon-rose); font-weight: bold; display: block; font-size: 0.7rem; text-transform: uppercase;">Deudas y Pasivos:</span>
                    <span style="color: var(--text-muted);">{decl.declared_debts_summary || 'Ninguna.'}</span>
                  </div>
                </div>
                {decl.source_url && (
                  <a href={decl.source_url} target="_blank" rel="noopener noreferrer" style="font-size: 0.75rem; color: var(--neon-blue); text-decoration: none; display: inline-block; margin-top: 0.5rem;">
                    🔗 Documento Oficial de Declaración
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>

      </section>
    )}

    <!-- PESTAÑA 4: RADAR, FUENTES Y COMPROBADOR -->
    {currentTab === 'fuentes' && (
      <div class="radar-grid" style="display: grid; grid-template-columns: 1.8fr 1.2fr; gap: 2rem;">
        
        <!-- Columna Izquierda: Comprobador y Cola -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Comprobador de URL -->
          <div class="cyber-card" style="padding: 2rem; background: linear-gradient(180deg, rgba(0, 240, 255, 0.04) 0%, rgba(18, 22, 41, 0.95) 100%); border: 2px solid rgba(0, 240, 255, 0.3);">
            <h3 style="font-size: 1.4rem; margin-bottom: 0.25rem; color: var(--neon-blue); font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
              🔍 <span class="text-gradient-blue">Comprobador de URL en Vivo</span>
            </h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem; line-height: 1.4;">
              Pega cualquier URL de redes o prensa. El sistema consultará la plataforma real, extraerá los metadatos verificados (títulos, autores, visualizaciones reales) y la vinculará al expediente.
            </p>

            <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 1rem;">
              <input type="hidden" name="action" value="check_url" />
              
              <div>
                <label style="font-size: 0.7rem; color: var(--neon-blue); display: block; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">URL a Verificar:</label>
                <input 
                  type="url" 
                  name="check_url" 
                  required 
                  placeholder="https://youtube.com/shorts/... o t.me/canal/123"
                  style="width: 100%; padding: 0.65rem; background: var(--bg-dark); border: 2px solid rgba(0, 240, 255, 0.25); color: var(--text-main); font-family: monospace; font-size: 0.85rem; border-radius: 4px;"
                />
              </div>

              <button type="submit" class="cyber-btn" style="width: 100%; border-color: var(--neon-blue); color: var(--neon-blue); font-weight: 800; box-shadow: 2px 2px 0px 0px rgba(0, 240, 255, 0.15);">
                ⚡ Analizar y Verificar URL
              </button>
            </form>

            <!-- Resultado del Análisis -->
            {urlCheckResult && urlCheckResult.isAccessible && (
              <div style="border: 2px solid rgba(57, 255, 20, 0.25); background: rgba(57, 255, 20, 0.02); padding: 1.25rem; margin-top: 1.5rem; border-radius: 6px;">
                <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-green); font-size: 0.7rem; letter-spacing: 0.05em; display: block; margin-bottom: 0.75rem;">✅ Metadatos Extraídos Exitosamente</span>
                
                <div style="display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.85rem;">
                  <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                    <span style="color: var(--text-muted);">Plataforma:</span>
                    <span style="color: var(--neon-blue); font-weight: 700;">{urlCheckResult.platform}</span>
                  </div>
                  {urlCheckResult.title && (
                    <div style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted); font-size: 0.75rem; display: block; margin-bottom: 0.15rem;">Título Extraído:</span>
                      <span style="color: var(--text-main); font-weight: 600; line-height: 1.3; display: block;">{urlCheckResult.title}</span>
                    </div>
                  )}
                  {urlCheckResult.author && (
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted);">Autor / Cuenta:</span>
                      <span style="color: var(--text-main); font-weight: 600;">{urlCheckResult.author}</span>
                    </div>
                  )}
                  {urlCheckResult.views && (
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted);">Vistas / Reproducciones:</span>
                      <span style="color: var(--neon-rose); font-weight: 700;">{urlCheckResult.views}</span>
                    </div>
                  )}
                  {urlCheckResult.date && (
                    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.35rem;">
                      <span style="color: var(--text-muted);">Fecha Publicación:</span>
                      <span style="color: var(--text-main);">{new Date(urlCheckResult.date).toLocaleString('es-ES')}</span>
                    </div>
                  )}
                  {urlCheckResult.imageUrl && (
                    <div style="margin-top: 0.75rem; border: 1px solid var(--border-color); overflow: hidden; border-radius: 4px;">
                      <img src={urlCheckResult.imageUrl} alt="Preview" style="width: 100%; height: auto; display: block; max-height: 180px; object-fit: cover;" />
                    </div>
                  )}
                </div>

                <!-- Confirmar e insertar en radar -->
                <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 1.25rem; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
                  <input type="hidden" name="action" value="insert_checked_url" />
                  <input type="hidden" name="url" value={urlCheckResult.rawUrl} />
                  <input type="hidden" name="platform" value={urlCheckResult.platform} />
                  <input type="hidden" name="title" value={urlCheckResult.title || ''} />
                  <input type="hidden" name="description" value={urlCheckResult.description || ''} />
                  <input type="hidden" name="author" value={urlCheckResult.author || 'Editor'} />

                  <div>
                    <label style="font-size: 0.75rem; color: var(--neon-green); display: block; margin-bottom: 0.25rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em;">Vincular a Expediente Temático:</label>
                    <select name="topic_id" class="edit-input" style="border-color: rgba(57, 255, 20, 0.25);">
                      <option value="">— Sin expediente (General) —</option>
                      {activeTopics.map(t => (
                        <option value={t.id}>[{t.category}] {t.title}</option>
                      ))}
                    </select>
                  </div>

                  <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main); font-weight: 800;">
                    ✅ Confirmar e Insertar en la Cola del Radar
                  </button>
                </form>
              </div>
            )}

            {urlCheckResult && !urlCheckResult.isAccessible && (
              <div style="border: 2px solid rgba(255, 51, 102, 0.25); background: rgba(255, 51, 102, 0.02); padding: 1.25rem; font-size: 0.85rem; margin-top: 1.5rem; border-radius: 6px;">
                <span style="font-weight: 800; text-transform: uppercase; color: var(--neon-rose); font-size: 0.7rem; display: block; margin-bottom: 0.35rem;">❌ URL No Accesible</span>
                <p style="color: var(--text-muted); margin: 0; line-height: 1.4;">{urlCheckResult.error || 'La URL no es pública o no devuelve una respuesta correcta. Puedes ingresarla manualmente en la caja inferior.'}</p>
              </div>
            )}
          </div>

          <!-- Cola de radar items -->
          <div class="cyber-card" style="padding: 1.5rem;">
            <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-purple); font-weight: 700;">📡 Cola del Radar ({pendingRadarItems.length})</h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.25rem;">
              Publicaciones capturadas automáticamente de redes esperando ser redactadas en lote.
            </p>

            <div style="display: flex; flex-direction: column; gap: 0.75rem; max-height: 400px; overflow-y: auto;">
              {pendingRadarItems.map(item => (
                <div style="border: 1px solid var(--border-color); padding: 0.75rem; background: var(--bg-dark); font-size: 0.8rem; border-radius: 4px;">
                  <div style="display: flex; justify-content: space-between; margin-bottom: 0.35rem;">
                    <span style="color: var(--neon-blue); font-weight: bold;">{item.platform}</span>
                    <span style="color: var(--neon-rose); font-weight: 700;">Vir: {item.virality_score}/10</span>
                  </div>
                  <p style="color: var(--text-muted); margin: 0 0 0.35rem 0; line-height: 1.35; font-size: 0.8rem;">
                    "{item.detected_claim || item.text.substring(0, 120)}..."
                  </p>
                  {item.url && (
                    <a href={item.url} target="_blank" rel="noopener noreferrer" style="font-size: 0.7rem; color: var(--text-muted); display: block; text-decoration: none; word-break: break-all; margin-bottom: 0.25rem;">
                      🔗 Link original: {item.url}
                    </a>
                  )}
                  <span style="font-size: 0.7rem; color: var(--text-muted); display: block; text-align: right;">
                    Ingresado: {new Date(item.created_at).toLocaleDateString('es-ES')}
                  </span>
                </div>
              ))}

              {pendingRadarItems.length === 0 && (
                <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 1.5rem;">No hay items pendientes en el radar.</p>
              )}
            </div>
          </div>

        </div>

        <!-- Columna Derecha: Configurar Fuentes e Inserción manual -->
        <div style="display: flex; flex-direction: column; gap: 2rem;">
          
          <!-- Configurar fuentes de radar -->
          <div class="cyber-card" style="padding: 1.5rem; background: rgba(0, 240, 255, 0.02); border-color: rgba(0, 240, 255, 0.25);">
            <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--neon-blue); font-weight: 700;">📡 Fuentes de Monitorización</h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.25rem;">
              Canales de Telegram, subreddits o feeds RSS monitorizados periódicamente.
            </p>

            <div style="display: flex; flex-direction: column; gap: 0.65rem; max-height: 300px; overflow-y: auto; margin-bottom: 1.25rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; padding-right: 0.25rem;">
              {radarSources.map(src => (
                <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem; background: var(--bg-dark); border: 1px solid var(--border-color); font-size: 0.8rem; border-radius: 4px;">
                  <div>
                    <span style="font-size: 0.65rem; font-weight: 800; text-transform: uppercase; background: rgba(255,255,255,0.05); padding: 0.1rem 0.25rem; border-radius: 2px; margin-right: 0.35rem; color: var(--neon-purple);">{src.platform}</span>
                    <strong style="color: var(--text-main);">{src.name}</strong>
                    <span style="display: block; font-size: 0.7rem; color: var(--text-muted); text-overflow: ellipsis; overflow: hidden; max-width: 170px; white-space: nowrap;" title={src.url_or_id}>{src.url_or_id}</span>
                  </div>
                  <form method="POST" style="margin: 0;">
                    <input type="hidden" name="action" value="delete_radar_source" />
                    <input type="hidden" name="source_id" value={src.id} />
                    <button type="submit" style="background: none; border: none; color: var(--neon-rose); cursor: pointer; font-size: 0.95rem;" title="Eliminar fuente">🗑️</button>
                  </form>
                </div>
              ))}
            </div>

            <!-- Formulario de añadir fuente -->
            <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
              <input type="hidden" name="action" value="add_radar_source" />
              
              <div>
                <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Plataforma:</label>
                <select name="platform" required class="edit-input" style="padding: 0.4rem;">
                  <option value="Telegram">Telegram (Canal Público)</option>
                  <option value="Reddit">Reddit (JSON Hot URL)</option>
                  <option value="RSS">RSS Feed de Prensa / Tendencias</option>
                </select>
              </div>

              <div>
                <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Nombre descriptivo:</label>
                <input type="text" name="name" required placeholder="Ej: Canal de Alvise" class="edit-input" style="padding: 0.4rem;" />
              </div>

              <div>
                <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Identificador o URL:</label>
                <input type="text" name="url_or_id" required placeholder="Ej: Alviseperez o URL RSS" class="edit-input" style="padding: 0.4rem; font-family: monospace;" />
              </div>

              <button type="submit" class="cyber-btn" style="width: 100%; border-color: var(--neon-blue); color: var(--neon-blue); box-shadow: 2px 2px 0px 0px rgba(0, 240, 255, 0.15); font-size: 0.75rem;">
                + Añadir Fuente al Radar
              </button>
            </form>
          </div>

          <!-- Insertar claim manual -->
          <div class="cyber-card" style="padding: 1.5rem;">
            <h3 style="font-size: 1.15rem; margin-bottom: 0.5rem; color: var(--neon-blue); font-weight: 700;">✍️ Insertar Claim Manual</h3>
            <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
              Añade un titular dudoso directamente a la cola del radar para que sea procesado por la IA.
            </p>

            <form method="POST" style="display: flex; flex-direction: column; gap: 0.75rem;">
              <input type="hidden" name="action" value="create_claim" />
              
              <div>
                <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Texto del Claim / Bulo:</label>
                <textarea 
                  name="claim" 
                  rows="3" 
                  placeholder="Ej: Dicen que el gobierno quitará los depósitos..."
                  required 
                  class="edit-input"
                  style="font-family: var(--font-body); font-size: 0.85rem; resize: none;"
                ></textarea>
              </div>

              <div>
                <label style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-bottom: 0.25rem;">Red de Origen:</label>
                <select name="platform" class="edit-input" style="padding: 0.4rem;">
                  <option value="WhatsApp">WhatsApp</option>
                  <option value="X (Twitter)">X (Twitter)</option>
                  <option value="Instagram">Instagram</option>
                  <option value="TikTok">TikTok</option>
                  <option value="Admin Manual">Entrada Manual Editor</option>
                </select>
              </div>

              <button type="submit" class="cyber-btn accent" style="width: 100%; box-shadow: 2px 2px 0px 0px var(--text-main); font-weight: 800;">
                Insertar en Radar
              </button>
            </form>
          </div>

        </div>

      </div>
    )}

  </div>
</Layout>

<script is:inline>
  function triggerBuild() {
    const box = document.getElementById('build-status-box');
    const btn = document.getElementById('build-btn');
    
    if (box && btn) {
      box.style.display = 'block';
      btn.innerText = 'Compilando...';
      btn.disabled = true;
      
      // Simular retraso de build
      setTimeout(() => {
        btn.innerText = '¡Compilado! ✓';
        btn.disabled = false;
        setTimeout(() => {
          btn.innerText = '🚀 Compilar SSG (Astro Build)';
          box.style.display = 'none';
        }, 3000);
      }, 2500);
    }
  }
</script>

</style>
