                          <input type="hidden" name="action" value="edit_measure" />
                          <input type="hidden" name="measure_id" value={meas.id} />
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Área:</label>
                            <input type="text" name="area" value={meas.area} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Título:</label>
                            <input type="text" name="title" value={meas.title} required class="edit-input" style="padding: 0.35rem; font-size: 0.8rem;" />
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Resumen:</label>
                            <textarea name="summary" rows="3" required class="edit-input" style="font-size: 0.8rem; line-height: 1.35; padding: 0.35rem;">{meas.plain_language_summary}</textarea>
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Impacto:</label>
                            <textarea name="impact" rows="2" class="edit-input" style="font-size: 0.8rem; line-height: 1.35; padding: 0.35rem;">{meas.possible_impact}</textarea>
                          </div>
                          <div>
                            <label class="edit-label" style="font-size: 0.65rem;">Colectivos:</label>
                            <textarea name="targets" rows="2" class="edit-input" style="font-size: 0.8rem; line-height: 1.35; padding: 0.35rem;">{meas.target_groups}</textarea>
