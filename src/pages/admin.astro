                    <span style="font-size: 0.7rem; font-weight: bold; background: rgba(255,255,255,0.05); padding: 0.15rem 0.4rem; border-radius: 3px; color: var(--neon-purple);">{meas.party_name}</span>
                    <span style="font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem;">Área: <strong>{meas.area}</strong></span>
                  </div>
                  <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <details style="margin: 0; position: relative;">
