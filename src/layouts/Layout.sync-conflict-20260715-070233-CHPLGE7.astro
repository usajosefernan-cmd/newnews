---
import '../styles/global.css';
import { DatabaseSync } from 'node:sqlite';
import path from 'node:path';

const { 
  title, 
  description = "NEWNEWS - Web de noticias, desmentidos y contrastación con fuentes oficiales de España.",
  category,
  activeNav = ''
} = Astro.props;

const dbPath = path.resolve('data/newnews.db');
const db = new DatabaseSync(dbPath);
db.exec('PRAGMA busy_timeout = 5000;');
db.exec('PRAGMA journal_mode = WAL;');

const topics = db.prepare("SELECT title, slug FROM topics WHERE status = 'activo' ORDER BY title").all() as any[];

const rawCategories = db.prepare("SELECT DISTINCT category FROM topics WHERE status = 'activo'").all() as any[];
const categories = rawCategories.map(c => {
  const cat = c.category;
  const slug = cat.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');
  return { name: cat, slug };
}).filter(c => c.name);

db.close();

const currentPath = Astro.url.pathname;

const base = import.meta.env.BASE_URL;
const getLink = (p) => {
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  const cleanP = p.startsWith('/') ? p : '/' + p;
  return cleanBase + cleanP;
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={getLink('/favicon.svg')} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | NEWNEWS</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | NEWNEWS`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | NEWNEWS`} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <!-- ═══ HEADER PREMIUM GLOBAL ═══ -->
    <header style="border-bottom: 1px solid var(--border-color); background: rgba(7, 9, 19, 0.75); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); position: sticky; top: 0; z-index: 1000; transition: all 0.3s ease;">
      <div class="container" style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
        
        <!-- Logo -->
        <a href={getLink('/')} style="text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
          <span style="font-family: var(--font-title); font-weight: 900; font-size: 1.45rem; letter-spacing: -0.04em; color: #ffffff;">
            NEW<span style="color: var(--neon-blue);">NEWS</span>
          </span>
          <span style="background: rgba(0, 240, 255, 0.12); border: 1px solid rgba(0, 240, 255, 0.25); color: var(--neon-blue); font-size: 0.55rem; font-weight: 900; text-transform: uppercase; padding: 0.12rem 0.4rem; border-radius: 4px; letter-spacing: 0.05em; font-family: var(--font-title);">
            DEONTOLÓGICO
          </span>
        </a>

        <!-- Desktop Navigation -->
        <nav style="display: flex; align-items: center; gap: 2rem;" class="desktop-nav">
          
          <!-- Dropdown Expedientes Vivos -->
          <div class="nav-dropdown" style="position: relative; display: inline-block;">
            <a href="#" class="nav-link dropdown-toggle" style="font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.35rem; text-decoration: none; font-weight: 700; font-family: var(--font-title);">
              📂 Expedientes Vivos <span style="font-size: 0.6rem; transition: transform 0.25s ease; display: inline-block;">▼</span>
            </a>
            <div class="dropdown-menu left-align" style="opacity: 0; transform: translateY(10px); pointer-events: none; position: absolute; top: 100%; left: 0; background: rgba(7, 9, 19, 0.95); border: 1px solid var(--border-color); border-radius: 8px; box-shadow: 0px 8px 32px rgba(0, 240, 255, 0.15); min-width: 250px; max-height: 400px; overflow-y: auto; z-index: 1000; padding: 0.5rem 0; margin-top: 0.5rem; backdrop-filter: blur(20px); transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);">
              {topics.map((t) => (
                <a href={getLink(`/tema/${t.slug}`)} style="display: flex; align-items: center; gap: 0.5rem; padding: 0.55rem 1.25rem; color: var(--text-muted); text-decoration: none; font-size: 0.8rem; font-weight: 600; font-family: var(--font-title); transition: all 0.2s; border-bottom: 1px solid rgba(255,255,255,0.02);" title={t.title}>
                  <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--neon-blue); flex-shrink: 0;"></span>
                  <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{t.title}</span>
                </a>
              ))}
            </div>
          </div>

          <a href={getLink('/interceptor')} class="nav-link" style="font-size: 0.85rem; color: var(--text-muted); text-decoration: none; font-weight: 700; font-family: var(--font-title); display: flex; align-items: center; gap: 0.25rem;">
            🕵️ Interceptor
          </a>

          <a href={getLink('/actualidad')} class="nav-link" style="font-size: 0.85rem; color: var(--text-muted); text-decoration: none; font-weight: 700; font-family: var(--font-title);">
            Actualidad
          </a>

          <!-- Dropdown Políticos -->
          <div class="nav-dropdown" style="position: relative; display: inline-block;">
            <a href="#" class="nav-link dropdown-toggle" style="font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.35rem; text-decoration: none; font-weight: 700; font-family: var(--font-title);">
