---
import '../styles/global.css';

const { 
  title, 
  description = "NEWNEWS - Web de noticias, desmentidos y contrastación con fuentes oficiales de España.",
  category
} = Astro.props;

const categories = [
  { name: 'Política', path: '/programas-politicos' },
  { name: 'Historia', path: '/tema/franco' },
  { name: 'Economía', path: '/tema/economia-espanola' },
  { name: 'Sociedad', path: '/tema/menores-extranjeros-no-acompanados' },
  { name: 'Vivienda', path: '/tema/vivienda-y-okupacion' }
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | NEWNEWS</title>
    <meta name="description" content={description} />
    
    <!-- Meta tags SEO -->
    <meta property="og:title" content={`${title} | NEWNEWS`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | NEWNEWS`} />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <header style="border-bottom: 1px solid var(--border-color); background: rgba(7, 9, 19, 0.75); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); position: sticky; top: 0; z-index: 100;">
      <div class="container" style="display: flex; align-items: center; justify-content: space-between; padding: 1rem; max-width: 680px;">
        
        <!-- Logo -->
        <a href="/" style="display: flex; align-items: center; gap: 0.5rem;">
          <span style="font-family: var(--font-title); font-weight: 800; font-size: 1.5rem; letter-spacing: -0.04em; display: inline-flex; align-items: center;">
            NEW<span style="color: var(--neon-blue);">NEWS</span>
          </span>
          <span style="background: rgba(0, 240, 255, 0.1); color: var(--neon-blue); font-size: 0.55rem; font-weight: 800; padding: 0.15rem 0.4rem; text-transform: uppercase; border-radius: 4px; letter-spacing: 0.05em; border: 1px solid rgba(0, 240, 255, 0.2);">
            RADAR
          </span>
        </a>

        <!-- Desktop Navigation Links -->
        <nav class="desktop-nav" style="display: flex; align-items: center; gap: 1.5rem;">
          <a href="/temas" class="nav-link" style="font-size: 0.85rem; color: var(--text-muted);">Temas</a>
          <a href="/programas-politicos" class="nav-link" style="font-size: 0.85rem; color: var(--text-muted);">Programas</a>
          <a href="/comparador-politico" class="nav-link" style="font-size: 0.85rem; color: var(--text-muted);">Comparador</a>
          <a href="/bienes-declarados" class="nav-link" style="font-size: 0.85rem; color: var(--text-muted);">Bienes</a>
        </nav>

        <!-- Right Elements -->
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <a href="/buscador" class="cyber-btn" style="padding: 0.4rem 0.8rem; font-size: 0.75rem; border-radius: 20px; border-color: rgba(255, 255, 255, 0.1); background: transparent;">
            Buscar
          </a>
        </div>

      </div>
    </header>

    <!-- Bottom Navigation Bar para Móviles (Fija abajo) -->
    <div class="bottom-nav-container">
      <nav class="bottom-nav">
        <a href="/" class="bottom-nav-item active">
          <span style="font-size: 1.1rem; display: block;">●</span>
          <span>Radar</span>
        </a>
        <a href="/temas" class="bottom-nav-item">
          <span style="font-size: 1.1rem; display: block;">■</span>
          <span>Temas</span>
        </a>
        <a href="/comparador-politico" class="bottom-nav-item">
          <span style="font-size: 1.1rem; display: block;">▲</span>
          <span>Votos</span>
        </a>
        <a href="/bienes-declarados" class="bottom-nav-item">
          <span style="font-size: 1.1rem; display: block;">◆</span>
          <span>Bienes</span>
        </a>
        <a href="/admin" class="bottom-nav-item">
          <span style="font-size: 1.1rem; display: block;">★</span>
          <span>Editor</span>
        </a>
      </nav>
    </div>

    <main style="min-height: calc(100vh - 150px);">
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--border-color); background: rgba(7, 9, 19, 0.8); backdrop-filter: blur(12px); padding: 4rem 0; font-size: 0.85rem; color: var(--text-muted);">
      <div class="container" style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem; max-width: 680px;">
        
        <div>
          <h3 style="color: var(--text-main); font-size: 1.25rem; margin-bottom: 0.75rem; letter-spacing: -0.03em;">NEW<span style="color: var(--neon-blue);">NEWS</span></h3>
          <p style="margin-bottom: 1.5rem; max-width: 400px; font-size: 0.9rem; line-height: 1.5;">
            Iniciativa neutral para analizar bulos virales, contrastar promesas políticas y explicar la actualidad de España con datos oficiales.
          </p>
          <p style="font-size: 0.8rem;">© {new Date().getFullYear()} NEWNEWS.</p>
        </div>

        <div>
          <h4 style="color: var(--text-main); font-size: 1rem; margin-bottom: 1rem; font-family: var(--font-title);">Metodología</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem;" class="footer-links">
            <li><a href="/temas">Expedientes Vivos</a></li>
            <li><a href="/programas-politicos">Programas Electorales</a></li>
            <li><a href="/comparador-politico">Comparador de Hechos</a></li>
          </ul>
        </div>

        <div>
          <h4 style="color: var(--text-main); font-size: 1rem; margin-bottom: 1rem; font-family: var(--font-title);">Fuentes Oficiales</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem;">
            <li><a href="https://www.ine.es" target="_blank" rel="noopener noreferrer">INE (Estadísticas)</a></li>
            <li><a href="https://www.boe.es" target="_blank" rel="noopener noreferrer">BOE (Leyes y Normas)</a></li>
            <li><a href="https://www.congreso.es" target="_blank" rel="noopener noreferrer">Congreso de los Diputados</a></li>
          </ul>
        </div>

      </div>
    </footer>
  </body>
</html>

<style>
  .nav-link {
    font-family: var(--font-title);
    font-weight: 600;
    transition: color 0.2s ease;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }
  
  .nav-link:hover {
    color: var(--neon-blue);
    border-bottom-color: var(--neon-blue);
  }

  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--neon-blue) !important;
  }

  /* Bottom Nav visible en móvil, oculta en Desktop */
  .bottom-nav-container {
    display: block;
  }

  @media (min-width: 900px) {
    .bottom-nav-container {
      display: none !important;
    }
    #header-admin-btn {
      display: inline-flex !important;
    }
  }

  /* Desktop Nav oculta en móvil, visible en Desktop */
  @media (max-width: 900px) {
    .desktop-nav {
      display: none !important;
    }
    footer {
      display: none !important; /* En móviles ocultamos el footer completo estilo App */
    }
  }
</style>
